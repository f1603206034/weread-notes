    {
      "bookmarkId": "3300015140_5_1052-1085",
      "chapterUid": 5,
      "range": "1052-1085",
      "markText": "但我却觉得，自己的想法就像丢失的航空行李，总是迟一步才到达目的地。",
      "totalCount": 658,
      "appLink": "weread://bestbookmark?bookId=3300015140&chapterUid=5&rangeStart=1052&rangeEnd=1085",
