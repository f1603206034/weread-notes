  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300048884_6_5699-5797",
      "chapterUid": 6,
      "range": "5699-5797",
      "markText": "真正重要的不是要寻找的东西，而是看的能力。这种不带目的，只是单纯地去看的能力，当今世界是缺失的。人人都成了心理生物，想为一切事物赋予意义。探寻不在于寻找什么，而在于强化你的感知能力，你看见的能力。",
      "totalCount": 693,
      "appLink": "weread://bestbookmark?bookId=3300048884&chapterUid=6&rangeStart=5699&rangeEnd=5797",
      "webLink": "https://weread.qq.com/web/reader/b9732780813ab7998g0149e3?chapterUid=6&rangeStart=5699&rangeEnd=5797"
    },
    {
      "bookmarkId": "3300048884_8_3703-3788",
      "chapterUid": 8,
      "range": "3703-3788",
      "markText": "创造自己的命运意味着，无论你的周围发生什么，你都一直稳步地迈向你的终极本质。它意味着你把自己打造成这样：无论你周围是什么环境，发生了什么，你都不会被它们击垮；你驾驭它们。",
      "totalCount": 672,
      "appLink": "weread://bestbookmark?bookId=3300048884&chapterUid=8&rangeStart=3703&rangeEnd=3788",
      "webLink": "https://weread.qq.com/web/reader/b9732780813ab7998g0149e3?chapterUid=8&rangeStart=3703&rangeEnd=3788"
    },
    {
      "bookmarkId": "3300048884_6_3615-3661",
      "chapterUid": 6,
      "range": "3615-3661",
      "markText": "语言不过就是人类的共谋。一个人在说话的时候，我意识到他们只是在发出声音，而在编造意思的是我。",
      "totalCount": 602,
      "appLink": "weread://bestbookmark?bookId=3300048884&chapterUid=6&rangeStart=3615&rangeEnd=3661",
      "webLink": "https://weread.qq.com/web/reader/b9732780813ab7998g0149e3?chapterUid=6&rangeStart=3615&rangeEnd=3661"
    },
    {
      "bookmarkId": "3300048884_7_2780-2826",
      "chapterUid": 7,
      "range": "2780-2826",
      "markText": "挡在你和你的幸福之间的只有一个简单的事实：你允许你的思想和情感听从外在的指令，而不是内在的。",
      "totalCount": 594,
      "appLink": "weread://bestbookmark?bookId=3300048884&chapterUid=7&rangeStart=2780&rangeEnd=2826",
      "webLink": "https://weread.qq.com/web/reader/b9732780813ab7998g0149e3?chapterUid=7&rangeStart=2780&rangeEnd=2826"
    },
    {
      "bookmarkId": "3300048884_3_1498-1563",
      "chapterUid": 3,
      "range": "1498-1563",
      "markText": "现在的问题是，你为十年前所发生的事而痛苦，也在为后天可能发生的事而痛苦。可是这些都不是现实，它们只不过是你的记忆和想象的剧本而已。",
      "totalCount": 572,
      "appLink": "weread://bestbookmark?bookId=3300048884&chapterUid=3&rangeStart=1498&rangeEnd=1563",
      "webLink": "https://weread.qq.com/web/reader/b9732780813ab7998g0149e3?chapterUid=3&rangeStart=1498&rangeEnd=1563"
    },
    {
      "bookmarkId": "3300048884_14_9608-9650",
      "chapterUid": 14,
      "range": "9608-9650",
      "markText": "一旦你的智力认同于什么，它就会被牢牢拴在那些身份认同上，从而完全扭曲你对世界的体验。",
      "totalCount": 560,
      "appLink": "weread://bestbookmark?bookId=3300048884&chapterUid=14&rangeStart=9608&rangeEnd=9650",
      "webLink": "https://weread.qq.com/web/reader/b9732780813ab7998g0149e3?chapterUid=14&rangeStart=9608&rangeEnd=9650"
    },
    {
      "bookmarkId": "3300048884_7_7692-7768",
      "chapterUid": 7,
      "range": "7692-7768",
      "markText": "开悟不是一项成就，它是一种回归。感官给你的感觉是你在体验外在事物，但是你从未体验过任何外在。当意识到你所体验到的一切都是内在的，这种彻底的归家就是开悟。",
      "totalCount": 540,
      "appLink": "weread://bestbookmark?bookId=3300048884&chapterUid=7&rangeStart=7692&rangeEnd=7768",
      "webLink": "https://weread.qq.com/web/reader/b9732780813ab7998g0149e3?chapterUid=7&rangeStart=7692&rangeEnd=7768"
    },
    {
      "bookmarkId": "3300048884_14_1640-1682",
      "chapterUid": 14,
      "range": "1640-1682",
      "markText": "如果你告诉自己不要去想什么，它就会成为你脑子里想出的第一件事！这就是人类头脑的本质。",
      "totalCount": 510,
      "appLink": "weread://bestbookmark?bookId=3300048884&chapterUid=14&rangeStart=1640&rangeEnd=1682",
      "webLink": "https://weread.qq.com/web/reader/b9732780813ab7998g0149e3?chapterUid=14&rangeStart=1640&rangeEnd=1682"
    },
    {
      "bookmarkId": "3300048884_14_12213-12266",
      "chapterUid": 14,
      "range": "12213-12266",
      "markText": "你获得的任何信息如果没有切身体验过，都是无意义的。这些信息或许非常神圣，但它无法解放你，只会将你缠得更紧。",
      "totalCount": 459,
      "appLink": "weread://bestbookmark?bookId=3300048884&chapterUid=14&rangeStart=12213&rangeEnd=12266",
      "webLink": "https://weread.qq.com/web/reader/b9732780813ab7998g0149e3?chapterUid=14&rangeStart=12213&rangeEnd=12266"
    },
    {
      "bookmarkId": "3300048884_6_7455-7491",
      "chapterUid": 6,
      "range": "7455-7491",
      "markText": "如果你干什么都成功，你会开始觉得那些行星不是在围着太阳转，而是围着你转。",
      "totalCount": 435,
      "appLink": "weread://bestbookmark?bookId=3300048884&chapterUid=6&rangeStart=7455&rangeEnd=7491",
      "webLink": "https://weread.qq.com/web/reader/b9732780813ab7998g0149e3?chapterUid=6&rangeStart=7455&rangeEnd=7491"
    },
    {
      "bookmarkId": "3300048884_15_2677-2750",
      "chapterUid": 15,
      "range": "2677-2750",
      "markText": "疼痛就已经够糟了，为什么还要把它再进一步放大，变成痛苦呢？痛苦完全是自己制造出来的。每个人都可以去选择受苦或不受苦，而选择后者并不需要多么有智慧。",
      "totalCount": 435,
      "appLink": "weread://bestbookmark?bookId=3300048884&chapterUid=15&rangeStart=2677&rangeEnd=2750",
      "webLink": "https://weread.qq.com/web/reader/b9732780813ab7998g0149e3?chapterUid=15&rangeStart=2677&rangeEnd=2750"
    },
    {
      "bookmarkId": "3300048884_7_376-447",
      "chapterUid": 7,
      "range": "376-447",
      "markText": "迄今为止，你在生命中所做的每件事都是为了追求一个东西——无论你是寻求事业、经营生意、挣钱还是建立家庭——都只是因为你想要一样简单的东西：快乐。",
      "totalCount": 425,
      "appLink": "weread://bestbookmark?bookId=3300048884&chapterUid=7&rangeStart=376&rangeEnd=447",
      "webLink": "https://weread.qq.com/web/reader/b9732780813ab7998g0149e3?chapterUid=7&rangeStart=376&rangeEnd=447"
    },
    {
      "bookmarkId": "3300048884_7_6354-6424",
      "chapterUid": 7,
      "range": "6354-6424",
      "markText": "你缺乏什么，什么就会变成最高的祈求。需要记住的是，无论什么都不能持久地让你满足。人类生命渴望的是无限扩展，那才是唯一能够让你彻底满足的东西。",
      "totalCount": 390,
      "appLink": "weread://bestbookmark?bookId=3300048884&chapterUid=7&rangeStart=6354&rangeEnd=6424",
      "webLink": "https://weread.qq.com/web/reader/b9732780813ab7998g0149e3?chapterUid=7&rangeStart=6354&rangeEnd=6424"
    },
    {
      "bookmarkId": "3300048884_7_9546-9594",
      "chapterUid": 7,
      "range": "9546-9594",
      "markText": "如果你向外寻求，那是一个无尽的旅程。如果你转向内在，就只要一个瞬间。就在那一瞬间，一切都会改变。",
      "totalCount": 378,
      "appLink": "weread://bestbookmark?bookId=3300048884&chapterUid=7&rangeStart=9546&rangeEnd=9594",
      "webLink": "https://weread.qq.com/web/reader/b9732780813ab7998g0149e3?chapterUid=7&rangeStart=9546&rangeEnd=9594"
    },
    {
      "bookmarkId": "3300048884_13_4492-4527",
      "chapterUid": 13,
      "range": "4492-4527",
      "markText": "人类的尴尬处境正是：你体验的起源就在你之内，可是你的感知完全是向外的。",
      "totalCount": 378,
      "appLink": "weread://bestbookmark?bookId=3300048884&chapterUid=13&rangeStart=4492&rangeEnd=4527",
      "webLink": "https://weread.qq.com/web/reader/b9732780813ab7998g0149e3?chapterUid=13&rangeStart=4492&rangeEnd=4527"
    },
    {
      "bookmarkId": "3300048884_14_7986-8036",
      "chapterUid": 14,
      "range": "7986-8036",
      "markText": "一旦你不再和你的头脑认同，你就可以自如地超越局限去体验人生。成佛的意思就是，你成为自己智力的旁观者。",
      "totalCount": 378,
      "appLink": "weread://bestbookmark?bookId=3300048884&chapterUid=14&rangeStart=7986&rangeEnd=8036",
      "webLink": "https://weread.qq.com/web/reader/b9732780813ab7998g0149e3?chapterUid=14&rangeStart=7986&rangeEnd=8036"
    },
    {
      "bookmarkId": "3300048884_9_3334-3427",
      "chapterUid": 9,
