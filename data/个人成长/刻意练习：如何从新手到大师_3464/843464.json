      "appLink": "weread://bestbookmark?bookId=843464&chapterUid=93&rangeStart=17120&rangeEnd=17136",
      "webLink": "https://weread.qq.com/web/reader/2e932c005cdec82e9a0e3e8?chapterUid=93&rangeStart=17120&rangeEnd=17136"
