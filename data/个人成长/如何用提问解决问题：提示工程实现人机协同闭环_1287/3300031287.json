  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300031287_3_620-634",
      "chapterUid": 3,
      "range": "620-634",
      "markText": "提问驱动思考，答案终止想象。",
      "totalCount": 648,
      "appLink": "weread://bestbookmark?bookId=3300031287&chapterUid=3&rangeStart=620&rangeEnd=634",
      "webLink": "https://weread.qq.com/web/reader/f6832900813ab72b8g0172cf?chapterUid=3&rangeStart=620&rangeEnd=634"
    },
    {
      "bookmarkId": "3300031287_5_944-1042",
      "chapterUid": 5,
      "range": "944-1042",
      "markText": "当我们在工作或生活中遇到困难时，只要花时间和精力提出问题，大都可以帮助我们做出更好的决策，采取更富有成效的行动。但所提出的问题必须是正确的，能切中复杂问题的要害或能够让我们从全新的角度看待旧难题。",
      "totalCount": 425,
      "appLink": "weread://bestbookmark?bookId=3300031287&chapterUid=5&rangeStart=944&rangeEnd=1042",
      "webLink": "https://weread.qq.com/web/reader/f6832900813ab72b8g0172cf?chapterUid=5&rangeStart=944&rangeEnd=1042"
    },
    {
      "bookmarkId": "3300031287_8_567-588",
      "chapterUid": 8,
      "range": "567-588",
      "markText": "我认为“提问的五大天敌”中最大的就是恐惧。",
      "totalCount": 403,
      "appLink": "weread://bestbookmark?bookId=3300031287&chapterUid=8&rangeStart=567&rangeEnd=588",
      "webLink": "https://weread.qq.com/web/reader/f6832900813ab72b8g0172cf?chapterUid=8&rangeStart=567&rangeEnd=588"
    },
    {
      "bookmarkId": "3300031287_3_2099-2127",
      "chapterUid": 3,
      "range": "2099-2127",
      "markText": "创新的3个重要作用：激发洞察力、放飞想象力和强化执行力。",
      "totalCount": 320,
      "appLink": "weread://bestbookmark?bookId=3300031287&chapterUid=3&rangeStart=2099&rangeEnd=2127",
      "webLink": "https://weread.qq.com/web/reader/f6832900813ab72b8g0172cf?chapterUid=3&rangeStart=2099&rangeEnd=2127"
    },
    {
      "bookmarkId": "3300031287_7_1160-1238",
      "chapterUid": 7,
      "range": "1160-1238",
      "markText": "一个提问的孩子不会被积累的知识和偏见束缚，也不会受到“世界如何运作”及“事物为何如此”的假设困扰。他的思想开放而广阔，这些恰恰是思考、探索和成长的理想条件。",
      "totalCount": 312,
      "appLink": "weread://bestbookmark?bookId=3300031287&chapterUid=7&rangeStart=1160&rangeEnd=1238",
      "webLink": "https://weread.qq.com/web/reader/f6832900813ab72b8g0172cf?chapterUid=7&rangeStart=1160&rangeEnd=1238"
    },
    {
      "bookmarkId": "3300031287_13_2870-2913",
      "chapterUid": 13,
      "range": "2870-2913",
      "markText": "人类倾向于仓促做出决定，因为“我们是认知吝啬鬼，我们不喜欢把精力花在消遣不确定性上”。",
      "totalCount": 300,
      "appLink": "weread://bestbookmark?bookId=3300031287&chapterUid=13&rangeStart=2870&rangeEnd=2913",
      "webLink": "https://weread.qq.com/web/reader/f6832900813ab72b8g0172cf?chapterUid=13&rangeStart=2870&rangeEnd=2913"
    },
    {
      "bookmarkId": "3300031287_3_384-399",
      "chapterUid": 3,
      "range": "384-399",
      "markText": "未来，属于提问，而非给予答案！",
      "totalCount": 273,
      "appLink": "weread://bestbookmark?bookId=3300031287&chapterUid=3&rangeStart=384&rangeEnd=399",
      "webLink": "https://weread.qq.com/web/reader/f6832900813ab72b8g0172cf?chapterUid=3&rangeStart=384&rangeEnd=399"
    },
    {
      "bookmarkId": "3300031287_8_397-410",
      "chapterUid": 8,
      "range": "397-410",
      "markText": "阻碍提问的五大敌人是什么？",
      "totalCount": 252,
      "appLink": "weread://bestbookmark?bookId=3300031287&chapterUid=8&rangeStart=397&rangeEnd=410",
      "webLink": "https://weread.qq.com/web/reader/f6832900813ab72b8g0172cf?chapterUid=8&rangeStart=397&rangeEnd=410"
    },
    {
      "bookmarkId": "3300031287_15_3045-3096",
      "chapterUid": 15,
      "range": "3045-3096",
      "markText": "我喜欢发现自己错了时的“惊喜”吗？发现自己在某件事情上错了不用感到羞愧，这是一种智力开放和成长的标志。",
      "totalCount": 238,
      "appLink": "weread://bestbookmark?bookId=3300031287&chapterUid=15&rangeStart=3045&rangeEnd=3096",
      "webLink": "https://weread.qq.com/web/reader/f6832900813ab72b8g0172cf?chapterUid=15&rangeStart=3045&rangeEnd=3096"
    },
    {
      "bookmarkId": "3300031287_3_2379-2466",
      "chapterUid": 3,
      "range": "2379-2466",
      "markText": "工作中同事们的观点只是一个个不成熟的假设，并不一定是事实，所以我们通过问“为什么”去验证假设是否合理。换个角度看，提出质疑其实就是一种认真负责的“打破砂锅问到底”的创新精神。",
      "totalCount": 234,
      "appLink": "weread://bestbookmark?bookId=3300031287&chapterUid=3&rangeStart=2379&rangeEnd=2466",
      "webLink": "https://weread.qq.com/web/reader/f6832900813ab72b8g0172cf?chapterUid=3&rangeStart=2379&rangeEnd=2466"
    },
    {
      "bookmarkId": "3300031287_9_2046-2078",
      "chapterUid": 9,
      "range": "2046-2078",
      "markText": "找时间问更多问题的问题归结为这个问题：花时间做这件事真的值得吗？",
      "totalCount": 225,
      "appLink": "weread://bestbookmark?bookId=3300031287&chapterUid=9&rangeStart=2046&rangeEnd=2078",
      "webLink": "https://weread.qq.com/web/reader/f6832900813ab72b8g0172cf?chapterUid=9&rangeStart=2046&rangeEnd=2078"
    },
    {
      "bookmarkId": "3300031287_3_1286-1340",
      "chapterUid": 3,
      "range": "1286-1340",
      "markText": "殊不知，产生以上这些“症状”，很大程度是由于我们缺乏提问领导力，而要发现和解决问题，你必须先提出正确的问题。",
      "totalCount": 224,
      "appLink": "weread://bestbookmark?bookId=3300031287&chapterUid=3&rangeStart=1286&rangeEnd=1340",
      "webLink": "https://weread.qq.com/web/reader/f6832900813ab72b8g0172cf?chapterUid=3&rangeStart=1286&rangeEnd=1340"
    },
    {
      "bookmarkId": "3300031287_3_2282-2299",
      "chapterUid": 3,
      "range": "2282-2299",
      "markText": "创新，必须敢于打破常规，质疑行规。",
