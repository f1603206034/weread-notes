  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "35433071_5_1279-1317",
      "chapterUid": 5,
      "range": "1279-1317",
      "markText": "阅读必须认真，先求认真，次求迅速，这是极重要的基本训练，要在阅读课中训练好。",
      "totalCount": 924,
      "appLink": "weread://bestbookmark?bookId=35433071&chapterUid=5&rangeStart=1279&rangeEnd=1317",
      "webLink": "https://weread.qq.com/web/reader/b8632dd0721caa6fb868569?chapterUid=5&rangeStart=1279&rangeEnd=1317"
    },
    {
      "bookmarkId": "35433071_2_1242-1288",
      "chapterUid": 2,
      "range": "1242-1288",
      "markText": "读书顶要紧的事情，是把书中的经验化为自身的经验。随时能够“化”，那才做到“开卷有益”的极致。",
      "totalCount": 759,
      "appLink": "weread://bestbookmark?bookId=35433071&chapterUid=2&rangeStart=1242&rangeEnd=1288",
      "webLink": "https://weread.qq.com/web/reader/b8632dd0721caa6fb868569?chapterUid=2&rangeStart=1242&rangeEnd=1288"
    },
    {
      "bookmarkId": "35433071_4_1993-2022",
      "chapterUid": 4,
      "range": "1993-2022",
      "markText": "阅读和写作都是人生的一种行为，凡是行为必须养成了习惯才行。",
      "totalCount": 592,
      "appLink": "weread://bestbookmark?bookId=35433071&chapterUid=4&rangeStart=1993&rangeEnd=2022",
      "webLink": "https://weread.qq.com/web/reader/b8632dd0721caa6fb868569?chapterUid=4&rangeStart=1993&rangeEnd=2022"
    },
    {
      "bookmarkId": "35433071_4_263-354",
      "chapterUid": 4,
      "range": "263-354",
      "markText": "自己有一种经验、一个意思，觉得它跟寻常的经验和意思有些不同，或者比较新鲜，或者特别深切，值得写下来作为个人生活的记录，将来需用的时候还可以供查考：为了这个缘故，作者才提起笔来写文章。",
      "totalCount": 576,
      "appLink": "weread://bestbookmark?bookId=35433071&chapterUid=4&rangeStart=263&rangeEnd=354",
      "webLink": "https://weread.qq.com/web/reader/b8632dd0721caa6fb868569?chapterUid=4&rangeStart=263&rangeEnd=354"
    },
    {
      "bookmarkId": "35433071_3_531-615",
      "chapterUid": 3,
      "range": "531-615",
      "markText": "要知道处理现实生活是目的，读书只是达到这个目的的许多手段之一。不要盲从“开卷有益”的成语，也不要相信“为读书而读书”的迂谈。要使书为你自己用，不要让你自己去做书的奴隶。",
      "totalCount": 520,
      "appLink": "weread://bestbookmark?bookId=35433071&chapterUid=3&rangeStart=531&rangeEnd=615",
      "webLink": "https://weread.qq.com/web/reader/b8632dd0721caa6fb868569?chapterUid=3&rangeStart=531&rangeEnd=615"
    },
    {
      "bookmarkId": "35433071_11_2488-2559",
      "chapterUid": 11,
      "range": "2488-2559",
      "markText": "读过一节停一停，回转去想一下这一节说的什么，这是个好办法。读过两节三节，又把两节三节连起来回想一下。这个办法可以使自己经常清楚，并且容易记住。",
      "totalCount": 510,
      "appLink": "weread://bestbookmark?bookId=35433071&chapterUid=11&rangeStart=2488&rangeEnd=2559",
      "webLink": "https://weread.qq.com/web/reader/b8632dd0721caa6fb868569?chapterUid=11&rangeStart=2488&rangeEnd=2559"
    },
    {
      "bookmarkId": "35433071_2_803-843",
      "chapterUid": 2,
      "range": "803-843",
      "markText": "同样的情形，一个人不能尽读所有的书。只能把自己需用的一部分读了，其余的不去过问。",
      "totalCount": 448,
      "appLink": "weread://bestbookmark?bookId=35433071&chapterUid=2&rangeStart=803&rangeEnd=843",
      "webLink": "https://weread.qq.com/web/reader/b8632dd0721caa6fb868569?chapterUid=2&rangeStart=803&rangeEnd=843"
    },
    {
      "bookmarkId": "35433071_4_1332-1392",
      "chapterUid": 4,
      "range": "1332-1392",
      "markText": "能写文章算不得什么可以夸耀的事儿，不能写文章却是一种缺陷，这种缺陷跟瞎了眼睛聋了耳朵差不多，在生活上有相当大的不利影响。",
      "totalCount": 364,
      "appLink": "weread://bestbookmark?bookId=35433071&chapterUid=4&rangeStart=1332&rangeEnd=1392",
      "webLink": "https://weread.qq.com/web/reader/b8632dd0721caa6fb868569?chapterUid=4&rangeStart=1332&rangeEnd=1392"
    },
    {
      "bookmarkId": "35433071_2_25-34",
      "chapterUid": 2,
      "range": "25-34",
      "markText": "书是人类经验的仓库",
      "totalCount": 340,
      "appLink": "weread://bestbookmark?bookId=35433071&chapterUid=2&rangeStart=25&rangeEnd=34",
      "webLink": "https://weread.qq.com/web/reader/b8632dd0721caa6fb868569?chapterUid=2&rangeStart=25&rangeEnd=34"
    },
    {
