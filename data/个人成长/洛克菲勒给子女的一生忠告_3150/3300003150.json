  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300003150_4_507-536",
      "chapterUid": 4,
      "range": "507-536",
      "markText": "知识原本是空的，除非把知识付诸行动，否则什么事都不会发生。",
      "totalCount": 1278,
      "appLink": "weread://bestbookmark?bookId=3300003150&chapterUid=4&rangeStart=507&rangeEnd=536",
      "webLink": "https://weread.qq.com/web/reader/dd932660813ab67bbg01032c?chapterUid=4&rangeStart=507&rangeEnd=536"
    },
    {
      "bookmarkId": "3300003150_4_3662-3720",
      "chapterUid": 4,
      "range": "3662-3720",
      "markText": "我做事总有一个习惯，在做决定之前，我总会冷静地思考、判断，但我一旦做出决定，就将义无反顾地执行到底。我相信你也能行。",
      "totalCount": 1080,
      "appLink": "weread://bestbookmark?bookId=3300003150&chapterUid=4&rangeStart=3662&rangeEnd=3720",
      "webLink": "https://weread.qq.com/web/reader/dd932660813ab67bbg01032c?chapterUid=4&rangeStart=3662&rangeEnd=3720"
    },
    {
      "bookmarkId": "3300003150_3_2581-2628",
      "chapterUid": 3,
      "range": "2581-2628",
      "markText": "洛克菲勒说：“如果把我剥得一文不名丢在沙漠的中央，只要一行驼队经过——我就可以重建整个王朝。”",
      "totalCount": 720,
      "appLink": "weread://bestbookmark?bookId=3300003150&chapterUid=3&rangeStart=2581&rangeEnd=2628",
      "webLink": "https://weread.qq.com/web/reader/dd932660813ab67bbg01032c?chapterUid=3&rangeStart=2581&rangeEnd=2628"
    },
    {
      "bookmarkId": "3300003150_4_1134-1165",
      "chapterUid": 4,
      "range": "1134-1165",
      "markText": "装傻的含义，是摆低姿态，变得谦虚，换句话说，就是瞒住你的聪明。",
      "totalCount": 672,
      "appLink": "weread://bestbookmark?bookId=3300003150&chapterUid=4&rangeStart=1134&rangeEnd=1165",
      "webLink": "https://weread.qq.com/web/reader/dd932660813ab67bbg01032c?chapterUid=4&rangeStart=1134&rangeEnd=1165"
    },
    {
      "bookmarkId": "3300003150_4_1930-1951",
      "chapterUid": 4,
      "range": "1930-1951",
      "markText": "处心积虑地去吃苦，是我笃信的成功信条之一。",
      "totalCount": 663,
      "appLink": "weread://bestbookmark?bookId=3300003150&chapterUid=4&rangeStart=1930&rangeEnd=1951",
      "webLink": "https://weread.qq.com/web/reader/dd932660813ab67bbg01032c?chapterUid=4&rangeStart=1930&rangeEnd=1951"
    },
    {
      "bookmarkId": "3300003150_4_963-983",
      "chapterUid": 4,
      "range": "963-983",
      "markText": "一头猪好好被夸奖一番，它就能爬到树上去。",
      "totalCount": 602,
      "appLink": "weread://bestbookmark?bookId=3300003150&chapterUid=4&rangeStart=963&rangeEnd=983",
      "webLink": "https://weread.qq.com/web/reader/dd932660813ab67bbg01032c?chapterUid=4&rangeStart=963&rangeEnd=983"
    },
    {
      "bookmarkId": "3300003150_4_1652-1684",
      "chapterUid": 4,
      "range": "1652-1684",
      "markText": "我希望你能去除对知识、学问的依赖心理，这是你走上人生坦途的关键。",
      "totalCount": 540,
      "appLink": "weread://bestbookmark?bookId=3300003150&chapterUid=4&rangeStart=1652&rangeEnd=1684",
      "webLink": "https://weread.qq.com/web/reader/dd932660813ab67bbg01032c?chapterUid=4&rangeStart=1652&rangeEnd=1684"
    },
    {
      "bookmarkId": "3300003150_4_2096-2120",
      "chapterUid": 4,
      "range": "2096-2120",
      "markText": "人要有远见，只有长时间地吃苦，才有长时间的收获。",
      "totalCount": 518,
      "appLink": "weread://bestbookmark?bookId=3300003150&chapterUid=4&rangeStart=2096&rangeEnd=2120",
      "webLink": "https://weread.qq.com/web/reader/dd932660813ab67bbg01032c?chapterUid=4&rangeStart=2096&rangeEnd=2120"
    },
    {
      "bookmarkId": "3300003150_4_3044-3069",
      "chapterUid": 4,
      "range": "3044-3069",
      "markText": "每一次说“不懂”的机会，都会成为我们人生的转折点。",
      "totalCount": 480,
      "appLink": "weread://bestbookmark?bookId=3300003150&chapterUid=4&rangeStart=3044&rangeEnd=3069",
      "webLink": "https://weread.qq.com/web/reader/dd932660813ab67bbg01032c?chapterUid=4&rangeStart=3044&rangeEnd=3069"
    },
    {
      "bookmarkId": "3300003150_4_2288-2377",
      "chapterUid": 4,
      "range": "2288-2377",
      "markText": "在这个世界上要活下去，要创造成就，你必须借助于人力，即别人的力量，但你必须从做小事开始，才会了解当部属的心情，等你有一天走上更高的职位，你就知道如何让他们贡献出全部的工作热情了。",
      "totalCount": 476,
      "appLink": "weread://bestbookmark?bookId=3300003150&chapterUid=4&rangeStart=2288&rangeEnd=2377",
      "webLink": "https://weread.qq.com/web/reader/dd932660813ab67bbg01032c?chapterUid=4&rangeStart=2288&rangeEnd=2377"
    },
    {
      "bookmarkId": "3300003150_6_3563-3612",
      "chapterUid": 6,
      "range": "3563-3612",
      "markText": "所谓乐观是一种信念，那就是相信生活终究是乐多苦少，相信即使不如人愿的事屡屡发生，好事终将占得上风。",
      "totalCount": 468,
      "appLink": "weread://bestbookmark?bookId=3300003150&chapterUid=6&rangeStart=3563&rangeEnd=3612",
      "webLink": "https://weread.qq.com/web/reader/dd932660813ab67bbg01032c?chapterUid=6&rangeStart=3563&rangeEnd=3612"
    },
    {
      "bookmarkId": "3300003150_5_4185-4245",
      "chapterUid": 5,
      "range": "4185-4245",
      "markText": "如果你视工作为一种乐趣，人生就是天堂；如果你视工作为一种义务，人生就是地狱。检视一下你的工作态度，那会让我们都感觉愉快。",
      "totalCount": 450,
      "appLink": "weread://bestbookmark?bookId=3300003150&chapterUid=5&rangeStart=4185&rangeEnd=4245",
      "webLink": "https://weread.qq.com/web/reader/dd932660813ab67bbg01032c?chapterUid=5&rangeStart=4185&rangeEnd=4245"
    },
    {
      "bookmarkId": "3300003150_4_806-824",
      "chapterUid": 4,
      "range": "806-824",
      "markText": "只有长时间地吃苦，才有长时间的收获。",
      "totalCount": 429,
      "appLink": "weread://bestbookmark?bookId=3300003150&chapterUid=4&rangeStart=806&rangeEnd=824",
      "webLink": "https://weread.qq.com/web/reader/dd932660813ab67bbg01032c?chapterUid=4&rangeStart=806&rangeEnd=824"
    },
    {
      "bookmarkId": "3300003150_4_1802-1894",
      "chapterUid": 4,
      "range": "1802-1894",
