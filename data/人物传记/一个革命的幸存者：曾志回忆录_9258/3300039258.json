  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300039258_8_46893-46982",
      "chapterUid": 8,
      "range": "46893-46982",
      "markText": "而那时我才23岁，我是共产党员、职业革命者，为革命随时都要作出牺牲；同时也早将“三从四德”、贞节牌坊那种封建的东西抛到九霄云外去了。因此，重新找对象是我的自由，我有权利作出选择。",
      "totalCount": 850,
      "appLink": "weread://bestbookmark?bookId=3300039258&chapterUid=8&rangeStart=46893&rangeEnd=46982",
      "webLink": "https://weread.qq.com/web/reader/7e032f20813ab75d5g0188fd?chapterUid=8&rangeStart=46893&rangeEnd=46982"
    },
    {
      "bookmarkId": "3300039258_12_17135-17213",
      "chapterUid": 12,
      "range": "17135-17213",
      "markText": "主席说：“我当时就那么想，读书吧！坚持真理，坚持原则，我不怕杀头，不怕坐牢，不怕开除党籍，不怕处分，也不怕老婆离婚，一切我都不在乎，我只一心一意去多读书！”",
      "totalCount": 738,
      "appLink": "weread://bestbookmark?bookId=3300039258&chapterUid=12&rangeStart=17135&rangeEnd=17213",
      "webLink": "https://weread.qq.com/web/reader/7e032f20813ab75d5g0188fd?chapterUid=12&rangeStart=17135&rangeEnd=17213"
    },
    {
      "bookmarkId": "3300039258_5_10949-11041",
      "chapterUid": 5,
      "range": "10949-11041",
      "markText": "这时，我不知道从哪里来的勇气和胆量，也许是仇恨和愤怒吧。我拿起梭镖用力朝他的肚子上扎去，他倒在地上，发出呼呼的喘气声和嗯嗯的呻吟声……那声音我至今还记得很清楚。这是我平生唯一一次杀人。",
      "totalCount": 715,
      "appLink": "weread://bestbookmark?bookId=3300039258&chapterUid=5&rangeStart=10949&rangeEnd=11041",
      "webLink": "https://weread.qq.com/web/reader/7e032f20813ab75d5g0188fd?chapterUid=5&rangeStart=10949&rangeEnd=11041"
    },
    {
      "bookmarkId": "3300039258_7_44862-44916",
      "chapterUid": 7,
      "range": "44862-44916",
      "markText": "是年5月，蔡协民高喊着“共产党万岁”的口号，在漳州英勇就义，时年33岁。他用壮烈的死，向党表明了自己的忠诚！",
      "totalCount": 572,
      "appLink": "weread://bestbookmark?bookId=3300039258&chapterUid=7&rangeStart=44862&rangeEnd=44916",
      "webLink": "https://weread.qq.com/web/reader/7e032f20813ab75d5g0188fd?chapterUid=7&rangeStart=44862&rangeEnd=44916"
    },
    {
      "bookmarkId": "3300039258_10_11704-11766",
      "chapterUid": 10,
      "range": "11704-11766",
      "markText": "共产党员，在任何困难面前和逆境中都要自觉为党做工作，这是我一生的信条。我这一辈子多次身处逆境，但这个信条却从未改变或动摇过。",
      "totalCount": 528,
      "appLink": "weread://bestbookmark?bookId=3300039258&chapterUid=10&rangeStart=11704&rangeEnd=11766",
      "webLink": "https://weread.qq.com/web/reader/7e032f20813ab75d5g0188fd?chapterUid=10&rangeStart=11704&rangeEnd=11766"
    },
    {
      "bookmarkId": "3300039258_6_27283-27358",
      "chapterUid": 6,
      "range": "27283-27358",
      "markText": "毛委员最爱跟贺子珍开玩笑，他们俩常常像小孩子一样，先是逗乐，你捅我一下，我打你一下，有时闹着闹着就真打了起来，可一会儿气就消了，又嘻嘻哈哈，闹着玩了。",
      "totalCount": 527,
      "appLink": "weread://bestbookmark?bookId=3300039258&chapterUid=6&rangeStart=27283&rangeEnd=27358",
      "webLink": "https://weread.qq.com/web/reader/7e032f20813ab75d5g0188fd?chapterUid=6&rangeStart=27283&rangeEnd=27358"
    },
    {
      "bookmarkId": "3300039258_6_1496-1563",
      "chapterUid": 6,
      "range": "1496-1563",
      "markText": "虽说夏明震刚牺牲不久，我也因此感到不安，但当时认为，革命者随时都有牺牲的可能，夫妻关系也就不是什么重要的事了，哪还讲什么“三从四德”。",
      "totalCount": 504,
      "appLink": "weread://bestbookmark?bookId=3300039258&chapterUid=6&rangeStart=1496&rangeEnd=1563",
      "webLink": "https://weread.qq.com/web/reader/7e032f20813ab75d5g0188fd?chapterUid=6&rangeStart=1496&rangeEnd=1563"
    },
    {
      "bookmarkId": "3300039258_7_19591-19787",
      "chapterUid": 7,
      "range": "19591-19787",
      "markText": "最后，王海萍终于吐露了实情。原来我们还没有到厦门时，厦门中心市委急需经费，听说我们刚生了孩子，便擅自作出组织决定，已将孩子“送”给一个叫叶延环的同志。",
      "totalCount": 486,
      "appLink": "weread://bestbookmark?bookId=3300039258&chapterUid=7&rangeStart=19591&rangeEnd=19787",
      "webLink": "https://weread.qq.com/web/reader/7e032f20813ab75d5g0188fd?chapterUid=7&rangeStart=19591&rangeEnd=19787"
    },
    {
      "bookmarkId": "3300039258_16_12500-12533",
      "chapterUid": 16,
      "range": "12500-12533",
      "markText": "对一个革命者来说，健康的身体和乐观的心情是适应各种环境的首要条件。",
      "totalCount": 486,
      "appLink": "weread://bestbookmark?bookId=3300039258&chapterUid=16&rangeStart=12500&rangeEnd=12533",
      "webLink": "https://weread.qq.com/web/reader/7e032f20813ab75d5g0188fd?chapterUid=16&rangeStart=12500&rangeEnd=12533"
    },
    {
      "bookmarkId": "3300039258_7_19835-19873",
      "chapterUid": 7,
      "range": "19835-19873",
      "markText": "党组织已预收了100块大洋，而且已用得差不多了。所以我送也得送，不送也得送。",
      "totalCount": 484,
      "appLink": "weread://bestbookmark?bookId=3300039258&chapterUid=7&rangeStart=19835&rangeEnd=19873",
      "webLink": "https://weread.qq.com/web/reader/7e032f20813ab75d5g0188fd?chapterUid=7&rangeStart=19835&rangeEnd=19873"
    },
    {
      "bookmarkId": "3300039258_3_1869-1933",
      "chapterUid": 3,
      "range": "1869-1933",
      "markText": "尽管父亲终生一事无成，但他却保住了一个知识分子规规矩矩做事，小小心心做人的节操，而这些在贪官污吏充斥的旧中国官场确是难能可贵的。",
      "totalCount": 464,
      "appLink": "weread://bestbookmark?bookId=3300039258&chapterUid=3&rangeStart=1869&rangeEnd=1933",
      "webLink": "https://weread.qq.com/web/reader/7e032f20813ab75d5g0188fd?chapterUid=3&rangeStart=1869&rangeEnd=1933"
    },
    {
      "bookmarkId": "3300039258_12_6003-6083",
      "chapterUid": 12,
      "range": "6003-6083",
      "markText": "至于后来毛主席慢慢被人高高捧到了天上，当作偶像一样供奉朝拜起来，由“人”变成了“神”，“一言堂”代替了党内民主，最终导致了“文化大革命”，自然是令人扼腕叹息的！",
      "totalCount": 459,
      "appLink": "weread://bestbookmark?bookId=3300039258&chapterUid=12&rangeStart=6003&rangeEnd=6083",
      "webLink": "https://weread.qq.com/web/reader/7e032f20813ab75d5g0188fd?chapterUid=12&rangeStart=6003&rangeEnd=6083"
    },
    {
      "bookmarkId": "3300039258_12_14608-14663",
      "chapterUid": 12,
      "range": "14608-14663",
      "markText": "多次盼望多次落空后，我便很失望了。什么最美满的一对，那只是我的一种美梦。我戳穿了自己的美梦，心情反倒平静些了。",
      "totalCount": 434,
      "appLink": "weread://bestbookmark?bookId=3300039258&chapterUid=12&rangeStart=14608&rangeEnd=14663",
