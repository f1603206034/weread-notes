  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300110859_50_19628-19689",
      "chapterUid": 50,
      "range": "19628-19689",
      "markText": "“我是中国人民的儿子，我深情地爱着我的祖国和人民。我深深地相信，中国的未来是属于中国人民的，世界的未来是属于世界人民的。”",
      "totalCount": 3615,
      "appLink": "weread://bestbookmark?bookId=3300110859&chapterUid=50&rangeStart=19628&rangeEnd=19689",
      "webLink": "https://weread.qq.com/web/reader/34c32ff0813ab91cdg019b06?chapterUid=50&rangeStart=19628&rangeEnd=19689"
    },
    {
      "bookmarkId": "3300110859_29_31364-31390",
      "chapterUid": 29,
      "range": "31364-31390",
      "markText": "他望着空中，一字一顿地说了一句话：我还可以干二十年！",
      "totalCount": 1170,
      "appLink": "weread://bestbookmark?bookId=3300110859&chapterUid=29&rangeStart=31364&rangeEnd=31390",
      "webLink": "https://weread.qq.com/web/reader/34c32ff0813ab91cdg019b06?chapterUid=29&rangeStart=31364&rangeEnd=31390"
    },
    {
      "bookmarkId": "3300110859_29_3375-3414",
      "chapterUid": 29,
      "range": "3375-3414",
      "markText": "我们宁可再挨嘴巴子，世界上有些事情是必须由我们这些年轻人来做的，我们无可逃避。",
      "totalCount": 972,
      "appLink": "weread://bestbookmark?bookId=3300110859&chapterUid=29&rangeStart=3375&rangeEnd=3414",
      "webLink": "https://weread.qq.com/web/reader/34c32ff0813ab91cdg019b06?chapterUid=29&rangeStart=3375&rangeEnd=3414"
    },
    {
      "bookmarkId": "3300110859_39_24928-24998",
      "chapterUid": 39,
      "range": "24928-24998",
      "markText": "他想，这是个好东西，中国的幅员比日本辽阔得多，在各大城市之间如果都架设了高铁网络，那就会对生产要素的快速聚合、国民经济的发展带来很大的促进。",
      "totalCount": 705,
      "appLink": "weread://bestbookmark?bookId=3300110859&chapterUid=39&rangeStart=24928&rangeEnd=24998",
      "webLink": "https://weread.qq.com/web/reader/34c32ff0813ab91cdg019b06?chapterUid=39&rangeStart=24928&rangeEnd=24998"
    },
    {
      "bookmarkId": "3300110859_29_2882-2952",
      "chapterUid": 29,
      "range": "2882-2952",
      "markText": "人们在哀痛国家失去领袖的同时，好像还在哀痛着别的东西。人们心里有一种隐隐的恐惧感，这种恐惧感似乎很大，但是人们又不明白这种恐惧感到底是什么。",
      "totalCount": 688,
      "appLink": "weread://bestbookmark?bookId=3300110859&chapterUid=29&rangeStart=2882&rangeEnd=2952",
      "webLink": "https://weread.qq.com/web/reader/34c32ff0813ab91cdg019b06?chapterUid=29&rangeStart=2882&rangeEnd=2952"
    },
    {
      "bookmarkId": "3300110859_33_17909-17953",
      "chapterUid": 33,
      "range": "17909-17953",
      "markText": "邓小平一字一顿地说，实在没有纸张的话，就用印《毛选》五卷的纸张印试卷，五卷可以稍后再印。",
      "totalCount": 684,
      "appLink": "weread://bestbookmark?bookId=3300110859&chapterUid=33&rangeStart=17909&rangeEnd=17953",
      "webLink": "https://weread.qq.com/web/reader/34c32ff0813ab91cdg019b06?chapterUid=33&rangeStart=17909&rangeEnd=17953"
    },
    {
      "bookmarkId": "3300110859_47_12037-12090",
      "chapterUid": 47,
      "range": "12037-12090",
      "markText": "邓小平缓缓地说，既然香港税率是百分之十七点五，我们就要比它再低一点，就定百分之十五吧，特区就是要“特”嘛！",
      "totalCount": 666,
      "appLink": "weread://bestbookmark?bookId=3300110859&chapterUid=47&rangeStart=12037&rangeEnd=12090",
      "webLink": "https://weread.qq.com/web/reader/34c32ff0813ab91cdg019b06?chapterUid=47&rangeStart=12037&rangeEnd=12090"
    },
    {
      "bookmarkId": "3300110859_28_736-815",
      "chapterUid": 28,
      "range": "736-815",
      "markText": "这是一部大事不虚、小事不拘，令读者屡屡落泪的作品。它从普通人的视角去看时代的变动，它在写邓小平，更在写大时代。它是故事，却远远超越故事，它是历史，也充满反思。",
      "totalCount": 630,
      "appLink": "weread://bestbookmark?bookId=3300110859&chapterUid=28&rangeStart=736&rangeEnd=815",
      "webLink": "https://weread.qq.com/web/reader/34c32ff0813ab91cdg019b06?chapterUid=28&rangeStart=736&rangeEnd=815"
    },
    {
      "bookmarkId": "3300110859_29_21710-21753",
      "chapterUid": 29,
      "range": "21710-21753",
      "markText": "他没有听清，于是就把自己的耳朵尽可能地俯在总理的嘴边，便隐约听见总理在说，保护好小平。",
      "totalCount": 624,
      "appLink": "weread://bestbookmark?bookId=3300110859&chapterUid=29&rangeStart=21710&rangeEnd=21753",
      "webLink": "https://weread.qq.com/web/reader/34c32ff0813ab91cdg019b06?chapterUid=29&rangeStart=21710&rangeEnd=21753"
    },
    {
      "bookmarkId": "3300110859_47_34884-34944",
      "chapterUid": 47,
      "range": "34884-34944",
