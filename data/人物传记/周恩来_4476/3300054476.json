  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300054476_6_63694-63756",
      "chapterUid": 6,
      "range": "63694-63756",
      "markText": "1976年1月8日上午9时57分，周恩来在与癌症病魔作了最后的搏斗后，带着为中华民族子孙后代造福的众多美好设想，离开了人世。",
      "totalCount": 240,
      "appLink": "weread://bestbookmark?bookId=3300054476&chapterUid=6&rangeStart=63694&rangeEnd=63756",
      "webLink": "https://weread.qq.com/web/reader/94a324c0813ab7bc7g016192?chapterUid=6&rangeStart=63694&rangeEnd=63756"
    },
    {
      "bookmarkId": "3300054476_4_10243-10271",
      "chapterUid": 4,
      "range": "10243-10271",
      "markText": "当魏校长问到周恩来时，他庄重地回答：“为了中华之崛起。”",
      "totalCount": 210,
      "appLink": "weread://bestbookmark?bookId=3300054476&chapterUid=4&rangeStart=10243&rangeEnd=10271",
      "webLink": "https://weread.qq.com/web/reader/94a324c0813ab7bc7g016192?chapterUid=4&rangeStart=10243&rangeEnd=10271"
    },
    {
      "bookmarkId": "3300054476_4_2121-2143",
      "chapterUid": 4,
      "range": "2121-2143",
      "markText": "据周氏宗谱考证，周恩来与鲁迅的确是同宗同族。",
      "totalCount": 195,
      "appLink": "weread://bestbookmark?bookId=3300054476&chapterUid=4&rangeStart=2121&rangeEnd=2143",
      "webLink": "https://weread.qq.com/web/reader/94a324c0813ab7bc7g016192?chapterUid=4&rangeStart=2121&rangeEnd=2143"
    },
    {
      "bookmarkId": "3300054476_4_1819-1889",
      "chapterUid": 4,
      "range": "1819-1889",
      "markText": "在绍兴，无论是“百草园”周树人（鲁迅）的周家，还是“百岁堂”周恩来的周家，都尊奉一个始祖，那就是周茂。对这种渊源关系，周恩来后来曾多次提及。",
      "totalCount": 128,
      "appLink": "weread://bestbookmark?bookId=3300054476&chapterUid=4&rangeStart=1819&rangeEnd=1889",
      "webLink": "https://weread.qq.com/web/reader/94a324c0813ab7bc7g016192?chapterUid=4&rangeStart=1819&rangeEnd=1889"
    },
    {
      "bookmarkId": "3300054476_4_15234-15282",
      "chapterUid": 4,
      "range": "15234-15282",
      "markText": "1917年8月30日，周恩来在赴日留学前给同学写下了这样的临别赠言：“愿相会于中华腾飞世界时。”",
      "totalCount": 126,
      "appLink": "weread://bestbookmark?bookId=3300054476&chapterUid=4&rangeStart=15234&rangeEnd=15282",
      "webLink": "https://weread.qq.com/web/reader/94a324c0813ab7bc7g016192?chapterUid=4&rangeStart=15234&rangeEnd=15282"
    },
    {
      "bookmarkId": "3300054476_4_13942-13975",
      "chapterUid": 4,
      "range": "13942-13975",
      "markText": "校董严修也很赏识周恩来的人品和才学，他曾称誉周恩来“有宰相之才”。",
      "totalCount": 120,
      "appLink": "weread://bestbookmark?bookId=3300054476&chapterUid=4&rangeStart=13942&rangeEnd=13975",
      "webLink": "https://weread.qq.com/web/reader/94a324c0813ab7bc7g016192?chapterUid=4&rangeStart=13942&rangeEnd=13975"
    },
    {
      "bookmarkId": "3300054476_6_5482-5549",
      "chapterUid": 6,
      "range": "5482-5549",
      "markText": "我是政府总理，如果邓颖超是政府的一个部长，那么我这个总理和她那个部长就分不清了；人家会把她那个部长说的话，把她做的事当成是我支持的……",
      "totalCount": 108,
      "appLink": "weread://bestbookmark?bookId=3300054476&chapterUid=6&rangeStart=5482&rangeEnd=5549",
      "webLink": "https://weread.qq.com/web/reader/94a324c0813ab7bc7g016192?chapterUid=6&rangeStart=5482&rangeEnd=5549"
    },
    {
      "bookmarkId": "3300054476_4_11706-11795",
      "chapterUid": 4,
      "range": "11706-11795",
      "markText": "他抱定了立志救国、奋发读书的决心，对自己提出了五个“不虚度”的要求：读书不虚度，学业不虚度，习师不虚度，交友不虚度，光阴不虚度。的确，在四年的学校生活中，他完全实践了自己的诺言。",
      "totalCount": 91,
      "appLink": "weread://bestbookmark?bookId=3300054476&chapterUid=4&rangeStart=11706&rangeEnd=11795",
      "webLink": "https://weread.qq.com/web/reader/94a324c0813ab7bc7g016192?chapterUid=4&rangeStart=11706&rangeEnd=11795"
    },
    {
      "bookmarkId": "3300054476_6_39053-39094",
      "chapterUid": 6,
      "range": "39053-39094",
      "markText": "会前，毛泽东曾指出：农业、国防是拳头，基础工业是屁股，要使拳头有劲，屁股就要坐稳。",
      "totalCount": 90,
      "appLink": "weread://bestbookmark?bookId=3300054476&chapterUid=6&rangeStart=39053&rangeEnd=39094",
      "webLink": "https://weread.qq.com/web/reader/94a324c0813ab7bc7g016192?chapterUid=6&rangeStart=39053&rangeEnd=39094"
    },
    {
      "bookmarkId": "3300054476_4_4663-4710",
      "chapterUid": 4,
      "range": "4663-4710",
      "markText": "由于特殊的家庭环境和遭遇，周恩来与别人不同的是，在其性格中从小深深地打下了生母、嗣母的烙印……",
      "totalCount": 72,
      "appLink": "weread://bestbookmark?bookId=3300054476&chapterUid=4&rangeStart=4663&rangeEnd=4710",
      "webLink": "https://weread.qq.com/web/reader/94a324c0813ab7bc7g016192?chapterUid=4&rangeStart=4663&rangeEnd=4710"
    },
    {
      "bookmarkId": "3300054476_4_17647-17709",
      "chapterUid": 4,
      "range": "17647-17709",
      "markText": "第一，想要想比现在还新的思想；第二，做要做现在最新的事情；第三，学要学离现在最近的学问。思想要自由，做事要实在，学问要真切。",
      "totalCount": 72,
      "appLink": "weread://bestbookmark?bookId=3300054476&chapterUid=4&rangeStart=17647&rangeEnd=17709",
      "webLink": "https://weread.qq.com/web/reader/94a324c0813ab7bc7g016192?chapterUid=4&rangeStart=17647&rangeEnd=17709"
    },
    {
      "bookmarkId": "3300054476_4_3095-3109",
      "chapterUid": 4,
      "range": "3095-3109",
      "markText": "慎思明辨、思之缜密、行之周全",
      "totalCount": 66,
      "appLink": "weread://bestbookmark?bookId=3300054476&chapterUid=4&rangeStart=3095&rangeEnd=3109",
      "webLink": "https://weread.qq.com/web/reader/94a324c0813ab7bc7g016192?chapterUid=4&rangeStart=3095&rangeEnd=3109"
    },
    {
      "bookmarkId": "3300054476_4_8702-8738",
      "chapterUid": 4,
      "range": "8702-8738",
      "markText": "母亲把全部的爱，倾注在周恩来身上，而周恩来日后又把自己的一生献给了人民。",
      "totalCount": 65,
      "appLink": "weread://bestbookmark?bookId=3300054476&chapterUid=4&rangeStart=8702&rangeEnd=8738",
      "webLink": "https://weread.qq.com/web/reader/94a324c0813ab7bc7g016192?chapterUid=4&rangeStart=8702&rangeEnd=8738"
    },
    {
      "bookmarkId": "3300054476_4_18550-18568",
      "chapterUid": 4,
      "range": "18550-18568",
      "markText": "不能只顾一时的得失，动摇多年的志愿。",
      "totalCount": 65,
      "appLink": "weread://bestbookmark?bookId=3300054476&chapterUid=4&rangeStart=18550&rangeEnd=18568",
      "webLink": "https://weread.qq.com/web/reader/94a324c0813ab7bc7g016192?chapterUid=4&rangeStart=18550&rangeEnd=18568"
    },
    {
      "bookmarkId": "3300054476_6_56479-56489",
      "chapterUid": 6,
      "range": "56479-56489",
      "markText": "“不倒、不走、不死。",
      "totalCount": 64,
      "appLink": "weread://bestbookmark?bookId=3300054476&chapterUid=6&rangeStart=56479&rangeEnd=56489",
      "webLink": "https://weread.qq.com/web/reader/94a324c0813ab7bc7g016192?chapterUid=6&rangeStart=56479&rangeEnd=56489"
    },
    {
      "bookmarkId": "3300054476_4_13145-13208",
      "chapterUid": 4,
      "range": "13145-13208",
      "markText": "1914年3月，周恩来和张蓬仙、常策欧两位同学，在学校发起组织了一个业余团体──“敬业乐群会”，取“敬重学业，联络感情”之意。",
      "totalCount": 60,
      "appLink": "weread://bestbookmark?bookId=3300054476&chapterUid=4&rangeStart=13145&rangeEnd=13208",
      "webLink": "https://weread.qq.com/web/reader/94a324c0813ab7bc7g016192?chapterUid=4&rangeStart=13145&rangeEnd=13208"
    },
    {
      "bookmarkId": "3300054476_4_15386-15449",
      "chapterUid": 4,
      "range": "15386-15449",
      "markText": "大江歌罢掉头东，邃密群科济世穷， 面壁十年图破壁，难酬蹈海亦英雄。",
      "totalCount": 56,
      "appLink": "weread://bestbookmark?bookId=3300054476&chapterUid=4&rangeStart=15386&rangeEnd=15449",
      "webLink": "https://weread.qq.com/web/reader/94a324c0813ab7bc7g016192?chapterUid=4&rangeStart=15386&rangeEnd=15449"
    },
    {
      "bookmarkId": "3300054476_6_59853-59909",
      "chapterUid": 6,
      "range": "59853-59909",
      "markText": "我觉得自己身体还好，虽然已68岁了，还可以做一些技术性的工作，例如调查研究工作，还可以为党为人民做七八年的工作。",
      "totalCount": 56,
      "appLink": "weread://bestbookmark?bookId=3300054476&chapterUid=6&rangeStart=59853&rangeEnd=59909",
      "webLink": "https://weread.qq.com/web/reader/94a324c0813ab7bc7g016192?chapterUid=6&rangeStart=59853&rangeEnd=59909"
    },
    {
      "bookmarkId": "3300054476_4_6611-6663",
      "chapterUid": 4,
      "range": "6611-6663",
      "markText": "后来周恩来回忆道：“母亲在35岁时即患肺疾而死。原因是我家在祖父去世后，每况愈下，母亲因操劳过度成疾。”",
      "totalCount": 54,
      "appLink": "weread://bestbookmark?bookId=3300054476&chapterUid=4&rangeStart=6611&rangeEnd=6663",
      "webLink": "https://weread.qq.com/web/reader/94a324c0813ab7bc7g016192?chapterUid=4&rangeStart=6611&rangeEnd=6663"
    },
    {
      "bookmarkId": "3300054476_4_6980-7033",
      "chapterUid": 4,
      "range": "6980-7033",
      "markText": "不幸的是，一年以后的1908年夏天，嗣母也被当时的不治之症肺痨夺去了生命。嗣母的去世，给周恩来的打击最大。",
      "totalCount": 54,
