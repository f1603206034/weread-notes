    },
    {
      "bookmarkId": "709788_3_513-538",
      "chapterUid": 3,
      "range": "513-538",
      "markText": "只不过，对任何人我都没有提起自己将要去英国的事情。",
      "totalCount": 108,
      "appLink": "weread://bestbookmark?bookId=709788&chapterUid=3&rangeStart=513&rangeEnd=538",
      "webLink": "https://weread.qq.com/web/reader/dfc32d305ad49cdfc86e126?chapterUid=3&rangeStart=513&rangeEnd=538"
