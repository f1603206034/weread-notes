    },
    {
      "bookmarkId": "709788_21_194-222",
      "chapterUid": 21,
      "range": "194-222",
      "markText": "懒惰的代价是税的两倍，骄傲是税的三倍，而愚蠢则四倍于税。",
      "totalCount": 108,
      "appLink": "weread://bestbookmark?bookId=709788&chapterUid=21&rangeStart=194&rangeEnd=222",
      "webLink": "https://weread.qq.com/web/reader/dfc32d305ad49cdfc86e126?chapterUid=21&rangeStart=194&rangeEnd=222"
