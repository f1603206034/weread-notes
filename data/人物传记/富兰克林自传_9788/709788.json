    {
      "bookmarkId": "709788_3_2448-2494",
      "chapterUid": 3,
      "range": "2448-2494",
      "markText": "我并不是一个说教者，但我认为许多明显的错误就应该改正，而不是纵容，或者编造一些理由敷衍自己。",
      "totalCount": 108,
      "appLink": "weread://bestbookmark?bookId=709788&chapterUid=3&rangeStart=2448&rangeEnd=2494",
