  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "25409494_5_3184-3254",
      "chapterUid": 5,
      "range": "3184-3254",
      "markText": "很早就在学习法语、德语和俄语了，能够阅读这些语言的外文书籍，后来，我感到英语很有用，我就又开始学习英语，不久就能阅读英文书和英国文学作品了。",
      "totalCount": 160,
      "appLink": "weread://bestbookmark?bookId=25409494&chapterUid=5&rangeStart=3184&rangeEnd=3254",
      "webLink": "https://weread.qq.com/web/reader/c7832b907183b7d6c7889d4?chapterUid=5&rangeStart=3184&rangeEnd=3254"
    },
    {
      "bookmarkId": "25409494_5_1326-1385",
      "chapterUid": 5,
      "range": "1326-1385",
      "markText": "在农村，我不由得会感到无拘无束，散淡惬意。我之所以终生喜爱田野乡村，喜爱大自然，想必与这段值得怀念的生活经历不无关系。",
      "totalCount": 154,
      "appLink": "weread://bestbookmark?bookId=25409494&chapterUid=5&rangeStart=1326&rangeEnd=1385",
      "webLink": "https://weread.qq.com/web/reader/c7832b907183b7d6c7889d4?chapterUid=5&rangeStart=1326&rangeEnd=1385"
    },
    {
      "bookmarkId": "25409494_5_8107-8158",
      "chapterUid": 5,
      "range": "8107-8158",
      "markText": "当然，有时候，孤独之感会突然涌上心头，好在我的情绪通常十分平静，精神上十分满足，所以孤独情绪转瞬即逝。",
      "totalCount": 119,
      "appLink": "weread://bestbookmark?bookId=25409494&chapterUid=5&rangeStart=8107&rangeEnd=8158",
      "webLink": "https://weread.qq.com/web/reader/c7832b907183b7d6c7889d4?chapterUid=5&rangeStart=8107&rangeEnd=8158"
    },
    {
      "bookmarkId": "25409494_8_2008-2078",
      "chapterUid": 8,
      "range": "2008-2078",
      "markText": "美国的母亲们认为，大城市，尤其是纽约的环境不利于女孩子们的教育，而乡间既宁静又空旷，不仅有益于她们的身心健康，而且也可以让她们静下心来学习。",
      "totalCount": 112,
      "appLink": "weread://bestbookmark?bookId=25409494&chapterUid=8&rangeStart=2008&rangeEnd=2078",
      "webLink": "https://weread.qq.com/web/reader/c7832b907183b7d6c7889d4?chapterUid=8&rangeStart=2008&rangeEnd=2078"
    },
    {
      "bookmarkId": "25409494_6_10166-10243",
      "chapterUid": 6,
      "range": "10166-10243",
      "markText": "家庭生活中，重要的是相互体谅，彼此尊重，否则彼此之间是不可能感到愉快，自己也不可能精力充沛的。我们母女之间从来不说一句伤人的话，从来不做一件自私自利的事。",
      "totalCount": 108,
      "appLink": "weread://bestbookmark?bookId=25409494&chapterUid=6&rangeStart=10166&rangeEnd=10243",
      "webLink": "https://weread.qq.com/web/reader/c7832b907183b7d6c7889d4?chapterUid=6&rangeStart=10166&rangeEnd=10243"
    },
    {
      "bookmarkId": "25409494_5_8701-8777",
      "chapterUid": 5,
      "range": "8701-8777",
      "markText": "但第一学年临近结束时，我不得不离开这个小团体，因为我觉得自己应该把全部精力都放在学习上，这样才能尽快地完成学业，即使假期里，我也在抓紧时间复习我的数学。",
      "totalCount": 102,
      "appLink": "weread://bestbookmark?bookId=25409494&chapterUid=5&rangeStart=8701&rangeEnd=8777",
      "webLink": "https://weread.qq.com/web/reader/c7832b907183b7d6c7889d4?chapterUid=5&rangeStart=8701&rangeEnd=8777"
    },
    {
      "bookmarkId": "25409494_6_3453-3497",
      "chapterUid": 6,
      "range": "3453-3497",
      "markText": "新科学的路，这是我们开始时所没有预料到的，而且，我从此就再也没有离开过这条新的科学之路。",
      "totalCount": 102,
      "appLink": "weread://bestbookmark?bookId=25409494&chapterUid=6&rangeStart=3453&rangeEnd=3497",
      "webLink": "https://weread.qq.com/web/reader/c7832b907183b7d6c7889d4?chapterUid=6&rangeStart=3453&rangeEnd=3497"
    },
    {
      "bookmarkId": "25409494_5_2997-3069",
      "chapterUid": 5,
      "range": "2997-3069",
      "markText": "每个周末晚间，我们都围在他的膝下，听他给我们朗诵波兰的著名诗歌和散文。这样的夜晚对于我们来说其乐融融，而且爱国主义的情愫在不知不觉之中日益增强。",
      "totalCount": 91,
      "appLink": "weread://bestbookmark?bookId=25409494&chapterUid=5&rangeStart=2997&rangeEnd=3069",
      "webLink": "https://weread.qq.com/web/reader/c7832b907183b7d6c7889d4?chapterUid=5&rangeStart=2997&rangeEnd=3069"
    },
    {
      "bookmarkId": "25409494_5_8984-9064",
      "chapterUid": 5,
      "range": "8984-9064",
      "markText": "我自己也始终把这段时期的艰苦奋斗视为我一生中最值得回忆的一个美好的时期。在这一期间，我孤身奋斗，没日没夜地全身心地埋头钻研，终于达到了有能力进行科学研究的目的。",
      "totalCount": 90,
      "appLink": "weread://bestbookmark?bookId=25409494&chapterUid=5&rangeStart=8984&rangeEnd=9064",
      "webLink": "https://weread.qq.com/web/reader/c7832b907183b7d6c7889d4?chapterUid=5&rangeStart=8984&rangeEnd=9064"
    },
    {
      "bookmarkId": "25409494_15_3071-3101",
      "chapterUid": 15,
      "range": "3071-3101",
      "markText": "他一向认为最重要的是忠于自己真正的意愿，同时又尊重他人的观点",
      "totalCount": 90,
      "appLink": "weread://bestbookmark?bookId=25409494&chapterUid=15&rangeStart=3071&rangeEnd=3101",
      "webLink": "https://weread.qq.com/web/reader/c7832b907183b7d6c7889d4?chapterUid=15&rangeStart=3071&rangeEnd=3101"
    },
    {
      "bookmarkId": "25409494_6_7160-7225",
      "chapterUid": 6,
      "range": "7160-7225",
      "markText": "获奖之后，报纸和杂志对我们大加颂扬，致使我们有好长一段时间没法安心工作，每天都有人登门造访，有的请我们去作报告，有的则向我们约稿。",
      "totalCount": 85,
      "appLink": "weread://bestbookmark?bookId=25409494&chapterUid=6&rangeStart=7160&rangeEnd=7225",
      "webLink": "https://weread.qq.com/web/reader/c7832b907183b7d6c7889d4?chapterUid=6&rangeStart=7160&rangeEnd=7225"
    },
    {
      "bookmarkId": "25409494_5_1717-1781",
      "chapterUid": 5,
      "range": "1717-1781",
      "markText": "我母亲为人高尚、温柔敦厚、心慈面善，而且她知识渊博、心胸坦荡、严于律己。她宽容大度、温情善良，而且在家中很有威望，大家都信服她。",
      "totalCount": 80,
      "appLink": "weread://bestbookmark?bookId=25409494&chapterUid=5&rangeStart=1717&rangeEnd=1781",
      "webLink": "https://weread.qq.com/web/reader/c7832b907183b7d6c7889d4?chapterUid=5&rangeStart=1717&rangeEnd=1781"
    },
    {
      "bookmarkId": "25409494_5_4905-4952",
      "chapterUid": 5,
      "range": "4905-4952",
      "markText": "我渐渐地懂得了种植技术，并且一直在关心着谷物的生长情况。在庄园的马厩里，我还摸透了马匹的脾性。",
      "totalCount": 75,
      "appLink": "weread://bestbookmark?bookId=25409494&chapterUid=5&rangeStart=4905&rangeEnd=4952",
      "webLink": "https://weread.qq.com/web/reader/c7832b907183b7d6c7889d4?chapterUid=5&rangeStart=4905&rangeEnd=4952"
    },
    {
      "bookmarkId": "25409494_5_7839-7938",
      "chapterUid": 5,
      "range": "7839-7938",
      "markText": "我只有一盏酒精灯可以用来烧饭，其他的炊事用具就谈不上了。为了省钱省时间，我常常是一点点面包加一杯巧克力、再加几个鸡蛋和一个水果充饥。我独自处理家务，没有任何人帮助，取暖用的煤，也是我亲自弄上七楼的。",
      "totalCount": 72,
      "appLink": "weread://bestbookmark?bookId=25409494&chapterUid=5&rangeStart=7839&rangeEnd=7938",
      "webLink": "https://weread.qq.com/web/reader/c7832b907183b7d6c7889d4?chapterUid=5&rangeStart=7839&rangeEnd=7938"
    },
    {
      "bookmarkId": "25409494_6_1546-1594",
      "chapterUid": 6,
