  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "40857924_4_668-723",
      "chapterUid": 4,
      "range": "668-723",
      "markText": "而我试图思考的立足点是：作为一个将过渡性中间物视为自身命运并加以承担的人，他是如何在仅此一回的生命中活下去的。",
      "totalCount": 234,
      "appLink": "weread://bestbookmark?bookId=40857924&chapterUid=4&rangeStart=668&rangeEnd=723",
      "webLink": "https://weread.qq.com/web/reader/cee329b0726f7144cee4bee?chapterUid=4&rangeStart=668&rangeEnd=723"
    },
    {
      "bookmarkId": "40857924_4_495-542",
      "chapterUid": 4,
      "range": "495-542",
      "markText": "鲁迅写过一句话，“只要能培一朵花，就不妨做做会朽的腐草”（《近代世界短篇小说集》，1929）。",
      "totalCount": 196,
      "appLink": "weread://bestbookmark?bookId=40857924&chapterUid=4&rangeStart=495&rangeEnd=542",
      "webLink": "https://weread.qq.com/web/reader/cee329b0726f7144cee4bee?chapterUid=4&rangeStart=495&rangeEnd=542"
    },
    {
      "bookmarkId": "40857924_22_3283-3330",
      "chapterUid": 22,
      "range": "3283-3330",
      "markText": "人生最苦痛的是梦醒了无路可以走。做梦的人是幸福的；倘没有看出可走的路，最要紧的是不要去惊醒他。",
      "totalCount": 187,
      "appLink": "weread://bestbookmark?bookId=40857924&chapterUid=22&rangeStart=3283&rangeEnd=3330",
      "webLink": "https://weread.qq.com/web/reader/cee329b0726f7144cee4bee?chapterUid=22&rangeStart=3283&rangeEnd=3330"
    },
    {
      "bookmarkId": "40857924_20_5520-5564",
      "chapterUid": 20,
      "range": "5520-5564",
      "markText": "希望是本无所谓有，无所谓无的。这正如地上的路；其实地上本没有路，走的人多了，也便成了路。",
      "totalCount": 168,
      "appLink": "weread://bestbookmark?bookId=40857924&chapterUid=20&rangeStart=5520&rangeEnd=5564",
      "webLink": "https://weread.qq.com/web/reader/cee329b0726f7144cee4bee?chapterUid=20&rangeStart=5520&rangeEnd=5564"
    },
    {
      "bookmarkId": "40857924_6_3336-3432",
      "chapterUid": 6,
      "range": "3336-3432",
      "markText": "鲁瑞曾在兄弟们上课时旁听学习，但大约一年后家里便不许她听课，于是她依靠自学掌握了读书的能力。她是一位性格温和但意志坚强的女性，后来反对缠足的运动兴起时，她主动放开缠足，即便遭人非难也无所动摇。",
      "totalCount": 144,
      "appLink": "weread://bestbookmark?bookId=40857924&chapterUid=6&rangeStart=3336&rangeEnd=3432",
      "webLink": "https://weread.qq.com/web/reader/cee329b0726f7144cee4bee?chapterUid=6&rangeStart=3336&rangeEnd=3432"
    },
    {
      "bookmarkId": "40857924_3_3736-3765",
      "chapterUid": 3,
      "range": "3736-3765",
      "markText": "1933年2月，鲁迅在上海孙中山故居出席欢迎萧伯纳的午餐会",
      "totalCount": 143,
      "appLink": "weread://bestbookmark?bookId=40857924&chapterUid=3&rangeStart=3736&rangeEnd=3765",
      "webLink": "https://weread.qq.com/web/reader/cee329b0726f7144cee4bee?chapterUid=3&rangeStart=3736&rangeEnd=3765"
    },
    {
      "bookmarkId": "40857924_9_1836-1861",
      "chapterUid": 9,
      "range": "1836-1861",
      "markText": "或许是军事学校的缘故，学生处罚规定中甚至还有死刑。",
      "totalCount": 112,
      "appLink": "weread://bestbookmark?bookId=40857924&chapterUid=9&rangeStart=1836&rangeEnd=1861",
      "webLink": "https://weread.qq.com/web/reader/cee329b0726f7144cee4bee?chapterUid=9&rangeStart=1836&rangeEnd=1861"
    },
    {
      "bookmarkId": "40857924_25_5297-5379",
      "chapterUid": 25,
      "range": "5297-5379",
      "markText": "我蔑视他们了。我先前偶一想到爱，总立刻自己惭愧，怕不配，因为也不敢爱某一个人，但看清了他们的言行思想的内幕，便使我自信我决不是必须自己贬抑到那么样的人了，我可以爱！",
      "totalCount": 108,
