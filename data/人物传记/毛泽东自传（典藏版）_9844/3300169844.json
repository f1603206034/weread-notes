  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300169844_4_624-694",
      "chapterUid": 4,
      "range": "624-694",
      "markText": "显然他认为个人的重要性微乎其微。如同我遇见过的其他共产党人那样，他倾向于只谈委员会、组织、军队、决议、战斗、战术、措施等，很少谈个人的经历。",
      "totalCount": 570,
      "appLink": "weread://bestbookmark?bookId=3300169844&chapterUid=4&rangeStart=624&rangeEnd=694",
      "webLink": "https://weread.qq.com/web/reader/80432c80813aba8d8g014be1?chapterUid=4&rangeStart=624&rangeEnd=694"
    },
    {
      "bookmarkId": "3300169844_4_4004-4053",
      "chapterUid": 4,
      "range": "4004-4053",
      "markText": "从此我懂得了如何保护自己的权利，我一公开反抗，他就缓和下来，而我越一味软弱顺从，他就越训斥我打我。",
      "totalCount": 518,
      "appLink": "weread://bestbookmark?bookId=3300169844&chapterUid=4&rangeStart=4004&rangeEnd=4053",
      "webLink": "https://weread.qq.com/web/reader/80432c80813aba8d8g014be1?chapterUid=4&rangeStart=4004&rangeEnd=4053"
    },
    {
      "bookmarkId": "3300169844_5_7905-7937",
      "chapterUid": 5,
      "range": "7905-7937",
      "markText": "我和我的朋友只愿谈大事——人的本质、人类社会、中国、世界和宇宙！",
      "totalCount": 450,
      "appLink": "weread://bestbookmark?bookId=3300169844&chapterUid=5&rangeStart=7905&rangeEnd=7937",
      "webLink": "https://weread.qq.com/web/reader/80432c80813aba8d8g014be1?chapterUid=5&rangeStart=7905&rangeEnd=7937"
    },
    {
      "bookmarkId": "3300169844_4_2724-2800",
      "chapterUid": 4,
      "range": "2724-2800",
      "markText": "“然而，回家之后，令我惊喜的是状况有所改善。我父亲开始对我有些体贴，老师也较温和了一点。这次反抗的结果，给我留下的印象相当深刻。这是一次成功的‘斗争’。",
      "totalCount": 442,
      "appLink": "weread://bestbookmark?bookId=3300169844&chapterUid=4&rangeStart=2724&rangeEnd=2800",
      "webLink": "https://weread.qq.com/web/reader/80432c80813aba8d8g014be1?chapterUid=4&rangeStart=2724&rangeEnd=2800"
    },
    {
      "bookmarkId": "3300169844_4_5054-5129",
      "chapterUid": 4,
      "range": "5054-5129",
      "markText": "这事我思考了两年，后来我分析这些故事的内容，发现它们颂扬的都是武将、人民的统治者，他们都不事农桑，因为他们占有并控制了土地，显然他们让农民为他们种田。",
      "totalCount": 375,
      "appLink": "weread://bestbookmark?bookId=3300169844&chapterUid=4&rangeStart=5054&rangeEnd=5129",
      "webLink": "https://weread.qq.com/web/reader/80432c80813aba8d8g014be1?chapterUid=4&rangeStart=5054&rangeEnd=5129"
    },
    {
      "bookmarkId": "3300169844_4_7807-7855",
      "chapterUid": 4,
      "range": "7807-7855",
      "markText": "双方互不相让。我在这场争端中采取中立，因为我是外乡人。结果三个地区的学生都歧视我，我心情很郁闷。",
      "totalCount": 306,
      "appLink": "weread://bestbookmark?bookId=3300169844&chapterUid=4&rangeStart=7807&rangeEnd=7855",
      "webLink": "https://weread.qq.com/web/reader/80432c80813aba8d8g014be1?chapterUid=4&rangeStart=7807&rangeEnd=7855"
    },
    {
      "bookmarkId": "3300169844_5_4550-4632",
      "chapterUid": 5,
      "range": "4550-4632",
      "markText": "我断定要成为一名经商专家，到那里去更好一些，就又花一元钱报了名，接着就写信把我的想法告诉了父亲。他很高兴，因为他知道精通商务的益处。我进了这所学校——仅待了一个月。",
      "totalCount": 288,
      "appLink": "weread://bestbookmark?bookId=3300169844&chapterUid=5&rangeStart=4550&rangeEnd=4632",
      "webLink": "https://weread.qq.com/web/reader/80432c80813aba8d8g014be1?chapterUid=5&rangeStart=4550&rangeEnd=4632"
    },
    {
      "bookmarkId": "3300169844_4_3223-3272",
      "chapterUid": 4,
      "range": "3223-3272",
      "markText": "我母亲主张不直接进攻的政策。她批评任何明显的情绪表露和对执政党的公开反抗，她说这不是中国人的传统。",
      "totalCount": 272,
      "appLink": "weread://bestbookmark?bookId=3300169844&chapterUid=4&rangeStart=3223&rangeEnd=3272",
      "webLink": "https://weread.qq.com/web/reader/80432c80813aba8d8g014be1?chapterUid=4&rangeStart=3223&rangeEnd=3272"
    },
    {
      "bookmarkId": "3300169844_4_800-831",
      "chapterUid": 4,
      "range": "800-831",
      "markText": "后来我才得知事情并非如此，而是他们大多数人记不清个人的琐事了。",
      "totalCount": 264,
      "appLink": "weread://bestbookmark?bookId=3300169844&chapterUid=4&rangeStart=800&rangeEnd=831",
      "webLink": "https://weread.qq.com/web/reader/80432c80813aba8d8g014be1?chapterUid=4&rangeStart=800&rangeEnd=831"
    },
    {
      "bookmarkId": "3300169844_4_6198-6253",
      "chapterUid": 4,
      "range": "6198-6253",
      "markText": "我永远忘不了这件事，我感到那些造反的人都是像我自己家人一样的普通老百姓，我对他们所受到的非正义的对待深抱不平。",
      "totalCount": 224,
      "appLink": "weread://bestbookmark?bookId=3300169844&chapterUid=4&rangeStart=6198&rangeEnd=6253",
      "webLink": "https://weread.qq.com/web/reader/80432c80813aba8d8g014be1?chapterUid=4&rangeStart=6198&rangeEnd=6253"
    },
    {
      "bookmarkId": "3300169844_4_4240-4322",
      "chapterUid": 4,
      "range": "4240-4322",
      "markText": "我是家中的‘秀才’，念过几本经书，但我不喜欢读经。我爱读的是中国古典小说，特别是造反的故事，我年纪不大时就读过《岳飞传》《水浒传》《说唐》《三国演义》《西游记》等，",
      "totalCount": 210,
      "appLink": "weread://bestbookmark?bookId=3300169844&chapterUid=4&rangeStart=4240&rangeEnd=4322",
      "webLink": "https://weread.qq.com/web/reader/80432c80813aba8d8g014be1?chapterUid=4&rangeStart=4240&rangeEnd=4322"
    },
    {
      "bookmarkId": "3300169844_4_5434-5530",
      "chapterUid": 4,
      "range": "5434-5530",
      "markText": "而我父亲更是吃惊不已，后来，他对这次奇迹般的脱险思忖良久，开始琢磨自己是否触犯了神灵。从那以后，他显得比较敬佛了，不时地焚香。然而我自己却越来越不信佛，他也不加干涉。他只是在有难时才求佛保佑。",
      "totalCount": 208,
      "appLink": "weread://bestbookmark?bookId=3300169844&chapterUid=4&rangeStart=5434&rangeEnd=5530",
      "webLink": "https://weread.qq.com/web/reader/80432c80813aba8d8g014be1?chapterUid=4&rangeStart=5434&rangeEnd=5530"
    },
    {
      "bookmarkId": "3300169844_4_6937-6973",
      "chapterUid": 4,
      "range": "6937-6973",
      "markText": "读罢，我感到十分抑郁，忧虑我的祖国的前途，开始意识到参与救国，人人有责。",
      "totalCount": 208,
      "appLink": "weread://bestbookmark?bookId=3300169844&chapterUid=4&rangeStart=6937&rangeEnd=6973",
      "webLink": "https://weread.qq.com/web/reader/80432c80813aba8d8g014be1?chapterUid=4&rangeStart=6937&rangeEnd=6973"
    },
    {
      "bookmarkId": "3300169844_5_5919-5998",
      "chapterUid": 5,
      "range": "5919-5998",
      "markText": "我为两位朋友写了作文，又为自己写了一篇，结果都被录取了——所以，我实际上被录取了三次。当时我并不觉得为朋友代考是不道德的行为，这只不过是一件出于朋友义气的事。",
      "totalCount": 208,
      "appLink": "weread://bestbookmark?bookId=3300169844&chapterUid=5&rangeStart=5919&rangeEnd=5998",
      "webLink": "https://weread.qq.com/web/reader/80432c80813aba8d8g014be1?chapterUid=5&rangeStart=5919&rangeEnd=5998"
    },
    {
      "bookmarkId": "3300169844_4_8956-9009",
