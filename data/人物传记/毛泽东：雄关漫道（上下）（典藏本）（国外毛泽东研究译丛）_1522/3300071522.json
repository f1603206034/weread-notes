  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300071522_7_13668-13693",
      "chapterUid": 7,
      "range": "13668-13693",
      "markText": "毛泽东无法胜任学习任何一门外语，他的一生都是如此。",
      "totalCount": 180,
      "appLink": "weread://bestbookmark?bookId=3300071522&chapterUid=7&rangeStart=13668&rangeEnd=13693",
      "webLink": "https://weread.qq.com/web/reader/8e832e00813ab8270g012a83?chapterUid=7&rangeStart=13668&rangeEnd=13693"
    },
    {
      "bookmarkId": "3300071522_26_12954-13029",
      "chapterUid": 26,
      "range": "12954-13029",
      "markText": "毛泽东醉心于权力的原因中实现自己的平等梦想要多于对权力的喜好。他热衷于建立在互助和慷慨基础上的平均社会主义，追求理想主义的乌托邦，却给人民带来了不幸。",
      "totalCount": 165,
      "appLink": "weread://bestbookmark?bookId=3300071522&chapterUid=26&rangeStart=12954&rangeEnd=13029",
      "webLink": "https://weread.qq.com/web/reader/8e832e00813ab8270g012a83?chapterUid=26&rangeStart=12954&rangeEnd=13029"
    },
    {
      "bookmarkId": "3300071522_8_5325-5400",
      "chapterUid": 8,
      "range": "5325-5400",
      "markText": "然后开始追溯自拿破仑以来法德之间的关系，一个国家强加一种屈辱给另一个国家，几十年后都会遭到报复：“包管十年二十年后，你们法国人，又有一番大大的头痛”。",
      "totalCount": 153,
      "appLink": "weread://bestbookmark?bookId=3300071522&chapterUid=8&rangeStart=5325&rangeEnd=5400",
      "webLink": "https://weread.qq.com/web/reader/8e832e00813ab8270g012a83?chapterUid=8&rangeStart=5325&rangeEnd=5400"
    },
    {
      "bookmarkId": "3300071522_5_2040-2098",
      "chapterUid": 5,
      "range": "2040-2098",
      "markText": "其实对于绝大多数的中国人而言，毛泽东不再是一个人：他是该国历史上区分贫弱中国和胜利中国的纪念碑，一个永不褪色的象征。",
      "totalCount": 126,
      "appLink": "weread://bestbookmark?bookId=3300071522&chapterUid=5&rangeStart=2040&rangeEnd=2098",
      "webLink": "https://weread.qq.com/web/reader/8e832e00813ab8270g012a83?chapterUid=5&rangeStart=2040&rangeEnd=2098"
    },
    {
      "bookmarkId": "3300071522_5_6172-6203",
      "chapterUid": 5,
      "range": "6172-6203",
      "markText": "邓小平用毛泽东评价斯大林的方法来评价毛泽东：七分功劳，三分过失",
      "totalCount": 126,
      "appLink": "weread://bestbookmark?bookId=3300071522&chapterUid=5&rangeStart=6172&rangeEnd=6203",
      "webLink": "https://weread.qq.com/web/reader/8e832e00813ab8270g012a83?chapterUid=5&rangeStart=6172&rangeEnd=6203"
    },
    {
      "bookmarkId": "3300071522_9_52930-52992",
      "chapterUid": 9,
      "range": "52930-52992",
      "markText": "他重新投入政治斗争，在6个月中，他深入中国内陆，确切地了解到一个新的情况：中国革命的命运取决于革命者调动农民巨大潜力的能力。",
      "totalCount": 126,
      "appLink": "weread://bestbookmark?bookId=3300071522&chapterUid=9&rangeStart=52930&rangeEnd=52992",
      "webLink": "https://weread.qq.com/web/reader/8e832e00813ab8270g012a83?chapterUid=9&rangeStart=52930&rangeEnd=52992"
    },
    {
      "bookmarkId": "3300071522_5_1075-1101",
      "chapterUid": 5,
      "range": "1075-1101",
      "markText": "虽然在中国有人有理由不喜欢他，但大部分人仍然尊重他，",
      "totalCount": 108,
      "appLink": "weread://bestbookmark?bookId=3300071522&chapterUid=5&rangeStart=1075&rangeEnd=1101",
      "webLink": "https://weread.qq.com/web/reader/8e832e00813ab8270g012a83?chapterUid=5&rangeStart=1075&rangeEnd=1101"
    },
    {
      "bookmarkId": "3300071522_5_2188-2256",
      "chapterUid": 5,
      "range": "2188-2256",
      "markText": "不管毛泽东在这次赶超中真正起到什么作用，他都是重要角色，而中国人感谢他，不论对或错。人们在毛泽东身上找到了一个曾经备受侮辱的国家的骄傲。",
      "totalCount": 108,
      "appLink": "weread://bestbookmark?bookId=3300071522&chapterUid=5&rangeStart=2188&rangeEnd=2256",
      "webLink": "https://weread.qq.com/web/reader/8e832e00813ab8270g012a83?chapterUid=5&rangeStart=2188&rangeEnd=2256"
    },
    {
      "bookmarkId": "3300071522_10_32202-32500",
      "chapterUid": 10,
      "range": "32202-32500",
      "markText": "革命不是请客吃饭，不易做文解，不是绘画绣花，不能那样雅致，那样从容不迫，文质彬彬，那样温良恭俭让。革命是暴动，是一个阶级推翻一个阶级的暴烈的行动”。",
      "totalCount": 108,
      "appLink": "weread://bestbookmark?bookId=3300071522&chapterUid=10&rangeStart=32202&rangeEnd=32500",
      "webLink": "https://weread.qq.com/web/reader/8e832e00813ab8270g012a83?chapterUid=10&rangeStart=32202&rangeEnd=32500"
    },
    {
      "bookmarkId": "3300071522_23_8170-8220",
      "chapterUid": 23,
      "range": "8170-8220",
      "markText": "不过，他一生中没有受过真正的大学教育，这让他很痛苦。自学成才，阅读广博，他在一生中都不信任正牌文人。",
      "totalCount": 108,
