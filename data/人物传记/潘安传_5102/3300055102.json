  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300055102_154_4862-4909",
      "chapterUid": 154,
      "range": "4862-4909",
      "markText": "若说韩寿是皮秀，夏侯湛是骨秀，那面前的这个少年就应称之为神秀。明月出海，漫天星辰顿时黯然无光。",
      "totalCount": 176,
      "appLink": "weread://bestbookmark?bookId=3300055102&chapterUid=154&rangeStart=4862&rangeEnd=4909",
      "webLink": "https://weread.qq.com/web/reader/301323b0813ab7c06g012894?chapterUid=154&rangeStart=4862&rangeEnd=4909"
    },
    {
      "bookmarkId": "3300055102_158_17630-17639",
      "chapterUid": 158,
      "range": "17630-17639",
      "markText": "那是一封退亲文书。",
      "totalCount": 150,
      "appLink": "weread://bestbookmark?bookId=3300055102&chapterUid=158&rangeStart=17630&rangeEnd=17639",
      "webLink": "https://weread.qq.com/web/reader/301323b0813ab7c06g012894?chapterUid=158&rangeStart=17630&rangeEnd=17639"
    },
    {
      "bookmarkId": "3300055102_150_537-579",
      "chapterUid": 150,
      "range": "537-579",
      "markText": "“智者不惑，仁者不忧，勇者不惧。我确实当不起那个‘仁’字，今后就称我‘潘安’好了。”",
      "totalCount": 144,
      "appLink": "weread://bestbookmark?bookId=3300055102&chapterUid=150&rangeStart=537&rangeEnd=579",
      "webLink": "https://weread.qq.com/web/reader/301323b0813ab7c06g012894?chapterUid=150&rangeStart=537&rangeEnd=579"
    },
    {
      "bookmarkId": "3300055102_152_5166-5232",
      "chapterUid": 152,
      "range": "5166-5232",
      "markText": "他是天下第一美男子，甚至天下第一才子，可也是这个人，近几年自甘堕落，与贾皇后一党同流合污，让从小仰慕他的郗宁恨不得杀了他来洗刷耻辱。",
      "totalCount": 112,
      "appLink": "weread://bestbookmark?bookId=3300055102&chapterUid=152&rangeStart=5166&rangeEnd=5232",
      "webLink": "https://weread.qq.com/web/reader/301323b0813ab7c06g012894?chapterUid=152&rangeStart=5166&rangeEnd=5232"
    },
    {
      "bookmarkId": "3300055102_152_2297-2363",
      "chapterUid": 152,
      "range": "2297-2363",
      "markText": "虽然只是在人群里远远望上一眼，却一辈子也忘不掉。我不识字，不知道怎么形容，只觉得一看到他，其他人就全都看不见了，好半天都缓不过来……",
      "totalCount": 108,
      "appLink": "weread://bestbookmark?bookId=3300055102&chapterUid=152&rangeStart=2297&rangeEnd=2363",
      "webLink": "https://weread.qq.com/web/reader/301323b0813ab7c06g012894?chapterUid=152&rangeStart=2297&rangeEnd=2363"
    },
    {
      "bookmarkId": "3300055102_156_6894-6936",
      "chapterUid": 156,
      "range": "6894-6936",
      "markText": "既然认定了要做一件事，他就绝不能只让司马攸一个人去承担这个罪责，这是义气，也是道德。",
      "totalCount": 108,
      "appLink": "weread://bestbookmark?bookId=3300055102&chapterUid=156&rangeStart=6894&rangeEnd=6936",
      "webLink": "https://weread.qq.com/web/reader/301323b0813ab7c06g012894?chapterUid=156&rangeStart=6894&rangeEnd=6936"
    },
    {
      "bookmarkId": "3300055102_215_7370-7426",
      "chapterUid": 215,
      "range": "7370-7426",
      "markText": "你放心，过不了多久，爹爹就会来陪你和你娘了……”潘岳抱紧女儿慢慢冷下去的身子，用旁人听不见的声音喃喃，“等着我。",
      "totalCount": 108,
      "appLink": "weread://bestbookmark?bookId=3300055102&chapterUid=215&rangeStart=7370&rangeEnd=7426",
      "webLink": "https://weread.qq.com/web/reader/301323b0813ab7c06g012894?chapterUid=215&rangeStart=7370&rangeEnd=7426"
    },
    {
      "bookmarkId": "3300055102_154_4530-4547",
      "chapterUid": 154,
      "range": "4530-4547",
      "markText": "“石公子不会又把他当作檀郎了吧？”",
      "totalCount": 105,
      "appLink": "weread://bestbookmark?bookId=3300055102&chapterUid=154&rangeStart=4530&rangeEnd=4547",
      "webLink": "https://weread.qq.com/web/reader/301323b0813ab7c06g012894?chapterUid=154&rangeStart=4530&rangeEnd=4547"
    },
    {
      "bookmarkId": "3300055102_154_8328-8428",
      "chapterUid": 154,
      "range": "8328-8428",
      "markText": "春风和煦，吹动了他身上月白色的锦袍，飘飘竟不似人间情形。围观众人顿时屏住了呼吸，不由自主地联想起日御羲和、月御望舒，仿佛潘岳所驾的并非普通的马车，而是天上璀璨的日月。日月一出，天下再无光辉可与之争锋。",
      "totalCount": 104,
      "appLink": "weread://bestbookmark?bookId=3300055102&chapterUid=154&rangeStart=8328&rangeEnd=8428",
      "webLink": "https://weread.qq.com/web/reader/301323b0813ab7c06g012894?chapterUid=154&rangeStart=8328&rangeEnd=8428"
    },
    {
      "bookmarkId": "3300055102_168_7406-7453",
      "chapterUid": 168,
      "range": "7406-7453",
      "markText": "她隔着层层叠叠的侍女和府兵与潘岳对望一眼，忽然冷冷一笑，转身扶住侍女，头也不回地走进王府去了。",
      "totalCount": 104,
      "appLink": "weread://bestbookmark?bookId=3300055102&chapterUid=168&rangeStart=7406&rangeEnd=7453",
      "webLink": "https://weread.qq.com/web/reader/301323b0813ab7c06g012894?chapterUid=168&rangeStart=7406&rangeEnd=7453"
    },
    {
      "bookmarkId": "3300055102_155_1848-1866",
      "chapterUid": 155,
      "range": "1848-1866",
      "markText": "我也可以像娘一样，把那些人杀了……”",
      "totalCount": 102,
      "appLink": "weread://bestbookmark?bookId=3300055102&chapterUid=155&rangeStart=1848&rangeEnd=1866",
      "webLink": "https://weread.qq.com/web/reader/301323b0813ab7c06g012894?chapterUid=155&rangeStart=1848&rangeEnd=1866"
    },
    {
      "bookmarkId": "3300055102_168_22085-22095",
      "chapterUid": 168,
      "range": "22085-22095",
      "markText": "天捶海淬，我只做我。",
      "totalCount": 102,
      "appLink": "weread://bestbookmark?bookId=3300055102&chapterUid=168&rangeStart=22085&rangeEnd=22095",
      "webLink": "https://weread.qq.com/web/reader/301323b0813ab7c06g012894?chapterUid=168&rangeStart=22085&rangeEnd=22095"
    },
    {
      "bookmarkId": "3300055102_213_8782-8823",
      "chapterUid": 213,
      "range": "8782-8823",
      "markText": "贾荃满怀期冀地盯着潘岳，“只要能杀了她们姐妹为桃符报仇，就是要我的命也在所不惜！”",
      "totalCount": 102,
      "appLink": "weread://bestbookmark?bookId=3300055102&chapterUid=213&rangeStart=8782&rangeEnd=8823",
      "webLink": "https://weread.qq.com/web/reader/301323b0813ab7c06g012894?chapterUid=213&rangeStart=8782&rangeEnd=8823"
    },
    {
      "bookmarkId": "3300055102_156_759-823",
      "chapterUid": 156,
      "range": "759-823",
      "markText": "整个苍穹就仿佛一口倒扣的铁锅，万物都不过是一盘烩在一起的食物，高尚也罢，卑贱也好，全都要被放在火上烹煮，再被无形的饕餮巨口吞噬。",
