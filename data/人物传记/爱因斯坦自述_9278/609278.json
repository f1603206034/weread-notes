  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "609278_4_1094-1164",
      "chapterUid": 4,
      "range": "1094-1164",
      "markText": "我在少年时代就已经深切地意识到一个道理，即大多数人为追逐一些毫无价值的东西而花费了自己毕生的时间。随后我就发现，这种追逐看似轻松，实则残酷。",
      "totalCount": 1035,
      "appLink": "weread://bestbookmark?bookId=609278&chapterUid=4&rangeStart=1094&rangeEnd=1164",
      "webLink": "https://weread.qq.com/web/reader/67732f50594bfe677e92230?chapterUid=4&rangeStart=1094&rangeEnd=1164"
    },
    {
      "bookmarkId": "609278_4_965-998",
      "chapterUid": 4,
      "range": "965-998",
      "markText": "由于当下的心境和状态会扭曲回忆的原貌，所以记忆也并非是完全可靠的。",
      "totalCount": 884,
      "appLink": "weread://bestbookmark?bookId=609278&chapterUid=4&rangeStart=965&rangeEnd=998",
      "webLink": "https://weread.qq.com/web/reader/67732f50594bfe677e92230?chapterUid=4&rangeStart=965&rangeEnd=998"
    },
    {
      "bookmarkId": "609278_4_6049-6111",
      "chapterUid": 4,
      "range": "6049-6111",
      "markText": "一头猛兽如果不饿，却被人用鞭子强逼着不停地进食，而且是吃那种经过千挑万选的食物，它必然会得上厌食症的。现代教学也是这个道理。",
      "totalCount": 714,
      "appLink": "weread://bestbookmark?bookId=609278&chapterUid=4&rangeStart=6049&rangeEnd=6111",
      "webLink": "https://weread.qq.com/web/reader/67732f50594bfe677e92230?chapterUid=4&rangeStart=6049&rangeEnd=6111"
    },
    {
      "bookmarkId": "609278_4_7865-7915",
      "chapterUid": 4,
      "range": "7865-7915",
      "markText": "因为像我这样的人，他一生中最主要的东西是自己思考的内容和方式，而不会去关心那些自己所经历和做的事情。",
      "totalCount": 660,
      "appLink": "weread://bestbookmark?bookId=609278&chapterUid=4&rangeStart=7865&rangeEnd=7915",
      "webLink": "https://weread.qq.com/web/reader/67732f50594bfe677e92230?chapterUid=4&rangeStart=7865&rangeEnd=7915"
    },
    {
      "bookmarkId": "609278_4_2948-3037",
      "chapterUid": 4,
      "range": "2948-3037",
      "markText": "当我们的经验和概念之间出现不可调和的激烈冲突时，我们就要修补、扬弃乃至重建自己的概念世界，反思自己的思维。从这个角度而言，不断地“吃惊”并摆脱“吃惊”的过程，就是思维进步的过程。",
      "totalCount": 629,
      "appLink": "weread://bestbookmark?bookId=609278&chapterUid=4&rangeStart=2948&rangeEnd=3037",
      "webLink": "https://weread.qq.com/web/reader/67732f50594bfe677e92230?chapterUid=4&rangeStart=2948&rangeEnd=3037"
    },
    {
      "bookmarkId": "609278_4_1452-1465",
      "chapterUid": 4,
      "range": "1452-1465",
      "markText": "国家总是用谎言欺骗年轻人。",
      "totalCount": 540,
      "appLink": "weread://bestbookmark?bookId=609278&chapterUid=4&rangeStart=1452&rangeEnd=1465",
      "webLink": "https://weread.qq.com/web/reader/67732f50594bfe677e92230?chapterUid=4&rangeStart=1452&rangeEnd=1465"
    },
    {
      "bookmarkId": "609278_5_1695-1721",
      "chapterUid": 5,
      "range": "1695-1721",
      "markText": "我原有的学习习惯还是没有变：广泛、自由而热情地自学。",
      "totalCount": 510,
      "appLink": "weread://bestbookmark?bookId=609278&chapterUid=5&rangeStart=1695&rangeEnd=1721",
      "webLink": "https://weread.qq.com/web/reader/67732f50594bfe677e92230?chapterUid=5&rangeStart=1695&rangeEnd=1721"
    },
    {
      "bookmarkId": "609278_4_1495-1522",
      "chapterUid": 4,
      "range": "1495-1522",
      "markText": "我敢于怀疑任何社会中的一切既存信念，敢于怀疑一切权威。",
      "totalCount": 435,
      "appLink": "weread://bestbookmark?bookId=609278&chapterUid=4&rangeStart=1495&rangeEnd=1522",
      "webLink": "https://weread.qq.com/web/reader/67732f50594bfe677e92230?chapterUid=4&rangeStart=1495&rangeEnd=1522"
    },
    {
      "bookmarkId": "609278_4_2284-2347",
      "chapterUid": 4,
      "range": "2284-2347",
      "markText": "在我看来，对于那些短暂的、仅仅作为个体的兴趣，渐渐地被“努力从思想上掌握和理解事物”的兴趣所取代，我人生发展的转折点就在此处。",
      "totalCount": 408,
      "appLink": "weread://bestbookmark?bookId=609278&chapterUid=4&rangeStart=2284&rangeEnd=2347",
      "webLink": "https://weread.qq.com/web/reader/67732f50594bfe677e92230?chapterUid=4&rangeStart=2284&rangeEnd=2347"
    },
    {
      "bookmarkId": "609278_4_7951-8000",
      "chapterUid": 4,
      "range": "7951-8000",
      "markText": "一种理论前提越简单，其所能囊括的应用范围就越大，所能包容的东西就越多，也就越能给人留下深刻的印象。",
      "totalCount": 294,
      "appLink": "weread://bestbookmark?bookId=609278&chapterUid=4&rangeStart=7951&rangeEnd=8000",
      "webLink": "https://weread.qq.com/web/reader/67732f50594bfe677e92230?chapterUid=4&rangeStart=7951&rangeEnd=8000"
    },
    {
      "bookmarkId": "609278_12_812-901",
      "chapterUid": 12,
      "range": "812-901",
      "markText": "大学里有很多讲座，然而却只有很少崇高的教师。大学里也有很大的教室，却只有很少真正渴求知识的年轻人。庸庸众生总是被大自然一代又一代地生产出来，然而拥有创造性的高超才华的人却不多见。",
      "totalCount": 286,
      "appLink": "weread://bestbookmark?bookId=609278&chapterUid=12&rangeStart=812&rangeEnd=901",
      "webLink": "https://weread.qq.com/web/reader/67732f50594bfe677e92230?chapterUid=12&rangeStart=812&rangeEnd=901"
    },
    {
      "bookmarkId": "609278_4_5544-5628",
      "chapterUid": 4,
      "range": "5544-5628",
      "markText": "可是不同于数学的是，在此领域当中，挑选、鉴别知识的眼光我很快就练出来了，挑出那种有用的知识，放弃其他多余的东西，特别是那些只会引领我偏离主要目标、占用我大脑容量的东西。",
      "totalCount": 266,
      "appLink": "weread://bestbookmark?bookId=609278&chapterUid=4&rangeStart=5544&rangeEnd=5628",
      "webLink": "https://weread.qq.com/web/reader/67732f50594bfe677e92230?chapterUid=4&rangeStart=5544&rangeEnd=5628"
    },
    {
      "bookmarkId": "609278_5_830-865",
      "chapterUid": 5,
      "range": "830-865",
      "markText": "我读书的时候，对所有问题都只喜欢深入理解，我记忆力不好，背诵的也很少。",
      "totalCount": 252,
      "appLink": "weread://bestbookmark?bookId=609278&chapterUid=5&rangeStart=830&rangeEnd=865",
      "webLink": "https://weread.qq.com/web/reader/67732f50594bfe677e92230?chapterUid=5&rangeStart=830&rangeEnd=865"
    },
    {
      "bookmarkId": "609278_4_2745-2790",
      "chapterUid": 4,
      "range": "2745-2790",
      "markText": "概念化的自由选择是我们一切思维的本质，我们概括经验能达到怎样的程度，思维的合理性就有多高。",
      "totalCount": 234,
      "appLink": "weread://bestbookmark?bookId=609278&chapterUid=4&rangeStart=2745&rangeEnd=2790",
      "webLink": "https://weread.qq.com/web/reader/67732f50594bfe677e92230?chapterUid=4&rangeStart=2745&rangeEnd=2790"
    },
    {
      "bookmarkId": "609278_7_3000-3095",
      "chapterUid": 7,
      "range": "3000-3095",
      "markText": "我觉得，为了自己的事业，一个人能够这样地付出，一定是不自觉的，就如同那些热恋中的人或虔诚的教徒一般。他们不需要深思熟虑，不需要做什么特别的计划，每天都充满热情地投入其中，这是一种伟大的激情。",
      "totalCount": 230,
      "appLink": "weread://bestbookmark?bookId=609278&chapterUid=7&rangeStart=3000&rangeEnd=3095",
      "webLink": "https://weread.qq.com/web/reader/67732f50594bfe677e92230?chapterUid=7&rangeStart=3000&rangeEnd=3095"
    },
    {
      "bookmarkId": "609278_4_5651-5736",
      "chapterUid": 4,
      "range": "5651-5736",
      "markText": "当然，还有个问题就是考试。即使不愿意，也要记住很多废物，因为要应付考试。在最后的考试通过之后，大约有整整一年时间，因为之前强迫学习造成的不快，使我丧失了对科学问题的兴趣。",
      "totalCount": 224,
      "appLink": "weread://bestbookmark?bookId=609278&chapterUid=4&rangeStart=5651&rangeEnd=5736",
      "webLink": "https://weread.qq.com/web/reader/67732f50594bfe677e92230?chapterUid=4&rangeStart=5651&rangeEnd=5736"
    },
    {
      "bookmarkId": "609278_5_2762-2835",
      "chapterUid": 5,
      "range": "2762-2835",
      "markText": "对我来说，有工作就是一种幸福，而若是能做实际工作就更完美了。可有些年轻人在学院中必须要写很多科学论文，在此类毫无意义的论文写作中，一点点变得浅薄。",
      "totalCount": 216,
      "appLink": "weread://bestbookmark?bookId=609278&chapterUid=5&rangeStart=2762&rangeEnd=2835",
      "webLink": "https://weread.qq.com/web/reader/67732f50594bfe677e92230?chapterUid=5&rangeStart=2762&rangeEnd=2835"
    },
    {
      "bookmarkId": "609278_5_5038-5129",
      "chapterUid": 5,
      "range": "5038-5129",
      "markText": "以前，要是有某张椅子刚被人坐过，然后我就坐上去，在椅子上感受到刚刚离开的人的热量时，我会很别扭。现在我不再有这种别扭的感觉了，因为物理学告诉我，热是某种普遍的东西，不属于哪个个人。”",
      "totalCount": 210,
      "appLink": "weread://bestbookmark?bookId=609278&chapterUid=5&rangeStart=5038&rangeEnd=5129",
      "webLink": "https://weread.qq.com/web/reader/67732f50594bfe677e92230?chapterUid=5&rangeStart=5038&rangeEnd=5129"
    },
    {
      "bookmarkId": "609278_5_5841-5887",
      "chapterUid": 5,
      "range": "5841-5887",
      "markText": "莱辛那句让人振奋的名言不由得在我耳边响起：比之于坐享其成者，追寻真理之人，要付出昂贵的代价。",
      "totalCount": 210,
      "appLink": "weread://bestbookmark?bookId=609278&chapterUid=5&rangeStart=5841&rangeEnd=5887",
      "webLink": "https://weread.qq.com/web/reader/67732f50594bfe677e92230?chapterUid=5&rangeStart=5841&rangeEnd=5887"
    },
    {
      "bookmarkId": "609278_7_1161-1245",
      "chapterUid": 7,
      "range": "1161-1245",
      "markText": "因为他们对职业并无特定选择，在人类活动的范围之内，他们会去干任何有机会干的工作，到底最后是成了工程师、商人、官员，抑或是科学家，无关乎他们本身的选择，而是由环境决定的。",
      "totalCount": 208,
      "appLink": "weread://bestbookmark?bookId=609278&chapterUid=7&rangeStart=1161&rangeEnd=1245",
