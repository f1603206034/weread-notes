  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300058587_7_515-581",
      "chapterUid": 7,
      "range": "515-581",
      "markText": "蒋介石写道：“……我比以前任何时候都确信苏联政治体制是独裁和恐怖主义的统治工具，它与以三民主义为基础的国民党的政治体制完全不同……”",
      "totalCount": 224,
      "appLink": "weread://bestbookmark?bookId=3300058587&chapterUid=7&rangeStart=515&rangeEnd=581",
      "webLink": "https://weread.qq.com/web/reader/053325a0813ab7d62g017c19?chapterUid=7&rangeStart=515&rangeEnd=581"
    },
    {
      "bookmarkId": "3300058587_3_1757-1816",
      "chapterUid": 3,
      "range": "1757-1816",
      "markText": "然而，青年时代的蒋介石，是个有名的风流人物，对上海的青楼了如指掌。他一方面放荡不羁，另一方面又遵循孔道，坚持克己自律。",
      "totalCount": 208,
      "appLink": "weread://bestbookmark?bookId=3300058587&chapterUid=3&rangeStart=1757&rangeEnd=1816",
      "webLink": "https://weread.qq.com/web/reader/053325a0813ab7d62g017c19?chapterUid=3&rangeStart=1757&rangeEnd=1816"
    },
    {
      "bookmarkId": "3300058587_9_387-463",
      "chapterUid": 9,
      "range": "387-463",
      "markText": "蒋介石曾在日记中表示他不喜欢政治，他写道：“政治使人过狗一般的生活……道德何在？友谊何在？”但是不久就表明，在政治权术方面，他是一个“进步”很快的新手。",
      "totalCount": 208,
      "appLink": "weread://bestbookmark?bookId=3300058587&chapterUid=9&rangeStart=387&rangeEnd=463",
      "webLink": "https://weread.qq.com/web/reader/053325a0813ab7d62g017c19?chapterUid=9&rangeStart=387&rangeEnd=463"
    },
    {
      "bookmarkId": "3300058587_26_10024-10036",
      "chapterUid": 26,
      "range": "10024-10036",
      "markText": "他的悲剧是他个人造成的。",
      "totalCount": 208,
      "appLink": "weread://bestbookmark?bookId=3300058587&chapterUid=26&rangeStart=10024&rangeEnd=10036",
      "webLink": "https://weread.qq.com/web/reader/053325a0813ab7d62g017c19?chapterUid=26&rangeStart=10024&rangeEnd=10036"
    },
    {
      "bookmarkId": "3300058587_4_1418-1434",
      "chapterUid": 4,
      "range": "1418-1434",
      "markText": "汉字复杂难懂，必然导致大量文盲。",
      "totalCount": 182,
      "appLink": "weread://bestbookmark?bookId=3300058587&chapterUid=4&rangeStart=1418&rangeEnd=1434",
      "webLink": "https://weread.qq.com/web/reader/053325a0813ab7d62g017c19?chapterUid=4&rangeStart=1418&rangeEnd=1434"
    },
    {
      "bookmarkId": "3300058587_16_15011-15049",
      "chapterUid": 16,
      "range": "15011-15049",
      "markText": "在西安事变这台令人惊奇的各种力量的三角戏中，只有少帅和他的追随者失去了一切。",
      "totalCount": 182,
      "appLink": "weread://bestbookmark?bookId=3300058587&chapterUid=16&rangeStart=15011&rangeEnd=15049",
      "webLink": "https://weread.qq.com/web/reader/053325a0813ab7d62g017c19?chapterUid=16&rangeStart=15011&rangeEnd=15049"
    },
    {
      "bookmarkId": "3300058587_3_2243-2278",
      "chapterUid": 3,
      "range": "2243-2278",
      "markText": "他徒劳地阻止革命潮流的进一步发展，企图在军阀混战中夺取政权而黄袍加身。",
      "totalCount": 176,
      "appLink": "weread://bestbookmark?bookId=3300058587&chapterUid=3&rangeStart=2243&rangeEnd=2278",
      "webLink": "https://weread.qq.com/web/reader/053325a0813ab7d62g017c19?chapterUid=3&rangeStart=2243&rangeEnd=2278"
    },
    {
      "bookmarkId": "3300058587_3_8215-8257",
      "chapterUid": 3,
      "range": "8215-8257",
      "markText": "毛泽东善于动员农民，发挥农民的无穷力量，而蒋介石却视农民为群氓，威胁他们顺服于自己。",
      "totalCount": 176,
      "appLink": "weread://bestbookmark?bookId=3300058587&chapterUid=3&rangeStart=8215&rangeEnd=8257",
      "webLink": "https://weread.qq.com/web/reader/053325a0813ab7d62g017c19?chapterUid=3&rangeStart=8215&rangeEnd=8257"
    },
    {
      "bookmarkId": "3300058587_4_7163-7205",
      "chapterUid": 4,
      "range": "7163-7205",
      "markText": "袁世凯像一个杀手，1912年他宴请国民党一位参加过武昌起义的将领，后来就把他谋杀了。",
      "totalCount": 170,
      "appLink": "weread://bestbookmark?bookId=3300058587&chapterUid=4&rangeStart=7163&rangeEnd=7205",
      "webLink": "https://weread.qq.com/web/reader/053325a0813ab7d62g017c19?chapterUid=4&rangeStart=7163&rangeEnd=7205"
    },
    {
      "bookmarkId": "3300058587_3_3875-3913",
      "chapterUid": 3,
      "range": "3875-3913",
      "markText": "他认为共产党是叛逆者，必须先征服他们；只有先安内，统一中国，才能抵御日本人。",
