  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "25298414_75_5654-5710",
      "chapterUid": 75,
      "range": "5654-5710",
      "markText": "当十四岁的她穿越茫茫雪原赶赴俄国的时候，世间无人能够想象到这段旅程竟会如此漫长而卓越，即便是她自己也未曾预料到。",
      "totalCount": 1326,
      "appLink": "weread://bestbookmark?bookId=25298414&chapterUid=75&rangeStart=5654&rangeEnd=5710",
      "webLink": "https://weread.qq.com/web/reader/91a32c60718205ee91a5457?chapterUid=75&rangeStart=5654&rangeEnd=5710"
    },
    {
      "bookmarkId": "25298414_3_7660-7691",
      "chapterUid": 3,
      "range": "7660-7691",
      "markText": "这一辈子我始终都乐于向温柔和理性屈服，压迫只会让我奋起抵抗。”",
      "totalCount": 1078,
      "appLink": "weread://bestbookmark?bookId=25298414&chapterUid=3&rangeStart=7660&rangeEnd=7691",
      "webLink": "https://weread.qq.com/web/reader/91a32c60718205ee91a5457?chapterUid=3&rangeStart=7660&rangeEnd=7691"
    },
    {
      "bookmarkId": "25298414_13_7232-7284",
      "chapterUid": 13,
      "range": "7232-7284",
      "markText": "她对自己的抱负所许下的诺言。她要嫁的不是一张脸，那张脸英俊与否都不重要，因为她要嫁的是一个帝国的继承人。",
      "totalCount": 969,
      "appLink": "weread://bestbookmark?bookId=25298414&chapterUid=13&rangeStart=7232&rangeEnd=7284",
      "webLink": "https://weread.qq.com/web/reader/91a32c60718205ee91a5457?chapterUid=13&rangeStart=7232&rangeEnd=7284"
    },
    {
      "bookmarkId": "25298414_3_8472-8527",
      "chapterUid": 3,
      "range": "8472-8527",
      "markText": "不应对孩子进行过度的责骂，应该培养起他们对他人的信任，这样在我们面前他们才不会把自己那些愚蠢的想法埋藏在心底。",
      "totalCount": 918,
      "appLink": "weread://bestbookmark?bookId=25298414&chapterUid=3&rangeStart=8472&rangeEnd=8527",
      "webLink": "https://weread.qq.com/web/reader/91a32c60718205ee91a5457?chapterUid=3&rangeStart=8472&rangeEnd=8527"
    },
    {
      "bookmarkId": "25298414_5_5432-5518",
