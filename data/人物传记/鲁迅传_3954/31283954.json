  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "31283954_5_4481-4518",
      "chapterUid": 5,
      "range": "4481-4518",
      "markText": "总之，这些东西，都是为了弄清事物的。可见中国的邪鬼，非常害怕明确，喜欢含混",
      "totalCount": 187,
      "appLink": "weread://bestbookmark?bookId=31283954&chapterUid=5&rangeStart=4481&rangeEnd=4518",
      "webLink": "https://weread.qq.com/web/reader/cf13228071dd5af2cf16adc?chapterUid=5&rangeStart=4481&rangeEnd=4518"
    },
    {
      "bookmarkId": "31283954_6_11955-12030",
      "chapterUid": 6,
      "range": "11955-12030",
      "markText": "这位逼他签字的长辈就是他开蒙的老师周兆蓝。鲁迅对他一直怀着敬意和好感的。可是这一位和蔼的老人在涉及利益问题的时候也不免声色俱厉了。这事对鲁迅的刺激很深",
      "totalCount": 187,
      "appLink": "weread://bestbookmark?bookId=31283954&chapterUid=6&rangeStart=11955&rangeEnd=12030",
      "webLink": "https://weread.qq.com/web/reader/cf13228071dd5af2cf16adc?chapterUid=6&rangeStart=11955&rangeEnd=12030"
    },
    {
      "bookmarkId": "31283954_13_12447-12523",
      "chapterUid": 13,
      "range": "12447-12523",
      "markText": "1917年7月1日，军阀张勋拥清废帝溥仪复辟。鲁迅不肯向复辟的皇帝陛下称臣，7月3日，他到教育部向同事道别，不干了。几天之后复辟乱平，他才回教育部上班。",
      "totalCount": 180,
      "appLink": "weread://bestbookmark?bookId=31283954&chapterUid=13&rangeStart=12447&rangeEnd=12523",
      "webLink": "https://weread.qq.com/web/reader/cf13228071dd5af2cf16adc?chapterUid=13&rangeStart=12447&rangeEnd=12523"
    },
    {
      "bookmarkId": "31283954_5_2111-2152",
      "chapterUid": 5,
      "range": "2111-2152",
      "markText": "尔辈知之：如用钱有馀，以买田为最好之计。勿存银号，勿开店铺，为市侩所骗，切记切记！",
      "totalCount": 176,
      "appLink": "weread://bestbookmark?bookId=31283954&chapterUid=5&rangeStart=2111&rangeEnd=2152",
      "webLink": "https://weread.qq.com/web/reader/cf13228071dd5af2cf16adc?chapterUid=5&rangeStart=2111&rangeEnd=2152"
    },
    {
      "bookmarkId": "31283954_5_755-834",
      "chapterUid": 5,
      "range": "755-834",
      "markText": "对于汉族知识分子，清朝一方面屡兴文字狱来立威，使他们经常处于恐惧之中，不敢妄发议论；一方面开科取士，使顺从者觉得有一条出路，少数幸运者可以通过这途径进入仕途。",
      "totalCount": 153,
      "appLink": "weread://bestbookmark?bookId=31283954&chapterUid=5&rangeStart=755&rangeEnd=834",
      "webLink": "https://weread.qq.com/web/reader/cf13228071dd5af2cf16adc?chapterUid=5&rangeStart=755&rangeEnd=834"
    },
    {
      "bookmarkId": "31283954_6_10978-11065",
      "chapterUid": 6,
      "range": "10978-11065",
      "markText": "初学先诵白居易诗，取其明白易晓，味淡而永。再诵陆游诗，志高词壮，且多越事。再诵苏诗，笔力雄健，辞足达意。再诵李诗，思致清逸。如杜之艰深，韩之奇崛，不能学亦不必学也。示樟寿诸孙",
      "totalCount": 143,
      "appLink": "weread://bestbookmark?bookId=31283954&chapterUid=6&rangeStart=10978&rangeEnd=11065",
      "webLink": "https://weread.qq.com/web/reader/cf13228071dd5af2cf16adc?chapterUid=6&rangeStart=10978&rangeEnd=11065"
    },
    {
      "bookmarkId": "31283954_10_4974-5017",
      "chapterUid": 10,
      "range": "4974-5017",
      "markText": "在婚姻问题上，上帝是苛待了鲁迅的。不过倒也好，这也就造就出了一位不世出的思想家和作家。",
