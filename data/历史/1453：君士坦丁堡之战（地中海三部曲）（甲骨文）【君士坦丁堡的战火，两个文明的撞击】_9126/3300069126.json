  "content": [
    {
      "chapterUid": 10,
      "chapterTitle": "1 燃烧的海",
      "items": [
        {
          "type": "highlight",
          "bookmarkId": "3300069126_10_14375-14517",
          "range": "14375-14517",
          "rangeStart": 14375,
          "rangeEnd": 14517,
          "markText": "东正教无比精细的繁华壮美与伊斯兰教的简单质朴形成了鲜明的对照。伊斯兰教提供的是沙漠地带的抽象的朴素，一种在任何看得见太阳的地方都可以进行的膜拜，以及与神的直接交流；东正教则富有形象、色彩和音乐，以及将灵魂引向天堂的神秘力量的令人陶醉的隐喻。两种宗教同样执着地要让全世界皈依他们的信仰。",
          "colorStyle": 0,
          "colorLabel": "",
          "createTime": 1721390741,
          "createTimeFormatted": "2024-07-19 20:05:41",
          "chapterUid": 10,
          "appLink": "weread://bestbookmark?bookId=3300069126&chapterUid=10&rangeStart=14375&rangeEnd=14517",
          "webLink": "https://weread.qq.com/web/reader/27532fb0813ab8180g016fee?chapterUid=10&rangeStart=14375&rangeEnd=14517"
        }
      ]
    }
  ],
  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300069126_10_6416-6461",
      "chapterUid": 10,
      "range": "6416-6461",
      "markText": "他说服了马斯拉玛，他说如果阿拉伯人销毁自己的储粮，并给守军一些谷物的话，他就能让城市投降。",
      "totalCount": 416,
      "appLink": "weread://bestbookmark?bookId=3300069126&chapterUid=10&rangeStart=6416&rangeEnd=6461",
      "webLink": "https://weread.qq.com/web/reader/27532fb0813ab8180g016fee?chapterUid=10&rangeStart=6416&rangeEnd=6461"
    },
    {
      "bookmarkId": "3300069126_16_3244-3335",
      "chapterUid": 16,
      "range": "3244-3335",
      "markText": "对获得战利品和飞黄腾达的憧憬以及圣战的使命感让他们激情满怀，这些主题密不可分地结合在《古兰经》中：根据伊斯兰教的神圣法律，凡是通过武力攻克一座城市之后，可以在三天之内合法地进行掳掠。",
      "totalCount": 414,
      "appLink": "weread://bestbookmark?bookId=3300069126&chapterUid=16&rangeStart=3244&rangeEnd=3335",
      "webLink": "https://weread.qq.com/web/reader/27532fb0813ab8180g016fee?chapterUid=16&rangeStart=3244&rangeEnd=3335"
    },
    {
      "bookmarkId": "3300069126_21_2369-2466",
      "chapterUid": 21,
      "range": "2369-2466",
      "markText": "拜占庭人有一种观念，认为时间是环形循环和对称的。第二个关于皇室的预言更印证了这种观念：建立和丧失城市的皇帝都叫君士坦丁，他们的母亲都叫海伦娜。的确，君士坦丁一世和君士坦丁十一世的母亲都叫海伦娜。",
      "totalCount": 374,
      "appLink": "weread://bestbookmark?bookId=3300069126&chapterUid=21&rangeStart=2369&rangeEnd=2466",
      "webLink": "https://weread.qq.com/web/reader/27532fb0813ab8180g016fee?chapterUid=21&rangeStart=2369&rangeEnd=2466"
    },
    {
      "bookmarkId": "3300069126_18_10472-10542",
      "chapterUid": 18,
      "range": "10472-10542",
      "markText": "君士坦丁十一世向西方求援是基于宗教上的考虑，这种思维是典型中世纪的；但他求援的对象却是被经济因素驱动的国家，而且这些国家的思维惊人地现代化。",
      "totalCount": 336,
      "appLink": "weread://bestbookmark?bookId=3300069126&chapterUid=18&rangeStart=10472&rangeEnd=10542",
      "webLink": "https://weread.qq.com/web/reader/27532fb0813ab8180g016fee?chapterUid=18&rangeStart=10472&rangeEnd=10542"
    },
    {
      "bookmarkId": "3300069126_16_11872-11903",
      "chapterUid": 16,
      "range": "11872-11903",
      "markText": "君士坦丁十一世要统计自己的兵力就简单得多，只需要数一数就行了。",
      "totalCount": 323,
      "appLink": "weread://bestbookmark?bookId=3300069126&chapterUid=16&rangeStart=11872&rangeEnd=11903",
      "webLink": "https://weread.qq.com/web/reader/27532fb0813ab8180g016fee?chapterUid=16&rangeStart=11872&rangeEnd=11903"
    },
    {
      "bookmarkId": "3300069126_14_639-901",
      "chapterUid": 14,
      "range": "639-901",
      "markText": "让一个国家受伊斯兰教统治，远胜于让它落到不肯承认天主教会权力的基督徒手中。 ——教皇格列高利七世，1073年",
      "totalCount": 304,
      "appLink": "weread://bestbookmark?bookId=3300069126&chapterUid=14&rangeStart=639&rangeEnd=901",
      "webLink": "https://weread.qq.com/web/reader/27532fb0813ab8180g016fee?chapterUid=14&rangeStart=639&rangeEnd=901"
    },
    {
      "bookmarkId": "3300069126_10_5897-5939",
      "chapterUid": 10,
      "range": "5897-5939",
      "markText": "令伊斯兰神学界不可思议的是，人类竟然没有渐渐全部皈依伊斯兰教或者屈服于穆斯林的统治。",
      "totalCount": 272,
      "appLink": "weread://bestbookmark?bookId=3300069126&chapterUid=10&rangeStart=5897&rangeEnd=5939",
      "webLink": "https://weread.qq.com/web/reader/27532fb0813ab8180g016fee?chapterUid=10&rangeStart=5897&rangeEnd=5939"
