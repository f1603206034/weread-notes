  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300036999_11_3571-3625",
      "chapterUid": 11,
      "range": "3571-3625",
      "markText": "到第三次，他才以群臣所说的应当以社稷为重作为理由，勉如所请。这一番推辞和接受的过程，有条不紊，有如经过预习。",
      "totalCount": 7242,
      "appLink": "weread://bestbookmark?bookId=3300036999&chapterUid=11&rangeStart=3571&rangeEnd=3625",
      "webLink": "https://weread.qq.com/web/reader/af732390813ab74f3g019ddd?chapterUid=11&rangeStart=3571&rangeEnd=3625"
    },
    {
      "bookmarkId": "3300036999_11_25628-25664",
      "chapterUid": 11,
      "range": "25628-25664",
      "markText": "皇室的情谊不同于世俗，它不具有世俗友谊的那种由于互相关怀而产生的永久性。",
      "totalCount": 5490,
      "appLink": "weread://bestbookmark?bookId=3300036999&chapterUid=11&rangeStart=25628&rangeEnd=25664",
      "webLink": "https://weread.qq.com/web/reader/af732390813ab74f3g019ddd?chapterUid=11&rangeStart=25628&rangeEnd=25664"
    },
    {
      "bookmarkId": "3300036999_12_15732-15779",
      "chapterUid": 12,
      "range": "15732-15779",
      "markText": "因之我们的政事，注重体制的安定，而不计较对一人一事的绝对公允。牺牲少数人，正是维持大局的办法。",
      "totalCount": 4730,
      "appLink": "weread://bestbookmark?bookId=3300036999&chapterUid=12&rangeStart=15732&rangeEnd=15779",
      "webLink": "https://weread.qq.com/web/reader/af732390813ab74f3g019ddd?chapterUid=12&rangeStart=15732&rangeEnd=15779"
    },
    {
      "bookmarkId": "3300036999_13_16121-16221",
      "chapterUid": 13,
      "range": "16121-16221",
      "markText": "一个具有高度行政效率的政府，具备体制上技术上的周密，则不致接二连三地在紧急情况下依赖于道德观念作救命的符箓。说得严重一点，后者已不是一种好现象，而是组织机构违反时代，不能在复杂的社会中推陈出新的结果。",
      "totalCount": 4680,
      "appLink": "weread://bestbookmark?bookId=3300036999&chapterUid=13&rangeStart=16121&rangeEnd=16221",
      "webLink": "https://weread.qq.com/web/reader/af732390813ab74f3g019ddd?chapterUid=13&rangeStart=16121&rangeEnd=16221"
    },
    {
      "bookmarkId": "3300036999_11_15189-15237",
      "chapterUid": 11,
      "range": "15189-15237",
      "markText": "在这些事例中，张居正的主张无疑都很正确，但是这种铁面无私的态度，在以后也并不是不需要付出代价的。",
      "totalCount": 4590,
      "appLink": "weread://bestbookmark?bookId=3300036999&chapterUid=11&rangeStart=15189&rangeEnd=15237",
      "webLink": "https://weread.qq.com/web/reader/af732390813ab74f3g019ddd?chapterUid=11&rangeStart=15189&rangeEnd=15237"
    },
    {
      "bookmarkId": "3300036999_12_9738-9834",
      "chapterUid": 12,
      "range": "9738-9834",
      "markText": "他的老成来自长期处理各种人事经验；这种经验，使他深知我们这个帝国有一个特点：一项政策能否付诸实施，实施后或成或败，全靠看它与所有文官的共同习惯是否相安无扰，否则理论上的完美，仍不过是空中楼阁。",
      "totalCount": 4400,
      "appLink": "weread://bestbookmark?bookId=3300036999&chapterUid=12&rangeStart=9738&rangeEnd=9834",
      "webLink": "https://weread.qq.com/web/reader/af732390813ab74f3g019ddd?chapterUid=12&rangeStart=9738&rangeEnd=9834"
    },
    {
      "bookmarkId": "3300036999_11_5573-5634",
      "chapterUid": 11,
      "range": "5573-5634",
      "markText": "这种珠帘是一种有趣的道具，它们在皇帝的眼前脑后来回晃动，使他极不舒服，其目的就在于提醒他必须具有端庄的仪态，不能轻浮造次。",
      "totalCount": 4320,
      "appLink": "weread://bestbookmark?bookId=3300036999&chapterUid=11&rangeStart=5573&rangeEnd=5634",
      "webLink": "https://weread.qq.com/web/reader/af732390813ab74f3g019ddd?chapterUid=11&rangeStart=5573&rangeEnd=5634"
    },
    {
      "bookmarkId": "3300036999_11_22087-22163",
      "chapterUid": 11,
      "range": "22087-22163",
      "markText": "统治我们这个庞大帝国，专靠严刑峻法是不可能的，其秘诀在于运用伦理道德的力量使卑下者服从尊上，女人听男人的吩咐，而未受教育的愚民则以读书识字的人作为楷模。",
      "totalCount": 4128,
      "appLink": "weread://bestbookmark?bookId=3300036999&chapterUid=11&rangeStart=22087&rangeEnd=22163",
      "webLink": "https://weread.qq.com/web/reader/af732390813ab74f3g019ddd?chapterUid=11&rangeStart=22087&rangeEnd=22163"
    },
    {
