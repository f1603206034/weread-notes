      "appLink": "weread://bestbookmark?bookId=913482&chapterUid=8&rangeStart=1306&rangeEnd=1345",
      "webLink": "https://weread.qq.com/web/reader/eae327905df04aeaefac8cc?chapterUid=8&rangeStart=1306&rangeEnd=1345"
