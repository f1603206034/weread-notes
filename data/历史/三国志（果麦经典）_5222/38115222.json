  "content": [
    {
      "chapterUid": 41,
      "chapterTitle": "三十五卷 蜀书五︱诸葛亮传",
      "items": [
        {
          "type": "highlight",
          "bookmarkId": "38115222_41_11032-11122",
          "range": "11032-11122",
          "rangeStart": 11032,
          "rangeEnd": 11122,
          "markText": "张郃曰：“彼远来逆我，请战不得，谓我利在不战，欲以长计制之也。且祁山知大军以在近，人情自固，可止屯于此，分为奇兵，示出其后，不宜进前而不敢逼，坐失民望也。今亮县军食少，亦行去矣。”",
          "colorStyle": 3,
          "colorLabel": "",
          "createTime": 1744355365,
          "createTimeFormatted": "2025-04-11 15:09:25",
          "chapterUid": 41,
          "appLink": "weread://bestbookmark?bookId=38115222&chapterUid=41&rangeStart=11032&rangeEnd=11122",
          "webLink": "https://weread.qq.com/web/reader/0b332e70724597960b32d0c?chapterUid=41&rangeStart=11032&rangeEnd=11122"
        },
        {
          "type": "review",
          "reviewId": "32618646_7ZknZGfx4",
          "range": "10975-10977",
          "chapterName": "",
          "content": "shànɡ ɡuī\n古县名。本邽戎地，即今甘肃天水市。公元前688年秦武公取其地，置邽县，后改为上邽县。北魏时因避武帝珪讳，改名上封；隋大业初复名上邽。处渭水上游，又当陇山外围，汉唐之间为秦陇地区交通中心和军事重镇，晋以后常为天水郡和秦州治所。唐代安史之乱后地属吐蕃，大中时收复，改为镇。",
          "abstract": "上邽",
          "star": -1,
          "createTime": 1744357217,
          "createTimeFormatted": "2025-04-11 15:40:17",
          "isFinish": false,
          "chapterUid": 41
        },
        {
          "type": "review",
          "reviewId": "32618646_7ZklZXeE1",
          "range": "11029-11031",
          "chapterName": "三十五卷 蜀书五︱诸葛亮传",
          "content": "在今甘肃省天水市、甘谷县之间。三国蜀诸葛亮斩魏将张郃于此。",
          "abstract": "卤城",
          "star": -1,
          "createTime": 1744355389,
          "createTimeFormatted": "2025-04-11 15:09:49",
          "isFinish": false,
          "chapterUid": 41
        }
      ]
    },
    {
