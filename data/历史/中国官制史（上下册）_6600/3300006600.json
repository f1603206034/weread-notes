  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300006600_3_961-1123",
      "chapterUid": 3,
      "range": "961-1123",
      "markText": "]封闭的地理环境还使“中国认为自己居于世界的中央，它的成就是其他国家无法比较的。正是这样一种文化的优越感，加上狭隘的自上而下的专制，使中国成为一个不图改进，怠于学习的国家，在工业化时代落后了”[2]。",
      "totalCount": 782,
      "appLink": "weread://bestbookmark?bookId=3300006600&chapterUid=3&rangeStart=961&rangeEnd=1123",
      "webLink": "https://weread.qq.com/web/reader/3fd32650813ab6914g010ac4?chapterUid=3&rangeStart=961&rangeEnd=1123"
    },
    {
      "bookmarkId": "3300006600_3_427-492",
      "chapterUid": 3,
      "range": "427-492",
      "markText": "中国有六千年文明史，有确凿史料记载的官制也已经有近五千年，在这漫长的发展过程中，中国官制沿革大体清晰，内容比较集中，特点也很突出。",
      "totalCount": 368,
      "appLink": "weread://bestbookmark?bookId=3300006600&chapterUid=3&rangeStart=427&rangeEnd=492",
      "webLink": "https://weread.qq.com/web/reader/3fd32650813ab6914g010ac4?chapterUid=3&rangeStart=427&rangeEnd=492"
    },
    {
      "bookmarkId": "3300006600_3_5644-5704",
      "chapterUid": 3,
      "range": "5644-5704",
      "markText": "要是所有的统治者都能成为理想的贤君明主，达到上述要求，担当起他们应有的责任，从理论上讲，他们治理国家应该是没有什么困难。",
      "totalCount": 357,
      "appLink": "weread://bestbookmark?bookId=3300006600&chapterUid=3&rangeStart=5644&rangeEnd=5704",
      "webLink": "https://weread.qq.com/web/reader/3fd32650813ab6914g010ac4?chapterUid=3&rangeStart=5644&rangeEnd=5704"
    },
    {
      "bookmarkId": "3300006600_3_10398-10426",
      "chapterUid": 3,
      "range": "10398-10426",
      "markText": "法律要求是公正，它并没有要求平等，因为平等往往会失去公正",
      "totalCount": 306,
      "appLink": "weread://bestbookmark?bookId=3300006600&chapterUid=3&rangeStart=10398&rangeEnd=10426",
      "webLink": "https://weread.qq.com/web/reader/3fd32650813ab6914g010ac4?chapterUid=3&rangeStart=10398&rangeEnd=10426"
    },
    {
      "bookmarkId": "3300006600_3_625-721",
      "chapterUid": 3,
      "range": "625-721",
      "markText": "封闭的地理环境，在很大程度上支配着这一地区的社会历史进程。所以，中国初期的国家形成过程中，缺少像希腊、罗马及地中海沿岸国家那样的较为开放的地理环境和商业因素的作用，社会分工很不发达，农业始终是",
      "totalCount": 255,
      "appLink": "weread://bestbookmark?bookId=3300006600&chapterUid=3&rangeStart=625&rangeEnd=721",
      "webLink": "https://weread.qq.com/web/reader/3fd32650813ab6914g010ac4?chapterUid=3&rangeStart=625&rangeEnd=721"
    },
    {
      "bookmarkId": "3300006600_3_10566-10613",
      "chapterUid": 3,
      "range": "10566-10613",
      "markText": "如果在法律面前人人平等了，社会分工如何完成？没有人人都是总统的国家，也没有人人都是乞丐的社会。",
      "totalCount": 220,
      "appLink": "weread://bestbookmark?bookId=3300006600&chapterUid=3&rangeStart=10566&rangeEnd=10613",
      "webLink": "https://weread.qq.com/web/reader/3fd32650813ab6914g010ac4?chapterUid=3&rangeStart=10566&rangeEnd=10613"
    },
    {
      "bookmarkId": "3300006600_3_1333-1371",
      "chapterUid": 3,
      "range": "1333-1371",
      "markText": "君主专制和权力私有既是中国古代政治的根本特点，也是中国官制史应该关注的问题。",
      "totalCount": 195,
      "appLink": "weread://bestbookmark?bookId=3300006600&chapterUid=3&rangeStart=1333&rangeEnd=1371",
      "webLink": "https://weread.qq.com/web/reader/3fd32650813ab6914g010ac4?chapterUid=3&rangeStart=1333&rangeEnd=1371"
    },
    {
      "bookmarkId": "3300006600_3_1197-1283",
      "chapterUid": 3,
      "range": "1197-1283",
      "markText": "中国古代国家的形成道路，并不是在家长制家庭解体，个体家庭与私有财产充分发展的基础上最后形成的，而是由家长制家庭公社内部的血缘关系和与之相辅相成的公社土地关系直接演变而来的。",
      "totalCount": 182,
      "appLink": "weread://bestbookmark?bookId=3300006600&chapterUid=3&rangeStart=1197&rangeEnd=1283",
      "webLink": "https://weread.qq.com/web/reader/3fd32650813ab6914g010ac4?chapterUid=3&rangeStart=1197&rangeEnd=1283"
    },
    {
      "bookmarkId": "3300006600_3_9223-9254",
      "chapterUid": 3,
      "range": "9223-9254",
      "markText": "在总结自己宦途经历时，竟然得出“多磕头，少说话”的六字为官要诀",
      "totalCount": 143,
      "appLink": "weread://bestbookmark?bookId=3300006600&chapterUid=3&rangeStart=9223&rangeEnd=9254",
      "webLink": "https://weread.qq.com/web/reader/3fd32650813ab6914g010ac4?chapterUid=3&rangeStart=9223&rangeEnd=9254"
    },
    {
      "bookmarkId": "3300006600_3_2134-2164",
      "chapterUid": 3,
      "range": "2134-2164",
      "markText": "以政权和神权为制定制度的标准，是一切剥削阶级政权的共同手段。",
      "totalCount": 140,
      "appLink": "weread://bestbookmark?bookId=3300006600&chapterUid=3&rangeStart=2134&rangeEnd=2164",
      "webLink": "https://weread.qq.com/web/reader/3fd32650813ab6914g010ac4?chapterUid=3&rangeStart=2134&rangeEnd=2164"
    },
    {
      "bookmarkId": "3300006600_3_4243-4338",
      "chapterUid": 3,
      "range": "4243-4338",
      "markText": "传统的儒家思想从根本上体现为政治统治是建立在伦理道德的基础上，主张以道德治国，而实际上的政治统治却不是道德所能替代的。这种传统的伦理道德往往是流露在表面上，而骨子里却是权力在发挥着决定作用。",
      "totalCount": 132,
      "appLink": "weread://bestbookmark?bookId=3300006600&chapterUid=3&rangeStart=4243&rangeEnd=4338",
      "webLink": "https://weread.qq.com/web/reader/3fd32650813ab6914g010ac4?chapterUid=3&rangeStart=4243&rangeEnd=4338"
    },
    {
      "bookmarkId": "3300006600_3_4063-4112",
      "chapterUid": 3,
      "range": "4063-4112",
      "markText": "一般来说，伦理道德与政治制度是两个不同的领域，政治制度与伦理道德相分离，是社会政治发展的根本途径。",
      "totalCount": 130,
      "appLink": "weread://bestbookmark?bookId=3300006600&chapterUid=3&rangeStart=4063&rangeEnd=4112",
      "webLink": "https://weread.qq.com/web/reader/3fd32650813ab6914g010ac4?chapterUid=3&rangeStart=4063&rangeEnd=4112"
    },
    {
      "bookmarkId": "3300006600_5_2709-2763",
      "chapterUid": 5,
      "range": "2709-2763",
      "markText": "燧人氏就是中国的普罗米修斯，他比普罗米修斯更伟大，因为他不是偷火，而是自己取火，所依靠的是人类自身的聪明才智",
      "totalCount": 120,
      "appLink": "weread://bestbookmark?bookId=3300006600&chapterUid=5&rangeStart=2709&rangeEnd=2763",
      "webLink": "https://weread.qq.com/web/reader/3fd32650813ab6914g010ac4?chapterUid=5&rangeStart=2709&rangeEnd=2763"
    },
    {
      "bookmarkId": "3300006600_3_6504-6569",
      "chapterUid": 3,
      "range": "6504-6569",
      "markText": "第四，贵族特权和官僚政治伴随着中国官制史的始终，专制主义中央集权制度的日益加强，显示出官制的集权化、严密化、严酷化和任意化的特点。",
      "totalCount": 119,
      "appLink": "weread://bestbookmark?bookId=3300006600&chapterUid=3&rangeStart=6504&rangeEnd=6569",
      "webLink": "https://weread.qq.com/web/reader/3fd32650813ab6914g010ac4?chapterUid=3&rangeStart=6504&rangeEnd=6569"
    },
    {
      "bookmarkId": "3300006600_3_1822-1894",
      "chapterUid": 3,
      "range": "1822-1894",
      "markText": "当时许多人都认为，一切礼乐征伐都应该由君主决策和发号施令，没有君主，就犹如失去了首脑和主宰，所谓栖栖遑遑，天下不可一日无君，正是这种认识的反映。",
      "totalCount": 108,
      "appLink": "weread://bestbookmark?bookId=3300006600&chapterUid=3&rangeStart=1822&rangeEnd=1894",
      "webLink": "https://weread.qq.com/web/reader/3fd32650813ab6914g010ac4?chapterUid=3&rangeStart=1822&rangeEnd=1894"
    },
    {
      "bookmarkId": "3300006600_3_532-568",
      "chapterUid": 3,
      "range": "532-568",
      "markText": "第一，君主专制、个人集权与宗法血缘关系、婚姻裙带关系贯穿着官制史的始终。",
      "totalCount": 105,
      "appLink": "weread://bestbookmark?bookId=3300006600&chapterUid=3&rangeStart=532&rangeEnd=568",
      "webLink": "https://weread.qq.com/web/reader/3fd32650813ab6914g010ac4?chapterUid=3&rangeStart=532&rangeEnd=568"
    },
    {
      "bookmarkId": "3300006600_3_1283-1333",
      "chapterUid": 3,
      "range": "1283-1333",
      "markText": "这也决定中国古代社会没有经历过像古希腊时期的城邦制度或古罗马人的共和制度，而是直接实行君主专制统治。",
      "totalCount": 105,
      "appLink": "weread://bestbookmark?bookId=3300006600&chapterUid=3&rangeStart=1283&rangeEnd=1333",
      "webLink": "https://weread.qq.com/web/reader/3fd32650813ab6914g010ac4?chapterUid=3&rangeStart=1283&rangeEnd=1333"
    },
    {
      "bookmarkId": "3300006600_3_8314-8364",
      "chapterUid": 3,
      "range": "8314-8364",
      "markText": "理想中完美的官与现实中平庸的官之间的差距，不但成为专制政体不可解决的难题，也成为滋生政治腐败的土壤。",
      "totalCount": 98,
      "appLink": "weread://bestbookmark?bookId=3300006600&chapterUid=3&rangeStart=8314&rangeEnd=8364",
      "webLink": "https://weread.qq.com/web/reader/3fd32650813ab6914g010ac4?chapterUid=3&rangeStart=8314&rangeEnd=8364"
    },
    {
      "bookmarkId": "3300006600_3_11326-11391",
