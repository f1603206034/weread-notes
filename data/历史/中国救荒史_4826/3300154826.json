      "appLink": "weread://bestbookmark?bookId=3300154826&chapterUid=8&rangeStart=27309&rangeEnd=27350",
      "webLink": "https://weread.qq.com/web/reader/2a032de0813aba2fag016fb6?chapterUid=8&rangeStart=27309&rangeEnd=27350"
    },
