  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300198996_12_4851-4908",
      "chapterUid": 12,
      "range": "4851-4908",
      "markText": "很明显，中国历史与西方历史的交会不可能发生在地理大发现时代之前，而这两个文明的直接碰撞也不可能发生在工业革命以前。",
      "totalCount": 144,
      "appLink": "weread://bestbookmark?bookId=3300198996&chapterUid=12&rangeStart=4851&rangeEnd=4908",
      "webLink": "https://weread.qq.com/web/reader/16032ff0813abb43bg0169fc?chapterUid=12&rangeStart=4851&rangeEnd=4908"
    },
    {
      "bookmarkId": "3300198996_7_1849-1911",
      "chapterUid": 7,
      "range": "1849-1911",
      "markText": "只要双方和平共处、容忍差异、增进协调和谅解，就会出现一个史无前例的和平昌盛的新纪元。在太平洋两岸都需要有睿智贤明的治国之道。",
      "totalCount": 128,
      "appLink": "weread://bestbookmark?bookId=3300198996&chapterUid=7&rangeStart=1849&rangeEnd=1911",
      "webLink": "https://weread.qq.com/web/reader/16032ff0813abb43bg0169fc?chapterUid=7&rangeStart=1849&rangeEnd=1911"
    },
    {
      "bookmarkId": "3300198996_12_7850-7917",
      "chapterUid": 12,
      "range": "7850-7917",
      "markText": "它只采纳了西方文明中那些具有直接实用价值的东西，而另一些更为可取的方面——如政治体制、经济制度、哲学、文学和艺术等——却完全被忽略了。",
      "totalCount": 112,
      "appLink": "weread://bestbookmark?bookId=3300198996&chapterUid=12&rangeStart=7850&rangeEnd=7917",
      "webLink": "https://weread.qq.com/web/reader/16032ff0813abb43bg0169fc?chapterUid=12&rangeStart=7850&rangeEnd=7917"
    },
    {
      "bookmarkId": "3300198996_12_7480-7567",
      "chapterUid": 12,
      "range": "7480-7567",
      "markText": "对一种新秩序的探求涉及一场极其艰难的观念之争，需要排除那种过度的自尊意识和对外来事物的藐视之情，抛开那种认为富庶的中华上国无须借鉴化外蛮夷、也无须与彼等结交的根深蒂固的信念。",
      "totalCount": 96,
      "appLink": "weread://bestbookmark?bookId=3300198996&chapterUid=12&rangeStart=7480&rangeEnd=7567",
      "webLink": "https://weread.qq.com/web/reader/16032ff0813abb43bg0169fc?chapterUid=12&rangeStart=7480&rangeEnd=7567"
    },
    {
      "bookmarkId": "3300198996_14_10130-10187",
      "chapterUid": 14,
      "range": "10130-10187",
      "markText": "1683年，清军攻占台湾，一年后置为福建省的一个府。随着这个最后的大明遗臣集团的失败，清朝完成了对整个中国的统一。",
      "totalCount": 85,
      "appLink": "weread://bestbookmark?bookId=3300198996&chapterUid=14&rangeStart=10130&rangeEnd=10187",
      "webLink": "https://weread.qq.com/web/reader/16032ff0813abb43bg0169fc?chapterUid=14&rangeStart=10130&rangeEnd=10187"
    },
    {
      "bookmarkId": "3300198996_12_5459-5519",
      "chapterUid": 12,
      "range": "5459-5519",
      "markText": "19世纪中叶以后，有许多洋人受聘担任政府官职，从而使满—汉二元体制扩展为一种“满—汉—夷”的混合体制（synarchy）",
      "totalCount": 84,
      "appLink": "weread://bestbookmark?bookId=3300198996&chapterUid=12&rangeStart=5459&rangeEnd=5519",
      "webLink": "https://weread.qq.com/web/reader/16032ff0813abb43bg0169fc?chapterUid=12&rangeStart=5459&rangeEnd=5519"
    },
    {
      "bookmarkId": "3300198996_12_7080-7132",
      "chapterUid": 12,
      "range": "7080-7132",
      "markText": "。讽刺的是，西方文明在其他地方显得极有创造力且生机勃勃，但在与中国的直接对抗时，却表现出破坏性大于建设性",
      "totalCount": 80,
      "appLink": "weread://bestbookmark?bookId=3300198996&chapterUid=12&rangeStart=7080&rangeEnd=7132",
      "webLink": "https://weread.qq.com/web/reader/16032ff0813abb43bg0169fc?chapterUid=12&rangeStart=7080&rangeEnd=7132"
    },
    {
      "bookmarkId": "3300198996_22_18314-18360",
      "chapterUid": 22,
      "range": "18314-18360",
      "markText": "最后他被俄国和法国的外交官伊格纳季耶夫将军和葛罗男爵说服，放弃了这两个想法，代之以火烧圆明园",
      "totalCount": 75,
      "appLink": "weread://bestbookmark?bookId=3300198996&chapterUid=22&rangeStart=18314&rangeEnd=18360",
      "webLink": "https://weread.qq.com/web/reader/16032ff0813abb43bg0169fc?chapterUid=22&rangeStart=18314&rangeEnd=18360"
    },
    {
      "bookmarkId": "3300198996_27_7279-7335",
      "chapterUid": 27,
      "range": "7279-7335",
      "markText": "左宗棠说，西方列强为占有海港、口岸而开仗，而且通常仅仅是为了商业上的特权，而俄国既想获取商业让步，也有领土要求。",
      "totalCount": 70,
      "appLink": "weread://bestbookmark?bookId=3300198996&chapterUid=27&rangeStart=7279&rangeEnd=7335",
      "webLink": "https://weread.qq.com/web/reader/16032ff0813abb43bg0169fc?chapterUid=27&rangeStart=7279&rangeEnd=7335"
    },
    {
      "bookmarkId": "3300198996_7_1750-1806",
      "chapterUid": 7,
      "range": "1750-1806",
      "markText": "从文化的意义上来说，中国是中华文明的继承者，而美国则可以被看作西方文明的现代化身。它们以前所未有的方式相互碰撞。",
      "totalCount": 68,
      "appLink": "weread://bestbookmark?bookId=3300198996&chapterUid=7&rangeStart=1750&rangeEnd=1806",
      "webLink": "https://weread.qq.com/web/reader/16032ff0813abb43bg0169fc?chapterUid=7&rangeStart=1750&rangeEnd=1806"
    },
    {
      "bookmarkId": "3300198996_18_1129-1228",
      "chapterUid": 18,
      "range": "1129-1228",
      "markText": "在他们个人控制范围之外的一些事情上，出现任何疏忽或过失都可能招来惩罚。最终出现的普遍情形是，对普通官员来说，最慎重的做法是尽可能少地承担责任——多注意在形式上遵守成文的章程，少去做那些利君惠民的事情",
      "totalCount": 68,
      "appLink": "weread://bestbookmark?bookId=3300198996&chapterUid=18&rangeStart=1129&rangeEnd=1228",
      "webLink": "https://weread.qq.com/web/reader/16032ff0813abb43bg0169fc?chapterUid=18&rangeStart=1129&rangeEnd=1228"
    },
    {
      "bookmarkId": "3300198996_31_10315-10369",
      "chapterUid": 31,
      "range": "10315-10369",
      "markText": "席卷华北、内蒙古和东北，并使231个外国人丧生和成千上万的中国基督教徒惨遭杀戮的义和团事件，终于平息下来了。",
      "totalCount": 68,
      "appLink": "weread://bestbookmark?bookId=3300198996&chapterUid=31&rangeStart=10315&rangeEnd=10369",
      "webLink": "https://weread.qq.com/web/reader/16032ff0813abb43bg0169fc?chapterUid=31&rangeStart=10315&rangeEnd=10369"
    },
    {
      "bookmarkId": "3300198996_37_7028-7057",
      "chapterUid": 37,
      "range": "7028-7057",
      "markText": "翌年，李大钊受聘为图书馆馆长，他雇用了年轻的毛泽东为助理。",
      "totalCount": 65,
      "appLink": "weread://bestbookmark?bookId=3300198996&chapterUid=37&rangeStart=7028&rangeEnd=7057",
      "webLink": "https://weread.qq.com/web/reader/16032ff0813abb43bg0169fc?chapterUid=37&rangeStart=7028&rangeEnd=7057"
    },
    {
      "bookmarkId": "3300198996_14_11784-11837",
      "chapterUid": 14,
      "range": "11784-11837",
      "markText": "但是，1682年10月21日以后，为了照顾那些不住在皇宫附近的大臣，朝会改到了春夏7点开始、秋冬8点开始。",
      "totalCount": 64,
      "appLink": "weread://bestbookmark?bookId=3300198996&chapterUid=14&rangeStart=11784&rangeEnd=11837",
      "webLink": "https://weread.qq.com/web/reader/16032ff0813abb43bg0169fc?chapterUid=14&rangeStart=11784&rangeEnd=11837"
    },
    {
      "bookmarkId": "3300198996_7_603-658",
      "chapterUid": 7,
      "range": "603-658",
      "markText": "新中国成立前的一个世纪，中国内部的腐败和外来帝国主义的羞辱性掠夺，如同一对孪生恶魔，给社会带来了长时期的衰落。",
      "totalCount": 60,
      "appLink": "weread://bestbookmark?bookId=3300198996&chapterUid=7&rangeStart=603&rangeEnd=658",
      "webLink": "https://weread.qq.com/web/reader/16032ff0813abb43bg0169fc?chapterUid=7&rangeStart=603&rangeEnd=658"
    },
    {
      "bookmarkId": "3300198996_12_5228-5305",
      "chapterUid": 12,
      "range": "5228-5305",
      "markText": "清廷大兴文字狱，惩罚讥讽清朝统治的人；设立宗人府，监督满族显贵的出身、受业和婚姻；禁止满汉通婚，并严禁汉人迁居满洲。通过这些措施，努力维护满族的民族特性。",
      "totalCount": 60,
      "appLink": "weread://bestbookmark?bookId=3300198996&chapterUid=12&rangeStart=5228&rangeEnd=5305",
      "webLink": "https://weread.qq.com/web/reader/16032ff0813abb43bg0169fc?chapterUid=12&rangeStart=5228&rangeEnd=5305"
    },
    {
      "bookmarkId": "3300198996_12_9053-9142",
      "chapterUid": 12,
      "range": "9053-9142",
      "markText": "首先是影响器物的技术；而后是关于国家和社会的原理；最后则是触及精神生活核心的观念。同治朝的洋务运动、1898年的维新变法和1919年的“五四运动”各自标志了这三个阶段的思想要点。",
      "totalCount": 60,
      "appLink": "weread://bestbookmark?bookId=3300198996&chapterUid=12&rangeStart=9053&rangeEnd=9142",
      "webLink": "https://weread.qq.com/web/reader/16032ff0813abb43bg0169fc?chapterUid=12&rangeStart=9053&rangeEnd=9142"
    },
    {
      "bookmarkId": "3300198996_12_1781-1840",
      "chapterUid": 12,
      "range": "1781-1840",
      "markText": "西方历史学家认为，这场战争意味着外国在华活动的加剧，这些活动打破了中国的孤立局面，并在中国开创了一个革命性变化的时代。",
      "totalCount": 56,
      "appLink": "weread://bestbookmark?bookId=3300198996&chapterUid=12&rangeStart=1781&rangeEnd=1840",
      "webLink": "https://weread.qq.com/web/reader/16032ff0813abb43bg0169fc?chapterUid=12&rangeStart=1781&rangeEnd=1840"
    },
    {
      "bookmarkId": "3300198996_12_2506-2562",
      "chapterUid": 12,
      "range": "2506-2562",
      "markText": "耶稣会士传入了天文学、数学、地理学、制图学和建筑学等西方科学，但他们的影响只局限于中国统治集团内部的少数士大夫。",
      "totalCount": 55,
      "appLink": "weread://bestbookmark?bookId=3300198996&chapterUid=12&rangeStart=2506&rangeEnd=2562",
      "webLink": "https://weread.qq.com/web/reader/16032ff0813abb43bg0169fc?chapterUid=12&rangeStart=2506&rangeEnd=2562"
    },
    {
      "bookmarkId": "3300198996_25_17681-17742",
      "chapterUid": 25,
      "range": "17681-17742",
      "markText": "中国政府花费了55万英镑购买了一支舰队，然后解散，除了惹上一身麻烦之外，一无所获。第一次组建一支新式水师的尝试可谓彻底失败",
      "totalCount": 55,
      "appLink": "weread://bestbookmark?bookId=3300198996&chapterUid=25&rangeStart=17681&rangeEnd=17742",
      "webLink": "https://weread.qq.com/web/reader/16032ff0813abb43bg0169fc?chapterUid=25&rangeStart=17681&rangeEnd=17742"
    }
