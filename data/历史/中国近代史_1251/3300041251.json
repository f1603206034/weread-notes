  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300041251_6_3259-3305",
      "chapterUid": 6,
      "range": "3259-3305",
      "markText": "中西的关系是特别的。在鸦片战争以前，我们不肯给外国平等待遇；在以后，他们不肯给我们平等待遇。",
      "totalCount": 720,
      "appLink": "weread://bestbookmark?bookId=3300041251&chapterUid=6&rangeStart=3259&rangeEnd=3305",
      "webLink": "https://weread.qq.com/web/reader/c81329b0813ab769dg0111c3?chapterUid=6&rangeStart=3259&rangeEnd=3305"
    },
    {
      "bookmarkId": "3300041251_8_8228-8257",
      "chapterUid": 8,
      "range": "8228-8257",
      "markText": "严格说来，民众的迷信是我民族近代接受西洋文化的大阻碍之一。",
      "totalCount": 375,
      "appLink": "weread://bestbookmark?bookId=3300041251&chapterUid=8&rangeStart=8228&rangeEnd=8257",
      "webLink": "https://weread.qq.com/web/reader/c81329b0813ab769dg0111c3?chapterUid=8&rangeStart=8228&rangeEnd=8257"
    },
    {
      "bookmarkId": "3300041251_6_14029-14052",
      "chapterUid": 6,
      "range": "14029-14052",
      "markText": "他病太重，以后不久就死了，他的名誉借此保存了。",
      "totalCount": 360,
      "appLink": "weread://bestbookmark?bookId=3300041251&chapterUid=6&rangeStart=14029&rangeEnd=14052",
      "webLink": "https://weread.qq.com/web/reader/c81329b0813ab769dg0111c3?chapterUid=6&rangeStart=14029&rangeEnd=14052"
    },
    {
      "bookmarkId": "3300041251_17_2102-2136",
      "chapterUid": 17,
      "range": "2102-2136",
      "markText": "可惜在我们这个社会里，糊涂的见解用激昂的文辞发表出来，有误国的能力。",
      "totalCount": 255,
      "appLink": "weread://bestbookmark?bookId=3300041251&chapterUid=17&rangeStart=2102&rangeEnd=2136",
      "webLink": "https://weread.qq.com/web/reader/c81329b0813ab769dg0111c3?chapterUid=17&rangeStart=2102&rangeEnd=2136"
    },
    {
      "bookmarkId": "3300041251_6_11541-11581",
      "chapterUid": 6,
      "range": "11541-11581",
      "markText": "不平等条约的根源一部分由于我们的无知，一部分由于我们的法制未达到近代文明的水准。",
      "totalCount": 247,
      "appLink": "weread://bestbookmark?bookId=3300041251&chapterUid=6&rangeStart=11541&rangeEnd=11581",
      "webLink": "https://weread.qq.com/web/reader/c81329b0813ab769dg0111c3?chapterUid=6&rangeStart=11541&rangeEnd=11581"
    },
    {
      "bookmarkId": "3300041251_6_8578-8633",
      "chapterUid": 6,
      "range": "8578-8633",
      "markText": "从民族的历史看，鸦片战争的军事失败还不是民族致命伤。失败以后还不明了失败的理由，力图改革，那才是民族的致命伤。",
      "totalCount": 224,
      "appLink": "weread://bestbookmark?bookId=3300041251&chapterUid=6&rangeStart=8578&rangeEnd=8633",
      "webLink": "https://weread.qq.com/web/reader/c81329b0813ab769dg0111c3?chapterUid=6&rangeStart=8578&rangeEnd=8633"
    },
    {
      "bookmarkId": "3300041251_7_9412-9442",
      "chapterUid": 7,
      "range": "9412-9442",
      "markText": "追究其祸根，我们不能不归咎于湘军。于此也可看出旧法子的毛病。",
      "totalCount": 224,
      "appLink": "weread://bestbookmark?bookId=3300041251&chapterUid=7&rangeStart=9412&rangeEnd=9442",
      "webLink": "https://weread.qq.com/web/reader/c81329b0813ab769dg0111c3?chapterUid=7&rangeStart=9412&rangeEnd=9442"
    },
    {
      "bookmarkId": "3300041251_6_10656-10694",
      "chapterUid": 6,
      "range": "10656-10694",
      "markText": "英国人初提香港的时候，北京还不知道香港在哪里。时人反对割地，不是反对割香港。",
      "totalCount": 204,
      "appLink": "weread://bestbookmark?bookId=3300041251&chapterUid=6&rangeStart=10656&rangeEnd=10694",
      "webLink": "https://weread.qq.com/web/reader/c81329b0813ab769dg0111c3?chapterUid=6&rangeStart=10656&rangeEnd=10694"
    },
    {
      "bookmarkId": "3300041251_6_9883-9952",
      "chapterUid": 6,
      "range": "9883-9952",
      "markText": "难怪他后来虽又做陕甘总督和云贵总督，他总不肯公开提倡改革。他让主持清议的士大夫睡在梦中，他让国家日趋衰弱，而不肯牺牲自己的名誉去与时人奋斗",
      "totalCount": 200,
      "appLink": "weread://bestbookmark?bookId=3300041251&chapterUid=6&rangeStart=9883&rangeEnd=9952",
      "webLink": "https://weread.qq.com/web/reader/c81329b0813ab769dg0111c3?chapterUid=6&rangeStart=9883&rangeEnd=9952"
    },
    {
      "bookmarkId": "3300041251_6_14790-14807",
      "chapterUid": 6,
      "range": "14790-14807",
      "markText": "士大夫阶级所依赖的民心竟毫无力量。",
      "totalCount": 195,
      "appLink": "weread://bestbookmark?bookId=3300041251&chapterUid=6&rangeStart=14790&rangeEnd=14807",
      "webLink": "https://weread.qq.com/web/reader/c81329b0813ab769dg0111c3?chapterUid=6&rangeStart=14790&rangeEnd=14807"
    },
    {
      "bookmarkId": "3300041251_6_4916-4982",
      "chapterUid": 6,
      "range": "4916-4982",
      "markText": "在他们的私函中，他们承认禁烟的困难，但是在他们的奏章中，他们总是逢迎上峰的意旨，唱高调。这种不诚实的行为是我国士大夫阶级大毛病之一。",
