  ],
  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "23549079_16_3495-3526",
      "chapterUid": 16,
      "range": "3495-3526",
      "markText": "要国家强大，领导人就得多活几年，各国领导人如是老人，政治就好。",
      "totalCount": 1079,
      "appLink": "weread://bestbookmark?bookId=23549079&chapterUid=16&rangeStart=3495&rangeEnd=3526",
      "webLink": "https://weread.qq.com/web/reader/840322807167549784061bc?chapterUid=16&rangeStart=3495&rangeEnd=3526"
    },
    {
      "bookmarkId": "23549079_17_1837-1892",
      "chapterUid": 17,
      "range": "1837-1892",
      "markText": "只有教育可以救中国，要有“五十年以后”的精神，今日世界各国都有大学在上课，应该有志气与他们在五十年以后比一比。",
      "totalCount": 828,
      "appLink": "weread://bestbookmark?bookId=23549079&chapterUid=17&rangeStart=1837&rangeEnd=1892",
      "webLink": "https://weread.qq.com/web/reader/840322807167549784061bc?chapterUid=17&rangeStart=1837&rangeEnd=1892"
    },
    {
      "bookmarkId": "23549079_20_984-1037",
      "chapterUid": 20,
      "range": "984-1037",
      "markText": "人不是“血统”的，是“文化”的。没有文化教育，国家就危险，自己不承认是国家，外国也不会承认，就会变成游魂。",
      "totalCount": 828,
      "appLink": "weread://bestbookmark?bookId=23549079&chapterUid=20&rangeStart=984&rangeEnd=1037",
      "webLink": "https://weread.qq.com/web/reader/840322807167549784061bc?chapterUid=20&rangeStart=984&rangeEnd=1037"
    },
    {
      "bookmarkId": "23549079_22_1204-1292",
      "chapterUid": 22,
      "range": "1204-1292",
      "markText": "石勒并没有杀害此等养清望之人，只说他们衣冠神气像样，代表中国文化，不可杀。摆放着又没有用。现今也有这一类人，他们代表着一个社会，什么都好，风流、神采非凡，但事情却坏在他们手里。",
      "totalCount": 615,
      "appLink": "weread://bestbookmark?bookId=23549079&chapterUid=22&rangeStart=1204&rangeEnd=1292",
      "webLink": "https://weread.qq.com/web/reader/840322807167549784061bc?chapterUid=22&rangeStart=1204&rangeEnd=1292"
    },
    {
      "bookmarkId": "23549079_18_1836-1876",
      "chapterUid": 18,
      "range": "1836-1876",
      "markText": "曹操、司马懿等辈打破了君臣伦理关系，一切礼仪制度随即打破，故社会垮了，人伦灭了。",
      "totalCount": 585,
      "appLink": "weread://bestbookmark?bookId=23549079&chapterUid=18&rangeStart=1836&rangeEnd=1876",
      "webLink": "https://weread.qq.com/web/reader/840322807167549784061bc?chapterUid=18&rangeStart=1836&rangeEnd=1876"
    },
    {
      "bookmarkId": "23549079_6_445-491",
      "chapterUid": 6,
      "range": "445-491",
      "markText": "一件东西的发明，绝非一个人能成事，而是陆续由人不断改进，但讲出来时便只举出一个代表人物而已。",
      "totalCount": 560,
      "appLink": "weread://bestbookmark?bookId=23549079&chapterUid=6&rangeStart=445&rangeEnd=491",
      "webLink": "https://weread.qq.com/web/reader/840322807167549784061bc?chapterUid=6&rangeStart=445&rangeEnd=491"
    },
    {
      "bookmarkId": "23549079_13_4743-4810",
      "chapterUid": 13,
      "range": "4743-4810",
      "markText": "秦是中国第一个统一政府，是贵族的；汉是中国第一个士人政府，是平民的。历史进步是有步骤的，眼光不应短视，吾人应具有“范畴”的系统的看法。",
      "totalCount": 560,
      "appLink": "weread://bestbookmark?bookId=23549079&chapterUid=13&rangeStart=4743&rangeEnd=4810",
      "webLink": "https://weread.qq.com/web/reader/840322807167549784061bc?chapterUid=13&rangeStart=4743&rangeEnd=4810"
    },
    {
      "bookmarkId": "23549079_4_1148-1161",
      "chapterUid": 4,
      "range": "1148-1161",
      "markText": "凡有一字之改正，皆吾师也。",
      "totalCount": 540,
      "appLink": "weread://bestbookmark?bookId=23549079&chapterUid=4&rangeStart=1148&rangeEnd=1161",
      "webLink": "https://weread.qq.com/web/reader/840322807167549784061bc?chapterUid=4&rangeStart=1148&rangeEnd=1161"
    },
    {
      "bookmarkId": "23549079_7_772-812",
      "chapterUid": 7,
      "range": "772-812",
      "markText": "从夏朝到商朝历时四百年，文字的逐步进化亦需要四百年，故文字在夏朝时实际上已有了。",
      "totalCount": 528,
      "appLink": "weread://bestbookmark?bookId=23549079&chapterUid=7&rangeStart=772&rangeEnd=812",
      "webLink": "https://weread.qq.com/web/reader/840322807167549784061bc?chapterUid=7&rangeStart=772&rangeEnd=812"
    },
    {
      "bookmarkId": "23549079_25_897-997",
      "chapterUid": 25,
      "range": "897-997",
      "markText": "路一走正，国家民族变为富强便很快。历史不能看现状，要看趋向。如看现状，则隋又富又强，却一路走下坡，唐却从低处往上进。做人也如此，要比趋向，看势头。一百年来中国只懂得现状，现状无法回转，而趋向可以回转。",
      "totalCount": 510,
      "appLink": "weread://bestbookmark?bookId=23549079&chapterUid=25&rangeStart=897&rangeEnd=997",
      "webLink": "https://weread.qq.com/web/reader/840322807167549784061bc?chapterUid=25&rangeStart=897&rangeEnd=997"
    },
    {
      "bookmarkId": "23549079_13_4648-4714",
      "chapterUid": 13,
      "range": "4648-4714",
      "markText": "旧势力崩溃，新势力平民阶级兴起，故秦统一中国，并非打倒六国，乃是平民社会希望统一。故汉朝是新兴的平民政治，这就是古代封建社会结束了。",
      "totalCount": 504,
      "appLink": "weread://bestbookmark?bookId=23549079&chapterUid=13&rangeStart=4648&rangeEnd=4714",
      "webLink": "https://weread.qq.com/web/reader/840322807167549784061bc?chapterUid=13&rangeStart=4648&rangeEnd=4714"
    },
    {
      "bookmarkId": "23549079_23_652-707",
      "chapterUid": 23,
      "range": "652-707",
      "markText": "印度气候暖，觉天地丰富，故信仰多神；阿拉伯是海边沙漠，觉天地很简单，故选一神教。宗教之缘起，实由环境不同而生。",
      "totalCount": 490,
      "appLink": "weread://bestbookmark?bookId=23549079&chapterUid=23&rangeStart=652&rangeEnd=707",
      "webLink": "https://weread.qq.com/web/reader/840322807167549784061bc?chapterUid=23&rangeStart=652&rangeEnd=707"
    },
    {
      "bookmarkId": "23549079_11_1400-1470",
      "chapterUid": 11,
      "range": "1400-1470",
      "markText": "封建是周公所发明，没有封建，就无周朝。尊王攘夷霸诸侯是管仲发明。故今日需要有一个人出来讲一句话打开时代的僵局。只要能发明一句，便是大政治家。",
      "totalCount": 468,
      "appLink": "weread://bestbookmark?bookId=23549079&chapterUid=11&rangeStart=1400&rangeEnd=1470",
      "webLink": "https://weread.qq.com/web/reader/840322807167549784061bc?chapterUid=11&rangeStart=1400&rangeEnd=1470"
    },
    {
      "bookmarkId": "23549079_9_1508-1597",
      "chapterUid": 9,
      "range": "1508-1597",
      "markText": "周公用手段来完成道德的目的。周朝第一次封建是周武王，第二次封建是周公分封宗戚并兴灭国继绝世，于是周朝以德治天下，有八百年历史。所以说，中国文化是和平的文化，中国历史是和平的历史。",
      "totalCount": 420,
      "appLink": "weread://bestbookmark?bookId=23549079&chapterUid=9&rangeStart=1508&rangeEnd=1597",
      "webLink": "https://weread.qq.com/web/reader/840322807167549784061bc?chapterUid=9&rangeStart=1508&rangeEnd=1597"
    },
    {
      "bookmarkId": "23549079_26_1886-1936",
      "chapterUid": 26,
      "range": "1886-1936",
      "markText": "唐之亡并非亡在贵妃身上，实因安禄山之权委实太大，杨贵妃进宫时，天下之大乱早已造成了，故不能责怪贵妃。",
      "totalCount": 416,
      "appLink": "weread://bestbookmark?bookId=23549079&chapterUid=26&rangeStart=1886&rangeEnd=1936",
      "webLink": "https://weread.qq.com/web/reader/840322807167549784061bc?chapterUid=26&rangeStart=1886&rangeEnd=1936"
    },
    {
      "bookmarkId": "23549079_17_2030-2058",
