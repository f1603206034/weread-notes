  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300197667_30_8202-8237",
      "chapterUid": 30,
      "range": "8202-8237",
      "markText": "此外还有应缴库项银六千八百余、应赔罚银八百余两等，焦头烂额，只能挪移。",
      "totalCount": 2684,
      "appLink": "weread://bestbookmark?bookId=3300197667&chapterUid=30&rangeStart=8202&rangeEnd=8237",
      "webLink": "https://weread.qq.com/web/reader/e8332cf0813abb3b6g01767c?chapterUid=30&rangeStart=8202&rangeEnd=8237"
    },
    {
      "bookmarkId": "3300197667_34_5830-6034",
      "chapterUid": 34,
      "range": "5830-6034",
      "markText": "乾隆三十八年至乾隆四十四年，由于私盐充斥，导致川省滞销盐引累积达五万三千余，“比较之下，殊属过多”。",
      "totalCount": 2680,
      "appLink": "weread://bestbookmark?bookId=3300197667&chapterUid=34&rangeStart=5830&rangeEnd=6034",
      "webLink": "https://weread.qq.com/web/reader/e8332cf0813abb3b6g01767c?chapterUid=34&rangeStart=5830&rangeEnd=6034"
    },
    {
      "bookmarkId": "3300197667_37_4715-4754",
      "chapterUid": 37,
      "range": "4715-4754",
      "markText": "将原来分散的省河一百五十余埠，合成一公局（纲局），共同经营，此后官方停发官银。",
      "totalCount": 2680,
      "appLink": "weread://bestbookmark?bookId=3300197667&chapterUid=37&rangeStart=4715&rangeEnd=4754",
      "webLink": "https://weread.qq.com/web/reader/e8332cf0813abb3b6g01767c?chapterUid=37&rangeStart=4715&rangeEnd=4754"
    },
    {
      "bookmarkId": "3300197667_33_3256-3295",
      "chapterUid": 33,
      "range": "3256-3295",
      "markText": "五月十七日，因为扬州盐商暂缓向汉口发盐，户部令两淮盐政三保迅速督运，不得耽搁。",
      "totalCount": 2675,
      "appLink": "weread://bestbookmark?bookId=3300197667&chapterUid=33&rangeStart=3256&rangeEnd=3295",
      "webLink": "https://weread.qq.com/web/reader/e8332cf0813abb3b6g01767c?chapterUid=33&rangeStart=3256&rangeEnd=3295"
    },
    {
      "bookmarkId": "3300197667_11_1448-1476",
      "chapterUid": 11,
      "range": "1448-1476",
      "markText": "结果讷亲报告，苏州只有虎丘是名胜，不过就是个大坟包而已。",
      "totalCount": 2662,
      "appLink": "weread://bestbookmark?bookId=3300197667&chapterUid=11&rangeStart=1448&rangeEnd=1476",
      "webLink": "https://weread.qq.com/web/reader/e8332cf0813abb3b6g01767c?chapterUid=11&rangeStart=1448&rangeEnd=1476"
    },
    {
      "bookmarkId": "3300197667_7_1564-1615",
      "chapterUid": 7,
      "range": "1564-1615",
      "markText": "“第一是走盐商，走久接地方，一派纲总更气象，水晶顶，海龙裳，大轿玻璃窗儿亮，跑如飞蝗，把运司衙门上。”",
      "totalCount": 2657,
      "appLink": "weread://bestbookmark?bookId=3300197667&chapterUid=7&rangeStart=1564&rangeEnd=1615",
      "webLink": "https://weread.qq.com/web/reader/e8332cf0813abb3b6g01767c?chapterUid=7&rangeStart=1564&rangeEnd=1615"
    },
    {
      "bookmarkId": "3300197667_11_8751-8782",
      "chapterUid": 11,
      "range": "8751-8782",
      "markText": "同行的友人刘弘谟精于占卜拆字，行至江宁观音门时，船只遇风靠岸。",
      "totalCount": 2657,
      "appLink": "weread://bestbookmark?bookId=3300197667&chapterUid=11&rangeStart=8751&rangeEnd=8782",
      "webLink": "https://weread.qq.com/web/reader/e8332cf0813abb3b6g01767c?chapterUid=11&rangeStart=8751&rangeEnd=8782"
    },
    {
      "bookmarkId": "3300197667_34_3566-3633",
      "chapterUid": 34,
      "range": "3566-3633",
      "markText": "盐井的开凿、煮盐的设备、房灶的建设乃至运输，都需要相当的资金投入，故而盐井多为合资方式。",
      "totalCount": 2653,
      "appLink": "weread://bestbookmark?bookId=3300197667&chapterUid=34&rangeStart=3566&rangeEnd=3633",
      "webLink": "https://weread.qq.com/web/reader/e8332cf0813abb3b6g01767c?chapterUid=34&rangeStart=3566&rangeEnd=3633"
    },
    {
      "bookmarkId": "3300197667_39_6907-6962",
      "chapterUid": 39,
      "range": "6907-6962",
      "markText": "俘获的大小金川各地男女老幼，共计两万八百余人，大部分被封赏给了帮助清军作战的土司，另有七千七百余人被充作兵弁。",
      "totalCount": 2653,
      "appLink": "weread://bestbookmark?bookId=3300197667&chapterUid=39&rangeStart=6907&rangeEnd=6962",
      "webLink": "https://weread.qq.com/web/reader/e8332cf0813abb3b6g01767c?chapterUid=39&rangeStart=6907&rangeEnd=6962"
    },
    {
      "bookmarkId": "3300197667_4_2417-2458",
      "chapterUid": 4,
      "range": "2417-2458",
      "markText": "十月时，乾隆帝“查两淮盐法，从前浮费繁多，商力日困”，要求“彻底清查，革除浮费”。",
      "totalCount": 2648,
      "appLink": "weread://bestbookmark?bookId=3300197667&chapterUid=4&rangeStart=2417&rangeEnd=2458",
      "webLink": "https://weread.qq.com/web/reader/e8332cf0813abb3b6g01767c?chapterUid=4&rangeStart=2417&rangeEnd=2458"
    },
    {
      "bookmarkId": "3300197667_13_2764-2871",
      "chapterUid": 13,
      "range": "2764-2871",
      "markText": "皇帝用完膳，由盐政高恒代盐商领取赏赐的饭菜，一等饭菜二十桌，每桌八品（青瓷碗），蒸食一盘、炉食一盘、攒盘肉一盘，每桌猪肉六斤、羊肉四斤，外膳房肉丝汤、膳房饭，牲口一只。",
      "totalCount": 2648,
      "appLink": "weread://bestbookmark?bookId=3300197667&chapterUid=13&rangeStart=2764&rangeEnd=2871",
      "webLink": "https://weread.qq.com/web/reader/e8332cf0813abb3b6g01767c?chapterUid=13&rangeStart=2764&rangeEnd=2871"
    },
    {
      "bookmarkId": "3300197667_30_7941-7963",
      "chapterUid": 30,
      "range": "7941-7963",
      "markText": "“虽有追缴，仍多压欠，历年既久，为数较多。”",
      "totalCount": 2648,
      "appLink": "weread://bestbookmark?bookId=3300197667&chapterUid=30&rangeStart=7941&rangeEnd=7963",
      "webLink": "https://weread.qq.com/web/reader/e8332cf0813abb3b6g01767c?chapterUid=30&rangeStart=7941&rangeEnd=7963"
    },
    {
      "bookmarkId": "3300197667_37_5259-5289",
      "chapterUid": 37,
      "range": "5259-5289",
      "markText": "早先官帑收盐时，埠商都是散商，改埠归纲后，散商则从属于公局。",
      "totalCount": 2648,
      "appLink": "weread://bestbookmark?bookId=3300197667&chapterUid=37&rangeStart=5259&rangeEnd=5289",
      "webLink": "https://weread.qq.com/web/reader/e8332cf0813abb3b6g01767c?chapterUid=37&rangeStart=5259&rangeEnd=5289"
    },
    {
      "bookmarkId": "3300197667_30_7799-7830",
      "chapterUid": 30,
      "range": "7799-7830",
      "markText": "接任官查明后，如有弊端，应该及时汇报督抚，将亏空官员革职治罪。",
      "totalCount": 2644,
      "appLink": "weread://bestbookmark?bookId=3300197667&chapterUid=30&rangeStart=7799&rangeEnd=7830",
      "webLink": "https://weread.qq.com/web/reader/e8332cf0813abb3b6g01767c?chapterUid=30&rangeStart=7799&rangeEnd=7830"
    },
    {
      "bookmarkId": "3300197667_29_5948-5980",
      "chapterUid": 29,
      "range": "5948-5980",
      "markText": "乾隆帝决定：“嗣后两淮盐政，所有商人一切日费供应，俱著一律裁革。",
      "totalCount": 2639,
      "appLink": "weread://bestbookmark?bookId=3300197667&chapterUid=29&rangeStart=5948&rangeEnd=5980",
      "webLink": "https://weread.qq.com/web/reader/e8332cf0813abb3b6g01767c?chapterUid=29&rangeStart=5948&rangeEnd=5980"
    },
    {
      "bookmarkId": "3300197667_9_2681-2732",
      "chapterUid": 9,
      "range": "2681-2732",
      "markText": "这些晋商利欲熏心，丝毫不顾及国家利益，不但贩卖人参、貂皮等物品入关，更敢贩卖火药这样的军需物资给后金。",
      "totalCount": 2635,
      "appLink": "weread://bestbookmark?bookId=3300197667&chapterUid=9&rangeStart=2681&rangeEnd=2732",
      "webLink": "https://weread.qq.com/web/reader/e8332cf0813abb3b6g01767c?chapterUid=9&rangeStart=2681&rangeEnd=2732"
    },
    {
      "bookmarkId": "3300197667_37_2623-2658",
      "chapterUid": 37,
      "range": "2623-2658",
      "markText": "潮汕地方上宗族势力之强大，联合族人组织械斗之本领，让其他各地望尘莫及。",
      "totalCount": 2635,
      "appLink": "weread://bestbookmark?bookId=3300197667&chapterUid=37&rangeStart=2623&rangeEnd=2658",
      "webLink": "https://weread.qq.com/web/reader/e8332cf0813abb3b6g01767c?chapterUid=37&rangeStart=2623&rangeEnd=2658"
    },
    {
      "bookmarkId": "3300197667_30_7652-7687",
      "chapterUid": 30,
      "range": "7652-7687",
      "markText": "清代地方钱粮，在起运交付中央之外，地方留下部分作为开销，但要及时奏销。",
      "totalCount": 2630,
      "appLink": "weread://bestbookmark?bookId=3300197667&chapterUid=30&rangeStart=7652&rangeEnd=7687",
      "webLink": "https://weread.qq.com/web/reader/e8332cf0813abb3b6g01767c?chapterUid=30&rangeStart=7652&rangeEnd=7687"
    },
    {
      "bookmarkId": "3300197667_9_2963-3026",
      "chapterUid": 9,
      "range": "2963-3026",
      "markText": "范三拔生有五子，其中第三子范毓馪于康熙四十七年成为范氏生意的掌门人。",
      "totalCount": 2626,
      "appLink": "weread://bestbookmark?bookId=3300197667&chapterUid=9&rangeStart=2963&rangeEnd=3026",
      "webLink": "https://weread.qq.com/web/reader/e8332cf0813abb3b6g01767c?chapterUid=9&rangeStart=2963&rangeEnd=3026"
    },
    {
      "bookmarkId": "3300197667_21_4781-4808",
      "chapterUid": 21,
      "range": "4781-4808",
      "markText": "乾隆三十二年，达色由长芦盐政调任河东盐政。",
      "totalCount": 2613,
      "appLink": "weread://bestbookmark?bookId=3300197667&chapterUid=21&rangeStart=4781&rangeEnd=4808",
