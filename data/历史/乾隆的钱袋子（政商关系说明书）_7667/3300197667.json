    {
      "chapterUid": 4,
      "chapterTitle": "理性之外：朱轼遗奏与行盐难题",
      "items": [
        {
          "type": "highlight",
          "bookmarkId": "3300197667_4_3434-3468",
          "range": "3434-3468",
          "rangeStart": 3434,
          "rangeEnd": 3468,
          "markText": "朱轼在奏折中指出，盐政一事，上关国计，下系民生，时日一久，百弊丛生。",
          "colorStyle": 2,
          "colorLabel": "",
          "createTime": 1774973714,
          "createTimeFormatted": "2026-04-01 00:15:14",
          "chapterUid": 4,
