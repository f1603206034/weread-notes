  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300069206_3_1324-1364",
      "chapterUid": 3,
      "range": "1324-1364",
      "markText": "往事并不如烟，对于一个历史书写者来说，真相绝对不是我们书写的真正目的，人性才是。",
      "totalCount": 432,
      "appLink": "weread://bestbookmark?bookId=3300069206&chapterUid=3&rangeStart=1324&rangeEnd=1364",
      "webLink": "https://weread.qq.com/web/reader/75532cd0813ab8188g0165a9?chapterUid=3&rangeStart=1324&rangeEnd=1364"
    },
    {
      "bookmarkId": "3300069206_4_4489-4583",
      "chapterUid": 4,
      "range": "4489-4583",
      "markText": "利用谶语的效应鼓动民众造反这种计谋，数百年屡试不爽，甚至连手法都不变。历史是周而复始的转圈游戏，城头变幻大王旗。在人心浮动之际，这种不具有原创精神的游戏所带来的功效是那些堂皇说教的千万倍。",
      "totalCount": 408,
      "appLink": "weread://bestbookmark?bookId=3300069206&chapterUid=4&rangeStart=4489&rangeEnd=4583",
      "webLink": "https://weread.qq.com/web/reader/75532cd0813ab8188g0165a9?chapterUid=4&rangeStart=4489&rangeEnd=4583"
    },
    {
      "bookmarkId": "3300069206_4_627-669",
      "chapterUid": 4,
      "range": "627-669",
      "markText": "杀光那些毫无用处的中原人，使广袤的土地变成丰美的牧场，用来牧放征服世界所需要的战马。",
      "totalCount": 323,
      "appLink": "weread://bestbookmark?bookId=3300069206&chapterUid=4&rangeStart=627&rangeEnd=669",
      "webLink": "https://weread.qq.com/web/reader/75532cd0813ab8188g0165a9?chapterUid=4&rangeStart=627&rangeEnd=669"
    },
    {
      "bookmarkId": "3300069206_3_1024-1069",
      "chapterUid": 3,
      "range": "1024-1069",
      "markText": "我始终认为，一个连本民族历史都谈不上尊重的人，还能指望他对我们所生活的这个时代有所馈赠吗？",
      "totalCount": 315,
      "appLink": "weread://bestbookmark?bookId=3300069206&chapterUid=3&rangeStart=1024&rangeEnd=1069",
      "webLink": "https://weread.qq.com/web/reader/75532cd0813ab8188g0165a9?chapterUid=3&rangeStart=1024&rangeEnd=1069"
    },
    {
      "bookmarkId": "3300069206_4_17821-17844",
      "chapterUid": 4,
      "range": "17821-17844",
      "markText": "在残酷的世界里，唯有精神的强大才能让人活下去。",
      "totalCount": 310,
      "appLink": "weread://bestbookmark?bookId=3300069206&chapterUid=4&rangeStart=17821&rangeEnd=17844",
      "webLink": "https://weread.qq.com/web/reader/75532cd0813ab8188g0165a9?chapterUid=4&rangeStart=17821&rangeEnd=17844"
    },
    {
      "bookmarkId": "3300069206_4_3350-3402",
      "chapterUid": 4,
      "range": "3350-3402",
      "markText": "元朝从一开始就犯了致命的错误，它将人口最庞大的群体定义为“四等人”，这等于是为自己培养起最具潜力的对手。",
      "totalCount": 299,
      "appLink": "weread://bestbookmark?bookId=3300069206&chapterUid=4&rangeStart=3350&rangeEnd=3402",
      "webLink": "https://weread.qq.com/web/reader/75532cd0813ab8188g0165a9?chapterUid=4&rangeStart=3350&rangeEnd=3402"
    },
    {
      "bookmarkId": "3300069206_3_514-543",
      "chapterUid": 3,
      "range": "514-543",
      "markText": "英国历史学家卡尔说：“历史是现在与过去之间永无休止的对话。",
      "totalCount": 288,
      "appLink": "weread://bestbookmark?bookId=3300069206&chapterUid=3&rangeStart=514&rangeEnd=543",
      "webLink": "https://weread.qq.com/web/reader/75532cd0813ab8188g0165a9?chapterUid=3&rangeStart=514&rangeEnd=543"
    },
    {
      "bookmarkId": "3300069206_4_6631-6699",
