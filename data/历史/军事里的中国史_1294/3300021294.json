  "content": [
    {
      "chapterUid": 6,
      "chapterTitle": "第三章 烽火篇",
      "items": [
        {
          "type": "highlight",
          "bookmarkId": "3300021294_6_7771-7871",
          "range": "7771-7871",
          "rangeStart": 7771,
