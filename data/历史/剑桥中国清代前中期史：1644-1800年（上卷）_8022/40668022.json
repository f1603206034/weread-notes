    {
      "bookmarkId": "40668022_16_1372-1392",
      "chapterUid": 16,
      "range": "1372-1392",
      "markText": "在那时，成为猛哥帖木儿的后代是十分有利的",
      "totalCount": 72,
      "appLink": "weread://bestbookmark?bookId=40668022&chapterUid=16&rangeStart=1372&rangeEnd=1392",
