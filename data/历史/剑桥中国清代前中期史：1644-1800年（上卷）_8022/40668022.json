      "appLink": "weread://bestbookmark?bookId=40668022&chapterUid=27&rangeStart=2672&rangeEnd=2686",
      "webLink": "https://weread.qq.com/web/reader/c8932250726c8b76c896891?chapterUid=27&rangeStart=2672&rangeEnd=2686"
    },
    {
      "bookmarkId": "40668022_39_9050-9124",
      "chapterUid": 39,
      "range": "9050-9124",
      "markText": "田文镜看不起科甲人员，源自他与科甲官员和在野的士绅打交道的经验。田文镜认为政府应该由经过训练的管理者掌握，这些人不是醉心于儒家经典，而是“圣谕律条”",
      "totalCount": 56,
      "appLink": "weread://bestbookmark?bookId=40668022&chapterUid=39&rangeStart=9050&rangeEnd=9124",
      "webLink": "https://weread.qq.com/web/reader/c8932250726c8b76c896891?chapterUid=39&rangeStart=9050&rangeEnd=9124"
