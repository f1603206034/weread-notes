      "chapterUid": 6,
      "range": "3028-3059",
      "markText": "东方的丰饶，与最先进的西方技术相结合，会不会导致西方的没落呢？",
      "totalCount": 187,
      "appLink": "weread://bestbookmark?bookId=3300149062&chapterUid=6&rangeStart=3028&rangeEnd=3059",
      "webLink": "https://weread.qq.com/web/reader/82432980813aba0bag012d60?chapterUid=6&rangeStart=3028&rangeEnd=3059"
    },
    {
      "bookmarkId": "3300149062_12_1545-1831",
