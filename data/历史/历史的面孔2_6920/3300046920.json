      "appLink": "weread://bestbookmark?bookId=3300046920&chapterUid=9&rangeStart=5610&rangeEnd=5669",
      "webLink": "https://weread.qq.com/web/reader/af232d00813ab78d4g010f6f?chapterUid=9&rangeStart=5610&rangeEnd=5669"
