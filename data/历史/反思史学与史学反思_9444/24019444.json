    },
    {
      "bookmarkId": "24019444_55_2560-2798",
      "chapterUid": 55,
      "range": "2560-2798",
      "markText": "典范中国民族史造成许多人的“汉族中心主义”及“中国中心主义”,使得他们无法理性对待少数民族及日、韩、越、印等邻国之人。",
      "totalCount": 108,
      "appLink": "weread://bestbookmark?bookId=24019444&chapterUid=55&rangeStart=2560&rangeEnd=2798",
