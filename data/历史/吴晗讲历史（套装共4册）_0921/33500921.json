  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "33500921_4_949-989",
      "chapterUid": 4,
      "range": "949-989",
      "markText": "历史上的所谓亡国，就是指某一个家族的政权被推翻，国家还是存在的，人民还是存在的。",
      "totalCount": 221,
      "appLink": "weread://bestbookmark?bookId=33500921&chapterUid=4&rangeStart=949&rangeEnd=989",
      "webLink": "https://weread.qq.com/web/reader/12332a0071ff2ef9123f3c7?chapterUid=4&rangeStart=949&rangeEnd=989"
    },
    {
      "bookmarkId": "33500921_4_1015-1070",
      "chapterUid": 4,
      "range": "1015-1070",
      "markText": "这个国跟我们今天的中华人民共和国有本质的不同，它只代表一个家族、一个集团的利益，而不代表整个民族的共同的利益。",
