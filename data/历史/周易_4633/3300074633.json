  "hotBookmarks": [
    {
      "bookmarkId": "3300074633_39_7828-7871",
      "chapterUid": 39,
      "range": "7828-7871",
      "markText": "唯涉及方位的图未加翻转，读者当自知古人惯例，地图下北上南、左东右西，恰与今人习惯相反。",
      "totalCount": 70,
      "appLink": "weread://bestbookmark?bookId=3300074633&chapterUid=39&rangeStart=7828&rangeEnd=7871",
      "webLink": "https://weread.qq.com/web/reader/66632150813ab83a7g0131e1?chapterUid=39&rangeStart=7828&rangeEnd=7871"
    },
    {
      "bookmarkId": "3300074633_39_399-455",
      "chapterUid": 39,
      "range": "399-455",
      "markText": "两千多年以来，中国的读书人正式学习的教材都是儒家的经书。不同时期有五经、七经、十三经等提法，但《易经》总是其首。",
      "totalCount": 54,
      "appLink": "weread://bestbookmark?bookId=3300074633&chapterUid=39&rangeStart=399&rangeEnd=455",
      "webLink": "https://weread.qq.com/web/reader/66632150813ab83a7g0131e1?chapterUid=39&rangeStart=399&rangeEnd=455"
    },
    {
      "bookmarkId": "3300074633_4_456-475",
      "chapterUid": 4,
      "range": "456-475",
      "markText": "盈天地间莫非男女，则盈天地间莫非易矣。",
      "totalCount": 51,
      "appLink": "weread://bestbookmark?bookId=3300074633&chapterUid=4&rangeStart=456&rangeEnd=475",
      "webLink": "https://weread.qq.com/web/reader/66632150813ab83a7g0131e1?chapterUid=4&rangeStart=456&rangeEnd=475"
    },
    {
      "bookmarkId": "3300074633_18_445-454",
      "chapterUid": 18,
      "range": "445-454",
      "markText": "阳极于六，阴极于六",
      "totalCount": 45,
      "appLink": "weread://bestbookmark?bookId=3300074633&chapterUid=18&rangeStart=445&rangeEnd=454",
      "webLink": "https://weread.qq.com/web/reader/66632150813ab83a7g0131e1?chapterUid=18&rangeStart=445&rangeEnd=454"
    },
    {
      "bookmarkId": "3300074633_51_16750-16778",
      "chapterUid": 51,
      "range": "16750-16778",
      "markText": "盖乾以刚固为贞，坤以柔顺为贞，言如牝马之顺而不息则正矣。",
      "totalCount": 45,
      "appLink": "weread://bestbookmark?bookId=3300074633&chapterUid=51&rangeStart=16750&rangeEnd=16778",
      "webLink": "https://weread.qq.com/web/reader/66632150813ab83a7g0131e1?chapterUid=51&rangeStart=16750&rangeEnd=16778"
    },
    {
      "bookmarkId": "3300074633_52_1113-1161",
      "chapterUid": 52,
      "range": "1113-1161",
      "markText": "刚柔者，乾坤也。始交者，震也。一索得震，故为乾坤始交。难生者，坎也，言万物始生即遇坎难，故名为屯",
      "totalCount": 45,
      "appLink": "weread://bestbookmark?bookId=3300074633&chapterUid=52&rangeStart=1113&rangeEnd=1161",
      "webLink": "https://weread.qq.com/web/reader/66632150813ab83a7g0131e1?chapterUid=52&rangeStart=1113&rangeEnd=1161"
    },
    {
      "bookmarkId": "3300074633_4_370-391",
      "chapterUid": 4,
      "range": "370-391",
      "markText": "乾坤者，万物之男女也；男女者，一物之乾坤也",
      "totalCount": 44,
      "appLink": "weread://bestbookmark?bookId=3300074633&chapterUid=4&rangeStart=370&rangeEnd=391",
      "webLink": "https://weread.qq.com/web/reader/66632150813ab83a7g0131e1?chapterUid=4&rangeStart=370&rangeEnd=391"
    },
    {
      "bookmarkId": "3300074633_56_4453-4470",
      "chapterUid": 56,
      "range": "4453-4470",
      "markText": "刚健笃实，辉光日新，其德刚上而尚贤",
      "totalCount": 44,
      "appLink": "weread://bestbookmark?bookId=3300074633&chapterUid=56&rangeStart=4453&rangeEnd=4470",
      "webLink": "https://weread.qq.com/web/reader/66632150813ab83a7g0131e1?chapterUid=56&rangeStart=4453&rangeEnd=4470"
    },
    {
      "bookmarkId": "3300074633_51_5679-5688",
      "chapterUid": 51,
      "range": "5679-5688",
      "markText": "首出庶物，万国咸宁",
      "totalCount": 42,
      "appLink": "weread://bestbookmark?bookId=3300074633&chapterUid=51&rangeStart=5679&rangeEnd=5688",
      "webLink": "https://weread.qq.com/web/reader/66632150813ab83a7g0131e1?chapterUid=51&rangeStart=5679&rangeEnd=5688"
    },
    {
      "bookmarkId": "3300074633_39_763-847",
      "chapterUid": 39,
      "range": "763-847",
      "markText": "一部著作不外乎以叙事、说理或抒情中的一种表达为主，然后按一定的逻辑结构组合起来。比如《诗经》以抒情为主，是三百多首诗的集合；《春秋》以叙事为主，是二百多年间的大事记录。",
      "totalCount": 36,
      "appLink": "weread://bestbookmark?bookId=3300074633&chapterUid=39&rangeStart=763&rangeEnd=847",
      "webLink": "https://weread.qq.com/web/reader/66632150813ab83a7g0131e1?chapterUid=39&rangeStart=763&rangeEnd=847"
    },
    {
      "bookmarkId": "3300074633_39_7025-7041",
      "chapterUid": 39,
      "range": "7025-7041",
      "markText": "没有了应试，阅读的目的会纯洁许多",
      "totalCount": 36,
      "appLink": "weread://bestbookmark?bookId=3300074633&chapterUid=39&rangeStart=7025&rangeEnd=7041",
      "webLink": "https://weread.qq.com/web/reader/66632150813ab83a7g0131e1?chapterUid=39&rangeStart=7025&rangeEnd=7041"
    },
    {
      "bookmarkId": "3300074633_51_8125-8167",
      "chapterUid": 51,
      "range": "8125-8167",
      "markText": "不相妨害之谓利，利则必和，无所乖戾之谓和，和则必利。盖义公天下之利，本有自然之和也。",
      "totalCount": 36,
      "appLink": "weread://bestbookmark?bookId=3300074633&chapterUid=51&rangeStart=8125&rangeEnd=8167",
      "webLink": "https://weread.qq.com/web/reader/66632150813ab83a7g0131e1?chapterUid=51&rangeStart=8125&rangeEnd=8167"
    },
    {
      "bookmarkId": "3300074633_51_14526-14534",
      "chapterUid": 51,
      "range": "14526-14534",
      "markText": "利见大人，君德也",
      "totalCount": 36,
      "appLink": "weread://bestbookmark?bookId=3300074633&chapterUid=51&rangeStart=14526&rangeEnd=14534",
      "webLink": "https://weread.qq.com/web/reader/66632150813ab83a7g0131e1?chapterUid=51&rangeStart=14526&rangeEnd=14534"
    },
    {
      "bookmarkId": "3300074633_52_1472-1488",
      "chapterUid": 52,
      "range": "1472-1488",
      "markText": "勿用攸往非终不动也，审而后动也。",
      "totalCount": 36,
      "appLink": "weread://bestbookmark?bookId=3300074633&chapterUid=52&rangeStart=1472&rangeEnd=1488",
      "webLink": "https://weread.qq.com/web/reader/66632150813ab83a7g0131e1?chapterUid=52&rangeStart=1472&rangeEnd=1488"
    },
    {
      "bookmarkId": "3300074633_52_5178-5187",
      "chapterUid": 52,
      "range": "5178-5187",
      "markText": "蒙以养正，圣功也。",
      "totalCount": 36,
      "appLink": "weread://bestbookmark?bookId=3300074633&chapterUid=52&rangeStart=5178&rangeEnd=5187",
      "webLink": "https://weread.qq.com/web/reader/66632150813ab83a7g0131e1?chapterUid=52&rangeStart=5178&rangeEnd=5187"
    },
    {
      "bookmarkId": "3300074633_52_5332-5351",
      "chapterUid": 52,
      "range": "5332-5351",
      "markText": "匪我求童蒙，童蒙求我，乃教人之正道也。",
      "totalCount": 36,
      "appLink": "weread://bestbookmark?bookId=3300074633&chapterUid=52&rangeStart=5332&rangeEnd=5351",
      "webLink": "https://weread.qq.com/web/reader/66632150813ab83a7g0131e1?chapterUid=52&rangeStart=5332&rangeEnd=5351"
    },
    {
      "bookmarkId": "3300074633_52_7416-7425",
      "chapterUid": 52,
      "range": "7416-7425",
      "markText": "勿用取女，行不顺也",
      "totalCount": 36,
      "appLink": "weread://bestbookmark?bookId=3300074633&chapterUid=52&rangeStart=7416&rangeEnd=7425",
      "webLink": "https://weread.qq.com/web/reader/66632150813ab83a7g0131e1?chapterUid=52&rangeStart=7416&rangeEnd=7425"
    },
    {
      "bookmarkId": "3300074633_54_18816-18830",
      "chapterUid": 54,
      "range": "18816-18830",
      "markText": "甲居于寅，坤在上，乾在下为泰",
      "totalCount": 36,
      "appLink": "weread://bestbookmark?bookId=3300074633&chapterUid=54&rangeStart=18816&rangeEnd=18830",
      "webLink": "https://weread.qq.com/web/reader/66632150813ab83a7g0131e1?chapterUid=54&rangeStart=18816&rangeEnd=18830"
    },
    {
      "bookmarkId": "3300074633_34_1610-1639",
      "chapterUid": 34,
      "range": "1610-1639",
      "markText": "凡人之知属气属魂，凡人之能属形属魄。故乾以知言，坤以能言也",
      "totalCount": 34,
      "appLink": "weread://bestbookmark?bookId=3300074633&chapterUid=34&rangeStart=1610&rangeEnd=1639",
      "webLink": "https://weread.qq.com/web/reader/66632150813ab83a7g0131e1?chapterUid=34&rangeStart=1610&rangeEnd=1639"
    },
    {
      "bookmarkId": "3300074633_39_1162-1239",
      "chapterUid": 39,
      "range": "1162-1239",
      "markText": "产生《易经》的年代，占卜不是游戏，不是迷信，它是严肃的，对国家、社会具有性命攸关的重要作用，所以，《易经》这样的占卜书显然倾注了几代、几十代精英的最高智慧",
      "totalCount": 34,
      "appLink": "weread://bestbookmark?bookId=3300074633&chapterUid=39&rangeStart=1162&rangeEnd=1239",
