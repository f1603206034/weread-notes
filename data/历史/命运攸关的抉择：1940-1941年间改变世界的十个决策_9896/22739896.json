  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "22739896_4_3138-3156",
      "chapterUid": 4,
      "range": "3138-3156",
      "markText": "昭和的意思是“百姓昭明，协和万邦”。",
      "totalCount": 198,
      "appLink": "weread://bestbookmark?bookId=22739896&chapterUid=4&rangeStart=3138&rangeEnd=3156",
      "webLink": "https://weread.qq.com/web/reader/8b932f80715afbb88b9f6a5?chapterUid=4&rangeStart=3138&rangeEnd=3156"
    },
    {
      "bookmarkId": "22739896_11_67148-67191",
      "chapterUid": 11,
      "range": "67148-67191",
      "markText": "苏联的政治体系当中，无论哪一级都已经习惯于只向苏联独裁者提供那些能证实他的判断的信息。",
      "totalCount": 180,
      "appLink": "weread://bestbookmark?bookId=22739896&chapterUid=11&rangeStart=67148&rangeEnd=67191",
      "webLink": "https://weread.qq.com/web/reader/8b932f80715afbb88b9f6a5?chapterUid=11&rangeStart=67148&rangeEnd=67191"
    },
    {
      "bookmarkId": "22739896_6_24646-24712",
      "chapterUid": 6,
      "range": "24646-24712",
      "markText": "希特勒和伦斯德探讨了前线局势，随后下令装甲部队停止前进，不再继续向敦刻尔克进攻。这个决定后来被视为错失全歼英国远征军战机的关键失误。",
      "totalCount": 170,
      "appLink": "weread://bestbookmark?bookId=22739896&chapterUid=6&rangeStart=24646&rangeEnd=24712",
      "webLink": "https://weread.qq.com/web/reader/8b932f80715afbb88b9f6a5?chapterUid=6&rangeStart=24646&rangeEnd=24712"
    },
    {
      "bookmarkId": "22739896_7_30089-30133",
      "chapterUid": 7,
      "range": "30089-30133",
      "markText": "这份备忘录不仅狂妄至极，而且告诉我们，在德国的精英领导层当中，不仅仅只有希特勒才是狂人。",
      "totalCount": 162,
      "appLink": "weread://bestbookmark?bookId=22739896&chapterUid=7&rangeStart=30089&rangeEnd=30133",
      "webLink": "https://weread.qq.com/web/reader/8b932f80715afbb88b9f6a5?chapterUid=7&rangeStart=30089&rangeEnd=30133"
    },
    {
      "bookmarkId": "22739896_9_71906-71987",
      "chapterUid": 9,
      "range": "71906-71987",
      "markText": "意大利在军事上原本的主攻方向应该是面对力量薄弱的英军，扫荡整个埃及直至征服苏伊士运河。现在它被完全不必要的希腊冒险所拖累。这是意大利的头号战略错误，而且代价惨重。",
      "totalCount": 160,
      "appLink": "weread://bestbookmark?bookId=22739896&chapterUid=9&rangeStart=71906&rangeEnd=71987",
      "webLink": "https://weread.qq.com/web/reader/8b932f80715afbb88b9f6a5?chapterUid=9&rangeStart=71906&rangeEnd=71987"
    },
    {
      "bookmarkId": "22739896_3_584-649",
      "chapterUid": 3,
      "range": "584-649",
      "markText": "1941年最著名的重大事件包括德国入侵苏联（还导致纳粹对犹太人的杀戮迅速升级为全面的种族屠杀）、日本袭击珍珠港和美国参加欧洲战争。",
      "totalCount": 150,
      "appLink": "weread://bestbookmark?bookId=22739896&chapterUid=3&rangeStart=584&rangeEnd=649",
      "webLink": "https://weread.qq.com/web/reader/8b932f80715afbb88b9f6a5?chapterUid=3&rangeStart=584&rangeEnd=649"
    },
    {
      "bookmarkId": "22739896_9_42697-42738",
      "chapterUid": 9,
      "range": "42697-42738",
      "markText": "其实，后来的事实表明，意大利如果保持中立，德国少了个猪一样的队友，对德国可能更好。",
      "totalCount": 140,
      "appLink": "weread://bestbookmark?bookId=22739896&chapterUid=9&rangeStart=42697&rangeEnd=42738",
      "webLink": "https://weread.qq.com/web/reader/8b932f80715afbb88b9f6a5?chapterUid=9&rangeStart=42697&rangeEnd=42738"
    },
    {
      "bookmarkId": "22739896_11_88839-88895",
      "chapterUid": 11,
      "range": "88839-88895",
      "markText": "我们只知道，斯大林的选择招致了灾难。而苏联后来能够令人惊讶地从那场灾难中恢复过来，那就是另一个完全不同的故事了。",
      "totalCount": 140,
      "appLink": "weread://bestbookmark?bookId=22739896&chapterUid=11&rangeStart=88839&rangeEnd=88895",
      "webLink": "https://weread.qq.com/web/reader/8b932f80715afbb88b9f6a5?chapterUid=11&rangeStart=88839&rangeEnd=88895"
    },
    {
      "bookmarkId": "22739896_9_60253-60288",
      "chapterUid": 9,
      "range": "60253-60288",
      "markText": "一个命运攸关的重要抉择就这样在恼怒和自尊心受伤害的情况下匆匆做出来了。",
      "totalCount": 128,
      "appLink": "weread://bestbookmark?bookId=22739896&chapterUid=9&rangeStart=60253&rangeEnd=60288",
      "webLink": "https://weread.qq.com/web/reader/8b932f80715afbb88b9f6a5?chapterUid=9&rangeStart=60253&rangeEnd=60288"
    },
    {
      "bookmarkId": "22739896_8_46020-46204",
      "chapterUid": 8,
      "range": "46020-46204",
      "markText": "日本的领导人觉察到国家正处于转折点，他们面临着命运攸关的抉择。对他们来说，要么是向美国长期的统治地位屈膝投降，要么是为了对抗美国，采取不可逆转且危险重重的措施，并面对无法预见的后果。他们选择了后者。",
      "totalCount": 126,
      "appLink": "weread://bestbookmark?bookId=22739896&chapterUid=8&rangeStart=46020&rangeEnd=46204",
      "webLink": "https://weread.qq.com/web/reader/8b932f80715afbb88b9f6a5?chapterUid=8&rangeStart=46020&rangeEnd=46204"
    },
    {
      "bookmarkId": "22739896_9_46090-46144",
      "chapterUid": 9,
      "range": "46090-46144",
      "markText": "6月底，内定指挥利比亚攻势的巴尔博元帅乘坐飞机在托布鲁克附近被自己军队的高射炮击落身亡，这可无助于发动进攻。",
      "totalCount": 126,
      "appLink": "weread://bestbookmark?bookId=22739896&chapterUid=9&rangeStart=46090&rangeEnd=46144",
      "webLink": "https://weread.qq.com/web/reader/8b932f80715afbb88b9f6a5?chapterUid=9&rangeStart=46090&rangeEnd=46144"
    },
    {
      "bookmarkId": "22739896_11_23954-23976",
      "chapterUid": 11,
      "range": "23954-23976",
      "markText": "一次历史上最为臭名昭著的外交行动很快就完成了",
      "totalCount": 120,
      "appLink": "weread://bestbookmark?bookId=22739896&chapterUid=11&rangeStart=23954&rangeEnd=23976",
      "webLink": "https://weread.qq.com/web/reader/8b932f80715afbb88b9f6a5?chapterUid=11&rangeStart=23954&rangeEnd=23976"
    },
    {
      "bookmarkId": "22739896_9_65523-65608",
      "chapterUid": 9,
      "range": "65523-65608",
      "markText": "他们以为的独裁者的果断坚决其实完全是薄薄一层面纱之下掩盖的自我陶醉、肤浅的观察、业余的判断力以及完全缺乏批判精神的估计，而这一切都建立在一厢情愿的发生最好情况的假设之上。",
      "totalCount": 108,
      "appLink": "weread://bestbookmark?bookId=22739896&chapterUid=9&rangeStart=65523&rangeEnd=65608",
      "webLink": "https://weread.qq.com/web/reader/8b932f80715afbb88b9f6a5?chapterUid=9&rangeStart=65523&rangeEnd=65608"
    },
    {
      "bookmarkId": "22739896_10_47156-47221",
      "chapterUid": 10,
      "range": "47156-47221",
      "markText": "在此之前，为了不让法国舰队落入纳粹之手，英国于7月3日进攻并摧毁了锚泊在阿尔及利亚凯比尔港的法国舰队，导致1297名法国水兵阵亡。",
