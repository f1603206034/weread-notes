      "chapterUid": 4,
      "range": "1000-1018",
      "markText": "此显然即龟兹苏祗婆西域传来七调之一。",
      "totalCount": 34,
      "appLink": "weread://bestbookmark?bookId=3300172819&chapterUid=4&rangeStart=1000&rangeEnd=1018",
