  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "661145_4_2540-2568",
      "chapterUid": 4,
      "range": "2540-2568",
      "markText": "人民，不可以和他们谋划事业的开端，只能够和他们欢庆成功。",
      "totalCount": 1479,
      "appLink": "weread://bestbookmark?bookId=661145&chapterUid=4&rangeStart=2540&rangeEnd=2568",
      "webLink": "https://weread.qq.com/web/reader/45f32c205a169945fda42bb?chapterUid=4&rangeStart=2540&rangeEnd=2568"
    },
    {
      "bookmarkId": "661145_5_4568-4668",
      "chapterUid": 5,
      "range": "4568-4668",
      "markText": "不准音乐和异服在各郡县流行，农民外出劳作时就不会看见奇装异服，休息时听不到靡靡之音。休息时听不到靡靡之音，精神就不会浮荡。劳作时看不见奇装异服，心思就会专一。心思专一而不浮荡，荒地就一定能得到开垦了。",
      "totalCount": 1390,
      "appLink": "weread://bestbookmark?bookId=661145&chapterUid=5&rangeStart=4568&rangeEnd=4668",
      "webLink": "https://weread.qq.com/web/reader/45f32c205a169945fda42bb?chapterUid=5&rangeStart=4568&rangeEnd=4668"
    },
    {
      "bookmarkId": "661145_4_1835-1890",
      "chapterUid": 4,
      "range": "1835-1890",
      "markText": "愚者暗⑤于成事，知者见于未萌。民不可与虑始，而可与乐成。",
      "totalCount": 1368,
      "appLink": "weread://bestbookmark?bookId=661145&chapterUid=4&rangeStart=1835&rangeEnd=1890",
      "webLink": "https://weread.qq.com/web/reader/45f32c205a169945fda42bb?chapterUid=4&rangeStart=1835&rangeEnd=1890"
    },
    {
      "bookmarkId": "661145_5_3925-3963",
      "chapterUid": 5,
      "range": "3925-3963",
      "markText": "商人不得卖粮食，农民不得买粮食。农民不得买粮食，懒惰的农民就会努力积极务农。",
      "totalCount": 1224,
      "appLink": "weread://bestbookmark?bookId=661145&chapterUid=5&rangeStart=3925&rangeEnd=3963",
      "webLink": "https://weread.qq.com/web/reader/45f32c205a169945fda42bb?chapterUid=5&rangeStart=3925&rangeEnd=3963"
    },
    {
      "bookmarkId": "661145_5_5728-5784",
      "chapterUid": 5,
      "range": "5728-5784",
      "markText": "禁止开设旅馆，奸邪伪诈、见异思迁、私下交游、不专心务农的人就不会四处周游，开旅馆的人就没法谋生，他们必然会去务农",
      "totalCount": 1134,
      "appLink": "weread://bestbookmark?bookId=661145&chapterUid=5&rangeStart=5728&rangeEnd=5784",
      "webLink": "https://weread.qq.com/web/reader/45f32c205a169945fda42bb?chapterUid=5&rangeStart=5728&rangeEnd=5784"
    },
    {
      "bookmarkId": "661145_5_9728-9798",
      "chapterUid": 5,
      "range": "9728-9798",
      "markText": "农民没有地方听到奇谈怪论，那么有智慧的农民无法脱离原本从事的农业，愚昧的农民就会无知，不喜欢学问。愚昧的农民无知，不喜欢学问，就会积极务农。",
      "totalCount": 1080,
      "appLink": "weread://bestbookmark?bookId=661145&chapterUid=5&rangeStart=9728&rangeEnd=9798",
      "webLink": "https://weread.qq.com/web/reader/45f32c205a169945fda42bb?chapterUid=5&rangeStart=9728&rangeEnd=9798"
    },
    {
      "bookmarkId": "661145_5_2626-2712",
      "chapterUid": 5,
      "range": "2626-2712",
      "markText": "不因为务农以外的事情来给人封爵加官，那样百姓就不会重视学问，也不会轻视农业生产。百姓不重视学问，就会愚昧，百姓愚昧，就不会到外国交游。百姓不到外国交游，国家就安全没有危险。",
      "totalCount": 1045,
      "appLink": "weread://bestbookmark?bookId=661145&chapterUid=5&rangeStart=2626&rangeEnd=2712",
      "webLink": "https://weread.qq.com/web/reader/45f32c205a169945fda42bb?chapterUid=5&rangeStart=2626&rangeEnd=2712"
    },
    {
      "bookmarkId": "661145_5_5204-5286",
      "chapterUid": 5,
      "range": "5204-5286",
      "markText": "不准雇用佣工，卿、大夫家长就没有办法雇人建筑修缮房屋，他们娇生惯养的儿女就无法不劳而食，懒惰的人也不能偷懒，靠给人作佣工生活的人就没处混饭吃，这样他们就必然去务农。",
      "totalCount": 1026,
      "appLink": "weread://bestbookmark?bookId=661145&chapterUid=5&rangeStart=5204&rangeEnd=5286",
      "webLink": "https://weread.qq.com/web/reader/45f32c205a169945fda42bb?chapterUid=5&rangeStart=5204&rangeEnd=5286"
    },
    {
      "bookmarkId": "661145_6_4553-4586",
      "chapterUid": 6,
      "range": "4553-4586",
      "markText": "善于治国的国君，任命官吏的制度严明，所以不任用有智慧和懂谋略的人。",
