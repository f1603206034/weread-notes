    {
      "bookmarkId": "3300199279_59_1713-1785",
      "chapterUid": 59,
      "range": "1713-1785",
      "markText": "美国研究革命现象的著名学者詹隼（Chalmers Johnson）称：“19世纪与20世纪的中国革命，是所有历史个案中最大且最复杂的革命样本。”",
      "totalCount": 131,
      "appLink": "weread://bestbookmark?bookId=3300199279&chapterUid=59&rangeStart=1713&rangeEnd=1785",
      "webLink": "https://weread.qq.com/web/reader/00c325e0813abb457g019824?chapterUid=59&rangeStart=1713&rangeEnd=1785"
    },
    {
      "bookmarkId": "3300199279_24_12518-12549",
      "chapterUid": 24,
      "range": "12518-12549",
