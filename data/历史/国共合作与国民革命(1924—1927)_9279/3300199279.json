      "chapterUid": 50,
      "range": "18312-18351",
      "markText": "1926年12月时，月需军饷564万余元，到1927年4月增至1189万余元。",
      "totalCount": 131,
      "appLink": "weread://bestbookmark?bookId=3300199279&chapterUid=50&rangeStart=18312&rangeEnd=18351",
