      "chapterUid": 6,
      "range": "385-413",
      "markText": "太平天国运动(1851—1864)是世界上最糟的一场内战",
      "totalCount": 252,
      "appLink": "weread://bestbookmark?bookId=3300037348&chapterUid=6&rangeStart=385&rangeEnd=413",
