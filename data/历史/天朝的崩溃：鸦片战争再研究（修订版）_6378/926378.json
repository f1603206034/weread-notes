    {
      "bookmarkId": "926378_49_26793-26827",
      "chapterUid": 49,
      "range": "26793-26827",
      "markText": "历史学家这种不服输的心气，从本质上说来，仍是对多灾多难的祖国的挚爱。",
      "totalCount": 2528,
      "appLink": "weread://bestbookmark?bookId=926378&chapterUid=49&rangeStart=26793&rangeEnd=26827",
