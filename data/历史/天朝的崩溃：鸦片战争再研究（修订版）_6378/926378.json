          "range": "334-370",
          "rangeStart": 334,
          "rangeEnd": 370,
          "markText": "中国的历史学，最注重人物评价。打开史籍，善恶忠奸分明，好人坏人一目了然。",
          "colorStyle": 2,
          "colorLabel": "",
          "createTime": 1742559123,
          "createTimeFormatted": "2025-03-21 20:12:03",
          "chapterUid": 49,
          "appLink": "weread://bestbookmark?bookId=926378&chapterUid=49&rangeStart=334&rangeEnd=370",
          "webLink": "https://weread.qq.com/web/reader/68c32bf05e22aa68c605298?chapterUid=49&rangeStart=334&rangeEnd=370"
        },
        {
          "type": "highlight",
          "bookmarkId": "926378_49_29207-29239",
          "range": "29207-29239",
          "rangeStart": 29207,
          "rangeEnd": 29239,
