    {
      "bookmarkId": "793635_1_1450-1500",
      "chapterUid": 1,
      "range": "1450-1500",
      "markText": "如此清靜，漸入真道。既入真道，名為得道。雖名得道，實無所得。為化眾生，名為得道。能悟之者，可傳聖道。",
      "totalCount": 375,
      "appLink": "weread://bestbookmark?bookId=793635&chapterUid=1&rangeStart=1450&rangeEnd=1500",
      "webLink": "https://weread.qq.com/web/reader/fc1325b05c1c23fc15e674e?chapterUid=1&rangeStart=1450&rangeEnd=1500"
    },
    {
      "bookmarkId": "793635_1_376-388",
      "chapterUid": 1,
      "range": "376-388",
      "markText": "人能常清靜，天地悉皆歸。",
