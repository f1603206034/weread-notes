      "appLink": "weread://bestbookmark?bookId=793635&chapterUid=1&rangeStart=1657&rangeEnd=1691",
      "webLink": "https://weread.qq.com/web/reader/fc1325b05c1c23fc15e674e?chapterUid=1&rangeStart=1657&rangeEnd=1691"
