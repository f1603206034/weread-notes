  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "24274999_3_1916-1953",
      "chapterUid": 3,
      "range": "1916-1953",
      "markText": "年轻的学子应当学习写书评，通过纯学术的批评，矫正学术失范，使学术正常发展。",
      "totalCount": 150,
      "appLink": "weread://bestbookmark?bookId=24274999&chapterUid=3&rangeStart=1916&rangeEnd=1953",
      "webLink": "https://weread.qq.com/web/reader/30f32c907172683730f904c?chapterUid=3&rangeStart=1916&rangeEnd=1953"
    },
    {
      "bookmarkId": "24274999_4_820-859",
      "chapterUid": 4,
      "range": "820-859",
      "markText": "要做某一项历史研究之前，最重要的工作是阅读、检索历史文献，从中找到第一手材料。",
      "totalCount": 84,
      "appLink": "weread://bestbookmark?bookId=24274999&chapterUid=4&rangeStart=820&rangeEnd=859",
      "webLink": "https://weread.qq.com/web/reader/30f32c907172683730f904c?chapterUid=4&rangeStart=820&rangeEnd=859"
    },
    {
      "bookmarkId": "24274999_6_3951-4040",
      "chapterUid": 6,
      "range": "3951-4040",
      "markText": "季羡林先生在写作《糖史》的时候，每天都去图书馆古籍部翻看《四库全书》，抄录有关史料。在某种意义上讲，这是有象征意义的，表示学问就要这么做，即虽然只是收集糖史的材料，也要竭泽而渔。",
      "totalCount": 72,
      "appLink": "weread://bestbookmark?bookId=24274999&chapterUid=6&rangeStart=3951&rangeEnd=4040",
      "webLink": "https://weread.qq.com/web/reader/30f32c907172683730f904c?chapterUid=6&rangeStart=3951&rangeEnd=4040"
    },
    {
      "bookmarkId": "24274999_5_629-698",
      "chapterUid": 5,
      "range": "629-698",
      "markText": "《汉书·艺文志》既是我们奠定古籍目录学的基础，又是建立中国古代典籍基本构成的知识架构的必经途径，每个研究中国历史和传统文化的人都应当熟悉。",
      "totalCount": 70,
      "appLink": "weread://bestbookmark?bookId=24274999&chapterUid=5&rangeStart=629&rangeEnd=698",
      "webLink": "https://weread.qq.com/web/reader/30f32c907172683730f904c?chapterUid=5&rangeStart=629&rangeEnd=698"
    },
    {
      "bookmarkId": "24274999_3_763-808",
      "chapterUid": 3,
      "range": "763-808",
      "markText": "一方面要继续积累专业方面的知识，另一方面就要开始进行专业的学术训练，为撰写学术论文做准备。",
      "totalCount": 68,
      "appLink": "weread://bestbookmark?bookId=24274999&chapterUid=3&rangeStart=763&rangeEnd=808",
      "webLink": "https://weread.qq.com/web/reader/30f32c907172683730f904c?chapterUid=3&rangeStart=763&rangeEnd=808"
    },
    {
      "bookmarkId": "24274999_60_3413-3510",
      "chapterUid": 60,
      "range": "3413-3510",
      "markText": "在中国书评体制不健全的情况下，一旦一个作者的书受到批评，有时会被某些人利用这些书评来攻击作者，使得作者的职称评不上，甚至分配房子、提升工资也受影响。有时再加上报纸、网站的炒作，使得问题更加复杂。",
      "totalCount": 64,
      "appLink": "weread://bestbookmark?bookId=24274999&chapterUid=60&rangeStart=3413&rangeEnd=3510",
      "webLink": "https://weread.qq.com/web/reader/30f32c907172683730f904c?chapterUid=60&rangeStart=3413&rangeEnd=3510"
    },
    {
      "bookmarkId": "24274999_3_1048-1110",
      "chapterUid": 3,
      "range": "1048-1110",
      "markText": "文章的写作除了要遵守学术道德规范，也要遵守技术规范，标点符号都要准确到位，注释体例得当，参考文献便于查找，外语专名翻译准确。",
      "totalCount": 56,
      "appLink": "weread://bestbookmark?bookId=24274999&chapterUid=3&rangeStart=1048&rangeEnd=1110",
      "webLink": "https://weread.qq.com/web/reader/30f32c907172683730f904c?chapterUid=3&rangeStart=1048&rangeEnd=1110"
    },
    {
      "bookmarkId": "24274999_4_928-970",
      "chapterUid": 4,
      "range": "928-970",
      "markText": "中国古籍的构成，主要是经史子集四部，加上丛书、类书、释道书，这其中有些部分是重复的。",
      "totalCount": 54,
      "appLink": "weread://bestbookmark?bookId=24274999&chapterUid=4&rangeStart=928&rangeEnd=970",
      "webLink": "https://weread.qq.com/web/reader/30f32c907172683730f904c?chapterUid=4&rangeStart=928&rangeEnd=970"
    },
    {
      "bookmarkId": "24274999_5_1893-1912",
      "chapterUid": 5,
      "range": "1893-1912",
      "markText": "出土的简帛古书反映的情况是基本吻合的。",
      "totalCount": 54,
      "appLink": "weread://bestbookmark?bookId=24274999&chapterUid=5&rangeStart=1893&rangeEnd=1912",
      "webLink": "https://weread.qq.com/web/reader/30f32c907172683730f904c?chapterUid=5&rangeStart=1893&rangeEnd=1912"
    },
    {
      "bookmarkId": "24274999_26_426-459",
      "chapterUid": 26,
      "range": "426-459",
      "markText": "在翻看一种书之前，最好先了解这部书的版本情况，选用最好的版本来看。",
      "totalCount": 54,
      "appLink": "weread://bestbookmark?bookId=24274999&chapterUid=26&rangeStart=426&rangeEnd=459",
      "webLink": "https://weread.qq.com/web/reader/30f32c907172683730f904c?chapterUid=26&rangeStart=426&rangeEnd=459"
    },
    {
      "bookmarkId": "24274999_51_708-761",
      "chapterUid": 51,
      "range": "708-761",
      "markText": "博硕士论文题目最应当注意的一点是，要在写作之前就考虑好你的论题要有所限制，以便在规定的时间里完成全部论文。",
