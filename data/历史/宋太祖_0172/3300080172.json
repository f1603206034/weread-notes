      "totalCount": 54,
      "appLink": "weread://bestbookmark?bookId=3300080172&chapterUid=4&rangeStart=3282&rangeEnd=3369",
      "webLink": "https://weread.qq.com/web/reader/2ba326f0813ab85d1g012986?chapterUid=4&rangeStart=3282&rangeEnd=3369"
    },
    {
