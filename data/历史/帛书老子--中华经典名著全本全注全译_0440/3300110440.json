  "content": [
    {
      "chapterUid": 84,
      "chapterTitle": "三十六章（王本三十六章）",
      "items": [
        {
          "type": "highlight",
          "bookmarkId": "3300110440_84_5396-5424",
          "range": "5396-5424",
          "rangeStart": 5396,
          "rangeEnd": 5424,
          "markText": "是谓微明，柔弱胜刚强。鱼不可脱于渊，国之利器不可以示人。",
          "colorStyle": 0,
          "colorLabel": "",
          "createTime": 1735530281,
          "createTimeFormatted": "2024-12-30 11:44:41",
          "chapterUid": 84,
          "appLink": "weread://bestbookmark?bookId=3300110440&chapterUid=84&rangeStart=5396&rangeEnd=5424",
          "webLink": "https://weread.qq.com/web/reader/083323d0813ab91a4g010850?chapterUid=84&rangeStart=5396&rangeEnd=5424"
        },
        {
          "type": "highlight",
          "bookmarkId": "3300110440_84_3566-3923",
          "range": "3566-3923",
          "rangeStart": 3566,
          "rangeEnd": 3923,
          "markText": "将欲歙之￼，必固张之￼；将欲弱之，必固强之；将欲废之，必固兴之￼；将欲夺之，必固与之。",
          "colorStyle": 0,
