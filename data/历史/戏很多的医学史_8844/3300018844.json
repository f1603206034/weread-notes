    },
    {
      "bookmarkId": "3300018844_23_16432-16493",
      "chapterUid": 23,
      "range": "16432-16493",
      "markText": "一个德国医生福斯曼干了一件匪夷所思的事儿。那就是用一个导尿管，插进自己的血管里。而且一寸一寸地往前推，一直推到了心脏部位。",
      "totalCount": 1044,
      "appLink": "weread://bestbookmark?bookId=3300018844&chapterUid=23&rangeStart=16432&rangeEnd=16493",
      "webLink": "https://weread.qq.com/web/reader/41432a60813ab6ddcg01417f?chapterUid=23&rangeStart=16432&rangeEnd=16493"
    },
    {
