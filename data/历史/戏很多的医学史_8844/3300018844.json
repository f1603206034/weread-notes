    {
      "bookmarkId": "3300018844_3_964-1004",
      "chapterUid": 3,
      "range": "964-1004",
      "markText": "大家知道为什么给孩子过百日会那么重要吗？因为活过100天，大概这孩子算是留住了。",
      "totalCount": 1339,
      "appLink": "weread://bestbookmark?bookId=3300018844&chapterUid=3&rangeStart=964&rangeEnd=1004",
