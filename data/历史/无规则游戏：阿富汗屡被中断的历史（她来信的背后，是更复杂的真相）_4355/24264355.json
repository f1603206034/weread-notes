    {
      "bookmarkId": "24264355_85_9610-9693",
      "chapterUid": 85,
      "range": "9610-9693",
      "markText": "阿拉伯语中，学生被称为“塔利布”(Talib)，一群学生就是“塔利班”(Taliban)。所以，这个词起初并不是政党或运动的名称，只是描述了奥马尔及其同伴的学生身份。",
      "totalCount": 1258,
      "appLink": "weread://bestbookmark?bookId=24264355&chapterUid=85&rangeStart=9610&rangeEnd=9693",
