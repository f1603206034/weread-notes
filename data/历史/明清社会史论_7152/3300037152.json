  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300037152_26_723-779",
      "chapterUid": 26,
      "range": "723-779",
      "markText": "这一方面证实竞争性的科举考试制度确能平衡社会地位；一方面也呈现那些富有的和拥有高地位的家族，无法长期维持其地位。",
      "totalCount": 102,
      "appLink": "weread://bestbookmark?bookId=3300037152&chapterUid=26&rangeStart=723&rangeEnd=779",
      "webLink": "https://weread.qq.com/web/reader/ad432b40813ab7503g01289c?chapterUid=26&rangeStart=723&rangeEnd=779"
    },
    {
      "bookmarkId": "3300037152_13_4388-4458",
      "chapterUid": 13,
      "range": "4388-4458",
      "markText": "因此，在人数庞大的平民之中，有许多来自各种功能体系的精英(elite)被区分出来；传统中国社会阶层中，从未只有统治与被统治者两个极化的阶层。",
      "totalCount": 75,
      "appLink": "weread://bestbookmark?bookId=3300037152&chapterUid=13&rangeStart=4388&rangeEnd=4458",
      "webLink": "https://weread.qq.com/web/reader/ad432b40813ab7503g01289c?chapterUid=13&rangeStart=4388&rangeEnd=4458"
    },
    {
      "bookmarkId": "3300037152_13_1078-1130",
      "chapterUid": 13,
      "range": "1078-1130",
      "markText": "但审判之先，总要举行一个重要的典礼，剥夺他们的官品；于是在理论上，他们的地位已降为平民，这样才能进行审判",
      "totalCount": 68,
      "appLink": "weread://bestbookmark?bookId=3300037152&chapterUid=13&rangeStart=1078&rangeEnd=1130",
      "webLink": "https://weread.qq.com/web/reader/ad432b40813ab7503g01289c?chapterUid=13&rangeStart=1078&rangeEnd=1130"
    },
    {
      "bookmarkId": "3300037152_12_5876-5947",
      "chapterUid": 12,
      "range": "5876-5947",
      "markText": "他们一面拥护阶级社会，一面经由教育带来社会平等，推倒其天生的不公正，这就是为什么儒家社会意识能超越封建的界限，在封建制度崩溃后尚能长存的原因。",
      "totalCount": 64,
      "appLink": "weread://bestbookmark?bookId=3300037152&chapterUid=12&rangeStart=5876&rangeEnd=5947",
      "webLink": "https://weread.qq.com/web/reader/ad432b40813ab7503g01289c?chapterUid=12&rangeStart=5876&rangeEnd=5947"
    },
    {
      "bookmarkId": "3300037152_12_6424-6471",
      "chapterUid": 12,
      "range": "6424-6471",
      "markText": "因此，统治与被统治阶级间清晰的界线，取决于个人的成就与德性，完全地正当化了阶级社会的继续存在。",
      "totalCount": 64,
      "appLink": "weread://bestbookmark?bookId=3300037152&chapterUid=12&rangeStart=6424&rangeEnd=6471",
      "webLink": "https://weread.qq.com/web/reader/ad432b40813ab7503g01289c?chapterUid=12&rangeStart=6424&rangeEnd=6471"
    },
    {
      "bookmarkId": "3300037152_12_15647-15738",
      "chapterUid": 12,
      "range": "15647-15738",
      "markText": "虽然各家均了解在权利不平等的社会中，社会公平的重要，但只有儒家根本地碰触到问题的核心，因为孔子的门徒不只关注建立基于贤才来决定个人社会地位的观念，而且还为寒微之士创造公正的机缘结构。",
      "totalCount": 64,
      "appLink": "weread://bestbookmark?bookId=3300037152&chapterUid=12&rangeStart=15647&rangeEnd=15738",
      "webLink": "https://weread.qq.com/web/reader/ad432b40813ab7503g01289c?chapterUid=12&rangeStart=15647&rangeEnd=15738"
    },
    {
      "bookmarkId": "3300037152_14_10989-11074",
      "chapterUid": 14,
      "range": "10989-11074",
      "markText": "明清社会特别之处，在于除了这五个半世纪时期的最后60年之外，官僚制度与国家权力具有压倒性的力量，一直是管控社会流动的主要渠道，这多少符合当时确立已久的儒家传统的指导原则。",
      "totalCount": 64,
      "appLink": "weread://bestbookmark?bookId=3300037152&chapterUid=14&rangeStart=10989&rangeEnd=11074",
      "webLink": "https://weread.qq.com/web/reader/ad432b40813ab7503g01289c?chapterUid=14&rangeStart=10989&rangeEnd=11074"
    },
    {
      "bookmarkId": "3300037152_13_3037-3062",
      "chapterUid": 13,
      "range": "3037-3062",
      "markText": "但中国史上有哪一个时代曾严格地遵守，还是很值得怀疑",
      "totalCount": 60,
      "appLink": "weread://bestbookmark?bookId=3300037152&chapterUid=13&rangeStart=3037&rangeEnd=3062",
      "webLink": "https://weread.qq.com/web/reader/ad432b40813ab7503g01289c?chapterUid=13&rangeStart=3037&rangeEnd=3062"
    },
    {
      "bookmarkId": "3300037152_12_5280-5315",
      "chapterUid": 12,
      "range": "5280-5315",
      "markText": "事实上，若分析孔子的整个思想系统，显然他认为贤德者在位是好政府的基础。",
      "totalCount": 55,
      "appLink": "weread://bestbookmark?bookId=3300037152&chapterUid=12&rangeStart=5280&rangeEnd=5315",
      "webLink": "https://weread.qq.com/web/reader/ad432b40813ab7503g01289c?chapterUid=12&rangeStart=5280&rangeEnd=5315"
    },
    {
      "bookmarkId": "3300037152_13_9515-9567",
      "chapterUid": 13,
      "range": "9515-9567",
      "markText": "只要做过官，便可过着官员式的生活，而且社会上也承认他们是官，这更反映了官员与平民间严格而持久不变的区隔。",
      "totalCount": 51,
      "appLink": "weread://bestbookmark?bookId=3300037152&chapterUid=13&rangeStart=9515&rangeEnd=9567",
      "webLink": "https://weread.qq.com/web/reader/ad432b40813ab7503g01289c?chapterUid=13&rangeStart=9515&rangeEnd=9567"
    },
    {
      "bookmarkId": "3300037152_16_9311-9382",
      "chapterUid": 16,
      "range": "9311-9382",
      "markText": "万历(1573—1619)后期，京营各军行伍已溃不成军，军事训练与军纪全已不存，军士依靠着负贩与做小工过活，而且还要拿部分挣来过活的钱孝敬上级",
      "totalCount": 51,
      "appLink": "weread://bestbookmark?bookId=3300037152&chapterUid=16&rangeStart=9311&rangeEnd=9382",
      "webLink": "https://weread.qq.com/web/reader/ad432b40813ab7503g01289c?chapterUid=16&rangeStart=9311&rangeEnd=9382"
    },
    {
      "bookmarkId": "3300037152_36_3483-3507",
      "chapterUid": 36,
      "range": "3483-3507",
      "markText": "明代刻书业的特色是，注重出版科举中式者的考试时文",
      "totalCount": 51,
      "appLink": "weread://bestbookmark?bookId=3300037152&chapterUid=36&rangeStart=3483&rangeEnd=3507",
      "webLink": "https://weread.qq.com/web/reader/ad432b40813ab7503g01289c?chapterUid=36&rangeStart=3483&rangeEnd=3507"
    },
    {
      "bookmarkId": "3300037152_12_15786-15846",
      "chapterUid": 12,
      "range": "15786-15846",
      "markText": "儒家相信社会公平的真实形式是教育平等；若无教育平等，则一个各阶级间权利、义务与功能不平等的社会，终究不能被认为是正当的。",
      "totalCount": 50,
      "appLink": "weread://bestbookmark?bookId=3300037152&chapterUid=12&rangeStart=15786&rangeEnd=15846",
      "webLink": "https://weread.qq.com/web/reader/ad432b40813ab7503g01289c?chapterUid=12&rangeStart=15786&rangeEnd=15846"
    },
    {
      "bookmarkId": "3300037152_9_11612-11685",
      "chapterUid": 9,
      "range": "11612-11685",
      "markText": "发现从明代初期到后期，平民家庭出身各科次进士占进士总人数的比率，平均从75%跌至45%，而官员家庭出身的进士人数的比例，反而从24%提高到53%；",
      "totalCount": 48,
      "appLink": "weread://bestbookmark?bookId=3300037152&chapterUid=9&rangeStart=11612&rangeEnd=11685",
      "webLink": "https://weread.qq.com/web/reader/ad432b40813ab7503g01289c?chapterUid=9&rangeStart=11612&rangeEnd=11685"
    },
    {
      "bookmarkId": "3300037152_12_8853-8920",
      "chapterUid": 12,
      "range": "8853-8920",
      "markText": "也就因为儒家的主张合于常识、常情、常理、人文主义、普遍性、能随着时空调整，也能吸收其他学派有用的学说，使他们能渐渐胜过所有的竞争对手。",
      "totalCount": 48,
      "appLink": "weread://bestbookmark?bookId=3300037152&chapterUid=12&rangeStart=8853&rangeEnd=8920",
      "webLink": "https://weread.qq.com/web/reader/ad432b40813ab7503g01289c?chapterUid=12&rangeStart=8853&rangeEnd=8920"
    },
    {
      "bookmarkId": "3300037152_12_11589-11859",
      "chapterUid": 12,
      "range": "11589-11859",
      "markText": "在这将近3个世纪期间，不论南北，政治领域均由世家大族所控制，虽然仍有出身寒微的人因其雄心大志与贤能成为高级官员。但一般来说，高阶官位仍然是世家大族世袭的。",
      "totalCount": 48,
      "appLink": "weread://bestbookmark?bookId=3300037152&chapterUid=12&rangeStart=11589&rangeEnd=11859",
      "webLink": "https://weread.qq.com/web/reader/ad432b40813ab7503g01289c?chapterUid=12&rangeStart=11589&rangeEnd=11859"
    },
    {
      "bookmarkId": "3300037152_12_3612-3700",
      "chapterUid": 12,
      "range": "3612-3700",
      "markText": "很清楚地，不论是拥护封建秩序的儒家理想主义者，或《管子》一书中所代表的政治权术家，或攻击某些封建的特权而想拯救大众的墨家，或加速封建制度死亡的法家，都没有舍弃不平等社会的观念。",
      "totalCount": 45,
      "appLink": "weread://bestbookmark?bookId=3300037152&chapterUid=12&rangeStart=3612&rangeEnd=3700",
      "webLink": "https://weread.qq.com/web/reader/ad432b40813ab7503g01289c?chapterUid=12&rangeStart=3612&rangeEnd=3700"
    },
    {
