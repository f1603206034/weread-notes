  ],
  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300095518_5_792-879",
      "chapterUid": 5,
      "range": "792-879",
      "markText": "犹太教、基督教、拜上帝教都认上帝为唯一主神，但上帝分别派了三个人来干三件不同的事：一是委托摩西管理和拯救犹太民族；二是委托耶稣来净化人类的灵魂；三是委托洪秀全来拯救中国人民。",
      "totalCount": 140,
      "appLink": "weread://bestbookmark?bookId=3300095518&chapterUid=5&rangeStart=792&rangeEnd=879",
      "webLink": "https://weread.qq.com/web/reader/4b632430813ab8bcfg018dc3?chapterUid=5&rangeStart=792&rangeEnd=879"
    },
    {
      "bookmarkId": "3300095518_22_11998-12087",
      "chapterUid": 22,
      "range": "11998-12087",
      "markText": "湘军攻克南京后，再次屠城，“沿街死尸十九皆老者，其幼孩未满二三岁者亦斫戮以为戏”。曾国藩奏报朝廷称：曾国荃带领湘军在南京“分段搜杀，三日之间毙贼共十余万人。秦淮长河，尸首如麻”。",
      "totalCount": 140,
      "appLink": "weread://bestbookmark?bookId=3300095518&chapterUid=22&rangeStart=11998&rangeEnd=12087",
      "webLink": "https://weread.qq.com/web/reader/4b632430813ab8bcfg018dc3?chapterUid=22&rangeStart=11998&rangeEnd=12087"
    },
    {
      "bookmarkId": "3300095518_69_2397-2492",
      "chapterUid": 69,
      "range": "2397-2492",
      "markText": "载沣最终发现，辛辛苦苦练出来的新军，其实只有两种，一种是愿意跟着袁世凯搞君主立宪的，另一种是想要搞革命推翻清朝的，反正就是没有支持他们这帮清朝贵胄的。他们在中国已经是人心失尽，被彻底孤立了。",
      "totalCount": 126,
      "appLink": "weread://bestbookmark?bookId=3300095518&chapterUid=69&rangeStart=2397&rangeEnd=2492",
      "webLink": "https://weread.qq.com/web/reader/4b632430813ab8bcfg018dc3?chapterUid=69&rangeStart=2397&rangeEnd=2492"
    },
    {
      "bookmarkId": "3300095518_73_8743-8828",
      "chapterUid": 73,
      "range": "8743-8828",
      "markText": "人比制度重要，这个道理不仅对国家适用，对企业等非政治组织也同样适用。优秀的人才可以改变制度或者让同样的制度运行得更好；反之，贪婪无能的人在任何制度中都会带来可怕的破坏力。",
      "totalCount": 119,
      "appLink": "weread://bestbookmark?bookId=3300095518&chapterUid=73&rangeStart=8743&rangeEnd=8828",
      "webLink": "https://weread.qq.com/web/reader/4b632430813ab8bcfg018dc3?chapterUid=73&rangeStart=8743&rangeEnd=8828"
    },
    {
      "bookmarkId": "3300095518_51_12204-12249",
      "chapterUid": 51,
      "range": "12204-12249",
      "markText": "在危害国家利益、阻碍中国进步方面，更是祸国、窃国、卖国“三位一体”，堪称近代中国第一国贼。",
      "totalCount": 108,
      "appLink": "weread://bestbookmark?bookId=3300095518&chapterUid=51&rangeStart=12204&rangeEnd=12249",
      "webLink": "https://weread.qq.com/web/reader/4b632430813ab8bcfg018dc3?chapterUid=51&rangeStart=12204&rangeEnd=12249"
