  "content": [
    {
      "chapterUid": 73,
      "chapterTitle": "后记 先治人，后治法",
      "items": [
        {
          "type": "highlight",
          "bookmarkId": "3300095518_73_8743-8828",
          "range": "8743-8828",
          "rangeStart": 8743,
          "rangeEnd": 8828,
          "markText": "人比制度重要，这个道理不仅对国家适用，对企业等非政治组织也同样适用。优秀的人才可以改变制度或者让同样的制度运行得更好；反之，贪婪无能的人在任何制度中都会带来可怕的破坏力。",
          "colorStyle": 0,
          "colorLabel": "",
          "createTime": 1766024869,
          "createTimeFormatted": "2025-12-18 10:27:49",
          "chapterUid": 73,
          "appLink": "weread://bestbookmark?bookId=3300095518&chapterUid=73&rangeStart=8743&rangeEnd=8828",
          "webLink": "https://weread.qq.com/web/reader/4b632430813ab8bcfg018dc3?chapterUid=73&rangeStart=8743&rangeEnd=8828"
        }
      ]
