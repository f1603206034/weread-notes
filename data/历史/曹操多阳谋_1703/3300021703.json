    },
    {
      "bookmarkId": "3300021703_5_12679-12702",
      "chapterUid": 5,
      "range": "12679-12702",
      "markText": "善败者关键要吸取别人的教训，尤其是历史的教训。",
      "totalCount": 612,
      "appLink": "weread://bestbookmark?bookId=3300021703&chapterUid=5&rangeStart=12679&rangeEnd=12702",
