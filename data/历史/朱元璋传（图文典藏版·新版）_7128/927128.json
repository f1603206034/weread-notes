  "content": [
    {
      "chapterUid": 27,
      "chapterTitle": "四．晚年的悲哀",
      "items": [
        {
          "type": "highlight",
          "bookmarkId": "927128_27_949-1010",
          "range": "949-1010",
          "rangeStart": 949,
          "rangeEnd": 1010,
          "markText": "尽量避免两线作战，机动地争取主动，敏捷地利用对方弱点，转变形势，集中兵力使敌人处在被动地位，知己知彼，在战略上是完全成功的",
          "colorStyle": 1,
          "colorLabel": "",
          "createTime": 1714656727,
          "createTimeFormatted": "2024-05-02 21:32:07",
          "chapterUid": 27,
          "appLink": "weread://bestbookmark?bookId=927128&chapterUid=27&rangeStart=949&rangeEnd=1010",
          "webLink": "https://weread.qq.com/web/reader/b9032ea05e2598b900f7777?chapterUid=27&rangeStart=949&rangeEnd=1010"
