  ],
  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "35666877_17_3981-4024",
      "chapterUid": 17,
      "range": "3981-4024",
      "markText": "我们如得以自立，日本也助我等对付西洋，倘若我等不能自强，恐其将与西洋一道共同将我瓜分。",
      "totalCount": 85,
      "appLink": "weread://bestbookmark?bookId=35666877&chapterUid=17&rangeStart=3981&rangeEnd=4024",
      "webLink": "https://weread.qq.com/web/reader/af33258072203bbdaf35cb6?chapterUid=17&rangeStart=3981&rangeEnd=4024"
    },
    {
      "bookmarkId": "35666877_4_2835-2851",
      "chapterUid": 4,
      "range": "2835-2851",
      "markText": "或许小山也将李鸿章视为战争的元凶",
      "totalCount": 54,
      "appLink": "weread://bestbookmark?bookId=35666877&chapterUid=4&rangeStart=2835&rangeEnd=2851",
      "webLink": "https://weread.qq.com/web/reader/af33258072203bbdaf35cb6?chapterUid=4&rangeStart=2835&rangeEnd=2851"
    },
    {
      "bookmarkId": "35666877_9_2467-2516",
      "chapterUid": 9,
      "range": "2467-2516",
      "markText": "他们能得到迅猛壮大，是由于存在着大批潜在的支持势力。这些势力，正是湖南省的社会落后分子和秘密结社。",
      "totalCount": 54,
      "appLink": "weread://bestbookmark?bookId=35666877&chapterUid=9&rangeStart=2467&rangeEnd=2516",
      "webLink": "https://weread.qq.com/web/reader/af33258072203bbdaf35cb6?chapterUid=9&rangeStart=2467&rangeEnd=2516"
    },
    {
      "bookmarkId": "35666877_50_4425-4449",
      "chapterUid": 50,
      "range": "4425-4449",
      "markText": "继承帝位的是光绪帝的外甥、虚岁3岁的宣统帝溥仪。",
      "totalCount": 51,
      "appLink": "weread://bestbookmark?bookId=35666877&chapterUid=50&rangeStart=4425&rangeEnd=4449",
      "webLink": "https://weread.qq.com/web/reader/af33258072203bbdaf35cb6?chapterUid=50&rangeStart=4425&rangeEnd=4449"
    },
    {
      "bookmarkId": "35666877_13_7454-7517",
      "chapterUid": 13,
      "range": "7454-7517",
      "markText": "在1863年年底收复苏州时，率领两万名士兵投降的太平军将领等八人被全部问斩，戈登强烈反对，李鸿章毫不让步，两人的关系濒临决裂。",
      "totalCount": 45,
      "appLink": "weread://bestbookmark?bookId=35666877&chapterUid=13&rangeStart=7454&rangeEnd=7517",
      "webLink": "https://weread.qq.com/web/reader/af33258072203bbdaf35cb6?chapterUid=13&rangeStart=7454&rangeEnd=7517"
    },
    {
      "bookmarkId": "35666877_7_2780-2856",
      "chapterUid": 7,
      "range": "2780-2856",
      "markText": "这是一位无比幸运的皇帝，祖父苦战沙场致力于建国，父亲宵衣旰食励精图治，他坐享其成。而他本人也心宽体健，25岁即位，平安地实现了对中国长达60多年的统治。",
      "totalCount": 42,
      "appLink": "weread://bestbookmark?bookId=35666877&chapterUid=7&rangeStart=2780&rangeEnd=2856",
      "webLink": "https://weread.qq.com/web/reader/af33258072203bbdaf35cb6?chapterUid=7&rangeStart=2780&rangeEnd=2856"
    },
    {
      "bookmarkId": "35666877_37_9751-9795",
      "chapterUid": 37,
      "range": "9751-9795",
      "markText": "袭击了未能逃回日本公使馆的日本居留民40余人，其中的30多名妇女受到了清军的凌辱和掠杀。",
      "totalCount": 40,
      "appLink": "weread://bestbookmark?bookId=35666877&chapterUid=37&rangeStart=9751&rangeEnd=9795",
      "webLink": "https://weread.qq.com/web/reader/af33258072203bbdaf35cb6?chapterUid=37&rangeStart=9751&rangeEnd=9795"
    },
    {
      "bookmarkId": "35666877_7_2640-2719",
      "chapterUid": 7,
      "range": "2640-2719",
      "markText": "尤其是雍正，致力于对各地督抚的管控，让他们无一遗漏地将当地情况汇报上来，地方完全处于皇帝的直接统治之下。如此一来，中华传统的君主独裁制，在这里被发挥到了极致。",
      "totalCount": 36,
      "appLink": "weread://bestbookmark?bookId=35666877&chapterUid=7&rangeStart=2640&rangeEnd=2719",
      "webLink": "https://weread.qq.com/web/reader/af33258072203bbdaf35cb6?chapterUid=7&rangeStart=2640&rangeEnd=2719"
    },
    {
      "bookmarkId": "35666877_7_5703-5761",
      "chapterUid": 7,
      "range": "5703-5761",
      "markText": "当地居民为了能抵抗和击退少数的叛乱部队，开始持有武器并进行训练，以求自卫。像这样组成的自卫团、义勇军被称作“团练”。",
      "totalCount": 36,
      "appLink": "weread://bestbookmark?bookId=35666877&chapterUid=7&rangeStart=5703&rangeEnd=5761",
      "webLink": "https://weread.qq.com/web/reader/af33258072203bbdaf35cb6?chapterUid=7&rangeStart=5703&rangeEnd=5761"
    },
    {
      "bookmarkId": "35666877_21_2925-2996",
      "chapterUid": 21,
      "range": "2925-2996",
      "markText": "他比曾年少一岁，一直将其视作竞争对手。在个人能力上，左宗棠也许要更胜一筹。然而，他未能考取进士，再加上极其自负的性格，他未能占据官界的主流地位",
      "totalCount": 36,
      "appLink": "weread://bestbookmark?bookId=35666877&chapterUid=21&rangeStart=2925&rangeEnd=2996",
      "webLink": "https://weread.qq.com/web/reader/af33258072203bbdaf35cb6?chapterUid=21&rangeStart=2925&rangeEnd=2996"
    },
    {
      "bookmarkId": "35666877_6_2217-2292",
      "chapterUid": 6,
      "range": "2217-2292",
      "markText": "能拜师到如此人物的门下，也是其父李文安曾和曾国藩一同考上进士的缘故。这种关系在中国社会中至关重要，要说这一缘分几乎决定了李鸿章一生的命运，也绝不为过。",
      "totalCount": 34,
      "appLink": "weread://bestbookmark?bookId=35666877&chapterUid=6&rangeStart=2217&rangeEnd=2292",
      "webLink": "https://weread.qq.com/web/reader/af33258072203bbdaf35cb6?chapterUid=6&rangeStart=2217&rangeEnd=2292"
    },
    {
      "bookmarkId": "35666877_7_506-529",
      "chapterUid": 7,
      "range": "506-529",
      "markText": "对一个时代的认识，当代人和后代人是大不一样的。",
      "totalCount": 32,
      "appLink": "weread://bestbookmark?bookId=35666877&chapterUid=7&rangeStart=506&rangeEnd=529",
      "webLink": "https://weread.qq.com/web/reader/af33258072203bbdaf35cb6?chapterUid=7&rangeStart=506&rangeEnd=529"
    },
    {
      "bookmarkId": "35666877_7_1392-1451",
      "chapterUid": 7,
      "range": "1392-1451",
      "markText": "为了顺利地实现对这一版图的统治，它尽可能地尊重各个民族、各个地区原先就存在的惯例及制度，以此试图获得被统治民族的支持。",
      "totalCount": 32,
      "appLink": "weread://bestbookmark?bookId=35666877&chapterUid=7&rangeStart=1392&rangeEnd=1451",
      "webLink": "https://weread.qq.com/web/reader/af33258072203bbdaf35cb6?chapterUid=7&rangeStart=1392&rangeEnd=1451"
    },
    {
      "bookmarkId": "35666877_13_4463-4519",
      "chapterUid": 13,
      "range": "4463-4519",
      "markText": "是拜它强大的西式武器所赐。当然，这些配置需要相对应的财力。李鸿章在军事上的成功，也意味着他在财政上也取得了成功。",
      "totalCount": 32,
      "appLink": "weread://bestbookmark?bookId=35666877&chapterUid=13&rangeStart=4463&rangeEnd=4519",
      "webLink": "https://weread.qq.com/web/reader/af33258072203bbdaf35cb6?chapterUid=13&rangeStart=4463&rangeEnd=4519"
    },
    {
      "bookmarkId": "35666877_41_3876-3946",
      "chapterUid": 41,
      "range": "3876-3946",
      "markText": "胡燏棻原本对军事并不精通，尽管有专家汉纳根指导军务，但是他们关系并不好，也没有取得成果。因此十个多月他就被替换了下来，袁世凯接替了他的职务。",
      "totalCount": 32,
      "appLink": "weread://bestbookmark?bookId=35666877&chapterUid=41&rangeStart=3876&rangeEnd=3946",
      "webLink": "https://weread.qq.com/web/reader/af33258072203bbdaf35cb6?chapterUid=41&rangeStart=3876&rangeEnd=3946"
    },
    {
      "bookmarkId": "35666877_52_1519-1580",
      "chapterUid": 52,
      "range": "1519-1580",
      "markText": "公布的十三名阁僚中，以总理大臣庆亲王为首，满人占了八人，其中皇族就有五人，汉人只有副总理徐世昌、邮政大臣盛宣怀等四人而已。",
      "totalCount": 32,
      "appLink": "weread://bestbookmark?bookId=35666877&chapterUid=52&rangeStart=1519&rangeEnd=1580",
      "webLink": "https://weread.qq.com/web/reader/af33258072203bbdaf35cb6?chapterUid=52&rangeStart=1519&rangeEnd=1580"
    },
    {
      "bookmarkId": "35666877_52_4370-4414",
      "chapterUid": 52,
      "range": "4370-4414",
      "markText": "拒绝领命，向清政府提出完全转让军权、成立责任内阁召开国会、赦免政治犯等条件，才答应出马。",
      "totalCount": 32,
      "appLink": "weread://bestbookmark?bookId=35666877&chapterUid=52&rangeStart=4370&rangeEnd=4414",
      "webLink": "https://weread.qq.com/web/reader/af33258072203bbdaf35cb6?chapterUid=52&rangeStart=4370&rangeEnd=4414"
    },
    {
      "bookmarkId": "35666877_55_726-761",
      "chapterUid": 55,
      "range": "726-761",
      "markText": "革命归根到底，不过是对满人的种族复仇，汉人夺回政权并发扬中华主义罢了。",
      "totalCount": 32,
      "appLink": "weread://bestbookmark?bookId=35666877&chapterUid=55&rangeStart=726&rangeEnd=761",
      "webLink": "https://weread.qq.com/web/reader/af33258072203bbdaf35cb6?chapterUid=55&rangeStart=726&rangeEnd=761"
    },
    {
      "bookmarkId": "35666877_27_3916-3963",
      "chapterUid": 27,
      "range": "3916-3963",
      "markText": "《中俄密约》将沙俄的势力引入了东三省，成为日俄战争、九一八事变的导火线，后来又引发了中日战争。",
      "totalCount": 30,
      "appLink": "weread://bestbookmark?bookId=35666877&chapterUid=27&rangeStart=3916&rangeEnd=3963",
      "webLink": "https://weread.qq.com/web/reader/af33258072203bbdaf35cb6?chapterUid=27&rangeStart=3916&rangeEnd=3963"
    },
    {
      "bookmarkId": "35666877_43_540-588",
      "chapterUid": 43,
      "range": "540-588",
      "markText": "那么，袁世凯的动静又是如何呢，也是让人捉摸不透。仅仅从他前后的言行来看，很显然他是支持改革的人物",
      "totalCount": 30,
      "appLink": "weread://bestbookmark?bookId=35666877&chapterUid=43&rangeStart=540&rangeEnd=588",
      "webLink": "https://weread.qq.com/web/reader/af33258072203bbdaf35cb6?chapterUid=43&rangeStart=540&rangeEnd=588"
    }
  ],
