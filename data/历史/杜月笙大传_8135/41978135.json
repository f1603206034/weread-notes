          "range": "429-505",
          "rangeStart": 429,
          "rangeEnd": 505,
          "markText": "与此同时，杜月笙长袖善舞，上下通吃。对前清遗老、军阀政客、党国高层、社会名流，乃至金融工商巨子，无不执礼甚恭，倾力结交，甚至结拜为把兄弟，或收为门生弟子",
          "colorStyle": 0,
          "colorLabel": "",
          "createTime": 1735734682,
          "createTimeFormatted": "2025-01-01 20:31:22",
          "chapterUid": 1,
          "appLink": "weread://bestbookmark?bookId=41978135&chapterUid=1&rangeStart=429&rangeEnd=505",
          "webLink": "https://weread.qq.com/web/reader/97232ec072808917972df32?chapterUid=1&rangeStart=429&rangeEnd=505"
