  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "41978135_3_4557-4633",
      "chapterUid": 3,
      "range": "4557-4633",
      "markText": "因为这段恩情，杜月笙发迹以后，特地把黄文祥请到杜公馆做了账房先生，黄文祥去世后，他的儿子黄国栋接替了账房一职，黄文祥的两个儿子都得到了杜月笙很好的照顾。",
      "totalCount": 240,
      "appLink": "weread://bestbookmark?bookId=41978135&chapterUid=3&rangeStart=4557&rangeEnd=4633",
      "webLink": "https://weread.qq.com/web/reader/97232ec072808917972df32?chapterUid=3&rangeStart=4557&rangeEnd=4633"
    },
    {
      "bookmarkId": "41978135_1_1436-1469",
      "chapterUid": 1,
      "range": "1436-1469",
      "markText": "最终以区区十万美金的遗产谢幕人世，其晚境的凄凉与无奈，由此可见一斑",
      "totalCount": 221,
      "appLink": "weread://bestbookmark?bookId=41978135&chapterUid=1&rangeStart=1436&rangeEnd=1469",
      "webLink": "https://weread.qq.com/web/reader/97232ec072808917972df32?chapterUid=1&rangeStart=1436&rangeEnd=1469"
    },
    {
      "bookmarkId": "41978135_1_839-881",
      "chapterUid": 1,
      "range": "839-881",
      "markText": "尽管黄金荣一生小气吝啬，但他深深懂得，只有舍得用钱、会用钱，才能广结人脉，成就大事。",
      "totalCount": 176,
      "appLink": "weread://bestbookmark?bookId=41978135&chapterUid=1&rangeStart=839&rangeEnd=881",
      "webLink": "https://weread.qq.com/web/reader/97232ec072808917972df32?chapterUid=1&rangeStart=839&rangeEnd=881"
    },
    {
      "bookmarkId": "41978135_18_16060-16120",
      "chapterUid": 18,
      "range": "16060-16120",
      "markText": "只要议案通过，就让日本军队统统开进来，外国朋友一个也不要走，我杜月笙要在两个钟头之内，毁灭租界！我们大家一道死在这里！”",
      "totalCount": 153,
      "appLink": "weread://bestbookmark?bookId=41978135&chapterUid=18&rangeStart=16060&rangeEnd=16120",
      "webLink": "https://weread.qq.com/web/reader/97232ec072808917972df32?chapterUid=18&rangeStart=16060&rangeEnd=16120"
    },
    {
      "bookmarkId": "41978135_3_11027-11104",
      "chapterUid": 3,
      "range": "11027-11104",
      "markText": "事实上，杜月笙以后的发迹、崛起，也正是得益于青帮，他一生最大的权势也是建立在青帮帮众势力之上，而他一生最终没有实现的宏大“抱负”，也正是因了他的帮会出身。",
      "totalCount": 144,
      "appLink": "weread://bestbookmark?bookId=41978135&chapterUid=3&rangeStart=11027&rangeEnd=11104",
      "webLink": "https://weread.qq.com/web/reader/97232ec072808917972df32?chapterUid=3&rangeStart=11027&rangeEnd=11104"
    },
    {
      "bookmarkId": "41978135_9_6680-6747",
      "chapterUid": 9,
      "range": "6680-6747",
      "markText": "而杜月笙肚子里的知识，以及他的言谈举止，行为做派，无不得益于他的听书。在这些历史文化的熏陶下，他从里到外，渐渐脱掉了“白相人”的烙印。",
      "totalCount": 140,
      "appLink": "weread://bestbookmark?bookId=41978135&chapterUid=9&rangeStart=6680&rangeEnd=6747",
      "webLink": "https://weread.qq.com/web/reader/97232ec072808917972df32?chapterUid=9&rangeStart=6680&rangeEnd=6747"
    },
    {
      "bookmarkId": "41978135_5_418-477",
      "chapterUid": 5,
      "range": "418-477",
      "markText": "相反，你为人家解了燃眉之急，不收礼金，人家一定从心里对你感恩戴德，这人心是多少钱也买不来的。只要有了人心，还怕没钱吗？",
      "totalCount": 136,
      "appLink": "weread://bestbookmark?bookId=41978135&chapterUid=5&rangeStart=418&rangeEnd=477",
      "webLink": "https://weread.qq.com/web/reader/97232ec072808917972df32?chapterUid=5&rangeStart=418&rangeEnd=477"
    },
    {
      "bookmarkId": "41978135_9_8893-8933",
      "chapterUid": 9,
      "range": "8893-8933",
      "markText": "人家来托我办事，就是看得起我，信得过我。就冲这一点，我就应该帮他们把事体办好。”",
      "totalCount": 136,
      "appLink": "weread://bestbookmark?bookId=41978135&chapterUid=9&rangeStart=8893&rangeEnd=8933",
      "webLink": "https://weread.qq.com/web/reader/97232ec072808917972df32?chapterUid=9&rangeStart=8893&rangeEnd=8933"
    },
    {
      "bookmarkId": "41978135_3_7449-7522",
      "chapterUid": 3,
      "range": "7449-7522",
      "markText": "经历了这一系列的事，杜月笙终于悟出一个道理，要想在上海滩站住脚，混得像个人样，光有一帮小弟兄还不够，还要有靠山，于是决定——拜“老头子”，入青帮。",
      "totalCount": 128,
      "appLink": "weread://bestbookmark?bookId=41978135&chapterUid=3&rangeStart=7449&rangeEnd=7522",
      "webLink": "https://weread.qq.com/web/reader/97232ec072808917972df32?chapterUid=3&rangeStart=7449&rangeEnd=7522"
    },
