  "hotBookmarks": [
    {
      "bookmarkId": "3300166070_5_2787-2822",
      "chapterUid": 5,
      "range": "2787-2822",
      "markText": "古代口耳相传的传说及文字记载将疾病与精神或支配生命的终极力量联系起来。",
      "totalCount": 8,
      "appLink": "weread://bestbookmark?bookId=3300166070&chapterUid=5&rangeStart=2787&rangeEnd=2822",
      "webLink": "https://weread.qq.com/web/reader/20b32cd0813aba75fg010931?chapterUid=5&rangeStart=2787&rangeEnd=2822"
    },
    {
      "bookmarkId": "3300166070_5_2822-2877",
      "chapterUid": 5,
      "range": "2822-2877",
      "markText": "后来写进希伯来圣典的故事（《塔纳赫》，也称基督教《旧约》）描述了上帝耶和华如何用瘟疫惩罚希伯来人和他们的敌人。",
      "totalCount": 8,
      "appLink": "weread://bestbookmark?bookId=3300166070&chapterUid=5&rangeStart=2822&rangeEnd=2877",
      "webLink": "https://weread.qq.com/web/reader/20b32cd0813aba75fg010931?chapterUid=5&rangeStart=2822&rangeEnd=2877"
    },
    {
      "bookmarkId": "3300166070_5_3083-3125",
      "chapterUid": 5,
      "range": "3083-3125",
      "markText": "随着古代社会城市人口的扩张和贸易往来的密切，学者们反思了瘟疫的起因以及它带来的影响。",
      "totalCount": 8,
      "appLink": "weread://bestbookmark?bookId=3300166070&chapterUid=5&rangeStart=3083&rangeEnd=3125",
      "webLink": "https://weread.qq.com/web/reader/20b32cd0813aba75fg010931?chapterUid=5&rangeStart=3083&rangeEnd=3125"
    },
    {
      "bookmarkId": "3300166070_5_4387-4416",
      "chapterUid": 5,
      "range": "4387-4416",
      "markText": "在欧洲，人们直到18世纪甚至更晚，还在学习其中的医学知识。",
      "totalCount": 8,
      "appLink": "weread://bestbookmark?bookId=3300166070&chapterUid=5&rangeStart=4387&rangeEnd=4416",
      "webLink": "https://weread.qq.com/web/reader/20b32cd0813aba75fg010931?chapterUid=5&rangeStart=4387&rangeEnd=4416"
    },
    {
      "bookmarkId": "3300166070_5_5182-5220",
      "chapterUid": 5,
      "range": "5182-5220",
      "markText": "其次，此前的历史著作探讨了社会是如何确定哪些身体或精神状况是（或不是）疾病。",
      "totalCount": 8,
      "appLink": "weread://bestbookmark?bookId=3300166070&chapterUid=5&rangeStart=5182&rangeEnd=5220",
      "webLink": "https://weread.qq.com/web/reader/20b32cd0813aba75fg010931?chapterUid=5&rangeStart=5182&rangeEnd=5220"
    },
    {
      "bookmarkId": "3300166070_5_9875-9929",
      "chapterUid": 5,
      "range": "9875-9929",
      "markText": "首先是对当前科学界对疾病的认识做一个简短而粗略的概述，然后按时间顺序，对现代史上与该疾病相关的主题进行讨论。",
      "totalCount": 8,
      "appLink": "weread://bestbookmark?bookId=3300166070&chapterUid=5&rangeStart=9875&rangeEnd=9929",
      "webLink": "https://weread.qq.com/web/reader/20b32cd0813aba75fg010931?chapterUid=5&rangeStart=9875&rangeEnd=9929"
    },
    {
      "bookmarkId": "3300166070_5_9929-9963",
      "chapterUid": 5,
      "range": "9929-9963",
      "markText": "每一章都集中在一个特定的时间框架内阐明一个与现代世界发展相关的主题。",
      "totalCount": 8,
      "appLink": "weread://bestbookmark?bookId=3300166070&chapterUid=5&rangeStart=9929&rangeEnd=9963",
      "webLink": "https://weread.qq.com/web/reader/20b32cd0813aba75fg010931?chapterUid=5&rangeStart=9929&rangeEnd=9963"
    },
    {
      "bookmarkId": "3300166070_5_11668-11709",
      "chapterUid": 5,
      "range": "11668-11709",
      "markText": "广义地说，历史学家区分出两种史料：一种是他们研究时代范围内的历史产物（直接史料）；",
      "totalCount": 8,
      "appLink": "weread://bestbookmark?bookId=3300166070&chapterUid=5&rangeStart=11668&rangeEnd=11709",
      "webLink": "https://weread.qq.com/web/reader/20b32cd0813aba75fg010931?chapterUid=5&rangeStart=11668&rangeEnd=11709"
    },
    {
      "bookmarkId": "3300166070_5_11919-11961",
      "chapterUid": 5,
      "range": "11919-11961",
      "markText": "接下来就是实际阅读中的挑战：早期作家的思想或他们表达思想的方式，可能显得怪异或愚钝。",
      "totalCount": 8,
      "appLink": "weread://bestbookmark?bookId=3300166070&chapterUid=5&rangeStart=11919&rangeEnd=11961",
      "webLink": "https://weread.qq.com/web/reader/20b32cd0813aba75fg010931?chapterUid=5&rangeStart=11919&rangeEnd=11961"
    },
    {
      "bookmarkId": "3300166070_6_8971-9007",
      "chapterUid": 6,
      "range": "8971-9007",
      "markText": "在14世纪50、60年代，死亡的危险和频发的社会动乱抑制了各种经济活动。",
      "totalCount": 8,
      "appLink": "weread://bestbookmark?bookId=3300166070&chapterUid=6&rangeStart=8971&rangeEnd=9007",
      "webLink": "https://weread.qq.com/web/reader/20b32cd0813aba75fg010931?chapterUid=6&rangeStart=8971&rangeEnd=9007"
    },
    {
      "bookmarkId": "3300166070_6_17591-17650",
      "chapterUid": 6,
      "range": "17591-17650",
      "markText": "这一证据表明，在横扫欧洲的瘟疫于1352年结束后，一种菌株向东传回到中亚，在那里，其他几个鼠疫的疫源地之前就长期存在。",
      "totalCount": 8,
      "appLink": "weread://bestbookmark?bookId=3300166070&chapterUid=6&rangeStart=17591&rangeEnd=17650",
      "webLink": "https://weread.qq.com/web/reader/20b32cd0813aba75fg010931?chapterUid=6&rangeStart=17591&rangeEnd=17650"
    },
    {
      "bookmarkId": "3300166070_6_23043-23112",
      "chapterUid": 6,
      "range": "23043-23112",
      "markText": "例如，在存在主义作家阿尔贝·加缪的小说《鼠疫》（1947年）中，北非的一个城市暴发的疫情，迫使主人公在最终失去理性的世界中寻求生存的意义。",
      "totalCount": 8,
      "appLink": "weread://bestbookmark?bookId=3300166070&chapterUid=6&rangeStart=23043&rangeEnd=23112",
      "webLink": "https://weread.qq.com/web/reader/20b32cd0813aba75fg010931?chapterUid=6&rangeStart=23043&rangeEnd=23112"
    },
    {
      "bookmarkId": "3300166070_6_23193-23230",
      "chapterUid": 6,
      "range": "23193-23230",
      "markText": "梅毒的这个特征深刻地影响了西方的个人道德信仰以及社区在性行为监管中的作用。",
      "totalCount": 8,
      "appLink": "weread://bestbookmark?bookId=3300166070&chapterUid=6&rangeStart=23193&rangeEnd=23230",
      "webLink": "https://weread.qq.com/web/reader/20b32cd0813aba75fg010931?chapterUid=6&rangeStart=23193&rangeEnd=23230"
    },
    {
      "bookmarkId": "3300166070_7_9439-9501",
      "chapterUid": 7,
      "range": "9439-9501",
      "markText": "他们的著作加上紧接着的乌尔里希·冯·胡滕的论文，是第一批出版的关于愈创木的记述，这种植物也被称为“神圣之木”或“生命之木”。",
      "totalCount": 8,
      "appLink": "weread://bestbookmark?bookId=3300166070&chapterUid=7&rangeStart=9439&rangeEnd=9501",
      "webLink": "https://weread.qq.com/web/reader/20b32cd0813aba75fg010931?chapterUid=7&rangeStart=9439&rangeEnd=9501"
    },
    {
      "bookmarkId": "3300166070_7_31820-31909",
      "chapterUid": 7,
      "range": "31820-31909",
      "markText": "感染的物质因素并非欧洲唯一的输出物：与世界其他地区不同的是，基督教和西方科学使人们把疾病与道德败坏联系起来，即使在细菌理论促成了对梅毒病因和治疗的科学理解之后，这种联系仍然存在。",
      "totalCount": 8,
      "appLink": "weread://bestbookmark?bookId=3300166070&chapterUid=7&rangeStart=31820&rangeEnd=31909",
      "webLink": "https://weread.qq.com/web/reader/20b32cd0813aba75fg010931?chapterUid=7&rangeStart=31820&rangeEnd=31909"
    },
    {
      "bookmarkId": "3300166070_8_1796-1852",
      "chapterUid": 8,
      "range": "1796-1852",
      "markText": "学者们认为，欧洲人的到来开启了一场势不可挡的“微生物冲击”，并与其他因素结合起来，瓦解了原住民对殖民势力的抵抗。",
      "totalCount": 8,
      "appLink": "weread://bestbookmark?bookId=3300166070&chapterUid=8&rangeStart=1796&rangeEnd=1852",
      "webLink": "https://weread.qq.com/web/reader/20b32cd0813aba75fg010931?chapterUid=8&rangeStart=1796&rangeEnd=1852"
    },
    {
      "bookmarkId": "3300166070_8_9756-9804",
      "chapterUid": 8,
      "range": "9756-9804",
      "markText": "在同时期的欧洲人口中，由于先前接触过病原体而具有较高的免疫水平，天花大流行期间总死亡率普遍较低。",
      "totalCount": 8,
      "appLink": "weread://bestbookmark?bookId=3300166070&chapterUid=8&rangeStart=9756&rangeEnd=9804",
      "webLink": "https://weread.qq.com/web/reader/20b32cd0813aba75fg010931?chapterUid=8&rangeStart=9756&rangeEnd=9804"
    },
    {
      "bookmarkId": "3300166070_8_15277-15305",
