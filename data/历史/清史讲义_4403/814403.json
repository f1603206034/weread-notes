      "range": "22321-22330",
      "markText": "雍齿且侯，吾属无患",
      "totalCount": 119,
      "appLink": "weread://bestbookmark?bookId=814403&chapterUid=10&rangeStart=22321&rangeEnd=22330",
      "webLink": "https://weread.qq.com/web/reader/0c632da05c6d430c61cc5ab?chapterUid=10&rangeStart=22321&rangeEnd=22330"
