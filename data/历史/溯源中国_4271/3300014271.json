  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300014271_6_1209-1251",
      "chapterUid": 6,
      "range": "1209-1251",
      "markText": "一是科学理性、文明认知，追求的是史实复原；二是救亡图存、民族自觉，意欲建构国族认同。",
      "totalCount": 96,
      "appLink": "weread://bestbookmark?bookId=3300014271&chapterUid=6&rangeStart=1209&rangeEnd=1251",
      "webLink": "https://weread.qq.com/web/reader/4a632f70813ab6c13g011154?chapterUid=6&rangeStart=1209&rangeEnd=1251"
    },
    {
      "bookmarkId": "3300014271_16_8266-8360",
      "chapterUid": 16,
      "range": "8266-8360",
      "markText": "这种对夏文化探索的信心与共识显然已偏离了殷墟晚商王朝得以确认的根本前提，即地下文字材料与古典文献的互证。这样的共识与其说是实证的结果，毋宁说是一种情结；或像上引文所言，是一种“共同信念”。",
      "totalCount": 96,
      "appLink": "weread://bestbookmark?bookId=3300014271&chapterUid=16&rangeStart=8266&rangeEnd=8360",
      "webLink": "https://weread.qq.com/web/reader/4a632f70813ab6c13g011154?chapterUid=16&rangeStart=8266&rangeEnd=8360"
    },
    {
      "bookmarkId": "3300014271_2_5760-5849",
      "chapterUid": 2,
      "range": "5760-5849",
      "markText": "峰值期的良渚社会是一个宗教色彩极其浓重的社会，整个社会生活的运作被笼罩在厚重而偏激的宗教气氛里，为此，社会投入了大量非生产性劳动，而这些付出对社会的长期发展显然不会有任何正面效应",
      "totalCount": 90,
      "appLink": "weread://bestbookmark?bookId=3300014271&chapterUid=2&rangeStart=5760&rangeEnd=5849",
      "webLink": "https://weread.qq.com/web/reader/4a632f70813ab6c13g011154?chapterUid=2&rangeStart=5760&rangeEnd=5849"
    },
    {
      "bookmarkId": "3300014271_13_5717-5742",
      "chapterUid": 13,
      "range": "5717-5742",
      "markText": "夏朝是客观存在的，任何怀疑乃至否定都是没有根据的。",
      "totalCount": 90,
      "appLink": "weread://bestbookmark?bookId=3300014271&chapterUid=13&rangeStart=5717&rangeEnd=5742",
      "webLink": "https://weread.qq.com/web/reader/4a632f70813ab6c13g011154?chapterUid=13&rangeStart=5717&rangeEnd=5742"
    },
    {
      "bookmarkId": "3300014271_2_5681-5740",
      "chapterUid": 2,
      "range": "5681-5740",
      "markText": "其宗教信仰似乎带有浓厚的原始巫术的色彩；而近乎泛滥的、具有较强的视觉冲击力的宗教遗迹和遗物，并不能代表文明发展的高度。",
      "totalCount": 75,
      "appLink": "weread://bestbookmark?bookId=3300014271&chapterUid=2&rangeStart=5681&rangeEnd=5740",
      "webLink": "https://weread.qq.com/web/reader/4a632f70813ab6c13g011154?chapterUid=2&rangeStart=5681&rangeEnd=5740"
    },
    {
      "bookmarkId": "3300014271_20_12948-12979",
      "chapterUid": 20,
      "range": "12948-12979",
      "markText": "真正提出三星堆遗址第二期为三星堆文化之始的，则是四川以外的学者",
      "totalCount": 72,
      "appLink": "weread://bestbookmark?bookId=3300014271&chapterUid=20&rangeStart=12948&rangeEnd=12979",
      "webLink": "https://weread.qq.com/web/reader/4a632f70813ab6c13g011154?chapterUid=20&rangeStart=12948&rangeEnd=12979"
    },
    {
      "bookmarkId": "3300014271_4_618-670",
