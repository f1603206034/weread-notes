  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "37324724_4_931-997",
      "chapterUid": 4,
      "range": "931-997",
      "markText": "三天之后，在炎炎夏日中，他按照仪式碰触了2400名浑身恶臭的瘰疬病患者，人们素来相信受膏国王神圣的碰触能够治愈这种使人面目全非的疾病",
      "totalCount": 196,
      "appLink": "weread://bestbookmark?bookId=37324724&chapterUid=4&rangeStart=931&rangeEnd=997",
      "webLink": "https://weread.qq.com/web/reader/a4c32e70723987b4a4c3a31?chapterUid=4&rangeStart=931&rangeEnd=997"
    },
    {
      "bookmarkId": "37324724_12_9303-9382",
      "chapterUid": 12,
      "range": "9303-9382",
      "markText": "12月19日土伦被重新夺回，英国舰队仓皇逃走。在这场驱逐战中，扮演关键角色的是25岁的炮兵指挥官拿破仑·波拿巴，他在土伦战役中声名鹊起，两个月内即晋升为将军。",
      "totalCount": 144,
      "appLink": "weread://bestbookmark?bookId=37324724&chapterUid=12&rangeStart=9303&rangeEnd=9382",
      "webLink": "https://weread.qq.com/web/reader/a4c32e70723987b4a4c3a31?chapterUid=12&rangeStart=9303&rangeEnd=9382"
    },
    {
      "bookmarkId": "37324724_4_2628-2662",
      "chapterUid": 4,
      "range": "2628-2662",
      "markText": "每个行政区也有自己的度量衡，同一计量单位在不同地方往往有不同的数值。",
      "totalCount": 136,
      "appLink": "weread://bestbookmark?bookId=37324724&chapterUid=4&rangeStart=2628&rangeEnd=2662",
      "webLink": "https://weread.qq.com/web/reader/a4c32e70723987b4a4c3a31?chapterUid=4&rangeStart=2628&rangeEnd=2662"
    },
    {
      "bookmarkId": "37324724_4_520-602",
      "chapterUid": 4,
      "range": "520-602",
      "markText": "1775年6月11日在兰斯大教堂精心安排的路易十六传统祝圣仪式是在浪费公共财产。就在祝圣仪式的前一个月，巴黎周边的农村因高价面粉和面包引发了骚动，有人考虑将庆典延期",
      "totalCount": 112,
      "appLink": "weread://bestbookmark?bookId=37324724&chapterUid=4&rangeStart=520&rangeEnd=602",
      "webLink": "https://weread.qq.com/web/reader/a4c32e70723987b4a4c3a31?chapterUid=4&rangeStart=520&rangeEnd=602"
    },
    {
      "bookmarkId": "37324724_4_1069-1131",
      "chapterUid": 4,
      "range": "1069-1131",
      "markText": "路易十六举行的庆典以及他所履行的仪式，是一种奇怪的混合，既事关重大又微不足道，既意味深长又流于形式，既有诸多讲究又空洞乏味。",
      "totalCount": 108,
      "appLink": "weread://bestbookmark?bookId=37324724&chapterUid=4&rangeStart=1069&rangeEnd=1131",
      "webLink": "https://weread.qq.com/web/reader/a4c32e70723987b4a4c3a31?chapterUid=4&rangeStart=1069&rangeEnd=1131"
    },
    {
      "bookmarkId": "37324724_4_457-505",
      "chapterUid": 4,
      "range": "457-505",
      "markText": "法国国王其实不需要加冕礼，他在前国王去世时就领受神恩，登上宝座。加冕仅仅是遵从习俗，走过场而已。",
      "totalCount": 102,
      "appLink": "weread://bestbookmark?bookId=37324724&chapterUid=4&rangeStart=457&rangeEnd=505",
      "webLink": "https://weread.qq.com/web/reader/a4c32e70723987b4a4c3a31?chapterUid=4&rangeStart=457&rangeEnd=505"
    },
    {
      "bookmarkId": "37324724_3_500-521",
      "chapterUid": 3,
      "range": "500-521",
      "markText": "法国大革命是轰动性的，是近代政治文化的开端",
      "totalCount": 98,
      "appLink": "weread://bestbookmark?bookId=37324724&chapterUid=3&rangeStart=500&rangeEnd=521",
      "webLink": "https://weread.qq.com/web/reader/a4c32e70723987b4a4c3a31?chapterUid=3&rangeStart=500&rangeEnd=521"
    },
    {
      "bookmarkId": "37324724_4_21878-21942",
      "chapterUid": 4,
      "range": "21878-21942",
      "markText": "他们中几乎没有人愿意把钱留在当初发家的行业，贸易和制造业虽然利润可观，但毕竟不稳定。因此，资产阶级一旦有了钱，第一反应就是买地。",
      "totalCount": 96,
      "appLink": "weread://bestbookmark?bookId=37324724&chapterUid=4&rangeStart=21878&rangeEnd=21942",
      "webLink": "https://weread.qq.com/web/reader/a4c32e70723987b4a4c3a31?chapterUid=4&rangeStart=21878&rangeEnd=21942"
    },
    {
      "bookmarkId": "37324724_4_13895-13937",
      "chapterUid": 4,
      "range": "13895-13937",
      "markText": "一个从乡下来的姑娘经历大抵是这样的：先做女仆，怀孕，丢掉工作，为了养活孩子沦为妓女。",
      "totalCount": 90,
      "appLink": "weread://bestbookmark?bookId=37324724&chapterUid=4&rangeStart=13895&rangeEnd=13937",
      "webLink": "https://weread.qq.com/web/reader/a4c32e70723987b4a4c3a31?chapterUid=4&rangeStart=13895&rangeEnd=13937"
    },
    {
      "bookmarkId": "37324724_14_639-696",
      "chapterUid": 14,
      "range": "639-696",
      "markText": "但是7月12日比龙竟被免职，理由是他以前是个公爵。继任的罗西涅尔是名无套裤汉，虽然颇有政治声望，却是个无能的酒鬼。",
      "totalCount": 90,
      "appLink": "weread://bestbookmark?bookId=37324724&chapterUid=14&rangeStart=639&rangeEnd=696",
      "webLink": "https://weread.qq.com/web/reader/a4c32e70723987b4a4c3a31?chapterUid=14&rangeStart=639&rangeEnd=696"
    },
    {
      "bookmarkId": "37324724_4_22767-22856",
      "chapterUid": 4,
      "range": "22767-22856",
      "markText": "买官制起源于16世纪，一开始是作为国王借钱的手段，到了17世纪，官职买卖成了法国社会生活的基本制度，如果官员可以缴纳这个官职所需的年税，就可以把职位传给自己的孩子或者卖给第三方。",
