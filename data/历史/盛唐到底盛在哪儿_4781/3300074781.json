  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300074781_4_654-741",
      "chapterUid": 4,
      "range": "654-741",
      "markText": "唐朝的文化为什么让我们魂牵梦萦？因为它有一种令现代人感到心气相通的气质。它开放包容，恣意张扬，也不压抑人的个性。就连在中国历史上屡受欺压的女性，在唐代也能找到自己发挥的舞台。",
      "totalCount": 448,
      "appLink": "weread://bestbookmark?bookId=3300074781&chapterUid=4&rangeStart=654&rangeEnd=741",
      "webLink": "https://weread.qq.com/web/reader/d39329e0813ab83b6g011417?chapterUid=4&rangeStart=654&rangeEnd=741"
    },
    {
      "bookmarkId": "3300074781_4_402-473",
      "chapterUid": 4,
      "range": "402-473",
      "markText": "大约二十年前，各大历史博物馆基本上可以用“门可罗雀”来形容。但是最近这些年要换词了：博物馆必须用“门庭若市”来形容，到了假期更是“水泄不通”。",
      "totalCount": 342,
      "appLink": "weread://bestbookmark?bookId=3300074781&chapterUid=4&rangeStart=402&rangeEnd=473",
      "webLink": "https://weread.qq.com/web/reader/d39329e0813ab83b6g011417?chapterUid=4&rangeStart=402&rangeEnd=473"
    },
    {
      "bookmarkId": "3300074781_5_5915-6007",
      "chapterUid": 5,
      "range": "5915-6007",
      "markText": "当时的唐朝，对外保持着足够开放的态度。少数民族以及外国人进入长安之后，可以经商，可以出家，可以当官，可以考进士，可以成亲。但是对于本国国民，政策就非常严格了——本国国民，无故不得出国。",
      "totalCount": 340,
      "appLink": "weread://bestbookmark?bookId=3300074781&chapterUid=5&rangeStart=5915&rangeEnd=6007",
      "webLink": "https://weread.qq.com/web/reader/d39329e0813ab83b6g011417?chapterUid=5&rangeStart=5915&rangeEnd=6007"
    },
    {
      "bookmarkId": "3300074781_6_1413-1478",
      "chapterUid": 6,
      "range": "1413-1478",
      "markText": "第一个遣隋使的名字叫小野妹子——千万不要真的以为他是个妹子，小野妹子是男性，只是名字叫“妹子”而已。这是有记载以来的第一位遣隋史。",
      "totalCount": 308,
      "appLink": "weread://bestbookmark?bookId=3300074781&chapterUid=6&rangeStart=1413&rangeEnd=1478",
      "webLink": "https://weread.qq.com/web/reader/d39329e0813ab83b6g011417?chapterUid=6&rangeStart=1413&rangeEnd=1478"
    },
    {
      "bookmarkId": "3300074781_5_3069-3144",
      "chapterUid": 5,
      "range": "3069-3144",
      "markText": "我们极少把宋朝称为帝国，但是我们说唐朝是一个帝国。为什么这么说？那是因为唐朝在整个东亚世界的秩序当中是居于领导地位的，它是整个东亚、东北亚国家的领袖。",
      "totalCount": 306,
      "appLink": "weread://bestbookmark?bookId=3300074781&chapterUid=5&rangeStart=3069&rangeEnd=3144",
      "webLink": "https://weread.qq.com/web/reader/d39329e0813ab83b6g011417?chapterUid=5&rangeStart=3069&rangeEnd=3144"
    },
    {
      "bookmarkId": "3300074781_9_6615-6706",
      "chapterUid": 9,
      "range": "6615-6706",
      "markText": "一个人也好，一个时代也好，最需要警惕的不是吃苦受累的时候，而是高歌猛进的时候，因为成绩和盛世会掩盖矛盾与危险，会让人麻痹。“居安而思危”这句老话放在任何时代、任何人身上都永远不过时。",
      "totalCount": 306,
      "appLink": "weread://bestbookmark?bookId=3300074781&chapterUid=9&rangeStart=6615&rangeEnd=6706",
      "webLink": "https://weread.qq.com/web/reader/d39329e0813ab83b6g011417?chapterUid=9&rangeStart=6615&rangeEnd=6706"
    },
    {
      "bookmarkId": "3300074781_5_4633-4698",
      "chapterUid": 5,
      "range": "4633-4698",
      "markText": "我在韩国甚至看到过，在相当于我国唐代的新罗时期，他们新罗王的陵墓前面，也模仿唐朝竖立了胡人形象的藩臣像。可是新罗哪来的胡人藩臣呢？",
      "totalCount": 300,
      "appLink": "weread://bestbookmark?bookId=3300074781&chapterUid=5&rangeStart=4633&rangeEnd=4698",
      "webLink": "https://weread.qq.com/web/reader/d39329e0813ab83b6g011417?chapterUid=5&rangeStart=4633&rangeEnd=4698"
    },
    {
      "bookmarkId": "3300074781_4_498-549",
      "chapterUid": 4,
      "range": "498-549",
      "markText": "要知道，人在衣食无忧之后，一定会思索“我是谁，我从哪里来”的问题，而历史学正好可以给人提供问题的答案。",
      "totalCount": 252,
      "appLink": "weread://bestbookmark?bookId=3300074781&chapterUid=4&rangeStart=498&rangeEnd=549",
      "webLink": "https://weread.qq.com/web/reader/d39329e0813ab83b6g011417?chapterUid=4&rangeStart=498&rangeEnd=549"
    },
    {
      "bookmarkId": "3300074781_6_906-1004",
      "chapterUid": 6,
      "range": "906-1004",
      "markText": "唐朝打了这么一场胜仗，歼灭敌人三万多人，烧毁敌舰几百条，怎么都算是一场大胜。但这场胜利在唐朝的史料当中只留下来短短的几句话，两三行就写完了。我们现在研究白村江口战役，只能靠《日本书纪》等日本史料。",
      "totalCount": 252,
      "appLink": "weread://bestbookmark?bookId=3300074781&chapterUid=6&rangeStart=906&rangeEnd=1004",
      "webLink": "https://weread.qq.com/web/reader/d39329e0813ab83b6g011417?chapterUid=6&rangeStart=906&rangeEnd=1004"
    },
    {
      "bookmarkId": "3300074781_8_4871-4926",
      "chapterUid": 8,
      "range": "4871-4926",
      "markText": "网络上的很多言论为了追求“语不惊人死不休”，会失去真实性和公正性，但我们还是要用一种公正平和的心态来看待历史。",
      "totalCount": 192,
      "appLink": "weread://bestbookmark?bookId=3300074781&chapterUid=8&rangeStart=4871&rangeEnd=4926",
      "webLink": "https://weread.qq.com/web/reader/d39329e0813ab83b6g011417?chapterUid=8&rangeStart=4871&rangeEnd=4926"
    },
    {
      "bookmarkId": "3300074781_9_4014-4103",
      "chapterUid": 9,
      "range": "4014-4103",
      "markText": "粟特胡商，为他筹措军费。而且，唐玄宗还把财权下放，允许安禄山在上谷郡设置五座铸钱炉，让他拥有了铸币权。这等于把国家造币厂交给了安禄山，所以安禄山在反叛之前，在财政上也做好了准备。",
      "totalCount": 192,
      "appLink": "weread://bestbookmark?bookId=3300074781&chapterUid=9&rangeStart=4014&rangeEnd=4103",
      "webLink": "https://weread.qq.com/web/reader/d39329e0813ab83b6g011417?chapterUid=9&rangeStart=4014&rangeEnd=4103"
    },
    {
      "bookmarkId": "3300074781_5_2810-2897",
      "chapterUid": 5,
      "range": "2810-2897",
      "markText": "贵族子弟都去应征，最后李渊脱颖而出，他一箭就射中了孔雀的一只眼睛。之后为了证明自己不是蒙的，李渊张弓搭箭，又射中了第二只孔雀的眼睛，超规格完成了任务，抱得美人归，娶回了窦氏。",
      "totalCount": 182,
      "appLink": "weread://bestbookmark?bookId=3300074781&chapterUid=5&rangeStart=2810&rangeEnd=2897",
      "webLink": "https://weread.qq.com/web/reader/d39329e0813ab83b6g011417?chapterUid=5&rangeStart=2810&rangeEnd=2897"
    },
    {
      "bookmarkId": "3300074781_4_854-945",
      "chapterUid": 4,
      "range": "854-945",
      "markText": "唐人与今人的心气相通还有一个突出的体现，那就是他们不屑于进行道德说教。他们在文学作品当中，真实地展现自己的喜怒哀乐、快意恩仇，甚至连情爱也可以毫无保留地表达。这让我们感到无比地亲切。",
