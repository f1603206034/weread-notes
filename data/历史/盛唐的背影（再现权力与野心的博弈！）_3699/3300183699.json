  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300183699_21_8607-8701",
      "chapterUid": 21,
      "range": "8607-8701",
      "markText": "回到睢阳，城内连麻雀都被吃光了。张巡把自己的爱妾带出来，杀了让战士们充饥。人世间最惨烈的一幕上演了，妇女、老人、伤病员站了出来，充当食粮，竟然没有一个人叛逃，大家在慷慨赴死，为了国家不亡！",
      "totalCount": 221,
      "appLink": "weread://bestbookmark?bookId=3300183699&chapterUid=21&rangeStart=8607&rangeEnd=8701",
      "webLink": "https://weread.qq.com/web/reader/99b32a20813abae41g0192b4?chapterUid=21&rangeStart=8607&rangeEnd=8701"
    },
    {
      "bookmarkId": "3300183699_5_5444-5490",
      "chapterUid": 5,
      "range": "5444-5490",
      "markText": "在社会快速发展的时候，一定要加倍注意分配公平和吏治清明，这是安史之乱留给后世的第一个重要启示",
      "totalCount": 182,
      "appLink": "weread://bestbookmark?bookId=3300183699&chapterUid=5&rangeStart=5444&rangeEnd=5490",
      "webLink": "https://weread.qq.com/web/reader/99b32a20813abae41g0192b4?chapterUid=5&rangeStart=5444&rangeEnd=5490"
    },
    {
      "bookmarkId": "3300183699_5_5260-5355",
      "chapterUid": 5,
      "range": "5260-5355",
      "markText": "因为社会的转变，会燃起人们心头追求公正和富裕的希望，更容易使他们感受到社会的不公。而这个时候，若统治者沉迷于社会发展的成就而松懈，或者鼓吹变革而没有能力去实现，就会带给社会更大的失望和挫折感",
      "totalCount": 156,
      "appLink": "weread://bestbookmark?bookId=3300183699&chapterUid=5&rangeStart=5260&rangeEnd=5355",
      "webLink": "https://weread.qq.com/web/reader/99b32a20813abae41g0192b4?chapterUid=5&rangeStart=5260&rangeEnd=5355"
    },
    {
      "bookmarkId": "3300183699_5_8676-8744",
      "chapterUid": 5,
      "range": "8676-8744",
      "markText": "一个国家、一个民族，如果兼收并蓄与包容涵育的精神低迷，眼界就会日渐狭隘短浅，开拓进取的意志就会越来越衰退，最终将一步步地走向封闭与沉沦。",
