      "appLink": "weread://bestbookmark?bookId=42701994&chapterUid=1&rangeStart=1907&rangeEnd=1946",
      "webLink": "https://weread.qq.com/web/reader/c9732590728b94aac97e27c?chapterUid=1&rangeStart=1907&rangeEnd=1946"
