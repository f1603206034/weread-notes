  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "42701994_1_4150-4231",
      "chapterUid": 1,
      "range": "4150-4231",
      "markText": "后来，在奖励耕战中尝到甜头的秦民有人称赞变法，结果也被商鞅抓起来全家流放边关。商鞅认为，人民要做的就是不折不扣地执行法令，不应该对新法说三道四，哪怕是赞美的声音。",
      "totalCount": 476,
      "appLink": "weread://bestbookmark?bookId=42701994&chapterUid=1&rangeStart=4150&rangeEnd=4231",
      "webLink": "https://weread.qq.com/web/reader/c9732590728b94aac97e27c?chapterUid=1&rangeStart=4150&rangeEnd=4231"
    },
    {
      "bookmarkId": "42701994_1_5681-5734",
      "chapterUid": 1,
      "range": "5681-5734",
      "markText": "现代有学者认为商鞅变法“为秦国缔造了一个强大到极点的政府、一个萎缩到极点的社会以及一群沉默到极点的个人”。",
      "totalCount": 312,
      "appLink": "weread://bestbookmark?bookId=42701994&chapterUid=1&rangeStart=5681&rangeEnd=5734",
      "webLink": "https://weread.qq.com/web/reader/c9732590728b94aac97e27c?chapterUid=1&rangeStart=5681&rangeEnd=5734"
    },
    {
      "bookmarkId": "42701994_1_3964-4021",
      "chapterUid": 1,
      "range": "3964-4021",
      "markText": "在商鞅看来，要震慑民众，使他们不敢触犯朝廷的法律，必须轻罪重刑。用重刑来惩罚犯轻罪之人，以此来加强刑罚的威慑作用。",
      "totalCount": 150,
      "appLink": "weread://bestbookmark?bookId=42701994&chapterUid=1&rangeStart=3964&rangeEnd=4021",
      "webLink": "https://weread.qq.com/web/reader/c9732590728b94aac97e27c?chapterUid=1&rangeStart=3964&rangeEnd=4021"
    },
    {
      "bookmarkId": "42701994_1_528-583",
      "chapterUid": 1,
      "range": "528-583",
      "markText": "卫鞅本姓公孙，曾是卫国贵族，打败魏军回来以后，因秦孝公把於、商十五个邑封给了他，封号商君，所以又被人称为商鞅。",
      "totalCount": 144,
      "appLink": "weread://bestbookmark?bookId=42701994&chapterUid=1&rangeStart=528&rangeEnd=583",
      "webLink": "https://weread.qq.com/web/reader/c9732590728b94aac97e27c?chapterUid=1&rangeStart=528&rangeEnd=583"
    },
    {
      "bookmarkId": "42701994_1_3770-3796",
      "chapterUid": 1,
      "range": "3770-3796",
      "markText": "商鞅认为，仁义不足以治天下，法令是民生、治国的根本。",
      "totalCount": 144,
      "appLink": "weread://bestbookmark?bookId=42701994&chapterUid=1&rangeStart=3770&rangeEnd=3796",
      "webLink": "https://weread.qq.com/web/reader/c9732590728b94aac97e27c?chapterUid=1&rangeStart=3770&rangeEnd=3796"
    },
    {
      "bookmarkId": "42701994_1_196-234",
      "chapterUid": 1,
      "range": "196-234",
      "markText": "卫鞅摇头说：“国君不能听从你的意见来任用我，又怎么能听从你的意见来杀我呢？”",
      "totalCount": 143,
      "appLink": "weread://bestbookmark?bookId=42701994&chapterUid=1&rangeStart=196&rangeEnd=234",
      "webLink": "https://weread.qq.com/web/reader/c9732590728b94aac97e27c?chapterUid=1&rangeStart=196&rangeEnd=234"
    },
    {
      "bookmarkId": "42701994_1_152-195",
      "chapterUid": 1,
      "range": "152-195",
      "markText": "“我必须先忠于君上，然后才能照顾属下；所以先建议惠王杀你，现在又告诉你。你赶快逃走吧！",
      "totalCount": 132,
      "appLink": "weread://bestbookmark?bookId=42701994&chapterUid=1&rangeStart=152&rangeEnd=195",
      "webLink": "https://weread.qq.com/web/reader/c9732590728b94aac97e27c?chapterUid=1&rangeStart=152&rangeEnd=195"
    },
    {
      "bookmarkId": "42701994_1_1192-1259",
      "chapterUid": 1,
      "range": "1192-1259",
      "markText": "正如商鞅对景监所言，若用帝王之道，耗时太长，况且贤能的君主，在位期间就要扬名天下，哪里能默默无闻地等待几十年、几百年来成就帝王之业呢？",
      "totalCount": 120,
      "appLink": "weread://bestbookmark?bookId=42701994&chapterUid=1&rangeStart=1192&rangeEnd=1259",
      "webLink": "https://weread.qq.com/web/reader/c9732590728b94aac97e27c?chapterUid=1&rangeStart=1192&rangeEnd=1259"
    },
    {
      "bookmarkId": "42701994_1_3830-3851",
      "chapterUid": 1,
      "range": "3830-3851",
      "markText": "人民弱势，国家就强大，人民强大，国家就弱势",
      "totalCount": 120,
      "appLink": "weread://bestbookmark?bookId=42701994&chapterUid=1&rangeStart=3830&rangeEnd=3851",
      "webLink": "https://weread.qq.com/web/reader/c9732590728b94aac97e27c?chapterUid=1&rangeStart=3830&rangeEnd=3851"
    },
    {
      "bookmarkId": "42701994_1_3156-3181",
      "chapterUid": 1,
      "range": "3156-3181",
      "markText": "不独邻里之间，夫妻、父子之间也负有检举揭发的义务。",
      "totalCount": 119,
      "appLink": "weread://bestbookmark?bookId=42701994&chapterUid=1&rangeStart=3156&rangeEnd=3181",
      "webLink": "https://weread.qq.com/web/reader/c9732590728b94aac97e27c?chapterUid=1&rangeStart=3156&rangeEnd=3181"
    },
    {
      "bookmarkId": "42701994_1_3656-3703",
      "chapterUid": 1,
      "range": "3656-3703",
      "markText": "商人是游民，来往四方，以追逐利润最大化为目的，虽然可以使经营者致富，但对国家却有很强的腐蚀性。",
      "totalCount": 119,
      "appLink": "weread://bestbookmark?bookId=42701994&chapterUid=1&rangeStart=3656&rangeEnd=3703",
      "webLink": "https://weread.qq.com/web/reader/c9732590728b94aac97e27c?chapterUid=1&rangeStart=3656&rangeEnd=3703"
    },
    {
      "bookmarkId": "42701994_3_3316-3402",
      "chapterUid": 3,
      "range": "3316-3402",
      "markText": "家里有15岁以上还没有结婚的女儿，也要加倍征赋，最高可达五算。政府这么做，显然是为了鼓励结婚，多生育人口。不过，如果这个女儿到了30岁还没有出嫁，你家也不用再加倍交算赋了。",
      "totalCount": 117,
      "appLink": "weread://bestbookmark?bookId=42701994&chapterUid=3&rangeStart=3316&rangeEnd=3402",
      "webLink": "https://weread.qq.com/web/reader/c9732590728b94aac97e27c?chapterUid=3&rangeStart=3316&rangeEnd=3402"
    },
    {
      "bookmarkId": "42701994_1_1544-1555",
      "chapterUid": 1,
      "range": "1544-1555",
      "markText": "废世卿世禄，按军功授爵",
      "totalCount": 110,
      "appLink": "weread://bestbookmark?bookId=42701994&chapterUid=1&rangeStart=1544&rangeEnd=1555",
      "webLink": "https://weread.qq.com/web/reader/c9732590728b94aac97e27c?chapterUid=1&rangeStart=1544&rangeEnd=1555"
    },
    {
      "bookmarkId": "42701994_13_1482-1555",
      "chapterUid": 13,
      "range": "1482-1555",
      "markText": "公元874年，著名的私盐贩子王仙芝聚众数千人，在河南长垣揭竿而起。不久，另一名私盐贩子黄巢也加入起义的队伍中。黄巢家三代贩私盐，是个资深私盐贩子。",
      "totalCount": 108,
      "appLink": "weread://bestbookmark?bookId=42701994&chapterUid=13&rangeStart=1482&rangeEnd=1555",
      "webLink": "https://weread.qq.com/web/reader/c9732590728b94aac97e27c?chapterUid=13&rangeStart=1482&rangeEnd=1555"
    },
    {
      "bookmarkId": "42701994_19_674-692",
      "chapterUid": 19,
      "range": "674-692",
      "markText": "赵光义说：“国家之守，在德不在险。”",
      "totalCount": 105,
      "appLink": "weread://bestbookmark?bookId=42701994&chapterUid=19&rangeStart=674&rangeEnd=692",
      "webLink": "https://weread.qq.com/web/reader/c9732590728b94aac97e27c?chapterUid=19&rangeStart=674&rangeEnd=692"
    },
    {
      "bookmarkId": "42701994_2_1598-1667",
      "chapterUid": 2,
      "range": "1598-1667",
      "markText": "但同时这也可能是一个历史的陷阱，因为失去了贵族这个中间阶层，国家直接统辖无数的“编户齐民”，极容易造成国家对国民的奴役、国民对国家的依附。",
      "totalCount": 104,
      "appLink": "weread://bestbookmark?bookId=42701994&chapterUid=2&rangeStart=1598&rangeEnd=1667",
      "webLink": "https://weread.qq.com/web/reader/c9732590728b94aac97e27c?chapterUid=2&rangeStart=1598&rangeEnd=1667"
    },
    {
      "bookmarkId": "42701994_3_4764-4861",
      "chapterUid": 3,
      "range": "4764-4861",
      "markText": "另一方面，轻徭薄赋的呼声之所以不断，反映了古代君主专制对人民的横征暴敛从来也没能在较长时间内杜绝过，轻徭薄赋的各种具体主张也没有完全实现过，这是轻徭薄赋思想在中国君主专制社会贯穿始终的客观原因。",
      "totalCount": 98,
      "appLink": "weread://bestbookmark?bookId=42701994&chapterUid=3&rangeStart=4764&rangeEnd=4861",
      "webLink": "https://weread.qq.com/web/reader/c9732590728b94aac97e27c?chapterUid=3&rangeStart=4764&rangeEnd=4861"
    },
    {
      "bookmarkId": "42701994_1_1151-1160",
      "chapterUid": 1,
      "range": "1151-1160",
      "markText": "诸侯卑秦，丑莫大焉",
      "totalCount": 96,
      "appLink": "weread://bestbookmark?bookId=42701994&chapterUid=1&rangeStart=1151&rangeEnd=1160",
      "webLink": "https://weread.qq.com/web/reader/c9732590728b94aac97e27c?chapterUid=1&rangeStart=1151&rangeEnd=1160"
    },
    {
      "bookmarkId": "42701994_1_1907-1946",
      "chapterUid": 1,
      "range": "1907-1946",
      "markText": "农，就是发展农业生产，非农不足以富；战，就是强兵，非战不足以强，甚至不能自保。",
