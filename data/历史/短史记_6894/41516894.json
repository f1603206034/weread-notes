  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "41516894_5_4886-4914",
      "chapterUid": 5,
      "range": "4886-4914",
      "markText": "所谓“秦民可以通过军功来改变自己的命运”，其实只是幻象。",
      "totalCount": 255,
      "appLink": "weread://bestbookmark?bookId=41516894&chapterUid=5&rangeStart=4886&rangeEnd=4914",
      "webLink": "https://weread.qq.com/web/reader/0ee32ee072797f5e0ee9235?chapterUid=5&rangeStart=4886&rangeEnd=4914"
    },
    {
      "bookmarkId": "41516894_16_4432-4451",
      "chapterUid": 16,
      "range": "4432-4451",
      "markText": "以上种种，才是宋朝民众的真实生存状况。",
      "totalCount": 160,
      "appLink": "weread://bestbookmark?bookId=41516894&chapterUid=16&rangeStart=4432&rangeEnd=4451",
      "webLink": "https://weread.qq.com/web/reader/0ee32ee072797f5e0ee9235?chapterUid=16&rangeStart=4432&rangeEnd=4451"
    },
    {
      "bookmarkId": "41516894_5_4277-4340",
      "chapterUid": 5,
      "range": "4277-4340",
      "markText": "秦律追求凡事“皆有法式”。用《盐铁论》中的话说，则是“秦法繁于秋荼，而网密于凝脂”，无论秦民干什么说什么，总有一款秦法适合他。",
      "totalCount": 154,
      "appLink": "weread://bestbookmark?bookId=41516894&chapterUid=5&rangeStart=4277&rangeEnd=4340",
      "webLink": "https://weread.qq.com/web/reader/0ee32ee072797f5e0ee9235?chapterUid=5&rangeStart=4277&rangeEnd=4340"
    },
    {
      "bookmarkId": "41516894_3_962-1093",
      "chapterUid": 3,
      "range": "962-1093",
      "markText": "1.回归常识，是窥破谎言的核心诀窍。 2.区分“事实陈述”与“观点表达”，是对史料进行脱水的核心手段。 3.解读史料时保持克制，是考据史实的必要心态。",
      "totalCount": 153,
      "appLink": "weread://bestbookmark?bookId=41516894&chapterUid=3&rangeStart=962&rangeEnd=1093",
      "webLink": "https://weread.qq.com/web/reader/0ee32ee072797f5e0ee9235?chapterUid=3&rangeStart=962&rangeEnd=1093"
    },
    {
      "bookmarkId": "41516894_3_2805-2866",
      "chapterUid": 3,
      "range": "2805-2866",
      "markText": "许多谣言产生的原因，是信息在传播过程中出现了变异。发生这种信息变异的一个重要原因，便在于许多人在解读史料时，没有保持克制。",
      "totalCount": 150,
      "appLink": "weread://bestbookmark?bookId=41516894&chapterUid=3&rangeStart=2805&rangeEnd=2866",
      "webLink": "https://weread.qq.com/web/reader/0ee32ee072797f5e0ee9235?chapterUid=3&rangeStart=2805&rangeEnd=2866"
    },
    {
      "bookmarkId": "41516894_6_4934-5001",
      "chapterUid": 6,
      "range": "4934-5001",
      "markText": "这些出土简牍反映的史实，与《大秦赋》里“我不要当楚民，愿成秦人”的情节，可谓截然相反。故此，最好不要将《大秦赋》当成“历史正剧”来看。",
      "totalCount": 144,
      "appLink": "weread://bestbookmark?bookId=41516894&chapterUid=6&rangeStart=4934&rangeEnd=5001",
      "webLink": "https://weread.qq.com/web/reader/0ee32ee072797f5e0ee9235?chapterUid=6&rangeStart=4934&rangeEnd=5001"
    },
    {
      "bookmarkId": "41516894_4_3048-3113",
      "chapterUid": 4,
      "range": "3048-3113",
      "markText": "“解决饥荒”之说，虽不是百分百的定论，但它有史料和考古佐证，也符合事理逻辑，显然要比用道德说教构筑起来的“恭行天罚”之说更为可信。",
      "totalCount": 126,
      "appLink": "weread://bestbookmark?bookId=41516894&chapterUid=4&rangeStart=3048&rangeEnd=3113",
      "webLink": "https://weread.qq.com/web/reader/0ee32ee072797f5e0ee9235?chapterUid=4&rangeStart=3048&rangeEnd=3113"
    },
    {
      "bookmarkId": "41516894_12_3939-3992",
      "chapterUid": 12,
      "range": "3939-3992",
      "markText": "好在《木兰辞》完整地流传到了今天。否则，那个活跃于南北朝与隋唐时代的活泼泼的木兰，就真被权力给彻底抹杀了。",
      "totalCount": 126,
      "appLink": "weread://bestbookmark?bookId=41516894&chapterUid=12&rangeStart=3939&rangeEnd=3992",
      "webLink": "https://weread.qq.com/web/reader/0ee32ee072797f5e0ee9235?chapterUid=12&rangeStart=3939&rangeEnd=3992"
    },
    {
      "bookmarkId": "41516894_13_2491-2539",
      "chapterUid": 13,
      "range": "2491-2539",
      "markText": "每次实施告密任务时，便组织这批人同时动作，以造成声势引起皇帝的注意，时人把这种手段叫作“罗织”。",
      "totalCount": 126,
      "appLink": "weread://bestbookmark?bookId=41516894&chapterUid=13&rangeStart=2491&rangeEnd=2539",
      "webLink": "https://weread.qq.com/web/reader/0ee32ee072797f5e0ee9235?chapterUid=13&rangeStart=2491&rangeEnd=2539"
    },
    {
      "bookmarkId": "41516894_20_6263-6346",
      "chapterUid": 20,
      "range": "6263-6346",
      "markText": "总而言之，“阳明学是明治维新的原动力”之说，是中日两国的部分知识分子，在近代共同建构的结果，它代表了一种现实需要，但并不符合史实——只有现代思想，才能催生出现代国家。",
      "totalCount": 120,
      "appLink": "weread://bestbookmark?bookId=41516894&chapterUid=20&rangeStart=6263&rangeEnd=6346",
      "webLink": "https://weread.qq.com/web/reader/0ee32ee072797f5e0ee9235?chapterUid=20&rangeStart=6263&rangeEnd=6346"
    },
    {
      "bookmarkId": "41516894_35_6313-6387",
      "chapterUid": 35,
      "range": "6313-6387",
      "markText": "“破格”可以有，它为刚性的制度保留了一点弹性，但这弹性存在的前提，是必须有足够的“破格之难”；这种“破格之难”，才是民国大学留下的最重要的精神遗产。",
      "totalCount": 119,
      "appLink": "weread://bestbookmark?bookId=41516894&chapterUid=35&rangeStart=6313&rangeEnd=6387",
      "webLink": "https://weread.qq.com/web/reader/0ee32ee072797f5e0ee9235?chapterUid=35&rangeStart=6313&rangeEnd=6387"
    },
    {
      "bookmarkId": "41516894_7_4307-4380",
      "chapterUid": 7,
      "range": "4307-4380",
      "markText": "秦二世元年，当部队因雨滞留在大泽乡时，陈胜与吴广，这两位曾奋勇斩获“甲首”、获得过低端爵位的秦军老兵，非常清晰地意识到自己的人生，已没有了安全感。",
      "totalCount": 108,
      "appLink": "weread://bestbookmark?bookId=41516894&chapterUid=7&rangeStart=4307&rangeEnd=4380",
      "webLink": "https://weread.qq.com/web/reader/0ee32ee072797f5e0ee9235?chapterUid=7&rangeStart=4307&rangeEnd=4380"
    },
    {
      "bookmarkId": "41516894_57_4332-4352",
