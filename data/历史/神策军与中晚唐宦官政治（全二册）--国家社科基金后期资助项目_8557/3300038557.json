  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300038557_5_2295-2361",
      "chapterUid": 5,
      "range": "2295-2361",
      "markText": "汉、明两朝宦官只是皇权的延伸，皇帝可以罢废甚至处死宦官。但是，中晚唐宦官形成了庞大的使职系统，不仅与南衙朝臣抗衡，甚至可以废立君王。",
      "totalCount": 102,
      "appLink": "weread://bestbookmark?bookId=3300038557&chapterUid=5&rangeStart=2295&rangeEnd=2361",
      "webLink": "https://weread.qq.com/web/reader/3ed32300813ab758fg017ecd?chapterUid=5&rangeStart=2295&rangeEnd=2361"
    },
    {
      "bookmarkId": "3300038557_5_14017-14052",
      "chapterUid": 5,
      "range": "14017-14052",
      "markText": "我们认为，中晚唐宦官政治也是皇权政治在唐宋社会转型时期的一种变态形式。",
      "totalCount": 90,
      "appLink": "weread://bestbookmark?bookId=3300038557&chapterUid=5&rangeStart=14017&rangeEnd=14052",
      "webLink": "https://weread.qq.com/web/reader/3ed32300813ab758fg017ecd?chapterUid=5&rangeStart=14017&rangeEnd=14052"
    },
    {
      "bookmarkId": "3300038557_5_6684-6711",
      "chapterUid": 5,
      "range": "6684-6711",
      "markText": "把仇、孙、梁、王、彭、吴等宦官世家的情况第一次公布于世",
      "totalCount": 84,
      "appLink": "weread://bestbookmark?bookId=3300038557&chapterUid=5&rangeStart=6684&rangeEnd=6711",
      "webLink": "https://weread.qq.com/web/reader/3ed32300813ab758fg017ecd?chapterUid=5&rangeStart=6684&rangeEnd=6711"
    },
    {
      "bookmarkId": "3300038557_6_441-497",
      "chapterUid": 6,
      "range": "441-497",
      "markText": "军队是政权的基础，军权旁落，武将们轻则拥兵叛乱，重则弑君易主，左右朝政。中晚唐宦官跋扈的根源在于宦官专典神策军。",
      "totalCount": 84,
      "appLink": "weread://bestbookmark?bookId=3300038557&chapterUid=6&rangeStart=441&rangeEnd=497",
      "webLink": "https://weread.qq.com/web/reader/3ed32300813ab758fg017ecd?chapterUid=6&rangeStart=441&rangeEnd=497"
    },
    {
      "bookmarkId": "3300038557_13_2623-2652",
      "chapterUid": 13,
      "range": "2623-2652",
      "markText": "肃、代时期的政治传统，应重用李诵之外的一个宗王来宣扬皇威。",
      "totalCount": 80,
      "appLink": "weread://bestbookmark?bookId=3300038557&chapterUid=13&rangeStart=2623&rangeEnd=2652",
      "webLink": "https://weread.qq.com/web/reader/3ed32300813ab758fg017ecd?chapterUid=13&rangeStart=2623&rangeEnd=2652"
    },
    {
      "bookmarkId": "3300038557_5_15512-15553",
      "chapterUid": 5,
      "range": "15512-15553",
      "markText": "德宗以神策中尉执掌禁军，虽然保证军权不致旁落异姓，但也导致后世子孙受制宦官的恶果。",
      "totalCount": 72,
      "appLink": "weread://bestbookmark?bookId=3300038557&chapterUid=5&rangeStart=15512&rangeEnd=15553",
      "webLink": "https://weread.qq.com/web/reader/3ed32300813ab758fg017ecd?chapterUid=5&rangeStart=15512&rangeEnd=15553"
    },
    {
      "bookmarkId": "3300038557_15_782-866",
      "chapterUid": 15,
      "range": "782-866",
      "markText": "由于穆宗是宪宗遇弑的直接受益者，过去有些学者常把穆宗描述为弑逆案的幕后主谋。事实上，穆宗乃昏聩之人，不具有宫廷密谋的城府和心计，不仅穆宗，他的生母郭太后也没有此类心机。",
      "totalCount": 72,
      "appLink": "weread://bestbookmark?bookId=3300038557&chapterUid=15&rangeStart=782&rangeEnd=866",
      "webLink": "https://weread.qq.com/web/reader/3ed32300813ab758fg017ecd?chapterUid=15&rangeStart=782&rangeEnd=866"
    },
    {
      "bookmarkId": "3300038557_7_11446-11603",
      "chapterUid": 7,
      "range": "11446-11603",
      "markText": "认为神策军本是有地盘的野战部队，神策外镇目的是以长安为中心，设置一个直属天子的节度使级管区，使其他藩镇不敢染指中央政权",
      "totalCount": 70,
      "appLink": "weread://bestbookmark?bookId=3300038557&chapterUid=7&rangeStart=11446&rangeEnd=11603",
      "webLink": "https://weread.qq.com/web/reader/3ed32300813ab758fg017ecd?chapterUid=7&rangeStart=11446&rangeEnd=11603"
    },
    {
      "bookmarkId": "3300038557_5_10088-10173",
      "chapterUid": 5,
      "range": "10088-10173",
      "markText": "牛李双方的政治进退并不是以自己实力的强弱来决定，一次宫廷政变足以彻底改变一派官僚的命运。这也就是说，牛李党争本身具有很强的依附性，脱离依附者而专言党争，很难触及问题本质。",
      "totalCount": 68,
      "appLink": "weread://bestbookmark?bookId=3300038557&chapterUid=5&rangeStart=10088&rangeEnd=10173",
      "webLink": "https://weread.qq.com/web/reader/3ed32300813ab758fg017ecd?chapterUid=5&rangeStart=10088&rangeEnd=10173"
    },
    {
      "bookmarkId": "3300038557_7_27013-27064",
      "chapterUid": 7,
      "range": "27013-27064",
      "markText": "重建禁军的理念从建中年间以制将分掌神策军，转向依赖宦官对神策军进行整合与控制，最终形成了神策两中尉制。",
      "totalCount": 68,
      "appLink": "weread://bestbookmark?bookId=3300038557&chapterUid=7&rangeStart=27013&rangeEnd=27064",
      "webLink": "https://weread.qq.com/web/reader/3ed32300813ab758fg017ecd?chapterUid=7&rangeStart=27013&rangeEnd=27064"
    },
    {
      "bookmarkId": "3300038557_19_19417-19441",
      "chapterUid": 19,
      "range": "19417-19441",
      "markText": "穆宗时另一枢密使崔潭峻与著名文人元稹为刎颈之交。",
      "totalCount": 68,
      "appLink": "weread://bestbookmark?bookId=3300038557&chapterUid=19&rangeStart=19417&rangeEnd=19441",
      "webLink": "https://weread.qq.com/web/reader/3ed32300813ab758fg017ecd?chapterUid=19&rangeStart=19417&rangeEnd=19441"
    },
    {
      "bookmarkId": "3300038557_30_2521-2605",
      "chapterUid": 30,
      "range": "2521-2605",
      "markText": "一是重建并控制军队，尤其是对禁军的控制，二是抑制过度膨胀的相权。武将和宰相都是皇帝猜忌提防之人，君主只得转而依靠自己身边的亲信之人，为宦官干政创造了极为有利的政治空间。",
      "totalCount": 68,
      "appLink": "weread://bestbookmark?bookId=3300038557&chapterUid=30&rangeStart=2521&rangeEnd=2605",
      "webLink": "https://weread.qq.com/web/reader/3ed32300813ab758fg017ecd?chapterUid=30&rangeStart=2521&rangeEnd=2605"
    },
    {
      "bookmarkId": "3300038557_29_1110-1198",
      "chapterUid": 29,
      "range": "1110-1198",
      "markText": "如所周知，东晋门阀政治的根源在于皇权衰弱，门阀士族趁势而起。以此类推，安史乱后的政治秩序重建过程中，皇权的积弱也可能会产生一种类似门阀士族的政治势力来弥补皇权衰弱后的政治空间。",
      "totalCount": 64,
      "appLink": "weread://bestbookmark?bookId=3300038557&chapterUid=29&rangeStart=1110&rangeEnd=1198",
      "webLink": "https://weread.qq.com/web/reader/3ed32300813ab758fg017ecd?chapterUid=29&rangeStart=1110&rangeEnd=1198"
    },
    {
      "bookmarkId": "3300038557_31_6021-6053",
      "chapterUid": 31,
      "range": "6021-6053",
      "markText": "只得转而委任宦官，这一特殊政局亦可用“与宦官共天下”来加以概括。",
      "totalCount": 64,
      "appLink": "weread://bestbookmark?bookId=3300038557&chapterUid=31&rangeStart=6021&rangeEnd=6053",
      "webLink": "https://weread.qq.com/web/reader/3ed32300813ab758fg017ecd?chapterUid=31&rangeStart=6021&rangeEnd=6053"
    },
    {
      "bookmarkId": "3300038557_35_4267-4344",
      "chapterUid": 35,
      "range": "4267-4344",
      "markText": "但是自始至终，明代宦官只是皇权的政治附庸，与操控军权的唐代宦官不可同日而语。从此意义上说，中晚唐毫无疑问是中国古代宦官干政的最高峰，这就是本书的最后结论。",
      "totalCount": 64,
      "appLink": "weread://bestbookmark?bookId=3300038557&chapterUid=35&rangeStart=4267&rangeEnd=4344",
      "webLink": "https://weread.qq.com/web/reader/3ed32300813ab758fg017ecd?chapterUid=35&rangeStart=4267&rangeEnd=4344"
    },
    {
      "bookmarkId": "3300038557_5_459-525",
      "chapterUid": 5,
      "range": "459-525",
      "markText": "所谓“宦官政治”，乃指某一特定历史时期宦官集团之势力全面干预军事、政治、经济等领域，甚至左右朝政，凌驾君主之上的一种畸形的政治格局。",
      "totalCount": 60,
      "appLink": "weread://bestbookmark?bookId=3300038557&chapterUid=5&rangeStart=459&rangeEnd=525",
      "webLink": "https://weread.qq.com/web/reader/3ed32300813ab758fg017ecd?chapterUid=5&rangeStart=459&rangeEnd=525"
    },
    {
      "bookmarkId": "3300038557_7_15615-15640",
      "chapterUid": 7,
      "range": "15615-15640",
      "markText": "其后，元载因贪赎专断，与皇权发生矛盾，被代宗诛杀。",
      "totalCount": 60,
      "appLink": "weread://bestbookmark?bookId=3300038557&chapterUid=7&rangeStart=15615&rangeEnd=15640",
      "webLink": "https://weread.qq.com/web/reader/3ed32300813ab758fg017ecd?chapterUid=7&rangeStart=15615&rangeEnd=15640"
    },
    {
      "bookmarkId": "3300038557_19_22663-22742",
      "chapterUid": 19,
      "range": "22663-22742",
      "markText": "中国封建社会的一个特点是，参与中枢决策的宰相官职最初多是皇帝身边地位卑微的近臣，然后地位逐渐上升，发展为宰相。成为宰相后，与皇权日益疏远，又被新的近臣所取代。",
