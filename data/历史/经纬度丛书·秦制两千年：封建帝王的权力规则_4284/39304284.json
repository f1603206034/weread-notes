  ],
  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "39304284_4_985-1051",
      "chapterUid": 4,
      "range": "985-1051",
      "markText": "皇帝拒绝赐书给诸侯王的背后潜藏着自秦汉至明清始终袭用的古老统治术，即公开宣扬的历史脉络与运行逻辑往往并不是真实的历史脉络与运行逻辑。",
      "totalCount": 2114,
      "appLink": "weread://bestbookmark?bookId=39304284&chapterUid=4&rangeStart=985&rangeEnd=1051",
      "webLink": "https://weread.qq.com/web/reader/e31323507257bc5ce312cfc?chapterUid=4&rangeStart=985&rangeEnd=1051"
    },
    {
      "bookmarkId": "39304284_5_1393-1476",
      "chapterUid": 5,
      "range": "1393-1476",
      "markText": "告密时代不需要正人君子。因为统治者追求的不是真相，而是恐惧。只有那些没有廉耻的人，才能源源不断地供给令人战栗的素材，让天下人胆战心惊，继而陷入思想与行为的自我审查中。",
      "totalCount": 2016,
      "appLink": "weread://bestbookmark?bookId=39304284&chapterUid=5&rangeStart=1393&rangeEnd=1476",
      "webLink": "https://weread.qq.com/web/reader/e31323507257bc5ce312cfc?chapterUid=5&rangeStart=1393&rangeEnd=1476"
    },
    {
      "bookmarkId": "39304284_9_4738-4784",
      "chapterUid": 9,
      "range": "4738-4784",
      "markText": "将国家与百姓对立起来，强调国家的富强必须建立在百姓的愚昧与贫穷之上，这是商鞅变法的核心理论。",
      "totalCount": 1548,
      "appLink": "weread://bestbookmark?bookId=39304284&chapterUid=9&rangeStart=4738&rangeEnd=4784",
      "webLink": "https://weread.qq.com/web/reader/e31323507257bc5ce312cfc?chapterUid=9&rangeStart=4738&rangeEnd=4784"
    },
    {
      "bookmarkId": "39304284_7_1328-1373",
      "chapterUid": 7,
      "range": "1328-1373",
      "markText": "宏大词汇里的慷慨激昂未必能够推动时代进步，具体而微的坚守与抗争才是文明生生不息的重要根源。",
      "totalCount": 1377,
      "appLink": "weread://bestbookmark?bookId=39304284&chapterUid=7&rangeStart=1328&rangeEnd=1373",
      "webLink": "https://weread.qq.com/web/reader/e31323507257bc5ce312cfc?chapterUid=7&rangeStart=1328&rangeEnd=1373"
    },
    {
      "bookmarkId": "39304284_10_3944-3983",
      "chapterUid": 10,
      "range": "3944-3983",
      "markText": "用商鞅、韩非之道治国而讳言自己是商鞅、韩非的信徒，是中国两千年秦制时代的常态。",
      "totalCount": 1320,
      "appLink": "weread://bestbookmark?bookId=39304284&chapterUid=10&rangeStart=3944&rangeEnd=3983",
      "webLink": "https://weread.qq.com/web/reader/e31323507257bc5ce312cfc?chapterUid=10&rangeStart=3944&rangeEnd=3983"
    },
    {
      "bookmarkId": "39304284_7_1038-1114",
      "chapterUid": 7,
      "range": "1038-1114",
      "markText": "美国历史学家海斯有一段论述：“凡爱抽象的人类，而侮辱具体的个人者，或出口便是对人类应负的责任，而无暇为其邻居服务者，这类的人，我们有充足的理由不相信他。",
      "totalCount": 1188,
      "appLink": "weread://bestbookmark?bookId=39304284&chapterUid=7&rangeStart=1038&rangeEnd=1114",
      "webLink": "https://weread.qq.com/web/reader/e31323507257bc5ce312cfc?chapterUid=7&rangeStart=1038&rangeEnd=1114"
    },
    {
      "bookmarkId": "39304284_10_2695-2738",
      "chapterUid": 10,
      "range": "2695-2738",
      "markText": "这六种人吃进去的是草，挤出来的是奶，被汲取疼了也不会叫唤，是韩非子心目中最理想的国民。",
      "totalCount": 1098,
      "appLink": "weread://bestbookmark?bookId=39304284&chapterUid=10&rangeStart=2695&rangeEnd=2738",
      "webLink": "https://weread.qq.com/web/reader/e31323507257bc5ce312cfc?chapterUid=10&rangeStart=2695&rangeEnd=2738"
    },
    {
      "bookmarkId": "39304284_10_3179-3239",
      "chapterUid": 10,
      "range": "3179-3239",
      "markText": "“禁心”的意思，韩非子的解释是“远仁义，去智能”，具体说来就是一手控制资讯，一手灌输错误逻辑，二者结合可以做到无往不利。",
      "totalCount": 1040,
      "appLink": "weread://bestbookmark?bookId=39304284&chapterUid=10&rangeStart=3179&rangeEnd=3239",
      "webLink": "https://weread.qq.com/web/reader/e31323507257bc5ce312cfc?chapterUid=10&rangeStart=3179&rangeEnd=3239"
    },
    {
      "bookmarkId": "39304284_44_7538-7562",
      "chapterUid": 44,
      "range": "7538-7562",
      "markText": "但长安的繁华终究只是权力的繁华，不是民生的繁华。",
      "totalCount": 1003,
      "appLink": "weread://bestbookmark?bookId=39304284&chapterUid=44&rangeStart=7538&rangeEnd=7562",
      "webLink": "https://weread.qq.com/web/reader/e31323507257bc5ce312cfc?chapterUid=44&rangeStart=7538&rangeEnd=7562"
    },
    {
      "bookmarkId": "39304284_9_6239-6310",
      "chapterUid": 9,
      "range": "6239-6310",
      "markText": "反对不可以，歌颂也不可以，目的是造成一种“民莫敢议令”的氛围。百姓不能议论，就会减少思考。百姓只需要遵守变法推行的政策，不需要思考政策的好坏。",
      "totalCount": 1001,
      "appLink": "weread://bestbookmark?bookId=39304284&chapterUid=9&rangeStart=6239&rangeEnd=6310",
      "webLink": "https://weread.qq.com/web/reader/e31323507257bc5ce312cfc?chapterUid=9&rangeStart=6239&rangeEnd=6310"
    },
    {
      "bookmarkId": "39304284_9_4307-4337",
      "chapterUid": 9,
      "range": "4307-4337",
      "markText": "也就是说，商鞅主张将百姓的生活水准控制在最低限度的温饱线上。",
      "totalCount": 900,
      "appLink": "weread://bestbookmark?bookId=39304284&chapterUid=9&rangeStart=4307&rangeEnd=4337",
      "webLink": "https://weread.qq.com/web/reader/e31323507257bc5ce312cfc?chapterUid=9&rangeStart=4307&rangeEnd=4337"
    },
    {
      "bookmarkId": "39304284_43_5387-5425",
      "chapterUid": 43,
      "range": "5387-5425",
      "markText": "但贞观之治的士大夫仍然是幸运的，至少，李世民愿意陪他们玩这样的形式主义游戏。",
      "totalCount": 867,
      "appLink": "weread://bestbookmark?bookId=39304284&chapterUid=43&rangeStart=5387&rangeEnd=5425",
      "webLink": "https://weread.qq.com/web/reader/e31323507257bc5ce312cfc?chapterUid=43&rangeStart=5387&rangeEnd=5425"
    },
    {
      "bookmarkId": "39304284_22_2573-2635",
      "chapterUid": 22,
      "range": "2573-2635",
      "markText": "游士退出，儒术上位，无为的时代已经过去。一个以官僚集团为统治基础、对百姓实行严格控制和高效汲取的新国家已经成形。秦制回来了！",
      "totalCount": 840,
      "appLink": "weread://bestbookmark?bookId=39304284&chapterUid=22&rangeStart=2573&rangeEnd=2635",
      "webLink": "https://weread.qq.com/web/reader/e31323507257bc5ce312cfc?chapterUid=22&rangeStart=2573&rangeEnd=2635"
    },
    {
      "bookmarkId": "39304284_34_6217-6303",
      "chapterUid": 34,
      "range": "6217-6303",
      "markText": "曹魏之所以能够在汉末、三国的乱世之中胜出，核心原因并不仅仅在于曹操、曹丕个人如何雄才大略，而是他们的手段够狠、够硬、够有效，建立起了比其他军阀更强大的人力、物力的汲取机制。",
