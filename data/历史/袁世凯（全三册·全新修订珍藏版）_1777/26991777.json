      "bookmarkId": "26991777_111_2449-2486",
      "chapterUid": 111,
      "range": "2449-2486",
      "markText": "端方带走鄂军三营，武昌兵力因之空虚。待机已久的革命党人，决定趁机发动起义。",
      "totalCount": 330,
      "appLink": "weread://bestbookmark?bookId=26991777&chapterUid=111&rangeStart=2449&rangeEnd=2486",
