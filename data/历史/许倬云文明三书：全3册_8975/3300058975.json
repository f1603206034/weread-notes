  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300058975_10_8448-8498",
      "chapterUid": 10,
      "range": "8448-8498",
      "markText": "儒家对中国文化和社会的影响延续长久，一直到最近两百年来，这一主导力量才慢慢衰退，而目前几乎已经消失。",
      "totalCount": 408,
      "appLink": "weread://bestbookmark?bookId=3300058975&chapterUid=10&rangeStart=8448&rangeEnd=8498",
      "webLink": "https://weread.qq.com/web/reader/4d532d50813ab7d89g01574d?chapterUid=10&rangeStart=8448&rangeEnd=8498"
    },
    {
      "bookmarkId": "3300058975_8_483-582",
      "chapterUid": 8,
      "range": "483-582",
      "markText": "最近二十年来，人类学界出现“非洲人种扩散论”，认为现在世界各地的人类都是最后一拨儿从非洲往北移动的人种的后代，称为“现代人种”。这一理论最受质疑之处是：本来在这些地方居住的其他人种，究竟到哪里去了？",
      "totalCount": 324,
      "appLink": "weread://bestbookmark?bookId=3300058975&chapterUid=8&rangeStart=483&rangeEnd=582",
      "webLink": "https://weread.qq.com/web/reader/4d532d50813ab7d89g01574d?chapterUid=8&rangeStart=483&rangeEnd=582"
    },
    {
      "bookmarkId": "3300058975_7_1457-1538",
      "chapterUid": 7,
      "range": "1457-1538",
      "markText": "中国挟其蓄势待发的“动能”，“接过”欧美留下来的制度和观念，然而问题在于，中国人接过来的是一个正在腐烂的“现代文明”，我们怎么能盼望已经衰败的种子长出优良的果实？",
      "totalCount": 308,
      "appLink": "weread://bestbookmark?bookId=3300058975&chapterUid=7&rangeStart=1457&rangeEnd=1538",
      "webLink": "https://weread.qq.com/web/reader/4d532d50813ab7d89g01574d?chapterUid=7&rangeStart=1457&rangeEnd=1538"
    },
    {
      "bookmarkId": "3300058975_6_3119-3166",
      "chapterUid": 6,
      "range": "3119-3166",
      "markText": "只要不独断地否定其他文明，可以共同求存，不致自我毁灭——国家内部分散到一定地步，就是自我毁灭。",
      "totalCount": 288,
      "appLink": "weread://bestbookmark?bookId=3300058975&chapterUid=6&rangeStart=3119&rangeEnd=3166",
      "webLink": "https://weread.qq.com/web/reader/4d532d50813ab7d89g01574d?chapterUid=6&rangeStart=3119&rangeEnd=3166"
    },
    {
      "bookmarkId": "3300058975_17_7781-7870",
      "chapterUid": 17,
      "range": "7781-7870",
      "markText": "如果可以适当地利用民间的自治能力，中国不仅可以由此来抵抗美国的压力，也可以由此开拓新的局面。如果我的话能帮助同胞们想一想，不管是在官的还是在野的，我死而无憾，死在讲台上我也愿意。",
      "totalCount": 252,
      "appLink": "weread://bestbookmark?bookId=3300058975&chapterUid=17&rangeStart=7781&rangeEnd=7870",
      "webLink": "https://weread.qq.com/web/reader/4d532d50813ab7d89g01574d?chapterUid=17&rangeStart=7781&rangeEnd=7870"
    },
    {
      "bookmarkId": "3300058975_17_8720-8786",
      "chapterUid": 17,
      "range": "8720-8786",
      "markText": "我衷心盼望将来中国不再一味发展大型城市，大型城市往往大而无当。可以发展许多中型城市，用快速交通连接，城市之间留下农耕地，这要好得多。",
      "totalCount": 238,
      "appLink": "weread://bestbookmark?bookId=3300058975&chapterUid=17&rangeStart=8720&rangeEnd=8786",
      "webLink": "https://weread.qq.com/web/reader/4d532d50813ab7d89g01574d?chapterUid=17&rangeStart=8720&rangeEnd=8786"
    },
    {
      "bookmarkId": "3300058975_10_8216-8264",
      "chapterUid": 10,
      "range": "8216-8264",
      "markText": "有见识的人，当有为之年，对应为之事，应当积极进取；在无力的老年，或面对不应为之事，则应宁静淡泊。",
      "totalCount": 234,
      "appLink": "weread://bestbookmark?bookId=3300058975&chapterUid=10&rangeStart=8216&rangeEnd=8264",
      "webLink": "https://weread.qq.com/web/reader/4d532d50813ab7d89g01574d?chapterUid=10&rangeStart=8216&rangeEnd=8264"
    },
    {
      "bookmarkId": "3300058975_16_10416-10482",
      "chapterUid": 16,
      "range": "10416-10482",
      "markText": "视野不能狭窄和短促，结构和思想不能僵化，在面对未来时，不要自限脚步、自设樊篱。来日多难，也多机缘，如何自求多福，全在我们自己的选择。",
      "totalCount": 221,
      "appLink": "weread://bestbookmark?bookId=3300058975&chapterUid=16&rangeStart=10416&rangeEnd=10482",
      "webLink": "https://weread.qq.com/web/reader/4d532d50813ab7d89g01574d?chapterUid=16&rangeStart=10416&rangeEnd=10482"
    },
    {
      "bookmarkId": "3300058975_47_2664-2726",
      "chapterUid": 47,
      "range": "2664-2726",
      "markText": "我们恐怕是当今世界，唯一可以将个人主义的极端性加以矫正的力量，所以，在这个特别的时机，我愿意把这些想法提出来，是心有戚戚焉。",
      "totalCount": 216,
      "appLink": "weread://bestbookmark?bookId=3300058975&chapterUid=47&rangeStart=2664&rangeEnd=2726",
      "webLink": "https://weread.qq.com/web/reader/4d532d50813ab7d89g01574d?chapterUid=47&rangeStart=2664&rangeEnd=2726"
    },
    {
      "bookmarkId": "3300058975_6_2663-2725",
      "chapterUid": 6,
      "range": "2663-2725",
      "markText": "我们恐怕是当今世界，唯一可以将个人主义的极端性加以矫正的力量，所以，在这个特别的时机，我愿意把这些想法提出来，是心有戚戚焉。",
      "totalCount": 204,
      "appLink": "weread://bestbookmark?bookId=3300058975&chapterUid=6&rangeStart=2663&rangeEnd=2725",
      "webLink": "https://weread.qq.com/web/reader/4d532d50813ab7d89g01574d?chapterUid=6&rangeStart=2663&rangeEnd=2725"
    },
    {
      "bookmarkId": "3300058975_9_7554-7598",
      "chapterUid": 9,
      "range": "7554-7598",
      "markText": "雅典其实是一个非常保守的国家，不愿意接受任何制度改变的可能，这和真正的民主有相当的距离。",
      "totalCount": 192,
      "appLink": "weread://bestbookmark?bookId=3300058975&chapterUid=9&rangeStart=7554&rangeEnd=7598",
      "webLink": "https://weread.qq.com/web/reader/4d532d50813ab7d89g01574d?chapterUid=9&rangeStart=7554&rangeEnd=7598"
    },
    {
      "bookmarkId": "3300058975_8_10367-10465",
