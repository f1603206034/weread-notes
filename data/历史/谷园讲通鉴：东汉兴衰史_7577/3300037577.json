  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300037577_15_3033-3104",
      "chapterUid": 15,
      "range": "3033-3104",
      "markText": "刘秀始终表现得很友善，凡是各地进贡来什么奇珍异宝、好吃好玩的，他都拿出来遍赐诸侯，自己什么也不留。最终，这三百六十五个开国功臣，一个也没被杀。",
      "totalCount": 150,
      "appLink": "weread://bestbookmark?bookId=3300037577&chapterUid=15&rangeStart=3033&rangeEnd=3104",
      "webLink": "https://weread.qq.com/web/reader/17232eb0813ab752dg017940?chapterUid=15&rangeStart=3033&rangeEnd=3104"
    },
    {
      "bookmarkId": "3300037577_6_3851-3902",
      "chapterUid": 6,
      "range": "3851-3902",
      "markText": "原来稳稳当当的大汉帝国的周边体系是经过汉武帝以来上百年用无数生命换来的，被王莽一改名，便完全破坏掉了。",
      "totalCount": 144,
      "appLink": "weread://bestbookmark?bookId=3300037577&chapterUid=6&rangeStart=3851&rangeEnd=3902",
      "webLink": "https://weread.qq.com/web/reader/17232eb0813ab752dg017940?chapterUid=6&rangeStart=3851&rangeEnd=3902"
    },
    {
      "bookmarkId": "3300037577_4_855-886",
      "chapterUid": 4,
      "range": "855-886",
      "markText": "秦皇、汉武虽有大功，却都是暴君，刘邦身上的“流氓气”也让人难受",
      "totalCount": 126,
      "appLink": "weread://bestbookmark?bookId=3300037577&chapterUid=4&rangeStart=855&rangeEnd=886",
      "webLink": "https://weread.qq.com/web/reader/17232eb0813ab752dg017940?chapterUid=4&rangeStart=855&rangeEnd=886"
    },
    {
      "bookmarkId": "3300037577_5_1217-1239",
      "chapterUid": 5,
      "range": "1217-1239",
      "markText": "人们工作都是出于天性喜好，而不是为了得到回报",
      "totalCount": 119,
      "appLink": "weread://bestbookmark?bookId=3300037577&chapterUid=5&rangeStart=1217&rangeEnd=1239",
      "webLink": "https://weread.qq.com/web/reader/17232eb0813ab752dg017940?chapterUid=5&rangeStart=1217&rangeEnd=1239"
    },
    {
      "bookmarkId": "3300037577_31_12795-12805",
      "chapterUid": 31,
      "range": "12795-12805",
      "markText": "谦和顺是女德的关键。",
      "totalCount": 112,
      "appLink": "weread://bestbookmark?bookId=3300037577&chapterUid=31&rangeStart=12795&rangeEnd=12805",
      "webLink": "https://weread.qq.com/web/reader/17232eb0813ab752dg017940?chapterUid=31&rangeStart=12795&rangeEnd=12805"
    },
    {
      "bookmarkId": "3300037577_9_8026-8074",
      "chapterUid": 9,
      "range": "8026-8074",
      "markText": "刘秀拿到这些信，是不是要仔细清查呢？没有，他瞅都没瞅，下令把将领们都召集来，将这堆书信当众烧掉。",
      "totalCount": 105,
      "appLink": "weread://bestbookmark?bookId=3300037577&chapterUid=9&rangeStart=8026&rangeEnd=8074",
      "webLink": "https://weread.qq.com/web/reader/17232eb0813ab752dg017940?chapterUid=9&rangeStart=8026&rangeEnd=8074"
    },
    {
      "bookmarkId": "3300037577_6_7352-7379",
      "chapterUid": 6,
      "range": "7352-7379",
      "markText": "历史给人们的最大教训就是人们从未在历史中吸取任何教训。",
      "totalCount": 96,
      "appLink": "weread://bestbookmark?bookId=3300037577&chapterUid=6&rangeStart=7352&rangeEnd=7379",
      "webLink": "https://weread.qq.com/web/reader/17232eb0813ab752dg017940?chapterUid=6&rangeStart=7352&rangeEnd=7379"
    },
    {
      "bookmarkId": "3300037577_5_1297-1332",
      "chapterUid": 5,
      "range": "1297-1332",
      "markText": "孔子称之为“大同”的这种理想社会，随即成为两千多年来中国人的共同理想。",
      "totalCount": 90,
      "appLink": "weread://bestbookmark?bookId=3300037577&chapterUid=5&rangeStart=1297&rangeEnd=1332",
      "webLink": "https://weread.qq.com/web/reader/17232eb0813ab752dg017940?chapterUid=5&rangeStart=1297&rangeEnd=1332"
    },
    {
      "bookmarkId": "3300037577_6_658-707",
      "chapterUid": 6,
      "range": "658-707",
      "markText": "那么多人崇拜他、拥护他，这个时候，他终于把持不住了！换谁也把持不住，不可能不飘飘然，不可能不骄狂。",
      "totalCount": 90,
      "appLink": "weread://bestbookmark?bookId=3300037577&chapterUid=6&rangeStart=658&rangeEnd=707",
      "webLink": "https://weread.qq.com/web/reader/17232eb0813ab752dg017940?chapterUid=6&rangeStart=658&rangeEnd=707"
    },
    {
      "bookmarkId": "3300037577_6_736-831",
      "chapterUid": 6,
      "range": "736-831",
      "markText": "曾国藩有个说法，一个人如果没经历足够多的挫折和失败就取得很大的成功，这样的人容易有一个毛病，那就是“视事太易”，会把什么事情都想得太容易、太简单，以为世上无难事，这样的人做事早晚要出大问题。",
      "totalCount": 90,
      "appLink": "weread://bestbookmark?bookId=3300037577&chapterUid=6&rangeStart=736&rangeEnd=831",
      "webLink": "https://weread.qq.com/web/reader/17232eb0813ab752dg017940?chapterUid=6&rangeStart=736&rangeEnd=831"
    },
    {
      "bookmarkId": "3300037577_3_1044-1102",
      "chapterUid": 3,
      "range": "1044-1102",
      "markText": "文言文好比马车；白话文好比汽车；视音频好比动车。我要让国学经典接地气，就得把马车上的东西，搬到汽车上，也搬到动车上。",
      "totalCount": 85,
      "appLink": "weread://bestbookmark?bookId=3300037577&chapterUid=3&rangeStart=1044&rangeEnd=1102",
      "webLink": "https://weread.qq.com/web/reader/17232eb0813ab752dg017940?chapterUid=3&rangeStart=1044&rangeEnd=1102"
    },
    {
      "bookmarkId": "3300037577_5_3277-3328",
      "chapterUid": 5,
      "range": "3277-3328",
      "markText": "王莽太着急了。历史上所有的社会改革从来都不是一蹴而就的，都得是分步骤、渐进式的。王莽没有这个历史认知。",
      "totalCount": 85,
      "appLink": "weread://bestbookmark?bookId=3300037577&chapterUid=5&rangeStart=3277&rangeEnd=3328",
      "webLink": "https://weread.qq.com/web/reader/17232eb0813ab752dg017940?chapterUid=5&rangeStart=3277&rangeEnd=3328"
    },
    {
      "bookmarkId": "3300037577_27_9070-9141",
      "chapterUid": 27,
      "range": "9070-9141",
      "markText": "耿恭眼前一亮：太好了！弟兄们，终于能吃点腥荤了。 直接把这个使者给煮了吃了。继续坚守。",
      "totalCount": 85,
      "appLink": "weread://bestbookmark?bookId=3300037577&chapterUid=27&rangeStart=9070&rangeEnd=9141",
      "webLink": "https://weread.qq.com/web/reader/17232eb0813ab752dg017940?chapterUid=27&rangeStart=9070&rangeEnd=9141"
    },
    {
      "bookmarkId": "3300037577_17_10267-10336",
      "chapterUid": 17,
      "range": "10267-10336",
      "markText": "士生一世，但取衣食裁足，乘下泽车，御款段马，为郡掾史，守坟墓，乡里称善人，斯可矣。致求盈余，但自苦耳。——《后汉书·马援传》",
      "totalCount": 75,
      "appLink": "weread://bestbookmark?bookId=3300037577&chapterUid=17&rangeStart=10267&rangeEnd=10336",
      "webLink": "https://weread.qq.com/web/reader/17232eb0813ab752dg017940?chapterUid=17&rangeStart=10267&rangeEnd=10336"
    },
    {
      "bookmarkId": "3300037577_35_6798-6857",
      "chapterUid": 35,
      "range": "6798-6857",
      "markText": "几天后，真有从成都到南阳的人说，就在那天那时那刻成都正发生一场大火灾，突然打东边乌云满天，一场大暴雨袭来，把火浇灭了。",
      "totalCount": 75,
      "appLink": "weread://bestbookmark?bookId=3300037577&chapterUid=35&rangeStart=6798&rangeEnd=6857",
      "webLink": "https://weread.qq.com/web/reader/17232eb0813ab752dg017940?chapterUid=35&rangeStart=6798&rangeEnd=6857"
    },
    {
      "bookmarkId": "3300037577_9_1048-1072",
      "chapterUid": 9,
      "range": "1048-1072",
      "markText": "疾风知劲草。——《后汉书·王霸传》",
