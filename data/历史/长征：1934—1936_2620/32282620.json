      "appLink": "weread://bestbookmark?bookId=32282620&chapterUid=7&rangeStart=11934&rangeEnd=11972",
      "webLink": "https://weread.qq.com/web/reader/4003260071ec97fc4008024?chapterUid=7&rangeStart=11934&rangeEnd=11972"
    },
