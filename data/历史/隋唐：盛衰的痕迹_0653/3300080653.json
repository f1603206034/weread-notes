  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300080653_38_557-618",
      "chapterUid": 38,
      "range": "557-618",
      "markText": "皇权在科举官僚和宦官的加持下，凌驾于贵族之上，而宦官作为皇权的延伸，从中央到地方都产生影响，逐渐成为皇位传承的主要执行者。",
      "totalCount": 108,
      "appLink": "weread://bestbookmark?bookId=3300080653&chapterUid=38&rangeStart=557&rangeEnd=618",
      "webLink": "https://weread.qq.com/web/reader/16032970813ab8601g013683?chapterUid=38&rangeStart=557&rangeEnd=618"
    },
    {
      "bookmarkId": "3300080653_42_1252-1270",
      "chapterUid": 42,
      "range": "1252-1270",
      "markText": "结果被指控品题朝士，贬为新州新兴尉。",
      "totalCount": 90,
      "appLink": "weread://bestbookmark?bookId=3300080653&chapterUid=42&rangeStart=1252&rangeEnd=1270",
      "webLink": "https://weread.qq.com/web/reader/16032970813ab8601g013683?chapterUid=42&rangeStart=1252&rangeEnd=1270"
    },
    {
      "bookmarkId": "3300080653_55_9748-9818",
      "chapterUid": 55,
      "range": "9748-9818",
      "markText": "内政与外交的连环性也因之后急转直下的局势而被演绎得格外生动，让人忍不住幻想，如果没有后来的安史之乱，不出意外，唐朝将在对吐蕃战争中取得完胜。",
      "totalCount": 85,
      "appLink": "weread://bestbookmark?bookId=3300080653&chapterUid=55&rangeStart=9748&rangeEnd=9818",
      "webLink": "https://weread.qq.com/web/reader/16032970813ab8601g013683?chapterUid=55&rangeStart=9748&rangeEnd=9818"
    },
    {
      "bookmarkId": "3300080653_33_485-526",
      "chapterUid": 33,
      "range": "485-526",
      "markText": "据史书记载，其生性英明果断、多才多艺、刻薄寡恩、睚眦必报，确实有一些处女座的特征。",
      "totalCount": 60,
      "appLink": "weread://bestbookmark?bookId=3300080653&chapterUid=33&rangeStart=485&rangeEnd=526",
      "webLink": "https://weread.qq.com/web/reader/16032970813ab8601g013683?chapterUid=33&rangeStart=485&rangeEnd=526"
    },
    {
      "bookmarkId": "3300080653_48_4492-4538",
      "chapterUid": 48,
      "range": "4492-4538",
      "markText": "士大夫耻于谈利，《旧唐书》对于宇文融的记载略为公平，而《资治通鉴》就对宇文融大加丑化和贬损。",
      "totalCount": 56,
      "appLink": "weread://bestbookmark?bookId=3300080653&chapterUid=48&rangeStart=4492&rangeEnd=4538",
      "webLink": "https://weread.qq.com/web/reader/16032970813ab8601g013683?chapterUid=48&rangeStart=4492&rangeEnd=4538"
    },
    {
      "bookmarkId": "3300080653_51_1593-1673",
      "chapterUid": 51,
      "range": "1593-1673",
      "markText": "。在史书中，李林甫被反复抹黑，说他得到相位，是因为托了武惠妃的关系，甚至说他跟裴光庭的妻子有私情等。但是毫无疑问，李林甫的才干几乎得到了前任宰相群体的一致认可。",
      "totalCount": 56,
      "appLink": "weread://bestbookmark?bookId=3300080653&chapterUid=51&rangeStart=1593&rangeEnd=1673",
      "webLink": "https://weread.qq.com/web/reader/16032970813ab8601g013683?chapterUid=51&rangeStart=1593&rangeEnd=1673"
    },
    {
      "bookmarkId": "3300080653_5_624-636",
      "chapterUid": 5,
      "range": "624-636",
      "markText": "告密是对人伦最大的破坏。",
      "totalCount": 54,
      "appLink": "weread://bestbookmark?bookId=3300080653&chapterUid=5&rangeStart=624&rangeEnd=636",
      "webLink": "https://weread.qq.com/web/reader/16032970813ab8601g013683?chapterUid=5&rangeStart=624&rangeEnd=636"
    },
    {
      "bookmarkId": "3300080653_55_5599-5622",
      "chapterUid": 55,
      "range": "5599-5622",
      "markText": "吐蕃误以为唐朝大军来袭，惊慌之下开始自相残杀。",
      "totalCount": 54,
      "appLink": "weread://bestbookmark?bookId=3300080653&chapterUid=55&rangeStart=5599&rangeEnd=5622",
      "webLink": "https://weread.qq.com/web/reader/16032970813ab8601g013683?chapterUid=55&rangeStart=5599&rangeEnd=5622"
    },
    {
      "bookmarkId": "3300080653_63_4941-4985",
      "chapterUid": 63,
      "range": "4941-4985",
      "markText": "绝大多数人虽然在这个世界上有过喜怒哀乐，但千年之后片瓦不存。没有人知道你曾来过这个世界。",
      "totalCount": 54,
      "appLink": "weread://bestbookmark?bookId=3300080653&chapterUid=63&rangeStart=4941&rangeEnd=4985",
      "webLink": "https://weread.qq.com/web/reader/16032970813ab8601g013683?chapterUid=63&rangeStart=4941&rangeEnd=4985"
    },
    {
      "bookmarkId": "3300080653_7_3536-3554",
      "chapterUid": 7,
      "range": "3536-3554",
      "markText": "裴伷先过山车般的命运并没有停止于此。",
      "totalCount": 52,
      "appLink": "weread://bestbookmark?bookId=3300080653&chapterUid=7&rangeStart=3536&rangeEnd=3554",
      "webLink": "https://weread.qq.com/web/reader/16032970813ab8601g013683?chapterUid=7&rangeStart=3536&rangeEnd=3554"
    },
    {
      "bookmarkId": "3300080653_20_662-687",
      "chapterUid": 20,
      "range": "662-687",
      "markText": "武则天的表现——不考虑她女性的身份——的确不杰出。",
      "totalCount": 52,
      "appLink": "weread://bestbookmark?bookId=3300080653&chapterUid=20&rangeStart=662&rangeEnd=687",
      "webLink": "https://weread.qq.com/web/reader/16032970813ab8601g013683?chapterUid=20&rangeStart=662&rangeEnd=687"
    },
    {
      "bookmarkId": "3300080653_5_6646-6726",
