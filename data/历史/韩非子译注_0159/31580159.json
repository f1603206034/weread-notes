    {
      "chapterUid": 24,
      "chapterTitle": "第七卷",
      "items": [
        {
          "type": "highlight",
          "bookmarkId": "31580159_24_5196-5571",
          "range": "5196-5571",
          "rangeStart": 5196,
          "rangeEnd": 5571,
          "markText": "越王入宦于吴1，而观之伐齐以弊吴。吴兵既胜齐人于艾陵2，张之于江、济，强之于黄池3，故可制于五湖4。故曰：“将欲翕之，必固张之5；将欲弱之，必固强之。”晋献公将欲袭虞，遗之以璧马6；知伯将袭仇由7，遗之以广车。故曰：“将欲取之，必固与之。”起事于无形，而要大功于天下8，“是谓微明”。处小弱而重自卑，谓“损弱胜强”也。",
          "colorStyle": 0,
          "colorLabel": "",
          "createTime": 1735530369,
          "createTimeFormatted": "2024-12-30 11:46:09",
          "chapterUid": 24,
          "appLink": "weread://bestbookmark?bookId=31580159&chapterUid=24&rangeStart=5196&rangeEnd=5571",
          "webLink": "https://weread.qq.com/web/reader/7e73277071e1dfff7e755df?chapterUid=24&rangeStart=5196&rangeEnd=5571"
        }
      ]
    },
