  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "36235888_5_3444-3515",
      "chapterUid": 5,
      "range": "3444-3515",
      "markText": "武帝泰始元年，封诸王，以郡为国。邑二万户为大国，置上中下三军，兵五千人；邑万户为次国，置上军下军，兵三千人；五千户为小国，置一军，兵千五百人。",
      "totalCount": 72,
      "appLink": "weread://bestbookmark?bookId=36235888&chapterUid=5&rangeStart=3444&rangeEnd=3515",
      "webLink": "https://weread.qq.com/web/reader/66b325107228ea7066bf34d?chapterUid=5&rangeStart=3444&rangeEnd=3515"
    },
    {
      "bookmarkId": "36235888_4_3433-3469",
      "chapterUid": 4,
      "range": "3433-3469",
      "markText": "母常欲生鱼，时天寒冰冻，祥解衣将剖冰求之，冰忽自解，双鲤跃出，持之而归。",
      "totalCount": 64,
      "appLink": "weread://bestbookmark?bookId=36235888&chapterUid=4&rangeStart=3433&rangeEnd=3469",
      "webLink": "https://weread.qq.com/web/reader/66b325107228ea7066bf34d?chapterUid=4&rangeStart=3433&rangeEnd=3469"
    },
    {
      "bookmarkId": "36235888_4_3866-3952",
      "chapterUid": 4,
      "range": "3866-3952",
      "markText": "又曰：“荀、何，君子之宗也。”然性奢豪，务在华侈。帷帐车服，穷极绮丽，厨膳滋味，过于王者。每燕见，不食太官所设，帝辄命取其食。蒸饼上不坼作十字不食。食日万钱，犹曰无下箸处。",
      "totalCount": 64,
      "appLink": "weread://bestbookmark?bookId=36235888&chapterUid=4&rangeStart=3866&rangeEnd=3952",
      "webLink": "https://weread.qq.com/web/reader/66b325107228ea7066bf34d?chapterUid=4&rangeStart=3866&rangeEnd=3952"
    },
    {
      "bookmarkId": "36235888_4_5417-5439",
      "chapterUid": 4,
      "range": "5417-5439",
      "markText": "植妻衣绣，太祖登台见之，以违制，命还家赐死。",
      "totalCount": 52,
      "appLink": "weread://bestbookmark?bookId=36235888&chapterUid=4&rangeStart=5417&rangeEnd=5439",
      "webLink": "https://weread.qq.com/web/reader/66b325107228ea7066bf34d?chapterUid=4&rangeStart=5417&rangeEnd=5439"
    },
    {
      "bookmarkId": "36235888_4_4458-4609",
      "chapterUid": 4,
      "range": "4458-4609",
      "markText": "皇太子将纳妃，顗上言贾充女姿德淑茂，可以参选，以此获讥于世。",
      "totalCount": 48,
      "appLink": "weread://bestbookmark?bookId=36235888&chapterUid=4&rangeStart=4458&rangeEnd=4609",
      "webLink": "https://weread.qq.com/web/reader/66b325107228ea7066bf34d?chapterUid=4&rangeStart=4458&rangeEnd=4609"
    },
    {
      "bookmarkId": "36235888_4_3691-3765",
      "chapterUid": 4,
      "range": "3691-3765",
      "markText": "曾性至孝，闺门整肃，自少及长，无声乐嬖幸之好。年老之后，与妻相见，皆正衣冠，相待如宾。己南向，妻北面，再拜上酒，酬酢既毕便出，一岁如此者不过再三焉。",
      "totalCount": 44,
      "appLink": "weread://bestbookmark?bookId=36235888&chapterUid=4&rangeStart=3691&rangeEnd=3765",
      "webLink": "https://weread.qq.com/web/reader/66b325107228ea7066bf34d?chapterUid=4&rangeStart=3691&rangeEnd=3765"
    },
    {
      "bookmarkId": "36235888_4_1222-1279",
      "chapterUid": 4,
      "range": "1222-1279",
      "markText": "诸子虽冠成人，不命曰进不敢进，不命曰坐不敢坐，不指有所问不敢言，父子之间肃如也。有子八人，朗最长，次即晋宣皇帝也。",
      "totalCount": 39,
      "appLink": "weread://bestbookmark?bookId=36235888&chapterUid=4&rangeStart=1222&rangeEnd=1279",
      "webLink": "https://weread.qq.com/web/reader/66b325107228ea7066bf34d?chapterUid=4&rangeStart=1222&rangeEnd=1279"
    },
    {
      "bookmarkId": "36235888_4_12505-12574",
      "chapterUid": 4,
      "range": "12505-12574",
      "markText": "民风国势如此，虽以中庸之才，守文之主治之，辛有必见之于祭祀，季札必得之于声乐，范燮必为之请死，贾谊必为之痛哭，又况我惠帝以放荡之德临之哉！",
      "totalCount": 36,
      "appLink": "weread://bestbookmark?bookId=36235888&chapterUid=4&rangeStart=12505&rangeEnd=12574",
      "webLink": "https://weread.qq.com/web/reader/66b325107228ea7066bf34d?chapterUid=4&rangeStart=12505&rangeEnd=12574"
    },
    {
      "bookmarkId": "36235888_6_1778-1826",
      "chapterUid": 6,
      "range": "1778-1826",
      "markText": "“遂使神州陆沉，百年丘墟，王夷甫诸人不得不任其责。”袁虎率尔对曰：“运自有废兴，岂必诸人之过？”",
      "totalCount": 36,
      "appLink": "weread://bestbookmark?bookId=36235888&chapterUid=6&rangeStart=1778&rangeEnd=1826",
      "webLink": "https://weread.qq.com/web/reader/66b325107228ea7066bf34d?chapterUid=6&rangeStart=1778&rangeEnd=1826"
    },
    {
      "bookmarkId": "36235888_8_1278-1313",
      "chapterUid": 8,
      "range": "1278-1313",
      "markText": "又陈：“羌胡与民同处者，宜以渐出之，使居民表崇廉耻之教，塞奸宄之路。”",
      "totalCount": 36,
      "appLink": "weread://bestbookmark?bookId=36235888&chapterUid=8&rangeStart=1278&rangeEnd=1313",
      "webLink": "https://weread.qq.com/web/reader/66b325107228ea7066bf34d?chapterUid=8&rangeStart=1278&rangeEnd=1313"
    },
    {
      "bookmarkId": "36235888_29_3353-3388",
      "chapterUid": 29,
      "range": "3353-3388",
      "markText": "汝于李勣无恩，我今将责出之。我死后汝当授以仆射，即荷汝恩，必致其死力。",
      "totalCount": 36,
      "appLink": "weread://bestbookmark?bookId=36235888&chapterUid=29&rangeStart=3353&rangeEnd=3388",
      "webLink": "https://weread.qq.com/web/reader/66b325107228ea7066bf34d?chapterUid=29&rangeStart=3353&rangeEnd=3388"
    },
    {
      "bookmarkId": "36235888_4_9434-9528",
      "chapterUid": 4,
      "range": "9434-9528",
      "markText": "陈骞，临淮东阳人也。父矫，魏司徒。武帝受禅，以佐命之勋，封高平郡公。与贾充、石苞、裴秀等俱为心膂，而骞智度过之，充等亦自以为不及也。弟稚与其子舆忿争，遂说骞子女秽行，骞表徙弟，以此获讥于世",
      "totalCount": 34,
      "appLink": "weread://bestbookmark?bookId=36235888&chapterUid=4&rangeStart=9434&rangeEnd=9528",
      "webLink": "https://weread.qq.com/web/reader/66b325107228ea7066bf34d?chapterUid=4&rangeStart=9434&rangeEnd=9528"
    },
    {
      "bookmarkId": "36235888_4_11649-11681",
      "chapterUid": 4,
      "range": "11649-11681",
      "markText": "峤家产丰富，拟于王者，然性至吝，以是获讥于世，杜预以为峤有钱癖。",
      "totalCount": 34,
      "appLink": "weread://bestbookmark?bookId=36235888&chapterUid=4&rangeStart=11649&rangeEnd=11681",
      "webLink": "https://weread.qq.com/web/reader/66b325107228ea7066bf34d?chapterUid=4&rangeStart=11649&rangeEnd=11681"
    },
    {
      "bookmarkId": "36235888_4_6903-6942",
      "chapterUid": 4,
      "range": "6903-6942",
      "markText": "司马懿父子，自握其柄，累有大功，除其烦苛而布其平惠，为之谋主而救其疾，民心归之",
      "totalCount": 32,
      "appLink": "weread://bestbookmark?bookId=36235888&chapterUid=4&rangeStart=6903&rangeEnd=6942",
      "webLink": "https://weread.qq.com/web/reader/66b325107228ea7066bf34d?chapterUid=4&rangeStart=6903&rangeEnd=6942"
    },
    {
      "bookmarkId": "36235888_11_2742-2770",
      "chapterUid": 11,
      "range": "2742-2770",
      "markText": "因过胡人前，弹指云：“兰阇，兰阇。”群胡同笑，四坐并欢。",
      "totalCount": 30,
      "appLink": "weread://bestbookmark?bookId=36235888&chapterUid=11&rangeStart=2742&rangeEnd=2770",
      "webLink": "https://weread.qq.com/web/reader/66b325107228ea7066bf34d?chapterUid=11&rangeStart=2742&rangeEnd=2770"
    },
    {
      "bookmarkId": "36235888_34_9517-9583",
      "chapterUid": 34,
      "range": "9517-9583",
      "markText": "杨钊，张易之之甥也，奏乞昭雪易之兄弟。庚辰，制引易之兄弟迎中宗于房陵之功，复其官爵，仍赐一子官。钊以图谶有金刀，请更名，上赐名国忠。",
      "totalCount": 30,
      "appLink": "weread://bestbookmark?bookId=36235888&chapterUid=34&rangeStart=9517&rangeEnd=9583",
      "webLink": "https://weread.qq.com/web/reader/66b325107228ea7066bf34d?chapterUid=34&rangeStart=9517&rangeEnd=9583"
    },
    {
      "bookmarkId": "36235888_55_2045-2071",
      "chapterUid": 55,
      "range": "2045-2071",
      "markText": "陈敏何以不能如孙氏之创业垂统，历数十年之久，基业未定",
      "totalCount": 30,
      "appLink": "weread://bestbookmark?bookId=36235888&chapterUid=55&rangeStart=2045&rangeEnd=2071",
      "webLink": "https://weread.qq.com/web/reader/66b325107228ea7066bf34d?chapterUid=55&rangeStart=2045&rangeEnd=2071"
    },
    {
      "bookmarkId": "36235888_4_9722-9750",
      "chapterUid": 4,
      "range": "9722-9750",
      "markText": "苞时奔丧，恸哭曰：“基业如此，而以人臣终乎！”葬礼乃定。",
