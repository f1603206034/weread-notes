  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300168276_8_2303-2364",
      "chapterUid": 8,
      "range": "2303-2364",
      "markText": "我恳请大家暂时将欧洲及其历史视为从属于亚洲及其历史的一部分，因为从非常真实的意义上来说，欧洲文明是长期抵御亚洲入侵的产物。",
      "totalCount": 187,
      "appLink": "weread://bestbookmark?bookId=3300168276&chapterUid=8&rangeStart=2303&rangeEnd=2364",
      "webLink": "https://weread.qq.com/web/reader/fac32610813aba83bg016ee4?chapterUid=8&rangeStart=2303&rangeEnd=2364"
    },
    {
      "bookmarkId": "3300168276_6_639-673",
      "chapterUid": 6,
      "range": "639-673",
      "markText": "地理学能否成为一门培养思维能力的学科，而非仅仅是一堆零散信息的集合？",
      "totalCount": 144,
      "appLink": "weread://bestbookmark?bookId=3300168276&chapterUid=6&rangeStart=639&rangeEnd=673",
      "webLink": "https://weread.qq.com/web/reader/fac32610813aba83bg016ee4?chapterUid=6&rangeStart=639&rangeEnd=673"
    },
    {
      "bookmarkId": "3300168276_8_14057-14150",
      "chapterUid": 8,
      "range": "14057-14150",
      "markText": "倘若中国在日本的组织下推翻俄罗斯帝国并征服其领土，那么他们将同时拥有海洋优势与庞大的大陆资源——这是目前占据枢纽地带的俄国尚未具备的有利条件，届时便可能形成对世界自由构成威胁的“黄祸”。",
      "totalCount": 132,
      "appLink": "weread://bestbookmark?bookId=3300168276&chapterUid=8&rangeStart=14057&rangeEnd=14150",
      "webLink": "https://weread.qq.com/web/reader/fac32610813aba83bg016ee4?chapterUid=8&rangeStart=14057&rangeEnd=14150"
    },
    {
      "bookmarkId": "3300168276_6_2364-2410",
      "chapterUid": 6,
      "range": "2364-2410",
      "markText": "因此，我建议将地理学定义为：一门以探寻人类社会与局部变化的环境之间相互作用为主要职能的科学。",
      "totalCount": 117,
      "appLink": "weread://bestbookmark?bookId=3300168276&chapterUid=6&rangeStart=2364&rangeEnd=2410",
      "webLink": "https://weread.qq.com/web/reader/fac32610813aba83bg016ee4?chapterUid=6&rangeStart=2364&rangeEnd=2410"
    },
    {
      "bookmarkId": "3300168276_6_1983-2002",
      "chapterUid": 6,
      "range": "1983-2002",
      "markText": "人类在很大程度上是“所处环境的产物”。",
      "totalCount": 105,
      "appLink": "weread://bestbookmark?bookId=3300168276&chapterUid=6&rangeStart=1983&rangeEnd=2002",
      "webLink": "https://weread.qq.com/web/reader/fac32610813aba83bg016ee4?chapterUid=6&rangeStart=1983&rangeEnd=2002"
    },
    {
      "bookmarkId": "3300168276_6_14189-14233",
      "chapterUid": 6,
      "range": "14189-14233",
      "markText": "正如我们之前所说，知识是一个有机的整体，将其划分为不同学科，是为了适应人类认知能力的局限",
      "totalCount": 80,
      "appLink": "weread://bestbookmark?bookId=3300168276&chapterUid=6&rangeStart=14189&rangeEnd=14233",
      "webLink": "https://weread.qq.com/web/reader/fac32610813aba83bg016ee4?chapterUid=6&rangeStart=14189&rangeEnd=14233"
    },
    {
      "bookmarkId": "3300168276_8_1168-1221",
      "chapterUid": 8,
      "range": "1168-1221",
      "markText": "或许正是出于对这一事实的某种隐约认知，世界各地的政治家最终会将大部分注意力从领土扩张转向更为激烈的实力竞争",
      "totalCount": 72,
      "appLink": "weread://bestbookmark?bookId=3300168276&chapterUid=8&rangeStart=1168&rangeEnd=1221",
      "webLink": "https://weread.qq.com/web/reader/fac32610813aba83bg016ee4?chapterUid=8&rangeStart=1168&rangeEnd=1221"
    },
    {
      "bookmarkId": "3300168276_8_12256-12354",
      "chapterUid": 8,
      "range": "12256-12354",
      "markText": "当我们回顾这一广阔的历史潮流时，难道没有发现某种地理关系的持续性吗？欧亚大陆上那片广阔的、船舶无法抵达，但在古代任由骑马游牧民族纵横驰骋，如今又即将遍布铁路的区域，不正是世界政治的“枢纽地带”吗？",
      "totalCount": 72,
      "appLink": "weread://bestbookmark?bookId=3300168276&chapterUid=8&rangeStart=12256&rangeEnd=12354",
      "webLink": "https://weread.qq.com/web/reader/fac32610813aba83bg016ee4?chapterUid=8&rangeStart=12256&rangeEnd=12354"
    },
    {
      "bookmarkId": "3300168276_6_3280-3343",
      "chapterUid": 6,
      "range": "3280-3343",
      "markText": "浅显的分析很容易导致错误。一方面，它无法区分那些表面相似但本质不同的事物；另一方面，它也无法发现那些本质相似但表面不同的事物。",
      "totalCount": 70,
      "appLink": "weread://bestbookmark?bookId=3300168276&chapterUid=6&rangeStart=3280&rangeEnd=3343",
      "webLink": "https://weread.qq.com/web/reader/fac32610813aba83bg016ee4?chapterUid=6&rangeStart=3280&rangeEnd=3343"
    },
    {
      "bookmarkId": "3300168276_6_11810-11888",
      "chapterUid": 6,
      "range": "11810-11888",
      "markText": "如果这座城市既能通陆路，又能通水路，其重要性便会进一步提升，因为它将成为一个水陆转运枢纽。如果它还是河流航运与海洋航运的必经交汇点，那重要性就更是不言而喻了",
      "totalCount": 64,
      "appLink": "weread://bestbookmark?bookId=3300168276&chapterUid=6&rangeStart=11810&rangeEnd=11888",
      "webLink": "https://weread.qq.com/web/reader/fac32610813aba83bg016ee4?chapterUid=6&rangeStart=11810&rangeEnd=11888"
    },
    {
      "bookmarkId": "3300168276_9_1871-1963",
      "chapterUid": 9,
      "range": "1871-1963",
      "markText": "如今，在欧亚大陆的另一端，又有一个较小的岛国（指日本）正在崛起。我完全有理由相信，这个岛国完全能够在亚洲大陆的东缘，发挥与英国（人口更少）在欧洲所发挥的同等重要且具有决定性的影响力。”",
      "totalCount": 64,
      "appLink": "weread://bestbookmark?bookId=3300168276&chapterUid=9&rangeStart=1871&rangeEnd=1963",
      "webLink": "https://weread.qq.com/web/reader/fac32610813aba83bg016ee4?chapterUid=9&rangeStart=1871&rangeEnd=1963"
    },
    {
      "bookmarkId": "3300168276_7_2468-2540",
      "chapterUid": 7,
      "range": "2468-2540",
      "markText": "我并非指在开展原创性研究时，人们不能只专注于无生命的自然现象，而是认为，作为一门通识学科，研究自然地理特征的主要目的，是为了理解人类的分布规律。",
      "totalCount": 56,
      "appLink": "weread://bestbookmark?bookId=3300168276&chapterUid=7&rangeStart=2468&rangeEnd=2540",
      "webLink": "https://weread.qq.com/web/reader/fac32610813aba83bg016ee4?chapterUid=7&rangeStart=2468&rangeEnd=2540"
    },
    {
      "bookmarkId": "3300168276_8_1846-1913",
      "chapterUid": 8,
      "range": "1846-1913",
      "markText": "一个国家之所以能区别于一群单纯的人类群体，其形成的核心观念往往是在共同苦难的压力下，以及为抵御外部势力而产生的共同需求中逐渐被接受的。",
      "totalCount": 55,
      "appLink": "weread://bestbookmark?bookId=3300168276&chapterUid=8&rangeStart=1846&rangeEnd=1913",
      "webLink": "https://weread.qq.com/web/reader/fac32610813aba83bg016ee4?chapterUid=8&rangeStart=1846&rangeEnd=1913"
    },
    {
      "bookmarkId": "3300168276_9_3258-3341",
      "chapterUid": 9,
      "range": "3258-3341",
      "markText": "他将俄罗斯描述为希腊文明的继承者。实际上，俄罗斯继承的并非古希腊文明，而是拜占庭文明；而拜占庭文明传承的是古老的东方君主制传统，只是融入了希腊语言和少量罗马文明元素。",
      "totalCount": 54,
      "appLink": "weread://bestbookmark?bookId=3300168276&chapterUid=9&rangeStart=3258&rangeEnd=3341",
      "webLink": "https://weread.qq.com/web/reader/fac32610813aba83bg016ee4?chapterUid=9&rangeStart=3258&rangeEnd=3341"
    },
    {
      "bookmarkId": "3300168276_6_2538-2597",
      "chapterUid": 6,
      "range": "2538-2597",
      "markText": "我们认为，若政治地理学不是建立在自然地理学的基础之上，并且在自然地理学之后发展起来，那么合理的政治地理学就不可能存在。",
      "totalCount": 52,
      "appLink": "weread://bestbookmark?bookId=3300168276&chapterUid=6&rangeStart=2538&rangeEnd=2597",
      "webLink": "https://weread.qq.com/web/reader/fac32610813aba83bg016ee4?chapterUid=6&rangeStart=2538&rangeEnd=2597"
    },
    {
      "bookmarkId": "3300168276_6_4180-4254",
      "chapterUid": 6,
      "range": "4180-4254",
      "markText": "归根结底，知识是一个有机的整体，但如今过度的专业化趋势，似乎让某些人忽略了这一事实。专业化程度越高，就越需要有人始终致力于探寻各专业学科之间的关联。",
      "totalCount": 52,
      "appLink": "weread://bestbookmark?bookId=3300168276&chapterUid=6&rangeStart=4180&rangeEnd=4254",
      "webLink": "https://weread.qq.com/web/reader/fac32610813aba83bg016ee4?chapterUid=6&rangeStart=4180&rangeEnd=4254"
    },
    {
      "bookmarkId": "3300168276_8_1600-1663",
      "chapterUid": 8,
      "range": "1600-1663",
      "markText": "人类是历史的发起者，而非自然，但自然在很大程度上掌控着历史的走向。我关注的是自然对历史的总体制约作用，而非世界历史的全部成因。",
      "totalCount": 52,
      "appLink": "weread://bestbookmark?bookId=3300168276&chapterUid=8&rangeStart=1600&rangeEnd=1663",
      "webLink": "https://weread.qq.com/web/reader/fac32610813aba83bg016ee4?chapterUid=8&rangeStart=1600&rangeEnd=1663"
    },
    {
      "bookmarkId": "3300168276_8_12585-12656",
      "chapterUid": 8,
      "range": "12585-12656",
      "markText": "俄国的统治者明智地认识到自身力量的局限性，因此放弃了阿拉斯加——对俄国而言，不在海外占有领土，就如同英国必须维持海上霸权一样，是一项基本国策。",
      "totalCount": 52,
      "appLink": "weread://bestbookmark?bookId=3300168276&chapterUid=8&rangeStart=12585&rangeEnd=12656",
      "webLink": "https://weread.qq.com/web/reader/fac32610813aba83bg016ee4?chapterUid=8&rangeStart=12585&rangeEnd=12656"
    },
    {
      "bookmarkId": "3300168276_9_7271-7314",
      "chapterUid": 9,
      "range": "7271-7314",
      "markText": "未来世界必将形成不同的经济区域：一个主要以海洋为基础，另一个则以大陆腹地和铁路为基础。",
      "totalCount": 52,
      "appLink": "weread://bestbookmark?bookId=3300168276&chapterUid=9&rangeStart=7271&rangeEnd=7314",
      "webLink": "https://weread.qq.com/web/reader/fac32610813aba83bg016ee4?chapterUid=9&rangeStart=7271&rangeEnd=7314"
    },
    {
      "bookmarkId": "3300168276_6_1516-1574",
      "chapterUid": 6,
      "range": "1516-1574",
      "markText": "“要将人们所认为的‘科学性’地理学与历史学融合在一起，难度很大。二者之间的区别，就如同地质学与天文学那般泾渭分明。”",
      "totalCount": 51,
      "appLink": "weread://bestbookmark?bookId=3300168276&chapterUid=6&rangeStart=1516&rangeEnd=1574",
      "webLink": "https://weread.qq.com/web/reader/fac32610813aba83bg016ee4?chapterUid=6&rangeStart=1516&rangeEnd=1574"
    }
