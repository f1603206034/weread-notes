  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "34127273_5_663-711",
      "chapterUid": 5,
      "range": "663-711",
      "markText": "现实人生的坎坷，常使学术路途中断，但我“困”而知之，不断激发求知的动能，进而丰富着我的学术人生。",
      "totalCount": 60,
      "appLink": "weread://bestbookmark?bookId=34127273&chapterUid=5&rangeStart=663&rangeEnd=711",
      "webLink": "https://weread.qq.com/web/reader/e6332d707208bda9e630b46?chapterUid=5&rangeStart=663&rangeEnd=711"
    },
    {
      "bookmarkId": "34127273_5_1573-1645",
      "chapterUid": 5,
      "range": "1573-1645",
      "markText": "透过古籍文献的整理与诠释，我不仅得到传统人文思想的熏陶，还表达了对极端化与绝对化的神权思想的反感，阐发了对威权体制下的人身崇拜和造神运动的批判。",
      "totalCount": 54,
      "appLink": "weread://bestbookmark?bookId=34127273&chapterUid=5&rangeStart=1573&rangeEnd=1645",
      "webLink": "https://weread.qq.com/web/reader/e6332d707208bda9e630b46?chapterUid=5&rangeStart=1573&rangeEnd=1645"
    },
    {
      "bookmarkId": "34127273_15_3451-3560",
      "chapterUid": 15,
      "range": "3451-3560",
      "markText": "《彖》曰：比，吉也〔一〕。比，辅也，下顺从也〔二〕。原筮，元永贞，无咎，以刚中也〔三〕。不宁方来，上下应也〔四〕。后夫凶，其道穷也",
      "totalCount": 54,
      "appLink": "weread://bestbookmark?bookId=34127273&chapterUid=15&rangeStart=3451&rangeEnd=3560",
      "webLink": "https://weread.qq.com/web/reader/e6332d707208bda9e630b46?chapterUid=15&rangeStart=3451&rangeEnd=3560"
    },
    {
      "bookmarkId": "34127273_19_6383-6473",
      "chapterUid": 19,
      "range": "6383-6473",
      "markText": "否极而倾的内部规律必须由主动倾否的外部条件来实现，否则，否塞的困境将会做长时期的延续，并给人类造成重大的伤害；而泰终则覆的内部规律在极大的程度上会自发地起作用，不以人的意志为转移。",
      "totalCount": 54,
      "appLink": "weread://bestbookmark?bookId=34127273&chapterUid=19&rangeStart=6383&rangeEnd=6473",
      "webLink": "https://weread.qq.com/web/reader/e6332d707208bda9e630b46?chapterUid=19&rangeStart=6383&rangeEnd=6473"
    },
    {
      "bookmarkId": "34127273_20_4482-4491",
      "chapterUid": 20,
      "range": "4482-4491",
      "markText": "同人于郊，志未得也",
      "totalCount": 54,
      "appLink": "weread://bestbookmark?bookId=34127273&chapterUid=20&rangeStart=4482&rangeEnd=4491",
      "webLink": "https://weread.qq.com/web/reader/e6332d707208bda9e630b46?chapterUid=20&rangeStart=4482&rangeEnd=4491"
    },
    {
      "bookmarkId": "34127273_21_1061-1074",
      "chapterUid": 21,
      "range": "1061-1074",
      "markText": "上九。自天佑之，吉无不利。",
      "totalCount": 52,
      "appLink": "weread://bestbookmark?bookId=34127273&chapterUid=21&rangeStart=1061&rangeEnd=1074",
      "webLink": "https://weread.qq.com/web/reader/e6332d707208bda9e630b46?chapterUid=21&rangeStart=1061&rangeEnd=1074"
    },
    {
      "bookmarkId": "34127273_8_11643-11697",
      "chapterUid": 8,
      "range": "11643-11697",
      "markText": "子曰：上下无常，非为邪也；进退无恒，非离群也；君子进德修业，欲及时也〔一四〕，故无咎。",
      "totalCount": 51,
      "appLink": "weread://bestbookmark?bookId=34127273&chapterUid=8&rangeStart=11643&rangeEnd=11697",
      "webLink": "https://weread.qq.com/web/reader/e6332d707208bda9e630b46?chapterUid=8&rangeStart=11643&rangeEnd=11697"
    },
    {
      "bookmarkId": "34127273_9_1142-1154",
      "chapterUid": 9,
      "range": "1142-1154",
      "markText": "上六。龙战于野，其血玄黄",
      "totalCount": 51,
      "appLink": "weread://bestbookmark?bookId=34127273&chapterUid=9&rangeStart=1142&rangeEnd=1154",
      "webLink": "https://weread.qq.com/web/reader/e6332d707208bda9e630b46?chapterUid=9&rangeStart=1142&rangeEnd=1154"
    },
    {
      "bookmarkId": "34127273_12_4226-4341",
      "chapterUid": 12,
      "range": "4226-4341",
      "markText": "《彖》曰：需，须也，险在前也〔一〕；刚健而不陷，其义不困穷矣〔二〕。需，有孚，光亨，贞吉，位乎天位，以正中也〔三〕。利涉大川，往有功也〔四〕。",
      "totalCount": 51,
      "appLink": "weread://bestbookmark?bookId=34127273&chapterUid=12&rangeStart=4226&rangeEnd=4341",
      "webLink": "https://weread.qq.com/web/reader/e6332d707208bda9e630b46?chapterUid=12&rangeStart=4226&rangeEnd=4341"
    },
    {
      "bookmarkId": "34127273_5_2365-2390",
      "chapterUid": 5,
      "range": "2365-2390",
      "markText": "事实上，战争与冲突的根源多在于东西方文化上的差异。",
