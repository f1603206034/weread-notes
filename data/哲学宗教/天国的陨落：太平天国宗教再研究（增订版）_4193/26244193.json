  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "26244193_8_8417-8458",
      "chapterUid": 8,
      "range": "8417-8458",
      "markText": "这种理解无疑是荒诞无稽的，但洪秀全此时的确就是这么认为的，并不带有什么矫饰的成分。",
      "totalCount": 108,
      "appLink": "weread://bestbookmark?bookId=26244193&chapterUid=8&rangeStart=8417&rangeEnd=8458",
      "webLink": "https://weread.qq.com/web/reader/069329d07190746106987e7?chapterUid=8&rangeStart=8417&rangeEnd=8458"
    },
    {
      "bookmarkId": "26244193_12_20230-20271",
      "chapterUid": 12,
      "range": "20230-20271",
      "markText": "与他的生父洪镜扬毫无关系，而且他的生母李氏居然成了上帝的偏房。这真是越说越糊涂了。",
      "totalCount": 96,
      "appLink": "weread://bestbookmark?bookId=26244193&chapterUid=12&rangeStart=20230&rangeEnd=20271",
      "webLink": "https://weread.qq.com/web/reader/069329d07190746106987e7?chapterUid=12&rangeStart=20230&rangeEnd=20271"
    },
    {
      "bookmarkId": "26244193_8_3862-3941",
      "chapterUid": 8,
      "range": "3862-3941",
      "markText": "他连续卧病一个多月，在神志不清的情形下，经常口呼“斩！斩！”作跳跃斩妖状，间或唱歌，或者教训人，举止十分怪异。于是，全村人都认为洪秀全神志失常，已变成了疯子。",
      "totalCount": 90,
      "appLink": "weread://bestbookmark?bookId=26244193&chapterUid=8&rangeStart=3862&rangeEnd=3941",
      "webLink": "https://weread.qq.com/web/reader/069329d07190746106987e7?chapterUid=8&rangeStart=3862&rangeEnd=3941"
    },
    {
      "bookmarkId": "26244193_9_6631-6808",
      "chapterUid": 9,
      "range": "6631-6808",
      "markText": "正是凭借这种坚忍不拔的意志和锲而不舍的精神，冯云山筚路蓝缕，惨淡经营，终于以紫荆山为中心，先后发展了两千多名信徒，成立了一个以拜上帝为主要特征的宗教组织——“上帝会”注44。",
      "totalCount": 90,
      "appLink": "weread://bestbookmark?bookId=26244193&chapterUid=9&rangeStart=6631&rangeEnd=6808",
      "webLink": "https://weread.qq.com/web/reader/069329d07190746106987e7?chapterUid=9&rangeStart=6631&rangeEnd=6808"
    },
    {
      "bookmarkId": "26244193_21_9186-9221",
      "chapterUid": 21,
      "range": "9186-9221",
      "markText": "后来民间习惯用“礼拜”一词来表示时间概念，这与太平天国的首倡不无关系。",
      "totalCount": 80,
      "appLink": "weread://bestbookmark?bookId=26244193&chapterUid=21&rangeStart=9186&rangeEnd=9221",
      "webLink": "https://weread.qq.com/web/reader/069329d07190746106987e7?chapterUid=21&rangeStart=9186&rangeEnd=9221"
    },
    {
      "bookmarkId": "26244193_8_11396-11435",
      "chapterUid": 8,
      "range": "11396-11435",
      "markText": "眼见出行一个多月的努力收效甚微，洪秀全心有不甘，便萌生了到邻省广西传教的念头。",
      "totalCount": 75,
      "appLink": "weread://bestbookmark?bookId=26244193&chapterUid=8&rangeStart=11396&rangeEnd=11435",
      "webLink": "https://weread.qq.com/web/reader/069329d07190746106987e7?chapterUid=8&rangeStart=11396&rangeEnd=11435"
    },
    {
      "bookmarkId": "26244193_10_7007-7068",
      "chapterUid": 10,
      "range": "7007-7068",
      "markText": "在早期布道作品中，他反复宣称中国曾经有过一段君民一体敬皇天的历史，只因上帝真道在中国久已失传，才导致国人惘然不识，自陷沉沦",
      "totalCount": 75,
      "appLink": "weread://bestbookmark?bookId=26244193&chapterUid=10&rangeStart=7007&rangeEnd=7068",
      "webLink": "https://weread.qq.com/web/reader/069329d07190746106987e7?chapterUid=10&rangeStart=7007&rangeEnd=7068"
    },
    {
      "bookmarkId": "26244193_9_5253-5428",
      "chapterUid": 9,
      "range": "5253-5428",
      "markText": "洪秀全懵懂地回答道：“我穷，没有生活来源，加入教堂将丢掉我的职业，我不知以后将怎样维持生活。”注41事态遂急转直下。由于被视为入教动机不纯，洪秀全受洗一事被无限期地推迟。",
      "totalCount": 72,
      "appLink": "weread://bestbookmark?bookId=26244193&chapterUid=9&rangeStart=5253&rangeEnd=5428",
      "webLink": "https://weread.qq.com/web/reader/069329d07190746106987e7?chapterUid=9&rangeStart=5253&rangeEnd=5428"
    },
    {
      "bookmarkId": "26244193_10_12666-12732",
      "chapterUid": 10,
      "range": "12666-12732",
      "markText": "天兄在紫荆山秘密召见络绎而至的各地骨干信徒，进行思想摸底和动员工作，并吩咐众人要注意保密，要真心拥戴洪秀全、冯云山、杨秀清、萧朝贵等",
      "totalCount": 72,
      "appLink": "weread://bestbookmark?bookId=26244193&chapterUid=10&rangeStart=12666&rangeEnd=12732",
      "webLink": "https://weread.qq.com/web/reader/069329d07190746106987e7?chapterUid=10&rangeStart=12666&rangeEnd=12732"
    },
    {
      "bookmarkId": "26244193_12_13091-13186",
      "chapterUid": 12,
      "range": "13091-13186",
      "markText": "正是基于这一信条，太平天国采用强硬手段，严禁偶像崇拜，掀起了一场狂飙式的毁灭偶像运动，同时严禁孔子崇拜和祖先崇拜，一度还焚禁古书，从而使太平天国的意识形态政策呈现出强烈的排斥传统文化的倾向。",
      "totalCount": 72,
      "appLink": "weread://bestbookmark?bookId=26244193&chapterUid=12&rangeStart=13091&rangeEnd=13186",
      "webLink": "https://weread.qq.com/web/reader/069329d07190746106987e7?chapterUid=12&rangeStart=13091&rangeEnd=13186"
    },
    {
      "bookmarkId": "26244193_18_15898-15931",
      "chapterUid": 18,
      "range": "15898-15931",
      "markText": "上帝是炎，故有神光；太兄是炎，故是大光；朕是太阳，故亦是光。钦此。",
      "totalCount": 72,
      "appLink": "weread://bestbookmark?bookId=26244193&chapterUid=18&rangeStart=15898&rangeEnd=15931",
      "webLink": "https://weread.qq.com/web/reader/069329d07190746106987e7?chapterUid=18&rangeStart=15898&rangeEnd=15931"
    },
    {
      "bookmarkId": "26244193_25_50364-50429",
      "chapterUid": 25,
      "range": "50364-50429",
      "markText": "从广西穷乡僻壤挺进到江南繁华富庶之地，太平军在不断开疆拓土的同时，其理想与锐气却悄然褪色，随之日益膨胀的是安富尊荣、及时行乐的意识",
      "totalCount": 72,
      "appLink": "weread://bestbookmark?bookId=26244193&chapterUid=25&rangeStart=50364&rangeEnd=50429",
      "webLink": "https://weread.qq.com/web/reader/069329d07190746106987e7?chapterUid=25&rangeStart=50364&rangeEnd=50429"
    },
    {
      "bookmarkId": "26244193_37_21242-21313",
      "chapterUid": 37,
      "range": "21242-21313",
      "markText": "从这几首文理不通形同梦呓的打油诗可以看出，幼天王颟顸平庸之极，与三国时蜀汉后主刘禅实在伯仲之间。倘若洪秀全九泉之下有知，将会有什么样的感想呢？",
      "totalCount": 72,
      "appLink": "weread://bestbookmark?bookId=26244193&chapterUid=37&rangeStart=21242&rangeEnd=21313",
      "webLink": "https://weread.qq.com/web/reader/069329d07190746106987e7?chapterUid=37&rangeStart=21242&rangeEnd=21313"
    },
    {
      "bookmarkId": "26244193_18_16704-16743",
      "chapterUid": 18,
      "range": "16704-16743",
      "markText": "洪秀全强调自己的这段证词是“诚实”的，其实连他自己也明白，这实际上是“伪证”。",
      "totalCount": 68,
      "appLink": "weread://bestbookmark?bookId=26244193&chapterUid=18&rangeStart=16704&rangeEnd=16743",
      "webLink": "https://weread.qq.com/web/reader/069329d07190746106987e7?chapterUid=18&rangeStart=16704&rangeEnd=16743"
    },
    {
      "bookmarkId": "26244193_9_7650-7798",
      "chapterUid": 9,
      "range": "7650-7798",
      "markText": "上帝会信徒日众，并涌现出一批骨干成员，诸如紫荆山的曾云正、卢六、杨秀清、萧朝贵，金田村的韦昌辉注48，贵县的石达开。",
      "totalCount": 66,
      "appLink": "weread://bestbookmark?bookId=26244193&chapterUid=9&rangeStart=7650&rangeEnd=7798",
      "webLink": "https://weread.qq.com/web/reader/069329d07190746106987e7?chapterUid=9&rangeStart=7650&rangeEnd=7798"
    },
    {
      "bookmarkId": "26244193_9_6906-6978",
      "chapterUid": 9,
      "range": "6906-6978",
      "markText": "冯云山是洪秀全最早、最忠实的追随者，他独自在紫荆山布道时，仍然遥奉洪秀全为教主，刻意维护、树立洪秀全的权威，包括渲染洪秀全在梦境中所见到的异象。",
      "totalCount": 65,
      "appLink": "weread://bestbookmark?bookId=26244193&chapterUid=9&rangeStart=6906&rangeEnd=6978",
      "webLink": "https://weread.qq.com/web/reader/069329d07190746106987e7?chapterUid=9&rangeStart=6906&rangeEnd=6978"
    },
    {
      "bookmarkId": "26244193_15_1798-1877",
      "chapterUid": 15,
      "range": "1798-1877",
      "markText": "虽然承认上帝教与基督教同宗同源，但一直奉自己的教义为正统，拒绝承认基督教的权威。针对西方人欲将上帝教纳入正统基督教轨道的企图，太平天国始终针锋相对，毫不妥协。",
      "totalCount": 65,
      "appLink": "weread://bestbookmark?bookId=26244193&chapterUid=15&rangeStart=1798&rangeEnd=1877",
      "webLink": "https://weread.qq.com/web/reader/069329d07190746106987e7?chapterUid=15&rangeStart=1798&rangeEnd=1877"
    },
    {
      "bookmarkId": "26244193_38_9860-9899",
      "chapterUid": 38,
      "range": "9860-9899",
      "markText": "与清代民间教门和秘密会党相比，上帝教所信奉的独一真神信仰无疑是一种历史的进步。",
      "totalCount": 65,
      "appLink": "weread://bestbookmark?bookId=26244193&chapterUid=38&rangeStart=9860&rangeEnd=9899",
      "webLink": "https://weread.qq.com/web/reader/069329d07190746106987e7?chapterUid=38&rangeStart=9860&rangeEnd=9899"
    },
    {
      "bookmarkId": "26244193_8_383-552",
      "chapterUid": 8,
      "range": "383-552",
      "markText": "洪秀全于1814年1月1日（嘉庆十八年十二月初十日）诞生在广东省花县（今广州市花都区）官村，小名火秀,族名仁坤，后来为了避上帝“爷火华”注10名讳而改为现名。",
      "totalCount": 64,
      "appLink": "weread://bestbookmark?bookId=26244193&chapterUid=8&rangeStart=383&rangeEnd=552",
      "webLink": "https://weread.qq.com/web/reader/069329d07190746106987e7?chapterUid=8&rangeStart=383&rangeEnd=552"
    },
    {
      "bookmarkId": "26244193_9_5612-5683",
      "chapterUid": 9,
      "range": "5612-5683",
      "markText": "洪秀全只身二次入桂，一路上经受了更大的考验。当行至梅子讯时，他路遇十余名持械的强盗，行李银钱被抢劫一空，包括一柄护身用的长剑，仅剩下替换衣服。",
      "totalCount": 60,
      "appLink": "weread://bestbookmark?bookId=26244193&chapterUid=9&rangeStart=5612&rangeEnd=5683",
      "webLink": "https://weread.qq.com/web/reader/069329d07190746106987e7?chapterUid=9&rangeStart=5612&rangeEnd=5683"
    }
