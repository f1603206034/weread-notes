  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "842282_11_5385-5446",
      "chapterUid": 11,
      "range": "5385-5446",
      "markText": "凡是合乎理性的东西都是现实的， 凡是现实的东西都是合乎理性的。",
      "totalCount": 1854,
      "appLink": "weread://bestbookmark?bookId=842282&chapterUid=11&rangeStart=5385&rangeEnd=5446",
      "webLink": "https://weread.qq.com/web/reader/9fe325a05cda2a9fea10c24?chapterUid=11&rangeStart=5385&rangeEnd=5446"
    },
    {
      "bookmarkId": "842282_11_830-894",
      "chapterUid": 11,
      "range": "830-894",
      "markText": "人的意识，对于对象总是先形成表象，后才形成概念，而且唯有通过表象，依靠表象，人的能思的心灵才进而达到对于事物的思维的认识和把握。",
      "totalCount": 1638,
      "appLink": "weread://bestbookmark?bookId=842282&chapterUid=11&rangeStart=830&rangeEnd=894",
      "webLink": "https://weread.qq.com/web/reader/9fe325a05cda2a9fea10c24?chapterUid=11&rangeStart=830&rangeEnd=894"
    },
    {
      "bookmarkId": "842282_12_521-559",
      "chapterUid": 12,
      "range": "521-559",
      "markText": "逻辑学是研究纯粹理念的科学，所谓纯粹理念就是思维的最抽象的要素所形成的理念。",
      "totalCount": 780,
      "appLink": "weread://bestbookmark?bookId=842282&chapterUid=12&rangeStart=521&rangeEnd=559",
      "webLink": "https://weread.qq.com/web/reader/9fe325a05cda2a9fea10c24?chapterUid=12&rangeStart=521&rangeEnd=559"
    },
    {
      "bookmarkId": "842282_10_1497-1577",
      "chapterUid": 10,
      "range": "1497-1577",
      "markText": "哲学所要反对的，一方面是精神沉陷在日常急迫的兴趣中，一方面是意见的空疏浅薄。精神一旦为这些空疏浅薄的意见所占据，理性便不能追寻它自身的目的，因而没有活动的余地。",
      "totalCount": 740,
      "appLink": "weread://bestbookmark?bookId=842282&chapterUid=10&rangeStart=1497&rangeEnd=1577",
      "webLink": "https://weread.qq.com/web/reader/9fe325a05cda2a9fea10c24?chapterUid=10&rangeStart=1497&rangeEnd=1577"
    },
    {
      "bookmarkId": "842282_10_771-817",
      "chapterUid": 10,
      "range": "771-817",
      "markText": "世界精神太忙碌于现实，太驰骛于外界，而不遑回到内心，转回自身，以徜徉自怡于自己原有的家园中。",
      "totalCount": 700,
      "appLink": "weread://bestbookmark?bookId=842282&chapterUid=10&rangeStart=771&rangeEnd=817",
      "webLink": "https://weread.qq.com/web/reader/9fe325a05cda2a9fea10c24?chapterUid=10&rangeStart=771&rangeEnd=817"
    },
    {
      "bookmarkId": "842282_11_5152-5208",
      "chapterUid": 11,
      "range": "5152-5208",
      "markText": "哲学的最高目的就在于确认思想与经验的一致，并达到自觉的理性与存在于事物中的理性的和解，亦即达到理性与现实的和解。",
      "totalCount": 644,
      "appLink": "weread://bestbookmark?bookId=842282&chapterUid=11&rangeStart=5152&rangeEnd=5208",
      "webLink": "https://weread.qq.com/web/reader/9fe325a05cda2a9fea10c24?chapterUid=11&rangeStart=5152&rangeEnd=5208"
    },
    {
      "bookmarkId": "842282_5_10136-10197",
      "chapterUid": 5,
      "range": "10136-10197",
      "markText": "马克思说：“理论只要说服人，就能掌握群众；而理论只要彻底，就能说服人。所谓彻底，就是抓住事物的根本。但人的根本就是人本身”",
      "totalCount": 637,
      "appLink": "weread://bestbookmark?bookId=842282&chapterUid=5&rangeStart=10136&rangeEnd=10197",
      "webLink": "https://weread.qq.com/web/reader/9fe325a05cda2a9fea10c24?chapterUid=5&rangeStart=10136&rangeEnd=10197"
    },
    {
      "bookmarkId": "842282_12_781-849",
      "chapterUid": 12,
      "range": "781-849",
      "markText": "理念并不是形式的思维，而是思维的特有规定和规律自身发展而成的全体，这些规定和规律，乃是思维自身给予的，决不是已经存在于外面的现成的事物。",
