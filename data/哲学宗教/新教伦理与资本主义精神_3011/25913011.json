  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "25913011_13_10483-10531",
      "chapterUid": 13,
      "range": "10483-10531",
      "markText": "人并非“天生”希望多多地挣钱，他只是希望像他已经习惯的那样生活，挣到为此目的必需挣到的那么多钱。",
      "totalCount": 935,
      "appLink": "weread://bestbookmark?bookId=25913011&chapterUid=13&rangeStart=10483&rangeEnd=10531",
      "webLink": "https://weread.qq.com/web/reader/ba432ac0718b66b3ba4a6a0?chapterUid=13&rangeStart=10483&rangeEnd=10531"
    },
    {
      "bookmarkId": "25913011_6_7767-7833",
      "chapterUid": 6,
      "range": "7767-7833",
      "markText": "人们总是会受到诱惑要阐明一个富有成效的新观念，把它用作打开所有门户的钥匙，并借助某个单独的原则去解释现实中由多种原因共同产生的现象。",
      "totalCount": 901,
      "appLink": "weread://bestbookmark?bookId=25913011&chapterUid=6&rangeStart=7767&rangeEnd=7833",
      "webLink": "https://weread.qq.com/web/reader/ba432ac0718b66b3ba4a6a0?chapterUid=6&rangeStart=7767&rangeEnd=7833"
    },
    {
      "bookmarkId": "25913011_6_4488-4530",
      "chapterUid": 6,
      "range": "4488-4530",
      "markText": "资本主义是作为蓬勃进取的资产阶级的实用唯心主义开局的，但它的结局却是唯物主义的狂欢。",
      "totalCount": 828,
      "appLink": "weread://bestbookmark?bookId=25913011&chapterUid=6&rangeStart=4488&rangeEnd=4530",
      "webLink": "https://weread.qq.com/web/reader/ba432ac0718b66b3ba4a6a0?chapterUid=6&rangeStart=4488&rangeEnd=4530"
    },
    {
      "bookmarkId": "25913011_7_9627-9674",
      "chapterUid": 7,
      "range": "9627-9674",
      "markText": "他坚信并不存在什么“历史规律”：现代资本主义在西方的出现，乃是各种事件在历史上特殊耦合的产物。",
      "totalCount": 612,
      "appLink": "weread://bestbookmark?bookId=25913011&chapterUid=7&rangeStart=9627&rangeEnd=9674",
      "webLink": "https://weread.qq.com/web/reader/ba432ac0718b66b3ba4a6a0?chapterUid=7&rangeStart=9627&rangeEnd=9674"
    },
    {
      "bookmarkId": "25913011_14_1807-1868",
      "chapterUid": 14,
      "range": "1807-1868",
      "markText": "令上帝满意的唯一生活方式，不是以修道院的禁欲主义超越世俗道德，而只是履行个人在尘世的地位所加诸于他的义务。这就是他的天职。",
      "totalCount": 612,
      "appLink": "weread://bestbookmark?bookId=25913011&chapterUid=14&rangeStart=1807&rangeEnd=1868",
      "webLink": "https://weread.qq.com/web/reader/ba432ac0718b66b3ba4a6a0?chapterUid=14&rangeStart=1807&rangeEnd=1868"
    },
    {
      "bookmarkId": "25913011_6_1608-1650",
      "chapterUid": 6,
      "range": "1608-1650",
      "markText": "韦伯试图回答的问题是个简单而又基本的问题——使资本主义文明有可能得以发展的心理条件。",
      "totalCount": 598,
      "appLink": "weread://bestbookmark?bookId=25913011&chapterUid=6&rangeStart=1608&rangeEnd=1650",
      "webLink": "https://weread.qq.com/web/reader/ba432ac0718b66b3ba4a6a0?chapterUid=6&rangeStart=1608&rangeEnd=1650"
    },
    {
      "bookmarkId": "25913011_12_1947-1994",
      "chapterUid": 12,
      "range": "1947-1994",
      "markText": "宗教改革并不意味着消除了教会对日常生活的控制，毋宁说，那只是用一种新的控制形式取代先前的控制。",
      "totalCount": 594,
      "appLink": "weread://bestbookmark?bookId=25913011&chapterUid=12&rangeStart=1947&rangeEnd=1994",
      "webLink": "https://weread.qq.com/web/reader/ba432ac0718b66b3ba4a6a0?chapterUid=12&rangeStart=1947&rangeEnd=1994"
    },
    {
      "bookmarkId": "25913011_9_5475-5552",
      "chapterUid": 9,
      "range": "5475-5552",
      "markText": "韦伯的忧虑是，基于功利主义考虑的“实用理性”生活方式，再加上刻板的官僚化工作场所，最终可能会产生一个对个人既缺乏崇高理想又缺少个人主义给予高度肯定的社会。",
      "totalCount": 578,
      "appLink": "weread://bestbookmark?bookId=25913011&chapterUid=9&rangeStart=5475&rangeEnd=5552",
      "webLink": "https://weread.qq.com/web/reader/ba432ac0718b66b3ba4a6a0?chapterUid=9&rangeStart=5475&rangeEnd=5552"
    },
    {
      "bookmarkId": "25913011_5_1988-2079",
      "chapterUid": 5,
      "range": "1988-2079",
      "markText": "韦伯著作的重要之处并不在于他如何判定观念因素还是经济因素具有相对重要性，而在于他分析社会行动系统的方法，因为在这个系统中，对行动发挥了影响的不光是“经济力量”，而且还有观念和价值观。",
      "totalCount": 561,
      "appLink": "weread://bestbookmark?bookId=25913011&chapterUid=5&rangeStart=1988&rangeEnd=2079",
      "webLink": "https://weread.qq.com/web/reader/ba432ac0718b66b3ba4a6a0?chapterUid=5&rangeStart=1988&rangeEnd=2079"
    },
    {
      "bookmarkId": "25913011_6_3992-4012",
      "chapterUid": 6,
      "range": "3992-4012",
      "markText": "资本主义就是加尔文主义神学的社会对应物。",
      "totalCount": 486,
      "appLink": "weread://bestbookmark?bookId=25913011&chapterUid=6&rangeStart=3992&rangeEnd=4012",
      "webLink": "https://weread.qq.com/web/reader/ba432ac0718b66b3ba4a6a0?chapterUid=6&rangeStart=3992&rangeEnd=4012"
    },
    {
      "bookmarkId": "25913011_6_3900-3964",
      "chapterUid": 6,
      "range": "3900-3964",
      "markText": "这里的关键是，道德标准发生了变革，一种天生的弱点转变成了为精神增光的因素，以往在各个时代被谴责为罪恶的种种习惯则变成了经济美德。",
      "totalCount": 464,
      "appLink": "weread://bestbookmark?bookId=25913011&chapterUid=6&rangeStart=3900&rangeEnd=3964",
