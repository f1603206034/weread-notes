      "appLink": "weread://bestbookmark?bookId=25789833&chapterUid=19&rangeStart=12584&rangeEnd=12626",
      "webLink": "https://weread.qq.com/web/reader/9b932b60718985899b9de18?chapterUid=19&rangeStart=12584&rangeEnd=12626"
    },
    {
      "bookmarkId": "25789833_19_33070-33100",
      "chapterUid": 19,
      "range": "33070-33100",
      "markText": "今日乃知，虽有多闻，若不修行，与不闻等，如人说食，终不能饱。",
