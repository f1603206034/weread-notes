      "appLink": "weread://bestbookmark?bookId=25789833&chapterUid=19&rangeStart=33070&rangeEnd=33100",
      "webLink": "https://weread.qq.com/web/reader/9b932b60718985899b9de18?chapterUid=19&rangeStart=33070&rangeEnd=33100"
