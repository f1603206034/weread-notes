  ],
  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300115144_104_1462-1529",
      "chapterUid": 104,
      "range": "1462-1529",
      "markText": "如果我们的兴趣仅仅是对这个故事的兴趣，那么这个艺术作品就成为推论性的象征，即一种传递信息的工具，从而只具有工具性的（而非内在的）价值。",
      "totalCount": 2190,
      "appLink": "weread://bestbookmark?bookId=3300115144&chapterUid=104&rangeStart=1462&rangeEnd=1529",
      "webLink": "https://weread.qq.com/web/reader/62132b70813ab937ag0145d6?chapterUid=104&rangeStart=1462&rangeEnd=1529"
    },
    {
      "bookmarkId": "3300115144_89_10976-11018",
      "chapterUid": 89,
      "range": "10976-11018",
      "markText": "笛卡儿显然认为，无论世界上是否实际存在着三角形这种东西，关于三角形的定理都是可证的。",
      "totalCount": 2175,
      "appLink": "weread://bestbookmark?bookId=3300115144&chapterUid=89&rangeStart=10976&rangeEnd=11018",
      "webLink": "https://weread.qq.com/web/reader/62132b70813ab937ag0145d6?chapterUid=89&rangeStart=10976&rangeEnd=11018"
    },
    {
      "bookmarkId": "3300115144_113_10153-10245",
      "chapterUid": 113,
      "range": "10153-10245",
      "markText": "作为立法者的政府等同于人民或其代表，这些代表被视为社会的“较强大的部分”(valentior pars)，是具有最高资格的部分。",
      "totalCount": 2175,
      "appLink": "weread://bestbookmark?bookId=3300115144&chapterUid=113&rangeStart=10153&rangeEnd=10245",
      "webLink": "https://weread.qq.com/web/reader/62132b70813ab937ag0145d6?chapterUid=113&rangeStart=10153&rangeEnd=10245"
    },
    {
      "bookmarkId": "3300115144_113_10491-10524",
      "chapterUid": 113,
      "range": "10491-10524",
      "markText": "教会的任务是布道和教化，是让自身关注超越世俗的事务，而不是去统治。",
      "totalCount": 2175,
      "appLink": "weread://bestbookmark?bookId=3300115144&chapterUid=113&rangeStart=10491&rangeEnd=10524",
      "webLink": "https://weread.qq.com/web/reader/62132b70813ab937ag0145d6?chapterUid=113&rangeStart=10491&rangeEnd=10524"
    },
    {
      "bookmarkId": "3300115144_73_5871-5918",
      "chapterUid": 73,
      "range": "5871-5918",
      "markText": "事物之所以如其所是地那样发生，是因为在能被发现的不同因素之间存在着无时间的、非故意的各种关系。",
      "totalCount": 2164,
      "appLink": "weread://bestbookmark?bookId=3300115144&chapterUid=73&rangeStart=5871&rangeEnd=5918",
      "webLink": "https://weread.qq.com/web/reader/62132b70813ab937ag0145d6?chapterUid=73&rangeStart=5871&rangeEnd=5918"
    },
    {
      "bookmarkId": "3300115144_114_11687-11719",
      "chapterUid": 114,
      "range": "11687-11719",
      "markText": "在自然状态中，由于没有共同的主权来阻止世人，便导致了可怕的后果。",
      "totalCount": 2161,
      "appLink": "weread://bestbookmark?bookId=3300115144&chapterUid=114&rangeStart=11687&rangeEnd=11719",
      "webLink": "https://weread.qq.com/web/reader/62132b70813ab937ag0145d6?chapterUid=114&rangeStart=11687&rangeEnd=11719"
    },
    {
      "bookmarkId": "3300115144_66_6423-6452",
      "chapterUid": 66,
      "range": "6423-6452",
      "markText": "社会不是个体的任意集合，个人主义和民主制只能导致混乱无序。",
      "totalCount": 2157,
      "appLink": "weread://bestbookmark?bookId=3300115144&chapterUid=66&rangeStart=6423&rangeEnd=6452",
      "webLink": "https://weread.qq.com/web/reader/62132b70813ab937ag0145d6?chapterUid=66&rangeStart=6423&rangeEnd=6452"
    },
    {
      "bookmarkId": "3300115144_66_9263-9314",
      "chapterUid": 66,
      "range": "9263-9314",
      "markText": "老密尔的论证基于适用于功利原则的对人类动机的解释：一切行为都源自趋乐避苦（这里的“乐”当做广义理解）。",
      "totalCount": 2157,
      "appLink": "weread://bestbookmark?bookId=3300115144&chapterUid=66&rangeStart=9263&rangeEnd=9314",
      "webLink": "https://weread.qq.com/web/reader/62132b70813ab937ag0145d6?chapterUid=66&rangeStart=9263&rangeEnd=9314"
    },
    {
      "bookmarkId": "3300115144_56_3322-3381",
      "chapterUid": 56,
      "range": "3322-3381",
      "markText": "他开始不仅把这一理论应用于圆的方和柏拉图式的实存物，而且应用于常识会认为完全实在的东西，如尤利乌斯·恺撒、桌子、椅子。",
      "totalCount": 2150,
      "appLink": "weread://bestbookmark?bookId=3300115144&chapterUid=56&rangeStart=3322&rangeEnd=3381",
      "webLink": "https://weread.qq.com/web/reader/62132b70813ab937ag0145d6?chapterUid=56&rangeStart=3322&rangeEnd=3381"
    },
    {
      "bookmarkId": "3300115144_85_2917-2962",
      "chapterUid": 85,
      "range": "2917-2962",
      "markText": "因此，普遍的质型论就倾向于支持一种将感觉作用最小化的知识论，因此自然导致某种形式的光照说。",
      "totalCount": 2150,
      "appLink": "weread://bestbookmark?bookId=3300115144&chapterUid=85&rangeStart=2917&rangeEnd=2962",
      "webLink": "https://weread.qq.com/web/reader/62132b70813ab937ag0145d6?chapterUid=85&rangeStart=2917&rangeEnd=2962"
    },
    {
      "bookmarkId": "3300115144_61_3377-3443",
      "chapterUid": 61,
      "range": "3377-3443",
      "markText": "而社会的变化为其增加了其他功能，包括建立或管理城镇，控制通货，支持并管理贸易，救济穷人，以及维护国家的宗教，或管理超国家的独立教会。",
      "totalCount": 2143,
      "appLink": "weread://bestbookmark?bookId=3300115144&chapterUid=61&rangeStart=3377&rangeEnd=3443",
      "webLink": "https://weread.qq.com/web/reader/62132b70813ab937ag0145d6?chapterUid=61&rangeStart=3377&rangeEnd=3443"
    },
    {
      "bookmarkId": "3300115144_74_3542-3572",
      "chapterUid": 74,
      "range": "3542-3572",
      "markText": "色诺芬尼向神祇致敬，并抨击流言中伤，遂使诗人们最终湮没无闻。",
      "totalCount": 2139,
      "appLink": "weread://bestbookmark?bookId=3300115144&chapterUid=74&rangeStart=3542&rangeEnd=3572",
      "webLink": "https://weread.qq.com/web/reader/62132b70813ab937ag0145d6?chapterUid=74&rangeStart=3542&rangeEnd=3572"
    },
    {
      "bookmarkId": "3300115144_73_8514-8556",
      "chapterUid": 73,
      "range": "8514-8556",
      "markText": "尽管有证据表明，他的描述大体上来自他对早期哲学家的记述，但他有可能歪曲了他们的思想；",
      "totalCount": 2135,
      "appLink": "weread://bestbookmark?bookId=3300115144&chapterUid=73&rangeStart=8514&rangeEnd=8556",
      "webLink": "https://weread.qq.com/web/reader/62132b70813ab937ag0145d6?chapterUid=73&rangeStart=8514&rangeEnd=8556"
    },
    {
      "bookmarkId": "3300115144_67_4242-4298",
      "chapterUid": 67,
      "range": "4242-4298",
      "markText": "作为在政治上温和的柏格森的信徒，索雷尔相信，只有人造的机械系统才遵循因果决定论，而自然中其余的一切都是一团纷乱。",
      "totalCount": 2132,
      "appLink": "weread://bestbookmark?bookId=3300115144&chapterUid=67&rangeStart=4242&rangeEnd=4298",
      "webLink": "https://weread.qq.com/web/reader/62132b70813ab937ag0145d6?chapterUid=67&rangeStart=4242&rangeEnd=4298"
    },
    {
      "bookmarkId": "3300115144_62_6861-6925",
      "chapterUid": 62,
      "range": "6861-6925",
      "markText": "城邦的不稳定要归咎于当地的贫富冲突，富人想极力建立寡头制——称之为富豪统治也许更达意，而穷人则要建立完全可以自由参加的暴民统治。",
