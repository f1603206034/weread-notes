  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300059465_20_1112-1202",
      "chapterUid": 20,
      "range": "1112-1202",
      "markText": "我们不能发现问题的本源，有时仅仅是因为我们懒惰，没有充分研究；有时则是耐心不够在作怪。对于要做的事情，我们总想着用最快的、一劳永逸的办法来解决，殊不知，问题的本源还在原地嘲笑我们。",
      "totalCount": 2856,
      "appLink": "weread://bestbookmark?bookId=3300059465&chapterUid=20&rangeStart=1112&rangeEnd=1202",
      "webLink": "https://weread.qq.com/web/reader/7d532990813ab7dbag015cf5?chapterUid=20&rangeStart=1112&rangeEnd=1202"
    },
    {
      "bookmarkId": "3300059465_12_1380-1406",
      "chapterUid": 12,
      "range": "1380-1406",
      "markText": "不要想当然地认为你的听众会领悟你没有直接表达的意思。",
      "totalCount": 2844,
      "appLink": "weread://bestbookmark?bookId=3300059465&chapterUid=12&rangeStart=1380&rangeEnd=1406",
      "webLink": "https://weread.qq.com/web/reader/7d532990813ab7dbag015cf5?chapterUid=12&rangeStart=1380&rangeEnd=1406"
    },
    {
      "bookmarkId": "3300059465_7_1869-1916",
      "chapterUid": 7,
      "range": "1869-1916",
      "markText": "由于主观事实得以确认的基础是对其他当事人完全信任，所以你必须首先考虑是否对其他当事人完全信任。",
      "totalCount": 2754,
      "appLink": "weread://bestbookmark?bookId=3300059465&chapterUid=7&rangeStart=1869&rangeEnd=1916",
      "webLink": "https://weread.qq.com/web/reader/7d532990813ab7dbag015cf5?chapterUid=7&rangeStart=1869&rangeEnd=1916"
    },
    {
      "bookmarkId": "3300059465_6_427-497",
      "chapterUid": 6,
      "range": "427-497",
      "markText": "许多错误的产生源于我们注意力不够集中，尤其是在面对相似的情景时。相似性使得我们忽略眼前的实际情况，对应该关注的地方视而不见，草率地得出结论。",
      "totalCount": 2616,
      "appLink": "weread://bestbookmark?bookId=3300059465&chapterUid=6&rangeStart=427&rangeEnd=497",
      "webLink": "https://weread.qq.com/web/reader/7d532990813ab7dbag015cf5?chapterUid=6&rangeStart=427&rangeEnd=497"
    },
