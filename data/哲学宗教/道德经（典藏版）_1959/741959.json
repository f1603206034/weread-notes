  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "741959_1_3-19",
      "chapterUid": 1,
      "range": "3-19",
      "markText": "道可道，非常道。名可名，非常名。",
      "totalCount": 5888,
      "appLink": "weread://bestbookmark?bookId=741959&chapterUid=1&rangeStart=3&rangeEnd=19",
      "webLink": "https://weread.qq.com/web/reader/163322505b5247163e9d900?chapterUid=1&rangeStart=3&rangeEnd=19"
    },
    {
      "bookmarkId": "741959_3_3-36",
      "chapterUid": 3,
      "range": "3-36",
      "markText": "不尚贤，使民不争；不贵难得之货，使民不为盗；不见可欲，使民心不乱。",
      "totalCount": 3760,
      "appLink": "weread://bestbookmark?bookId=741959&chapterUid=3&rangeStart=3&rangeEnd=36",
      "webLink": "https://weread.qq.com/web/reader/163322505b5247163e9d900?chapterUid=3&rangeStart=3&rangeEnd=36"
    },
    {
      "bookmarkId": "741959_5_3-27",
      "chapterUid": 5,
      "range": "3-27",
      "markText": "天地不仁，以万物为刍狗；圣人不仁，以百姓为刍狗。",
      "totalCount": 3468,
      "appLink": "weread://bestbookmark?bookId=741959&chapterUid=5&rangeStart=3&rangeEnd=27",
      "webLink": "https://weread.qq.com/web/reader/163322505b5247163e9d900?chapterUid=5&rangeStart=3&rangeEnd=27"
    },
    {
      "bookmarkId": "741959_2_4-29",
      "chapterUid": 2,
      "range": "4-29",
      "markText": "天下皆知美之为美，斯恶已。皆知善之为善，斯不善已。",
      "totalCount": 3420,
      "appLink": "weread://bestbookmark?bookId=741959&chapterUid=2&rangeStart=4&rangeEnd=29",
      "webLink": "https://weread.qq.com/web/reader/163322505b5247163e9d900?chapterUid=2&rangeStart=4&rangeEnd=29"
    },
    {
      "bookmarkId": "741959_1_41-60",
      "chapterUid": 1,
      "range": "41-60",
      "markText": "故常无，欲以观其妙；常有，欲以观其徼。",
      "totalCount": 3276,
      "appLink": "weread://bestbookmark?bookId=741959&chapterUid=1&rangeStart=41&rangeEnd=60",
      "webLink": "https://weread.qq.com/web/reader/163322505b5247163e9d900?chapterUid=1&rangeStart=41&rangeEnd=60"
    },
    {
      "bookmarkId": "741959_2_113-123",
      "chapterUid": 2,
      "range": "113-123",
      "markText": "夫唯弗居，是以不去。",
      "totalCount": 2784,
      "appLink": "weread://bestbookmark?bookId=741959&chapterUid=2&rangeStart=113&rangeEnd=123",
      "webLink": "https://weread.qq.com/web/reader/163322505b5247163e9d900?chapterUid=2&rangeStart=113&rangeEnd=123"
    },
    {
      "bookmarkId": "741959_1_23-37",
      "chapterUid": 1,
      "range": "23-37",
      "markText": "无名天地之始；有名万物之母。",
      "totalCount": 2528,
      "appLink": "weread://bestbookmark?bookId=741959&chapterUid=1&rangeStart=23&rangeEnd=37",
      "webLink": "https://weread.qq.com/web/reader/163322505b5247163e9d900?chapterUid=1&rangeStart=23&rangeEnd=37"
    },
    {
      "bookmarkId": "741959_2_72-85",
      "chapterUid": 2,
      "range": "72-85",
      "markText": "圣人处无为之事，行不言之教",
      "totalCount": 2465,
      "appLink": "weread://bestbookmark?bookId=741959&chapterUid=2&rangeStart=72&rangeEnd=85",
      "webLink": "https://weread.qq.com/web/reader/163322505b5247163e9d900?chapterUid=2&rangeStart=72&rangeEnd=85"
    },
    {
      "bookmarkId": "741959_7_3-29",
      "chapterUid": 7,
      "range": "3-29",
      "markText": "天长地久。天地所以能长且久者，以其不自生，故能长生。",
      "totalCount": 2380,
      "appLink": "weread://bestbookmark?bookId=741959&chapterUid=7&rangeStart=3&rangeEnd=29",
      "webLink": "https://weread.qq.com/web/reader/163322505b5247163e9d900?chapterUid=7&rangeStart=3&rangeEnd=29"
    },
    {
      "bookmarkId": "741959_18_3-37",
      "chapterUid": 18,
      "range": "3-37",
      "markText": "大道废，有仁义；智慧出，有大伪；六亲不和，有孝慈；国家昏乱，有忠臣。",
      "totalCount": 2314,
      "appLink": "weread://bestbookmark?bookId=741959&chapterUid=18&rangeStart=3&rangeEnd=37",
      "webLink": "https://weread.qq.com/web/reader/163322505b5247163e9d900?chapterUid=18&rangeStart=3&rangeEnd=37"
    },
    {
      "bookmarkId": "741959_1_64-89",
      "chapterUid": 1,
      "range": "64-89",
      "markText": "此两者，同出而异名，同谓之玄。玄之又玄，众妙之门。",
      "totalCount": 2178,
      "appLink": "weread://bestbookmark?bookId=741959&chapterUid=1&rangeStart=64&rangeEnd=89",
      "webLink": "https://weread.qq.com/web/reader/163322505b5247163e9d900?chapterUid=1&rangeStart=64&rangeEnd=89"
    },
    {
      "bookmarkId": "741959_2_33-66",
      "chapterUid": 2,
      "range": "33-66",
      "markText": "有无相生，难易相成，长短相形，高下相倾，音声相和，前后相随。恒也。",
      "totalCount": 1788,
      "appLink": "weread://bestbookmark?bookId=741959&chapterUid=2&rangeStart=33&rangeEnd=66",
      "webLink": "https://weread.qq.com/web/reader/163322505b5247163e9d900?chapterUid=2&rangeStart=33&rangeEnd=66"
    },
    {
      "bookmarkId": "741959_3_84-93",
      "chapterUid": 3,
      "range": "84-93",
      "markText": "为无为，则无不治。",
      "totalCount": 1788,
      "appLink": "weread://bestbookmark?bookId=741959&chapterUid=3&rangeStart=84&rangeEnd=93",
      "webLink": "https://weread.qq.com/web/reader/163322505b5247163e9d900?chapterUid=3&rangeStart=84&rangeEnd=93"
    },
    {
      "bookmarkId": "741959_8_3-29",
      "chapterUid": 8,
      "range": "3-29",
      "markText": "上善若水。水善利万物而不争，处众人之所恶，故几于道。",
      "totalCount": 1700,
      "appLink": "weread://bestbookmark?bookId=741959&chapterUid=8&rangeStart=3&rangeEnd=29",
      "webLink": "https://weread.qq.com/web/reader/163322505b5247163e9d900?chapterUid=8&rangeStart=3&rangeEnd=29"
    },
    {
      "bookmarkId": "741959_9_51-61",
      "chapterUid": 9,
      "range": "51-61",
      "markText": "功遂身退，天之道也。",
      "totalCount": 1694,
      "appLink": "weread://bestbookmark?bookId=741959&chapterUid=9&rangeStart=51&rangeEnd=61",
      "webLink": "https://weread.qq.com/web/reader/163322505b5247163e9d900?chapterUid=9&rangeStart=51&rangeEnd=61"
    },
    {
      "bookmarkId": "741959_11_63-76",
      "chapterUid": 11,
      "range": "63-76",
