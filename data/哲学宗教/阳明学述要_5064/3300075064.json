  "hotBookmarks": [
    {
      "bookmarkId": "3300075064_6_6156-6180",
      "chapterUid": 6,
      "range": "6156-6180",
      "markText": "治怒为难，治惧亦难。克己可以治怒，明理可以治惧。",
      "totalCount": 486,
      "appLink": "weread://bestbookmark?bookId=3300075064&chapterUid=6&rangeStart=6156&rangeEnd=6180",
      "webLink": "https://weread.qq.com/web/reader/86e32470813ab83d2g014f2b?chapterUid=6&rangeStart=6156&rangeEnd=6180"
    },
    {
      "bookmarkId": "3300075064_6_1198-1294",
      "chapterUid": 6,
      "range": "1198-1294",
      "markText": "他们的解答，不外是三点：一是说万物都是一个天神所创造，所以是一体的；一是说万物只是一种原质所变化，所以是一体的；一是说万物只是一个心镜所照现，所以是一体的。这三种说法，便成了宗教、科学和哲学。",
      "totalCount": 240,
      "appLink": "weread://bestbookmark?bookId=3300075064&chapterUid=6&rangeStart=1198&rangeEnd=1294",
      "webLink": "https://weread.qq.com/web/reader/86e32470813ab83d2g014f2b?chapterUid=6&rangeStart=1198&rangeEnd=1294"
    },
    {
      "bookmarkId": "3300075064_6_7077-7085",
      "chapterUid": 6,
      "range": "7077-7085",
      "markText": "人心不得有所系。",
      "totalCount": 238,
      "appLink": "weread://bestbookmark?bookId=3300075064&chapterUid=6&rangeStart=7077&rangeEnd=7085",
      "webLink": "https://weread.qq.com/web/reader/86e32470813ab83d2g014f2b?chapterUid=6&rangeStart=7077&rangeEnd=7085"
    },
    {
      "bookmarkId": "3300075064_4_532-565",
      "chapterUid": 4,
      "range": "532-565",
      "markText": "读者须脱弃训诂和条理的眼光，直透大义，反向自心，则自无不豁然解悟。",
      "totalCount": 195,
      "appLink": "weread://bestbookmark?bookId=3300075064&chapterUid=4&rangeStart=532&rangeEnd=565",
      "webLink": "https://weread.qq.com/web/reader/86e32470813ab83d2g014f2b?chapterUid=4&rangeStart=532&rangeEnd=565"
    },
    {
      "bookmarkId": "3300075064_6_2741-2763",
      "chapterUid": 6,
      "range": "2741-2763",
      "markText": "一人之心，即天地之心；一物之理，即万物之理。",
      "totalCount": 182,
      "appLink": "weread://bestbookmark?bookId=3300075064&chapterUid=6&rangeStart=2741&rangeEnd=2763",
      "webLink": "https://weread.qq.com/web/reader/86e32470813ab83d2g014f2b?chapterUid=6&rangeStart=2741&rangeEnd=2763"
    },
    {
      "bookmarkId": "3300075064_4_385-454",
      "chapterUid": 4,
      "range": "385-454",
      "markText": "讲理学最忌的是搬弄几个性理上的字面，作训诂条理的工夫，却全不得其人精神之所在。次之则争道统，立门户。尤其是讲王学，上述的伎俩，更是使不得。",
      "totalCount": 169,
      "appLink": "weread://bestbookmark?bookId=3300075064&chapterUid=4&rangeStart=385&rangeEnd=454",
      "webLink": "https://weread.qq.com/web/reader/86e32470813ab83d2g014f2b?chapterUid=4&rangeStart=385&rangeEnd=454"
    },
    {
      "bookmarkId": "3300075064_4_705-726",
      "chapterUid": 4,
      "range": "705-726",
      "markText": "阳明讲学，偏重实行，事上磨炼，是其着精神处",
      "totalCount": 153,
      "appLink": "weread://bestbookmark?bookId=3300075064&chapterUid=4&rangeStart=705&rangeEnd=726",
      "webLink": "https://weread.qq.com/web/reader/86e32470813ab83d2g014f2b?chapterUid=4&rangeStart=705&rangeEnd=726"
    },
    {
      "bookmarkId": "3300075064_5_537-546",
      "chapterUid": 5,
      "range": "537-546",
      "markText": "覆瓿之物，重灾梨枣",
      "totalCount": 153,
      "appLink": "weread://bestbookmark?bookId=3300075064&chapterUid=5&rangeStart=537&rangeEnd=546",
      "webLink": "https://weread.qq.com/web/reader/86e32470813ab83d2g014f2b?chapterUid=5&rangeStart=537&rangeEnd=546"
    },
    {
      "bookmarkId": "3300075064_13_1188-1240",
      "chapterUid": 13,
