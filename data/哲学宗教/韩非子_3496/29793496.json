    {
      "bookmarkId": "29793496_8_469-520",
      "chapterUid": 8,
      "range": "469-520",
      "markText": "臣闻不知而言不智，知而不言不忠。［2］为人臣不忠当死，言而不当亦当死。",
      "totalCount": 54,
      "appLink": "weread://bestbookmark?bookId=29793496&chapterUid=8&rangeStart=469&rangeEnd=520",
      "webLink": "https://weread.qq.com/web/reader/27b3281071c69cd827b259b?chapterUid=8&rangeStart=469&rangeEnd=520"
    },
    {
      "bookmarkId": "29793496_6_2998-3012",
      "chapterUid": 6,
      "range": "2998-3012",
      "markText": "木铎以声自毁，膏烛以明自烁。",
      "totalCount": 51,
      "appLink": "weread://bestbookmark?bookId=29793496&chapterUid=6&rangeStart=2998&rangeEnd=3012",
