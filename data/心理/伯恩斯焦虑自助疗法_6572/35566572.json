      "items": [
        {
          "type": "highlight",
          "bookmarkId": "35566572_38_17192-17304",
          "range": "17192-17304",
          "rangeStart": 17192,
          "rangeEnd": 17304,
          "markText": "在恐慌之时，我们不要刻意逃避，而是故意让自己暴露在害怕的事物面前，让自己充满焦虑。这时候，我们不要想着要如何战胜焦虑或是控制焦虑，而是向焦虑妥协，承认它的存在。最后，这种焦虑会像一支蜡烛一样自己燃烧殆尽，你自然就不再焦虑了。",
          "colorStyle": 0,
          "colorLabel": "",
          "createTime": 1722428631,
