      "chapterUid": 3,
      "range": "934-957",
      "markText": "他认为人类的理性决策离不开对身体情绪状态的感受",
      "totalCount": 102,
      "appLink": "weread://bestbookmark?bookId=3300051264&chapterUid=3&rangeStart=934&rangeEnd=957",
