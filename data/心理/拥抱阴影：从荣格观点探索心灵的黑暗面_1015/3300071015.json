          "range": "522-542",
          "rangeStart": 522,
          "rangeEnd": 542,
          "markText": "现代人浪费了巨大的能量来对抗自己的状态。",
          "colorStyle": 0,
          "colorLabel": "",
          "createTime": 1726014172,
          "createTimeFormatted": "2024-09-11 08:22:52",
          "chapterUid": 18,
          "appLink": "weread://bestbookmark?bookId=3300071015&chapterUid=18&rangeStart=522&rangeEnd=542",
