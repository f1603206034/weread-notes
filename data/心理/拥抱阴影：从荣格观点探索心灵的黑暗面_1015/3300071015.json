  ],
  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300071015_10_4361-4388",
      "chapterUid": 10,
      "range": "4361-4388",
      "markText": "这个故事表达的是等待的力量，等待其他人的阴影投射结束。",
      "totalCount": 162,
      "appLink": "weread://bestbookmark?bookId=3300071015&chapterUid=10&rangeStart=4361&rangeEnd=4388",
      "webLink": "https://weread.qq.com/web/reader/16c32b70813ab823dg015b61?chapterUid=10&rangeStart=4361&rangeEnd=4388"
    },
    {
      "bookmarkId": "3300071015_8_1776-1823",
      "chapterUid": 8,
      "range": "1776-1823",
      "markText": "我们的人格中一些纯粹而珍贵的部分会归入阴影之中，这是因为在文化的衡量架构下，它们无处可以容身。",
      "totalCount": 154,
      "appLink": "weread://bestbookmark?bookId=3300071015&chapterUid=8&rangeStart=1776&rangeEnd=1823",
      "webLink": "https://weread.qq.com/web/reader/16c32b70813ab823dg015b61?chapterUid=8&rangeStart=1776&rangeEnd=1823"
    },
    {
      "bookmarkId": "3300071015_10_4650-4735",
      "chapterUid": 10,
      "range": "4650-4735",
      "markText": "我们得到的建议，是去爱我们的敌人。但如果内在的敌人，也就是自身的阴影，正等着扑过来火上加油，那就实在不可能。只有当我们学习去爱内在的敌人时，才有机会去爱并救赎外在的敌人。",
      "totalCount": 144,
      "appLink": "weread://bestbookmark?bookId=3300071015&chapterUid=10&rangeStart=4650&rangeEnd=4735",
      "webLink": "https://weread.qq.com/web/reader/16c32b70813ab823dg015b61?chapterUid=10&rangeStart=4650&rangeEnd=4735"
    },
    {
      "bookmarkId": "3300071015_3_1836-1915",
      "chapterUid": 3,
      "range": "1836-1915",
      "markText": "荣格认为，人是情结的复合体，基本上，心灵就是由各种不同情结所构成的。而形成情结的原因，要追究到阴影。阴影先于情结存在，于情结背后担任主导的角色，两者皆属原型。",
      "totalCount": 136,
      "appLink": "weread://bestbookmark?bookId=3300071015&chapterUid=3&rangeStart=1836&rangeEnd=1915",
      "webLink": "https://weread.qq.com/web/reader/16c32b70813ab823dg015b61?chapterUid=3&rangeStart=1836&rangeEnd=1915"
    },
    {
      "bookmarkId": "3300071015_4_1959-2042",
      "chapterUid": 4,
      "range": "1959-2042",
      "markText": "那些不愿在自身处理阴影的人，就会将内心的黑暗丢给外界、丢给他人。阴影最容易在我们的家人、同事与朋友的身上找着。那些本该由我们承担的一切，成为了他们身上固有的邪恶特质。",
      "totalCount": 132,
      "appLink": "weread://bestbookmark?bookId=3300071015&chapterUid=4&rangeStart=1959&rangeEnd=2042",
      "webLink": "https://weread.qq.com/web/reader/16c32b70813ab823dg015b61?chapterUid=4&rangeStart=1959&rangeEnd=2042"
    },
    {
      "bookmarkId": "3300071015_18_1359-1423",
      "chapterUid": 18,
      "range": "1359-1423",
      "markText": "赢很好，输也很好；拥有很好，分给他人也很好；自由很好，服从权威也很好。从悖论的角度检视生活中的元素，便是打开一连串全新的可能性。",
      "totalCount": 130,
      "appLink": "weread://bestbookmark?bookId=3300071015&chapterUid=18&rangeStart=1359&rangeEnd=1423",
      "webLink": "https://weread.qq.com/web/reader/16c32b70813ab823dg015b61?chapterUid=18&rangeStart=1359&rangeEnd=1423"
    },
    {
      "bookmarkId": "3300071015_15_1017-1100",
      "chapterUid": 15,
      "range": "1017-1100",
      "markText": "当恋爱的投射耗尽，另一边的现实，以及人际交流中最为黑暗的可能性，就会取而代之。如果我们能够熬过这个阶段，便能够拥有人类之爱，虽然比神圣之爱来得不那么刺激，但稳定得多。",
      "totalCount": 126,
      "appLink": "weread://bestbookmark?bookId=3300071015&chapterUid=15&rangeStart=1017&rangeEnd=1100",
      "webLink": "https://weread.qq.com/web/reader/16c32b70813ab823dg015b61?chapterUid=15&rangeStart=1017&rangeEnd=1100"
    },
    {
      "bookmarkId": "3300071015_8_2944-3008",
      "chapterUid": 8,
      "range": "2944-3008",
      "markText": "也许有人会抱怨，这只是毫无意义地绕了一圈回到原点而已，唯一的差别就是最后的整体性是有意识的，而一开始的整体性则是无意识且幼稚的。",
      "totalCount": 110,
