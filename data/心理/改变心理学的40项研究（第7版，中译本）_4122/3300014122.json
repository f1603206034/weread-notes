      "totalCount": 1224,
      "appLink": "weread://bestbookmark?bookId=3300014122&chapterUid=7&rangeStart=7488&rangeEnd=7560",
      "webLink": "https://weread.qq.com/web/reader/fe3325b0813ab6c04g012a12?chapterUid=7&rangeStart=7488&rangeEnd=7560"
