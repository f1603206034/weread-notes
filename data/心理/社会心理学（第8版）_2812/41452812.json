  ],
  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "41452812_33_15581-15638",
      "chapterUid": 33,
      "range": "15581-15638",
      "markText": "客观现实的确存在，但我们总是透过信念与价值观的眼镜观察它们。",
      "totalCount": 8092,
      "appLink": "weread://bestbookmark?bookId=41452812&chapterUid=33&rangeStart=15581&rangeEnd=15638",
      "webLink": "https://weread.qq.com/web/reader/8f532bd07278850c8f51770?chapterUid=33&rangeStart=15581&rangeEnd=15638"
    },
    {
      "bookmarkId": "41452812_30_473-545",
      "chapterUid": 30,
      "range": "473-545",
      "markText": "社会心理学研究的就是人与环境的交互作用。换句话说，社会心理学是研究我们如何创造和改变环境，环境又如何反过来塑造我们的性格、影响我们的行为的科学。",
      "totalCount": 4879,
      "appLink": "weread://bestbookmark?bookId=41452812&chapterUid=30&rangeStart=473&rangeEnd=545",
      "webLink": "https://weread.qq.com/web/reader/8f532bd07278850c8f51770?chapterUid=30&rangeStart=473&rangeEnd=545"
    },
    {
      "bookmarkId": "41452812_33_3019-3061",
      "chapterUid": 33,
      "range": "3019-3061",
      "markText": "社交信念同样也可以变成自我实现的预言。别人对我们的偏见或许也会反过来影响我们的行为。",
      "totalCount": 4784,
      "appLink": "weread://bestbookmark?bookId=41452812&chapterUid=33&rangeStart=3019&rangeEnd=3061",
      "webLink": "https://weread.qq.com/web/reader/8f532bd07278850c8f51770?chapterUid=33&rangeStart=3019&rangeEnd=3061"
    },
    {
      "bookmarkId": "41452812_33_4764-4820",
      "chapterUid": 33,
      "range": "4764-4820",
      "markText": "我们人类总是有一种不可抑制的冲动，想要解释行为，对其归因，以使其变得次序井然，具有可预见性，使一切尽在掌握之中。",
      "totalCount": 4697,
      "appLink": "weread://bestbookmark?bookId=41452812&chapterUid=33&rangeStart=4764&rangeEnd=4820",
      "webLink": "https://weread.qq.com/web/reader/8f532bd07278850c8f51770?chapterUid=33&rangeStart=4764&rangeEnd=4820"
    },
    {
      "bookmarkId": "41452812_33_2708-2744",
      "chapterUid": 33,
      "range": "2708-2744",
      "markText": "我们的社会行为并不仅仅取决于客观情境，还取决于我们如何对其进行主观建构。",
      "totalCount": 3360,
      "appLink": "weread://bestbookmark?bookId=41452812&chapterUid=33&rangeStart=2708&rangeEnd=2744",
      "webLink": "https://weread.qq.com/web/reader/8f532bd07278850c8f51770?chapterUid=33&rangeStart=2708&rangeEnd=2744"
    },
    {
      "bookmarkId": "41452812_33_2010-2069",
      "chapterUid": 33,
      "range": "2010-2069",
      "markText": "他相信，我们人类“首先是情境中的生物”，“因为情境塑造了我们，决定我们未来的诸多可能性，我们便不可能独立于它而存在。”",
      "totalCount": 3192,
      "appLink": "weread://bestbookmark?bookId=41452812&chapterUid=33&rangeStart=2010&rangeEnd=2069",
      "webLink": "https://weread.qq.com/web/reader/8f532bd07278850c8f51770?chapterUid=33&rangeStart=2010&rangeEnd=2069"
    },
    {
      "bookmarkId": "41452812_33_4882-4939",
      "chapterUid": 33,
      "range": "4882-4939",
      "markText": "我们对朋友的责难做何反应，取决于我们对其所做的解释，取决于我们是把它归咎于朋友的敌意行为，还是归结于他糟糕的心情。",
      "totalCount": 3150,
      "appLink": "weread://bestbookmark?bookId=41452812&chapterUid=33&rangeStart=4882&rangeEnd=4939",
      "webLink": "https://weread.qq.com/web/reader/8f532bd07278850c8f51770?chapterUid=33&rangeStart=4882&rangeEnd=4939"
    },
    {
      "bookmarkId": "41452812_31_2670-2697",
      "chapterUid": 31,
      "range": "2670-2697",
      "markText": "一切存在的事物都可以用通俗的语言轻松而自然地加以表达”",
      "totalCount": 2941,
      "appLink": "weread://bestbookmark?bookId=41452812&chapterUid=31&rangeStart=2670&rangeEnd=2697",
      "webLink": "https://weread.qq.com/web/reader/8f532bd07278850c8f51770?chapterUid=31&rangeStart=2670&rangeEnd=2697"
    },
    {
      "bookmarkId": "41452812_35_4773-4892",
      "chapterUid": 35,
      "range": "4773-4892",
      "markText": "作为一个独特而复杂的人，你有多种方式来完成“我是_____”的句子填空。（你可能会给出什么样的五种答案呢？）把这些答案综合起来，就是你对自己的自我概念(self-concept)的定义。",
      "totalCount": 2795,
      "appLink": "weread://bestbookmark?bookId=41452812&chapterUid=35&rangeStart=4773&rangeEnd=4892",
      "webLink": "https://weread.qq.com/web/reader/8f532bd07278850c8f51770?chapterUid=35&rangeStart=4773&rangeEnd=4892"
    },
    {
      "bookmarkId": "41452812_33_3864-3922",
      "chapterUid": 33,
      "range": "3864-3922",
      "markText": "究竟什么情境会让人们变得乐于助人或贪婪？是否某些文化背景——或许是小城镇和小村落——能更好地培养人类乐于助人的品质？",
      "totalCount": 2682,
      "appLink": "weread://bestbookmark?bookId=41452812&chapterUid=33&rangeStart=3864&rangeEnd=3922",
      "webLink": "https://weread.qq.com/web/reader/8f532bd07278850c8f51770?chapterUid=33&rangeStart=3864&rangeEnd=3922"
    },
    {
      "bookmarkId": "41452812_33_23889-23930",
      "chapterUid": 33,
      "range": "23889-23930",
      "markText": "但有时候我们会对自己过分苛刻。我们忘记了事后看来显而易见的事情在当时并非那么明显。",
