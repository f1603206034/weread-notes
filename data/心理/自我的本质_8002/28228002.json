      "appLink": "weread://bestbookmark?bookId=28228002&chapterUid=48&rangeStart=6437&rangeEnd=6527",
      "webLink": "https://weread.qq.com/web/reader/d5e32b8071aeb9a2d5ec826?chapterUid=48&rangeStart=6437&rangeEnd=6527"
    },
    {
