      "chapterUid": 3,
      "range": "437-451",
      "markText": "你以为你以为的你就是真的你吗",
      "totalCount": 204,
      "appLink": "weread://bestbookmark?bookId=28228002&chapterUid=3&rangeStart=437&rangeEnd=451",
      "webLink": "https://weread.qq.com/web/reader/d5e32b8071aeb9a2d5ec826?chapterUid=3&rangeStart=437&rangeEnd=451"
