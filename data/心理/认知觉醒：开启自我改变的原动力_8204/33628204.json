  ],
  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "33628204_53_9247-9313",
      "chapterUid": 53,
      "range": "9247-9313",
      "markText": "每当遇到需要选择的情况时，我们要是能先停留几秒思考一下，就有可能激活自己的理智脑，启用元认知来审视当前的思维，然后做出不一样的选择。",
      "totalCount": 94665,
      "appLink": "weread://bestbookmark?bookId=33628204&chapterUid=53&rangeStart=9247&rangeEnd=9313",
      "webLink": "https://weread.qq.com/web/reader/6a732ce07201202c6a7b30a?chapterUid=53&rangeStart=9247&rangeEnd=9313"
    },
    {
      "bookmarkId": "33628204_54_7735-7830",
      "chapterUid": 54,
      "range": "7735-7830",
      "markText": "所以变聪明的秘诀就是：先保持极度专注，想不出答案时再将注意力转换到另一件与此毫不相干的事情上。即事前聚精会神，让意识极度投入；事后完全忘记，让意识彻底撒手。这样，灵感和答案就会大概率地出现。",
      "totalCount": 91638,
      "appLink": "weread://bestbookmark?bookId=33628204&chapterUid=54&rangeStart=7735&rangeEnd=7830",
      "webLink": "https://weread.qq.com/web/reader/6a732ce07201202c6a7b30a?chapterUid=54&rangeStart=7735&rangeEnd=7830"
    },
    {
      "bookmarkId": "33628204_51_6295-6358",
      "chapterUid": 51,
      "range": "6295-6358",
      "markText": "大多数时候我们以为自己在思考，其实都是在对自身的行为和欲望进行合理化，这正是人类被称作“自我解释的动物”的原因。",
      "totalCount": 91377,
      "appLink": "weread://bestbookmark?bookId=33628204&chapterUid=51&rangeStart=6295&rangeEnd=6358",
      "webLink": "https://weread.qq.com/web/reader/6a732ce07201202c6a7b30a?chapterUid=51&rangeStart=6295&rangeEnd=6358"
    },
    {
      "bookmarkId": "33628204_51_17816-17847",
      "chapterUid": 51,
      "range": "17816-17847",
      "markText": "耐心不是毅力带来的结果，而是具有长远目光的结果。",
      "totalCount": 83728,
      "appLink": "weread://bestbookmark?bookId=33628204&chapterUid=51&rangeStart=17816&rangeEnd=17847",
      "webLink": "https://weread.qq.com/web/reader/6a732ce07201202c6a7b30a?chapterUid=51&rangeStart=17816&rangeEnd=17847"
    },
    {
      "bookmarkId": "33628204_53_2873-2942",
      "chapterUid": 53,
      "range": "2873-2942",
      "markText": "从被动到主动，这是一个转折点。当一个人能主动开启第三视角、开始持续反观自己的思维和行为时，就意味着他真正开始觉醒了，他有了快速成长的可能。",
      "totalCount": 83264,
      "appLink": "weread://bestbookmark?bookId=33628204&chapterUid=53&rangeStart=2873&rangeEnd=2942",
      "webLink": "https://weread.qq.com/web/reader/6a732ce07201202c6a7b30a?chapterUid=53&rangeStart=2873&rangeEnd=2942"
    },
    {
      "bookmarkId": "33628204_51_8219-8269",
      "chapterUid": 51,
      "range": "8219-8269",
      "markText": "无论个体还是群体，人类的安全感都源于自己在某一方面拥有的独特优势：或能力，或财富，或权力，或影响力。",
      "totalCount": 79884,
      "appLink": "weread://bestbookmark?bookId=33628204&chapterUid=51&rangeStart=8219&rangeEnd=8269",
      "webLink": "https://weread.qq.com/web/reader/6a732ce07201202c6a7b30a?chapterUid=51&rangeStart=8219&rangeEnd=8269"
    },
    {
      "bookmarkId": "33628204_55_20384-20411",
      "chapterUid": 55,
      "range": "20384-20411",
      "markText": "只有当知识能够帮助你做实际决策的时候，它才是你的知识。",
      "totalCount": 77536,
      "appLink": "weread://bestbookmark?bookId=33628204&chapterUid=55&rangeStart=20384&rangeEnd=20411",
      "webLink": "https://weread.qq.com/web/reader/6a732ce07201202c6a7b30a?chapterUid=55&rangeStart=20384&rangeEnd=20411"
    },
    {
      "bookmarkId": "33628204_51_7553-7620",
      "chapterUid": 51,
      "range": "7553-7620",
      "markText": "理智脑不是直接干活的，干活是本能脑和情绪脑的事情，因为它们的“力气”大；上天赋予理智脑智慧，是让它驱动本能和情绪，而不是直接取代它们。",
      "totalCount": 72000,
      "appLink": "weread://bestbookmark?bookId=33628204&chapterUid=51&rangeStart=7553&rangeEnd=7620",
      "webLink": "https://weread.qq.com/web/reader/6a732ce07201202c6a7b30a?chapterUid=51&rangeStart=7553&rangeEnd=7620"
    },
    {
      "bookmarkId": "33628204_52_10666-10686",
      "chapterUid": 52,
      "range": "10666-10686",
      "markText": "如果没有任何经济压力，你会如何度过余生？",
