          "rangeStart": 10312,
          "rangeEnd": 10370,
          "markText": "归结起来，焦虑的原因就两条：想同时做很多事，又想立即看到效果。",
          "colorStyle": 1,
          "colorLabel": "",
          "createTime": 1687014315,
          "createTimeFormatted": "2023-06-17 23:05:15",
          "chapterUid": 51,
          "appLink": "weread://bestbookmark?bookId=33628204&chapterUid=51&rangeStart=10312&rangeEnd=10370",
          "webLink": "https://weread.qq.com/web/reader/6a732ce07201202c6a7b30a?chapterUid=51&rangeStart=10312&rangeEnd=10370"
