  "content": [
    {
      "chapterUid": 43,
      "chapterTitle": "第2章 作为新科学的进化心理学",
      "items": [
        {
          "type": "highlight",
          "bookmarkId": "3300174383_9_32286-32455",
          "range": "39717-39949",
          "rangeStart": 39717,
          "rangeEnd": 39949,
          "markText": "比较数据得到了下面的结果。雄性大猩猩的睾丸重量占体重的0.02%；猩猩的是0.05%；人类的是0.08%；而在黑猩猩样本中，睾丸重量占到体重的0.27%（Short, 1979; Smith, 1984）。总之，精子竞争最为激烈的物种拥有最大的睾丸容量，而精子竞争最少的物种则拥有最小的睾丸容量。所以，比较法的研究结果支持了精子竞争假设。",
          "colorStyle": 0,
          "colorLabel": "",
          "createTime": 1762228898,
          "createTimeFormatted": "2025-11-04 12:01:38",
          "chapterUid": 43,
          "appLink": "weread://bestbookmark?bookId=3300174383&chapterUid=43&rangeStart=39717&rangeEnd=39949",
          "webLink": "https://weread.qq.com/web/reader/f9632d30813abaa9eg013699?chapterUid=43&rangeStart=39717&rangeEnd=39949"
        },
        {
          "type": "review",
          "reviewId": "32618646_84p1OSwHn",
          "range": "39750-39752",
          "chapterName": "第2章 作为新科学的进化心理学",
          "content": "xīnɡ xinɡ\n灵长类哺乳动物。体毛赤褐毛。体高可达1.4米。上肢甚长，直立时可达脚踝。无尾和颊囊。头尖，眼小，耳小，口大。树栖，白昼活动，杂食果实、植物嫩芽、蜂蜜、鸟蛋等。产于加里曼丹和苏门答腊的森林中。又称红猩猩、褐猿。",
          "abstract": "猩猩",
          "star": -1,
          "createTime": 1762228977,
          "createTimeFormatted": "2025-11-04 12:02:57",
          "isFinish": false,
          "chapterUid": 43
        },
        {
          "type": "review",
          "reviewId": "32618646_84p1NHH5v",
          "range": "39772-39775",
          "chapterName": "第2章 作为新科学的进化心理学",
          "content": "hēi xīnɡ xīnɡ\n（Pantroglodytes）亦称“黑猿”。哺乳纲，灵长目，人科。体高1.2～1.5米。毛黑色，头较圆，耳大，向两边突出，眉骨高，两眼深陷；鼻小，唇长而薄；前肢长过膝部。生活在非洲中部和西部的热带森林中。成小群，常下地活动，能直立行走。晚间在树上筑巢过夜。杂食性，嗜食果实，也吃昆虫、鸟类。从小饲养者可教以较复杂的动作，适于作动物心理试验。",
          "abstract": "黑猩猩",
          "star": -1,
          "createTime": 1762228960,
          "createTimeFormatted": "2025-11-04 12:02:40",
          "isFinish": false,
          "chapterUid": 43
        },
        {
          "type": "review",
          "reviewId": "32618646_84p1MPTLi",
          "range": "39732-39735",
          "chapterName": "第2章 作为新科学的进化心理学",
          "content": "dà xīnɡ xīnɡ\n（Gorillagorilla）亦称“大猿”。哺乳纲，灵长目，人科。躯体魁梧，是最大的类人猿。雄性高约1.65米，雌性高约1.40米。前肢比后肢长，𧿹趾靠近其他四趾，适于在地上生活。犬齿特别发达。脑比人脑小得多，但结构和人脑最为相似。毛黑褐色，略发灰，老年时灰毛增多。栖息于密林中，雌性和幼仔常树居，雄性多在地面生活；通常3～5只在一起生活。主要以植物嫩芽、野果为食。分布于非洲西部和东部的赤道地区。",
          "abstract": "大猩猩",
          "star": -1,
          "createTime": 1762228947,
          "createTimeFormatted": "2025-11-04 12:02:27",
          "isFinish": false,
          "chapterUid": 43
        }
      ]
    },
