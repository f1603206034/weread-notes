      "appLink": "weread://bestbookmark?bookId=3300064234&chapterUid=6&rangeStart=458&rangeEnd=510",
      "webLink": "https://weread.qq.com/web/reader/6ab326d0813ab7f97g014662?chapterUid=6&rangeStart=458&rangeEnd=510"
    },
