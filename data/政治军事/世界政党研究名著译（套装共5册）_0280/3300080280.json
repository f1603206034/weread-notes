  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300080280_7_2162-2235",
      "chapterUid": 7,
      "range": "2162-2235",
      "markText": "土地贵族由于掌握了大量财富，也就掌控了通向权力的一切途径。绝大多数公职，都是纯粹名誉性和无偿的。此外，他们为了能够选上这些职位，还需要自证财力雄厚",
      "totalCount": 51,
      "appLink": "weread://bestbookmark?bookId=3300080280&chapterUid=7&rangeStart=2162&rangeEnd=2235",
      "webLink": "https://weread.qq.com/web/reader/a56321b0813ab85dcg010b31?chapterUid=7&rangeStart=2162&rangeEnd=2235"
    },
    {
      "bookmarkId": "3300080280_7_5750-5771",
      "chapterUid": 7,
      "range": "5750-5771",
      "markText": "英国的教会仅仅是作为领导阶级的附庸存在的。",
      "totalCount": 34,
      "appLink": "weread://bestbookmark?bookId=3300080280&chapterUid=7&rangeStart=5750&rangeEnd=5771",
      "webLink": "https://weread.qq.com/web/reader/a56321b0813ab85dcg010b31?chapterUid=7&rangeStart=5750&rangeEnd=5771"
    },
    {
      "bookmarkId": "3300080280_7_410-468",
      "chapterUid": 7,
      "range": "410-468",
      "markText": "民主时代的来临，打破了政治社会的旧有框架。等级制度及其内在的凝聚力被摧毁，传统社会中连接个人与集体的关系也随之瓦解。",
      "totalCount": 30,
      "appLink": "weread://bestbookmark?bookId=3300080280&chapterUid=7&rangeStart=410&rangeEnd=468",
      "webLink": "https://weread.qq.com/web/reader/a56321b0813ab85dcg010b31?chapterUid=7&rangeStart=410&rangeEnd=468"
    },
    {
      "bookmarkId": "3300080280_7_2727-2779",
      "chapterUid": 7,
      "range": "2727-2779",
      "markText": "。于是在地主和佃户之间就结成了一种类似家庭成员的关系：一方是父辈的爱、照拂和专断，另一方则是敬意和忠诚。",
      "totalCount": 28,
      "appLink": "weread://bestbookmark?bookId=3300080280&chapterUid=7&rangeStart=2727&rangeEnd=2779",
