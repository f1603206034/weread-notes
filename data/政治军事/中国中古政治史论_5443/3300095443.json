  ],
  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300095443_45_10771-10801",
      "chapterUid": 45,
      "range": "10771-10801",
      "markText": "杨师厚清除了魏博不服从自己的牙军，建立了自己的职业军人集团。",
      "totalCount": 706,
      "appLink": "weread://bestbookmark?bookId=3300095443&chapterUid=45&rangeStart=10771&rangeEnd=10801",
      "webLink": "https://weread.qq.com/web/reader/ebd32e40813ab8bc8g013f7a?chapterUid=45&rangeStart=10771&rangeEnd=10801"
    },
    {
      "bookmarkId": "3300095443_37_916-1011",
      "chapterUid": 37,
      "range": "916-1011",
      "markText": "大统九年以前，西魏与东魏间有六次大战役，在宇文泰阵营之中，史书记载参与将领凡九十二人，除二人史载不详外，其中五十一人系北镇人士，三十九人非北镇人士，非北镇人士大都是汉人豪族。",
      "totalCount": 697,
      "appLink": "weread://bestbookmark?bookId=3300095443&chapterUid=37&rangeStart=916&rangeEnd=1011",
      "webLink": "https://weread.qq.com/web/reader/ebd32e40813ab8bc8g013f7a?chapterUid=37&rangeStart=916&rangeEnd=1011"
    },
    {
      "bookmarkId": "3300095443_19_5187-5234",
      "chapterUid": 19,
      "range": "5187-5234",
      "markText": "出纳王命的中书舍人必须随侍在侧，又掌管军士的训练、调拨者，掌管战马之饲养、征集者亦须侍从左右。",
      "totalCount": 695,
      "appLink": "weread://bestbookmark?bookId=3300095443&chapterUid=19&rangeStart=5187&rangeEnd=5234",
      "webLink": "https://weread.qq.com/web/reader/ebd32e40813ab8bc8g013f7a?chapterUid=19&rangeStart=5187&rangeEnd=5234"
    },
    {
      "bookmarkId": "3300095443_8_1701-1766",
      "chapterUid": 8,
      "range": "1701-1766",
      "markText": "实则纵观我国历史，关东地区自春秋战国以还，在经济文化诸方面皆凌驾于关中之上，秦与西汉居关中而临天下，实含有浓厚的政治人为力量因素。",
      "totalCount": 694,
      "appLink": "weread://bestbookmark?bookId=3300095443&chapterUid=8&rangeStart=1701&rangeEnd=1766",
      "webLink": "https://weread.qq.com/web/reader/ebd32e40813ab8bc8g013f7a?chapterUid=8&rangeStart=1701&rangeEnd=1766"
    },
    {
      "bookmarkId": "3300095443_42_4116-4153",
      "chapterUid": 42,
      "range": "4116-4153",
      "markText": "贞观时，“置府分布，边疆地区一概置府，且大底两层环绕，内地军事重地亦置之。",
      "totalCount": 687,
      "appLink": "weread://bestbookmark?bookId=3300095443&chapterUid=42&rangeStart=4116&rangeEnd=4153",
      "webLink": "https://weread.qq.com/web/reader/ebd32e40813ab8bc8g013f7a?chapterUid=42&rangeStart=4116&rangeEnd=4153"
    },
    {
      "bookmarkId": "3300095443_8_2214-2411",
      "chapterUid": 8,
      "range": "2214-2411",
      "markText": "自安史乱后，藩镇跋扈，军府林立，无论是中央所任用的蕃将蕃兵，还是藩镇的军校牙兵，一个半世纪以来培养出一种职业军人集团，随着府兵之衰退，大唐中央军之羸弱，愈来愈衬托出这批人在历史上扮演的重要角色。",
      "totalCount": 682,
      "appLink": "weread://bestbookmark?bookId=3300095443&chapterUid=8&rangeStart=2214&rangeEnd=2411",
      "webLink": "https://weread.qq.com/web/reader/ebd32e40813ab8bc8g013f7a?chapterUid=8&rangeStart=2214&rangeEnd=2411"
    },
    {
      "bookmarkId": "3300095443_47_17638-17669",
      "chapterUid": 47,
      "range": "17638-17669",
      "markText": "能否摘取这种改变的果实，则端视客观的政治社会条件是否已经成熟。",
      "totalCount": 679,
      "appLink": "weread://bestbookmark?bookId=3300095443&chapterUid=47&rangeStart=17638&rangeEnd=17669",
      "webLink": "https://weread.qq.com/web/reader/ebd32e40813ab8bc8g013f7a?chapterUid=47&rangeStart=17638&rangeEnd=17669"
    },
    {
      "bookmarkId": "3300095443_40_4033-4080",
      "chapterUid": 40,
      "range": "4033-4080",
      "markText": "如上所述，琅琊王氏虽然拥有武力，但被拥上帝位者是司马氏而非王氏，此即表示当时有其他力量牵制也。",
      "totalCount": 677,
      "appLink": "weread://bestbookmark?bookId=3300095443&chapterUid=40&rangeStart=4033&rangeEnd=4080",
      "webLink": "https://weread.qq.com/web/reader/ebd32e40813ab8bc8g013f7a?chapterUid=40&rangeStart=4033&rangeEnd=4080"
    },
    {
      "bookmarkId": "3300095443_37_1323-1402",
      "chapterUid": 37,
      "range": "1323-1402",
      "markText": "六侨州是禁旅之所出，亦是北镇部人居住之所，西魏六侨州设在泾水、洛水上游之间，具有攻守之作用，而北周将六侨州迁至岐州武功一带，以表示北疆稳固，及宇文氏南图之意。",
      "totalCount": 666,
      "appLink": "weread://bestbookmark?bookId=3300095443&chapterUid=37&rangeStart=1323&rangeEnd=1402",
      "webLink": "https://weread.qq.com/web/reader/ebd32e40813ab8bc8g013f7a?chapterUid=37&rangeStart=1323&rangeEnd=1402"
    },
    {
      "bookmarkId": "3300095443_43_3505-3592",
      "chapterUid": 43,
      "range": "3505-3592",
      "markText": "这才使田承嗣安守境界，时田承嗣实际控制有贝、博、魏、卫、相、磁、洺等七州，约与以后的魏博节度使相当（魏博大部分时间拥有贝、博、魏、卫、相、澶），时在代宗大历十二年。",
      "totalCount": 666,
      "appLink": "weread://bestbookmark?bookId=3300095443&chapterUid=43&rangeStart=3505&rangeEnd=3592",
      "webLink": "https://weread.qq.com/web/reader/ebd32e40813ab8bc8g013f7a?chapterUid=43&rangeStart=3505&rangeEnd=3592"
    },
    {
      "bookmarkId": "3300095443_23_2258-2324",
      "chapterUid": 23,
      "range": "2258-2324",
      "markText": "按河东柳氏在两汉、晋朝时已有任职中央者，尤其是柳轨为晋吏部尚书，乃子景猷为晋侍中，此二职在中央官职中甚为重要，唯正史无传，不知其详。",
      "totalCount": 661,
      "appLink": "weread://bestbookmark?bookId=3300095443&chapterUid=23&rangeStart=2258&rangeEnd=2324",
      "webLink": "https://weread.qq.com/web/reader/ebd32e40813ab8bc8g013f7a?chapterUid=23&rangeStart=2258&rangeEnd=2324"
    },
    {
      "bookmarkId": "3300095443_13_1930-2000",
      "chapterUid": 13,
      "range": "1930-2000",
      "markText": "此地适宜牧畜及部分农耕，北魏道武帝时南面还拥有今山西、河北两省之地，平城出居庸关可达幽州，出飞狐关可达定州、易州，南出雁门关可达代州、并州。",
      "totalCount": 660,
      "appLink": "weread://bestbookmark?bookId=3300095443&chapterUid=13&rangeStart=1930&rangeEnd=2000",
      "webLink": "https://weread.qq.com/web/reader/ebd32e40813ab8bc8g013f7a?chapterUid=13&rangeStart=1930&rangeEnd=2000"
    },
    {
      "bookmarkId": "3300095443_7_4306-4339",
      "chapterUid": 7,
      "range": "4306-4339",
      "markText": "宇文泰使府兵将领与土地发生联系，把府兵将领都变成了关陇地区的豪族。",
      "totalCount": 654,
      "appLink": "weread://bestbookmark?bookId=3300095443&chapterUid=7&rangeStart=4306&rangeEnd=4339",
      "webLink": "https://weread.qq.com/web/reader/ebd32e40813ab8bc8g013f7a?chapterUid=7&rangeStart=4306&rangeEnd=4339"
    },
    {
      "bookmarkId": "3300095443_37_373-452",
      "chapterUid": 37,
      "range": "373-452",
      "markText": "西魏时期宇文泰亲信有于谨、贺兰祥、宇文导、宇文护、王盟、尉迟纲、尉迟迥、叱列伏龟、阎庆、宇文贵等，以宇文泰为中心，包括宇文泰之宗室、姻亲及最亲信之部将。",
      "totalCount": 653,
      "appLink": "weread://bestbookmark?bookId=3300095443&chapterUid=37&rangeStart=373&rangeEnd=452",
      "webLink": "https://weread.qq.com/web/reader/ebd32e40813ab8bc8g013f7a?chapterUid=37&rangeStart=373&rangeEnd=452"
    },
    {
      "bookmarkId": "3300095443_37_481-529",
      "chapterUid": 37,
      "range": "481-529",
      "markText": "贺拔胜集团有贺拔胜、独孤信、杨忠、史宁等，由于贺拔胜位高权轻，实际领袖是独孤信，统领原荆州部队。",
      "totalCount": 653,
      "appLink": "weread://bestbookmark?bookId=3300095443&chapterUid=37&rangeStart=481&rangeEnd=529",
      "webLink": "https://weread.qq.com/web/reader/ebd32e40813ab8bc8g013f7a?chapterUid=37&rangeStart=481&rangeEnd=529"
    },
    {
      "bookmarkId": "3300095443_30_4072-4108",
      "chapterUid": 30,
      "range": "4072-4108",
      "markText": "此二战略方向却由李渊实现，其间除了战略路线正确以外，亦需地方势力的支援。",
      "totalCount": 641,
      "appLink": "weread://bestbookmark?bookId=3300095443&chapterUid=30&rangeStart=4072&rangeEnd=4108",
      "webLink": "https://weread.qq.com/web/reader/ebd32e40813ab8bc8g013f7a?chapterUid=30&rangeStart=4072&rangeEnd=4108"
    },
    {
      "bookmarkId": "3300095443_20_833-883",
      "chapterUid": 20,
      "range": "833-883",
      "markText": "核心集团利用平城的战略地位，配合核心区内的名骑，屡屡征战，光芒四射，成为北中国以及草原一带的大帝国。",
      "totalCount": 637,
      "appLink": "weread://bestbookmark?bookId=3300095443&chapterUid=20&rangeStart=833&rangeEnd=883",
      "webLink": "https://weread.qq.com/web/reader/ebd32e40813ab8bc8g013f7a?chapterUid=20&rangeStart=833&rangeEnd=883"
    },
    {
      "bookmarkId": "3300095443_15_3117-3199",
      "chapterUid": 15,
      "range": "3117-3199",
      "markText": "从上引律令及神话来看，羽林、虎贲应该有田，田在京畿附近，羽林、虎贲本人防卫政治中心京师，有的派遣至巨镇戍守，正如同有许多国人在平城附近、有一些人被派至六镇戍守一样。",
      "totalCount": 636,
      "appLink": "weread://bestbookmark?bookId=3300095443&chapterUid=15&rangeStart=3117&rangeEnd=3199",
      "webLink": "https://weread.qq.com/web/reader/ebd32e40813ab8bc8g013f7a?chapterUid=15&rangeStart=3117&rangeEnd=3199"
    },
    {
      "bookmarkId": "3300095443_13_699-1323",
      "chapterUid": 13,
      "range": "699-1323",
      "markText": "由于这个区域位居沙漠南缘的草原地带，所以适宜畜牧生活，云中川一带畜牧甚盛，而盐池、桑干水、㶟水流域支流甚多，部分地区亦适宜农耕，所以这个地区是农牧兼宜的复式地带。",
