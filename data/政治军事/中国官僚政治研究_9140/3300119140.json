  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300119140_9_11894-11957",
      "chapterUid": 9,
      "range": "11894-11957",
      "markText": "但我相信，一个私有财产制不存在的社会，一般生产大众皆有政治发言权的社会，任何一种当作社会体制看的官僚政治形态是决计无法生根的。",
      "totalCount": 396,
      "appLink": "weread://bestbookmark?bookId=3300119140&chapterUid=9&rangeStart=11894&rangeEnd=11957",
      "webLink": "https://weread.qq.com/web/reader/e5332c90813ab950ag010104?chapterUid=9&rangeStart=11894&rangeEnd=11957"
    },
    {
      "bookmarkId": "3300119140_5_2661-2758",
      "chapterUid": 5,
      "range": "2661-2758",
      "markText": "王先生进一步指出：在阶级社会中，一个统治阶级要想巩固其统治地位，就必然要在把握社会物质基本生产手段之后进一步支配精神生产手段。官僚政治最终与儒家思想完美契合，成为统治中国的政治文化两千年的关键。",
      "totalCount": 340,
      "appLink": "weread://bestbookmark?bookId=3300119140&chapterUid=5&rangeStart=2661&rangeEnd=2758",
      "webLink": "https://weread.qq.com/web/reader/e5332c90813ab950ag010104?chapterUid=5&rangeStart=2661&rangeEnd=2758"
    },
    {
      "bookmarkId": "3300119140_5_5191-5247",
      "chapterUid": 5,
      "range": "5191-5247",
      "markText": "让人民、让一般工农大众普遍的自觉自动起来，参加并主导着政治革新运动了，那才是它（官僚政治）真正寿终正寝的时候”。",
      "totalCount": 304,
      "appLink": "weread://bestbookmark?bookId=3300119140&chapterUid=5&rangeStart=5191&rangeEnd=5247",
      "webLink": "https://weread.qq.com/web/reader/e5332c90813ab950ag010104?chapterUid=5&rangeStart=5191&rangeEnd=5247"
    },
    {
      "bookmarkId": "3300119140_16_5412-5486",
      "chapterUid": 16,
      "range": "5412-5486",
      "markText": "所以，把仕途向庶人开放，决不是基于什么平等或民主的观念，到了唐代那个历史阶段，要完成集权的专制官僚统治，是不能不采行一种比较稍有融通性的官人方法的。",
      "totalCount": 252,
      "appLink": "weread://bestbookmark?bookId=3300119140&chapterUid=16&rangeStart=5412&rangeEnd=5486",
      "webLink": "https://weread.qq.com/web/reader/e5332c90813ab950ag010104?chapterUid=16&rangeStart=5412&rangeEnd=5486"
    },
    {
      "bookmarkId": "3300119140_9_8257-8348",
      "chapterUid": 9,
      "range": "8257-8348",
      "markText": "监察机关用各种方法掩饰行政官的污点，他们有时也更换行政人员，但那是为了在人民心目中造成一种印象，以为政府也是反对官僚主义的，其实，那是政府惧怕人民骚动，故以监督官的名义来监督人民……",
      "totalCount": 238,
      "appLink": "weread://bestbookmark?bookId=3300119140&chapterUid=9&rangeStart=8257&rangeEnd=8348",
      "webLink": "https://weread.qq.com/web/reader/e5332c90813ab950ag010104?chapterUid=9&rangeStart=8257&rangeEnd=8348"
    },
    {
      "bookmarkId": "3300119140_5_3076-3103",
      "chapterUid": 5,
      "range": "3076-3103",
      "markText": "因而欧洲表现的是贵族的官僚化，而中国则是官僚的贵族化。",
      "totalCount": 234,
      "appLink": "weread://bestbookmark?bookId=3300119140&chapterUid=5&rangeStart=3076&rangeEnd=3103",
      "webLink": "https://weread.qq.com/web/reader/e5332c90813ab950ag010104?chapterUid=5&rangeStart=3076&rangeEnd=3103"
