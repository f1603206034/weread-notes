      "items": [
        {
          "type": "review",
          "reviewId": "32618646_85uJGOTRN",
          "range": "4535-4539",
          "chapterName": "第四节 秦灭六国 统一中原",
          "content": "chánɡ pínɡ zhī zhàn\n战国时秦国大败赵国的战役。秦昭王四十五年（前262年），秦将白起攻韩，取野王（今河南沁阳），上党郡（今山西沁河以东一带）与韩不能相通，郡守冯亭以地献赵，引起秦、赵在长平（今山西高平西北）大战。赵将廉颇坚守长平达三年之久。后赵国中秦反间计，改用赵括为将。赵括空谈兵法，无实战经验，一反廉颇坚守战略，率大军盲目出击。秦将白起在正面诈败后退，另用两支奇兵袭击赵军后路。赵军被包围，困守四十六日，不能突围，赵括被射死，赵军四十多万人被俘坑死。从此赵国国势衰落。",
          "abstract": "长平之战",
          "star": -1,
          "createTime": 1766074784,
          "createTimeFormatted": "2025-12-19 00:19:44",
          "isFinish": false,
          "chapterUid": 18
        }
