  "content": [
    {
      "chapterUid": 27,
      "chapterTitle": "第15章 走向未来的社会主义",
      "items": [
        {
          "type": "highlight",
          "bookmarkId": "3300068726_27_6651-6721",
          "range": "6651-6721",
          "rangeStart": 6651,
          "rangeEnd": 6721,
          "markText": "不管一个纪律严明的民主集中的政党在一个独裁国家夺权如何有力，历史已经证明，由此产生的一党统治并不能带领人民去建设一种长期可行的社会主义形式。",
          "colorStyle": 0,
          "colorLabel": "",
          "createTime": 1726013892,
          "createTimeFormatted": "2024-09-11 08:18:12",
          "chapterUid": 27,
          "appLink": "weread://bestbookmark?bookId=3300068726&chapterUid=27&rangeStart=6651&rangeEnd=6721",
          "webLink": "https://weread.qq.com/web/reader/99032c20813ab8158g0160cf?chapterUid=27&rangeStart=6651&rangeEnd=6721"
