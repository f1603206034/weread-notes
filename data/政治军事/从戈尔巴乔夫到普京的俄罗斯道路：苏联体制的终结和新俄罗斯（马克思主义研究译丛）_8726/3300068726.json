  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300068726_27_6129-6209",
      "chapterUid": 27,
      "range": "6129-6209",
      "markText": "第一，可行的社会主义制度必须包括民主的政体，尊重个人的公民自由；第二，必须用其他的制度来取代集权制和等级制；第三，社会主义必须拥有预防特权和统治精英滋生的体制。",
      "totalCount": 459,
      "appLink": "weread://bestbookmark?bookId=3300068726&chapterUid=27&rangeStart=6129&rangeEnd=6209",
      "webLink": "https://weread.qq.com/web/reader/99032c20813ab8158g0160cf?chapterUid=27&rangeStart=6129&rangeEnd=6209"
    },
    {
      "bookmarkId": "3300068726_13_9117-9209",
      "chapterUid": 13,
      "range": "9117-9209",
      "markText": "许许多多苏联知识分子根本就不认为国家社会主义为他们创造了优越的物质条件，在他们看来，他们的物质条件不管是在绝对的意义上，还是在相对的意义上，都要比生活在资本主义西方的知识分子糟糕许多。",
      "totalCount": 432,
      "appLink": "weread://bestbookmark?bookId=3300068726&chapterUid=13&rangeStart=9117&rangeEnd=9209",
      "webLink": "https://weread.qq.com/web/reader/99032c20813ab8158g0160cf?chapterUid=13&rangeStart=9117&rangeEnd=9209"
    },
    {
      "bookmarkId": "3300068726_27_6651-6721",
      "chapterUid": 27,
      "range": "6651-6721",
      "markText": "不管一个纪律严明的民主集中的政党在一个独裁国家夺权如何有力，历史已经证明，由此产生的一党统治并不能带领人民去建设一种长期可行的社会主义形式。",
      "totalCount": 400,
      "appLink": "weread://bestbookmark?bookId=3300068726&chapterUid=27&rangeStart=6651&rangeEnd=6721",
      "webLink": "https://weread.qq.com/web/reader/99032c20813ab8158g0160cf?chapterUid=27&rangeStart=6651&rangeEnd=6721"
    },
    {
      "bookmarkId": "3300068726_8_8368-8467",
      "chapterUid": 8,
      "range": "8368-8467",
      "markText": "有关苏联体制出人意料地突然终结与和平让渡的最终解释是：它被它自己的大多数精英抛弃了，随着苏联体制的发展，把这些人和任何社会主义形式联系在一起的物质和意识形态纽带越来越脆弱了。这是一场来自上层的革命。",
      "totalCount": 391,
      "appLink": "weread://bestbookmark?bookId=3300068726&chapterUid=8&rangeStart=8368&rangeEnd=8467",
      "webLink": "https://weread.qq.com/web/reader/99032c20813ab8158g0160cf?chapterUid=8&rangeStart=8368&rangeEnd=8467"
    },
    {
      "bookmarkId": "3300068726_27_12555-12611",
      "chapterUid": 27,
      "range": "12555-12611",
      "markText": "苏联建设社会主义的经历及其失败的最重要的教训是：我们不是处在社会主义挑战资本主义的终点，而是处在这一挑战的开端。",
      "totalCount": 363,
      "appLink": "weread://bestbookmark?bookId=3300068726&chapterUid=27&rangeStart=12555&rangeEnd=12611",
      "webLink": "https://weread.qq.com/web/reader/99032c20813ab8158g0160cf?chapterUid=27&rangeStart=12555&rangeEnd=12611"
    },
    {
      "bookmarkId": "3300068726_5_2557-2604",
      "chapterUid": 5,
      "range": "2557-2604",
      "markText": "我们认为，他们转而拥戴资本主义，是由于他们认识到从社会主义转变成资本主义能使他们变得更加富有。",
      "totalCount": 350,
      "appLink": "weread://bestbookmark?bookId=3300068726&chapterUid=5&rangeStart=2557&rangeEnd=2604",
      "webLink": "https://weread.qq.com/web/reader/99032c20813ab8158g0160cf?chapterUid=5&rangeStart=2557&rangeEnd=2604"
    },
    {
      "bookmarkId": "3300068726_8_2763-2820",
      "chapterUid": 8,
      "range": "2763-2820",
      "markText": "像苏联这样一个经济上和军事上都十分强大的实体突然坍塌，而且根本就没有什么外部入侵和内部暴乱，在现代历史上实属罕见。",
      "totalCount": 330,
      "appLink": "weread://bestbookmark?bookId=3300068726&chapterUid=8&rangeStart=2763&rangeEnd=2820",
      "webLink": "https://weread.qq.com/web/reader/99032c20813ab8158g0160cf?chapterUid=8&rangeStart=2763&rangeEnd=2820"
    },
    {
      "bookmarkId": "3300068726_20_34278-34363",
      "chapterUid": 20,
      "range": "34278-34363",
      "markText": "在建立市场体制的战略上，中国和俄罗斯的主要区别是，中国的战略是由中国领导人设计的，这些领导人都能密切关注其现存经济体制的特点，并懂得渐进的、由国家管理的经济转轨的优越性。",
