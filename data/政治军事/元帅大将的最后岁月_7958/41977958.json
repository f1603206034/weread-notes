      "chapterUid": 6,
      "range": "3449-3470",
      "markText": "毛泽东握着陈毅的手说：“陈老总，我保你！”",
      "totalCount": 120,
      "appLink": "weread://bestbookmark?bookId=41977958&chapterUid=6&rangeStart=3449&rangeEnd=3470",
      "webLink": "https://weread.qq.com/web/reader/e5232dc072808866e52beee?chapterUid=6&rangeStart=3449&rangeEnd=3470"
