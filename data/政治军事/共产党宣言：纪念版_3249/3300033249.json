  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300033249_33_4026-4086",
      "chapterUid": 33,
      "range": "4026-4086",
      "markText": "资产阶级抹去了一切向来受人尊崇和令人敬畏的职业的神圣光环。它把医生、律师、教士、诗人和学者变成了它出钱招雇的雇佣劳动者。",
      "totalCount": 5040,
      "appLink": "weread://bestbookmark?bookId=3300033249&chapterUid=33&rangeStart=4026&rangeEnd=4086",
      "webLink": "https://weread.qq.com/web/reader/7ee32da0813ab737cg019361?chapterUid=33&rangeStart=4026&rangeEnd=4086"
    },
    {
      "bookmarkId": "3300033249_33_1089-1473",
      "chapterUid": 33,
      "range": "1089-1473",
      "markText": "至今一切社会的历史都是阶级斗争的历史。",
      "totalCount": 4656,
      "appLink": "weread://bestbookmark?bookId=3300033249&chapterUid=33&rangeStart=1089&rangeEnd=1473",
      "webLink": "https://weread.qq.com/web/reader/7ee32da0813ab737cg019361?chapterUid=33&rangeStart=1089&rangeEnd=1473"
    },
    {
      "bookmarkId": "3300033249_33_16539-16581",
      "chapterUid": 33,
      "range": "16539-16581",
      "markText": "共产主义并不剥夺任何人占有社会产品的权力，它只剥夺利用这种占有去奴役他人劳动的权力。",
      "totalCount": 4014,
      "appLink": "weread://bestbookmark?bookId=3300033249&chapterUid=33&rangeStart=16539&rangeEnd=16581",
      "webLink": "https://weread.qq.com/web/reader/7ee32da0813ab737cg019361?chapterUid=33&rangeStart=16539&rangeEnd=16581"
    },
    {
      "bookmarkId": "3300033249_33_402-478",
      "chapterUid": 33,
      "range": "402-478",
      "markText": "一个幽灵，共产主义的幽灵，在欧洲游荡。为了对这个幽灵进行神圣的围剿，旧欧洲的一切势力，教皇和沙皇、梅特涅和基佐、法国的激进派和德国的警察，都联合起来了。",
      "totalCount": 3978,
      "appLink": "weread://bestbookmark?bookId=3300033249&chapterUid=33&rangeStart=402&rangeEnd=478",
      "webLink": "https://weread.qq.com/web/reader/7ee32da0813ab737cg019361?chapterUid=33&rangeStart=402&rangeEnd=478"
    },
    {
      "bookmarkId": "3300033249_33_18004-18060",
      "chapterUid": 33,
      "range": "18004-18060",
      "markText": "资产者是把自己的妻子看做单纯的生产工具的。他们听说生产工具将要公共使用，自然就不能不想到妇女也会遭到同样的命运。",
      "totalCount": 3330,
      "appLink": "weread://bestbookmark?bookId=3300033249&chapterUid=33&rangeStart=18004&rangeEnd=18060",
      "webLink": "https://weread.qq.com/web/reader/7ee32da0813ab737cg019361?chapterUid=33&rangeStart=18004&rangeEnd=18060"
    },
    {
      "bookmarkId": "3300033249_33_4115-4154",
      "chapterUid": 33,
      "range": "4115-4154",
      "markText": "资产阶级撕下了罩在家庭关系上的温情脉脉的面纱，把这种关系变成了纯粹的金钱关系。",
      "totalCount": 3179,
      "appLink": "weread://bestbookmark?bookId=3300033249&chapterUid=33&rangeStart=4115&rangeEnd=4154",
      "webLink": "https://weread.qq.com/web/reader/7ee32da0813ab737cg019361?chapterUid=33&rangeStart=4115&rangeEnd=4154"
    },
    {
      "bookmarkId": "3300033249_33_8675-8742",
      "chapterUid": 33,
      "range": "8675-8742",
      "markText": "当厂主对工人的剥削告一段落，工人领到了用现钱支付的工资的时候，马上就有资产阶级中的另一部分人——房东、小店主、当铺老板等等向他们扑来。",
      "totalCount": 2840,
      "appLink": "weread://bestbookmark?bookId=3300033249&chapterUid=33&rangeStart=8675&rangeEnd=8742",
      "webLink": "https://weread.qq.com/web/reader/7ee32da0813ab737cg019361?chapterUid=33&rangeStart=8675&rangeEnd=8742"
    },
    {
      "bookmarkId": "3300033249_33_5118-5164",
      "chapterUid": 33,
      "range": "5118-5164",
      "markText": "不断扩大产品销路的需要，驱使资产阶级奔走于全球各地。它必须到处落户，到处开发，到处建立联系。",
      "totalCount": 2656,
      "appLink": "weread://bestbookmark?bookId=3300033249&chapterUid=33&rangeStart=5118&rangeEnd=5164",
      "webLink": "https://weread.qq.com/web/reader/7ee32da0813ab737cg019361?chapterUid=33&rangeStart=5118&rangeEnd=5164"
    },
    {
      "bookmarkId": "3300033249_33_3795-3868",
      "chapterUid": 33,
      "range": "3795-3868",
      "markText": "它无情地斩断了把人们束缚于天然尊长的形形色色的封建羁绊，它使人和人之间除了赤裸裸的利害关系，除了冷酷无情的“现金交易”，就再也没有任何别的联系了。",
      "totalCount": 2655,
      "appLink": "weread://bestbookmark?bookId=3300033249&chapterUid=33&rangeStart=3795&rangeEnd=3868",
      "webLink": "https://weread.qq.com/web/reader/7ee32da0813ab737cg019361?chapterUid=33&rangeStart=3795&rangeEnd=3868"
    },
    {
      "bookmarkId": "3300033249_33_4921-4973",
      "chapterUid": 33,
      "range": "4921-4973",
      "markText": "生产的不断变革，一切社会状况不停的动荡，永远的不安定和变动，这就是资产阶级时代不同于过去一切时代的地方。",
      "totalCount": 2516,
      "appLink": "weread://bestbookmark?bookId=3300033249&chapterUid=33&rangeStart=4921&rangeEnd=4973",
      "webLink": "https://weread.qq.com/web/reader/7ee32da0813ab737cg019361?chapterUid=33&rangeStart=4921&rangeEnd=4973"
    },
    {
      "bookmarkId": "3300033249_33_12142-12182",
      "chapterUid": 33,
      "range": "12142-12182",
      "markText": "无产者没有什么自己的东西必须加以保护，他们必须摧毁至今保护和保障私有财产的一切。",
      "totalCount": 2448,
      "appLink": "weread://bestbookmark?bookId=3300033249&chapterUid=33&rangeStart=12142&rangeEnd=12182",
      "webLink": "https://weread.qq.com/web/reader/7ee32da0813ab737cg019361?chapterUid=33&rangeStart=12142&rangeEnd=12182"
    },
    {
      "bookmarkId": "3300033249_33_22229-22287",
      "chapterUid": 33,
      "range": "22229-22287",
      "markText": "代替那存在着阶级和阶级对立的资产阶级旧社会的，将是这样一个联合体，在那里，每个人的自由发展是一切人的自由发展的条件。",
      "totalCount": 2405,
      "appLink": "weread://bestbookmark?bookId=3300033249&chapterUid=33&rangeStart=22229&rangeEnd=22287",
      "webLink": "https://weread.qq.com/web/reader/7ee32da0813ab737cg019361?chapterUid=33&rangeStart=22229&rangeEnd=22287"
    },
    {
      "bookmarkId": "3300033249_33_4838-4885",
      "chapterUid": 33,
      "range": "4838-4885",
      "markText": "资产阶级除非对生产工具，从而对生产关系，从而对全部社会关系不断地进行革命，否则就不能生存下去。",
      "totalCount": 2300,
      "appLink": "weread://bestbookmark?bookId=3300033249&chapterUid=33&rangeStart=4838&rangeEnd=4885",
      "webLink": "https://weread.qq.com/web/reader/7ee32da0813ab737cg019361?chapterUid=33&rangeStart=4838&rangeEnd=4885"
    },
    {
      "bookmarkId": "3300033249_24_1579-1655",
      "chapterUid": 24,
      "range": "1579-1655",
      "markText": "《章程》第一条旗帜鲜明地指出：同盟的奋斗目标是“推翻资产阶级，建立无产阶级统治，消灭以阶级对立为基础的资产阶级旧社会，建立没有阶级、没有私有制的新社会”",
      "totalCount": 2268,
      "appLink": "weread://bestbookmark?bookId=3300033249&chapterUid=24&rangeStart=1579&rangeEnd=1655",
      "webLink": "https://weread.qq.com/web/reader/7ee32da0813ab737cg019361?chapterUid=24&rangeStart=1579&rangeEnd=1655"
    },
    {
      "bookmarkId": "3300033249_33_29731-29769",
      "chapterUid": 33,
      "range": "29731-29769",
      "markText": "资产阶级的社会主义就是这样一个论断：资产者之为资产者，是为了工人阶级的利益。",
      "totalCount": 2261,
