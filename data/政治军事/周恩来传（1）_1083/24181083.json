      "chapterUid": 4,
      "range": "2892-2937",
      "markText": "她在处理问题时，总是先耐心地听别人把情况说清楚，然后再发表意见，使问题得到比较顺利的解决。",
      "totalCount": 516,
      "appLink": "weread://bestbookmark?bookId=24181083&chapterUid=4&rangeStart=2892&rangeEnd=2937",
      "webLink": "https://weread.qq.com/web/reader/af732df07170f95baf74fad?chapterUid=4&rangeStart=2892&rangeEnd=2937"
    },
    {
      "bookmarkId": "24181083_20_19870-19953",
      "chapterUid": 20,
      "range": "19870-19953",
