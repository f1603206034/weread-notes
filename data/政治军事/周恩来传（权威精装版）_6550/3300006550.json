  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300006550_3_10094-10113",
      "chapterUid": 3,
      "range": "10094-10113",
      "markText": "只有周回答说：“为中华之崛起而读书。”",
      "totalCount": 1241,
      "appLink": "weread://bestbookmark?bookId=3300006550&chapterUid=3&rangeStart=10094&rangeEnd=10113",
      "webLink": "https://weread.qq.com/web/reader/0b732d30813ab690fg010000?chapterUid=3&rangeStart=10094&rangeEnd=10113"
    },
    {
      "bookmarkId": "3300006550_1_2178-2220",
      "chapterUid": 1,
      "range": "2178-2220",
      "markText": "他的行为近乎卑微，但他的助手们对他的恭敬态度却反映了他所具有的政治权力的强烈影响力。",
      "totalCount": 990,
      "appLink": "weread://bestbookmark?bookId=3300006550&chapterUid=1&rangeStart=2178&rangeEnd=2220",
      "webLink": "https://weread.qq.com/web/reader/0b732d30813ab690fg010000?chapterUid=1&rangeStart=2178&rangeEnd=2220"
    },
    {
      "bookmarkId": "3300006550_6_3847-3905",
      "chapterUid": 6,
      "range": "3847-3905",
      "markText": "另一种可能是继续假装支持这场运动，同时努力控制它的越轨行为，减少其危害，医治它所造成的创伤。这就是周恩来选择的道路。",
      "totalCount": 672,
      "appLink": "weread://bestbookmark?bookId=3300006550&chapterUid=6&rangeStart=3847&rangeEnd=3905",
      "webLink": "https://weread.qq.com/web/reader/0b732d30813ab690fg010000?chapterUid=6&rangeStart=3847&rangeEnd=3905"
    },
    {
      "bookmarkId": "3300006550_3_46390-46423",
      "chapterUid": 3,
      "range": "46390-46423",
      "markText": "他的考虑是对方既富有，家中又有权势，自己家中贫穷，将来会受制于人。",
      "totalCount": 559,
      "appLink": "weread://bestbookmark?bookId=3300006550&chapterUid=3&rangeStart=46390&rangeEnd=46423",
      "webLink": "https://weread.qq.com/web/reader/0b732d30813ab690fg010000?chapterUid=3&rangeStart=46390&rangeEnd=46423"
    },
    {
      "bookmarkId": "3300006550_3_41388-41454",
      "chapterUid": 3,
      "range": "41388-41454",
      "markText": "吴太太不得不到市中心把自己的珍贵戒指卖掉，用来作为周的盘缠。当天下午，她把急于回国的周恩来送上驶往东京的火车，然后周再从那里回中国。",
      "totalCount": 544,
      "appLink": "weread://bestbookmark?bookId=3300006550&chapterUid=3&rangeStart=41388&rangeEnd=41454",
      "webLink": "https://weread.qq.com/web/reader/0b732d30813ab690fg010000?chapterUid=3&rangeStart=41388&rangeEnd=41454"
    },
    {
      "bookmarkId": "3300006550_3_66199-66282",
      "chapterUid": 3,
      "range": "66199-66282",
      "markText": "几十年后，当中国共产党人在巴黎建立了大使馆时，周曾不嫌麻烦地为他在奥罗里咖啡馆赊账喝过的100杯咖啡还了账，还送给拉丁区一家咖啡馆300盒中国香烟，还上了另一笔赊账。",
      "totalCount": 486,
      "appLink": "weread://bestbookmark?bookId=3300006550&chapterUid=3&rangeStart=66199&rangeEnd=66282",
      "webLink": "https://weread.qq.com/web/reader/0b732d30813ab690fg010000?chapterUid=3&rangeStart=66199&rangeEnd=66282"
    },
    {
      "bookmarkId": "3300006550_5_26182-26226",
      "chapterUid": 5,
      "range": "26182-26226",
      "markText": "美国是历史上所知的最狂妄自大的侵略者，是世界和平的最凶恶的敌人和世界所有反动势力的靠山。",
      "totalCount": 450,
      "appLink": "weread://bestbookmark?bookId=3300006550&chapterUid=5&rangeStart=26182&rangeEnd=26226",
      "webLink": "https://weread.qq.com/web/reader/0b732d30813ab690fg010000?chapterUid=5&rangeStart=26182&rangeEnd=26226"
    },
    {
      "bookmarkId": "3300006550_3_63153-63228",
      "chapterUid": 3,
      "range": "63153-63228",
      "markText": "然而，他给他的女合作者提出了具体的希望：“勤奋刻苦……造你的成绩灿烂。磨炼你的才干；保你天真烂漫。”这个有现代思想的人仍对性的贞操抱着传统守旧的观念。",
      "totalCount": 442,
      "appLink": "weread://bestbookmark?bookId=3300006550&chapterUid=3&rangeStart=63153&rangeEnd=63228",
      "webLink": "https://weread.qq.com/web/reader/0b732d30813ab690fg010000?chapterUid=3&rangeStart=63153&rangeEnd=63228"
    },
    {
      "bookmarkId": "3300006550_3_25705-25752",
      "chapterUid": 3,
      "range": "25705-25752",
      "markText": "周在18岁那年仍然感到自己还不那么成熟，总是想得多而做得少，缺乏拼冲和抓住他人的想象力的勇气。",
      "totalCount": 434,
      "appLink": "weread://bestbookmark?bookId=3300006550&chapterUid=3&rangeStart=25705&rangeEnd=25752",
      "webLink": "https://weread.qq.com/web/reader/0b732d30813ab690fg010000?chapterUid=3&rangeStart=25705&rangeEnd=25752"
    },
    {
      "bookmarkId": "3300006550_6_51795-51893",
      "chapterUid": 6,
      "range": "51795-51893",
      "markText": "没有仪仗队，没有哀乐，只有沉默的市民站在大街的两旁—据说共达150万人，这些人都是听了口头传闻之后特地赶来为已故总理送行的。在那个令人悲伤的夜晚，他们冒着零下12度的严寒，默默地等候着灵车的到来。",
      "totalCount": 432,
      "appLink": "weread://bestbookmark?bookId=3300006550&chapterUid=6&rangeStart=51795&rangeEnd=51893",
      "webLink": "https://weread.qq.com/web/reader/0b732d30813ab690fg010000?chapterUid=6&rangeStart=51795&rangeEnd=51893"
    },
    {
      "bookmarkId": "3300006550_6_51170-51246",
      "chapterUid": 6,
      "range": "51170-51246",
      "markText": "1976年1月8日上午9点57分，这个在20世纪的中国最受人热爱、最有才能、最成功及最激动人心的政治领导人终于离开了人世，享年78岁，这一点是确信无疑的",
      "totalCount": 403,
      "appLink": "weread://bestbookmark?bookId=3300006550&chapterUid=6&rangeStart=51170&rangeEnd=51246",
      "webLink": "https://weread.qq.com/web/reader/0b732d30813ab690fg010000?chapterUid=6&rangeStart=51170&rangeEnd=51246"
    },
    {
      "bookmarkId": "3300006550_3_15471-15524",
      "chapterUid": 3,
      "range": "15471-15524",
      "markText": "周的一个同学回忆说，周当时只有一件蓝色棉上衣，他每个星期天把它洗洗，晚上把它晾干，然后星期一又穿着去上学。",
      "totalCount": 396,
      "appLink": "weread://bestbookmark?bookId=3300006550&chapterUid=3&rangeStart=15471&rangeEnd=15524",
      "webLink": "https://weread.qq.com/web/reader/0b732d30813ab690fg010000?chapterUid=3&rangeStart=15471&rangeEnd=15524"
    },
    {
      "bookmarkId": "3300006550_3_7380-7419",
      "chapterUid": 3,
      "range": "7380-7419",
      "markText": "当周6岁的时候，他的生母时来运转，她和她的弟弟合中了1张彩票，得了1万元的奖。",
      "totalCount": 360,
      "appLink": "weread://bestbookmark?bookId=3300006550&chapterUid=3&rangeStart=7380&rangeEnd=7419",
      "webLink": "https://weread.qq.com/web/reader/0b732d30813ab690fg010000?chapterUid=3&rangeStart=7380&rangeEnd=7419"
    },
    {
      "bookmarkId": "3300006550_3_72888-72914",
      "chapterUid": 3,
      "range": "72888-72914",
      "markText": "说得好听点，甚至像中国这样的国家，也许还会超过欧洲。",
      "totalCount": 357,
      "appLink": "weread://bestbookmark?bookId=3300006550&chapterUid=3&rangeStart=72888&rangeEnd=72914",
      "webLink": "https://weread.qq.com/web/reader/0b732d30813ab690fg010000?chapterUid=3&rangeStart=72888&rangeEnd=72914"
    },
    {
      "bookmarkId": "3300006550_6_54268-54352",
      "chapterUid": 6,
      "range": "54268-54352",
      "markText": "“他没有遗产，他没有嗣息，他没有坟墓，他也没有留下骨灰，他的骨灰撒在祖国的山河中。他似乎什么也没有给我们留下，但是……他拥有全中国，他儿孙好几亿，遍地黄土都是他的坟。”",
      "totalCount": 351,
      "appLink": "weread://bestbookmark?bookId=3300006550&chapterUid=6&rangeStart=54268&rangeEnd=54352",
      "webLink": "https://weread.qq.com/web/reader/0b732d30813ab690fg010000?chapterUid=6&rangeStart=54268&rangeEnd=54352"
    },
    {
      "bookmarkId": "3300006550_3_21558-21623",
      "chapterUid": 3,
      "range": "21558-21623",
      "markText": "为了掌握演讲艺术，周在自己创建的乐群会里进行练习，后来被选为南开中学辩论队的头头，这个队在与天津其他中学的辩论中成功地获得了胜利。",
      "totalCount": 342,
      "appLink": "weread://bestbookmark?bookId=3300006550&chapterUid=3&rangeStart=21558&rangeEnd=21623",
      "webLink": "https://weread.qq.com/web/reader/0b732d30813ab690fg010000?chapterUid=3&rangeStart=21558&rangeEnd=21623"
    },
    {
      "bookmarkId": "3300006550_3_27165-27205",
      "chapterUid": 3,
      "range": "27165-27205",
      "markText": "尽管他喜欢辩论，但他对理想的态度却是功利主义的，把它们看做是社会改良行为的工具。",
      "totalCount": 336,
      "appLink": "weread://bestbookmark?bookId=3300006550&chapterUid=3&rangeStart=27165&rangeEnd=27205",
      "webLink": "https://weread.qq.com/web/reader/0b732d30813ab690fg010000?chapterUid=3&rangeStart=27165&rangeEnd=27205"
    },
    {
      "bookmarkId": "3300006550_3_9831-9918",
      "chapterUid": 3,
      "range": "9831-9918",
      "markText": "他采用一些办法来对付学校中的那些恃强凌弱的学生，而他在后来的政治生涯中反复使用了这一战术，与那些受欺负的人结成朋友，把他们组织起来形成一条联合战线，以反对那些横行霸道的家伙。",
      "totalCount": 330,
      "appLink": "weread://bestbookmark?bookId=3300006550&chapterUid=3&rangeStart=9831&rangeEnd=9918",
      "webLink": "https://weread.qq.com/web/reader/0b732d30813ab690fg010000?chapterUid=3&rangeStart=9831&rangeEnd=9918"
    },
    {
      "bookmarkId": "3300006550_3_44771-44826",
      "chapterUid": 3,
      "range": "44771-44826",
      "markText": "他不介入权力之争，平等待人、热情善良，他善于迅速处理各种事情，如立刻看完交给他审阅的稿件而不是把它们搁置一边。",
      "totalCount": 330,
      "appLink": "weread://bestbookmark?bookId=3300006550&chapterUid=3&rangeStart=44771&rangeEnd=44826",
      "webLink": "https://weread.qq.com/web/reader/0b732d30813ab690fg010000?chapterUid=3&rangeStart=44771&rangeEnd=44826"
    },
    {
      "bookmarkId": "3300006550_1_2682-2751",
      "chapterUid": 1,
      "range": "2682-2751",
      "markText": "他的言行举止温柔和蔼，然而，为了使他的国家能迅速在一代人的时间内从封建主义进入现代社会，他的一些所作所为却显得冷酷、好斗，甚至是不可理解。",
      "totalCount": 324,
      "appLink": "weread://bestbookmark?bookId=3300006550&chapterUid=1&rangeStart=2682&rangeEnd=2751",
      "webLink": "https://weread.qq.com/web/reader/0b732d30813ab690fg010000?chapterUid=1&rangeStart=2682&rangeEnd=2751"
    }
