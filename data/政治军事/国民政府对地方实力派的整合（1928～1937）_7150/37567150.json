      "totalCount": 39,
      "appLink": "weread://bestbookmark?bookId=37567150&chapterUid=10&rangeStart=7536&rangeEnd=7601",
      "webLink": "https://weread.qq.com/web/reader/eaf32570723d3aaeeaf775d?chapterUid=10&rangeStart=7536&rangeEnd=7601"
