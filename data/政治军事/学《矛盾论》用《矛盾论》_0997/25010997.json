      "appLink": "weread://bestbookmark?bookId=25010997&chapterUid=6&rangeStart=11870&rangeEnd=11925",
      "webLink": "https://weread.qq.com/web/reader/88832600717da3358889b2f?chapterUid=6&rangeStart=11870&rangeEnd=11925"
