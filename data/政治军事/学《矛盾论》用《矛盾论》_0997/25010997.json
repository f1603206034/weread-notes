      "totalCount": 198,
      "appLink": "weread://bestbookmark?bookId=25010997&chapterUid=2&rangeStart=6779&rangeEnd=6833",
      "webLink": "https://weread.qq.com/web/reader/88832600717da3358889b2f?chapterUid=2&rangeStart=6779&rangeEnd=6833"
