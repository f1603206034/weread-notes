      "appLink": "weread://bestbookmark?bookId=25010997&chapterUid=2&rangeStart=9818&rangeEnd=9874",
      "webLink": "https://weread.qq.com/web/reader/88832600717da3358889b2f?chapterUid=2&rangeStart=9818&rangeEnd=9874"
