  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "34223944_10_1230-1278",
      "chapterUid": 10,
      "range": "1230-1278",
      "markText": "湘江之战，是长征途中最为惨烈的一次战斗。红五军团三十四师未能渡江，师长陈树湘和大多将士壮烈牺牲。",
      "totalCount": 85,
      "appLink": "weread://bestbookmark?bookId=34223944&chapterUid=10&rangeStart=1230&rangeEnd=1278",
      "webLink": "https://weread.qq.com/web/reader/b6232b70720a3748b627734?chapterUid=10&rangeStart=1230&rangeEnd=1278"
    },
    {
      "bookmarkId": "34223944_57_4162-4199",
      "chapterUid": 57,
      "range": "4162-4199",
      "markText": "他们当中最年轻的胡锦涛只有39岁，毕业于清华大学，当时任甘肃省建委副主任。",
      "totalCount": 60,
      "appLink": "weread://bestbookmark?bookId=34223944&chapterUid=57&rangeStart=4162&rangeEnd=4199",
      "webLink": "https://weread.qq.com/web/reader/b6232b70720a3748b627734?chapterUid=57&rangeStart=4162&rangeEnd=4199"
    },
    {
      "bookmarkId": "34223944_9_1712-1758",
      "chapterUid": 9,
      "range": "1712-1758",
      "markText": "他虽然只有二十七八岁，却举止沉稳，作风深入，富有卓见，成为一名资深干练而又年轻的职业革命家。",
      "totalCount": 54,
      "appLink": "weread://bestbookmark?bookId=34223944&chapterUid=9&rangeStart=1712&rangeEnd=1758",
      "webLink": "https://weread.qq.com/web/reader/b6232b70720a3748b627734?chapterUid=9&rangeStart=1712&rangeEnd=1758"
    },
    {
      "bookmarkId": "34223944_14_2272-2295",
      "chapterUid": 14,
      "range": "2272-2295",
      "markText": "新婚燕尔，陈云却一连花了3个晚上给于若木讲党史",
      "totalCount": 51,
      "appLink": "weread://bestbookmark?bookId=34223944&chapterUid=14&rangeStart=2272&rangeEnd=2295",
      "webLink": "https://weread.qq.com/web/reader/b6232b70720a3748b627734?chapterUid=14&rangeStart=2272&rangeEnd=2295"
    },
    {
      "bookmarkId": "34223944_10_3363-3463",
      "chapterUid": 10,
      "range": "3363-3463",
      "markText": "工人中大部吸鸦片，赤军则命人烧云南鸦片一大锅，随便由工人抽吸不算钱。且日夜进食六次，每次杀猪。而共党指挥渡河之人员，则每餐之菜蔬只吃青豆。” ",
      "totalCount": 48,
      "appLink": "weread://bestbookmark?bookId=34223944&chapterUid=10&rangeStart=3363&rangeEnd=3463",
      "webLink": "https://weread.qq.com/web/reader/b6232b70720a3748b627734?chapterUid=10&rangeStart=3363&rangeEnd=3463"
    },
    {
      "bookmarkId": "34223944_3_2758-2800",
      "chapterUid": 3,
      "range": "2758-2800",
      "markText": "短短一个月，异常刻苦的陈云基本掌握了珠算，还初步学会了写账，这成为他受益终身的技能。",
      "totalCount": 42,
      "appLink": "weread://bestbookmark?bookId=34223944&chapterUid=3&rangeStart=2758&rangeEnd=2800",
      "webLink": "https://weread.qq.com/web/reader/b6232b70720a3748b627734?chapterUid=3&rangeStart=2758&rangeEnd=2800"
    },
    {
      "bookmarkId": "34223944_16_2320-2405",
      "chapterUid": 16,
      "range": "2320-2405",
      "markText": "陈云特别强调说：“这件事比什么都重要。学习哲学，可以使人开窍；学好哲学，终身受用。”也就在这一时期，陈云提出了“不唯上、不唯书、只唯实，交换、比较、反复”的思想工作方法。",
      "totalCount": 39,
      "appLink": "weread://bestbookmark?bookId=34223944&chapterUid=16&rangeStart=2320&rangeEnd=2405",
      "webLink": "https://weread.qq.com/web/reader/b6232b70720a3748b627734?chapterUid=16&rangeStart=2320&rangeEnd=2405"
    },
    {
      "bookmarkId": "34223944_25_4799-4834",
      "chapterUid": 25,
      "range": "4799-4834",
      "markText": "后来，毛泽东总结说，陈云所领导的这场经济战役的意义“不下于淮海战役”。",
      "totalCount": 39,
      "appLink": "weread://bestbookmark?bookId=34223944&chapterUid=25&rangeStart=4799&rangeEnd=4834",
      "webLink": "https://weread.qq.com/web/reader/b6232b70720a3748b627734?chapterUid=25&rangeStart=4799&rangeEnd=4834"
    },
    {
      "bookmarkId": "34223944_4_2638-2679",
      "chapterUid": 4,
      "range": "2638-2679",
      "markText": "这不同的地方，就是五四运动特有的精神。这种精神就是（一）直接行动；（二）牺牲的精神",
      "totalCount": 36,
      "appLink": "weread://bestbookmark?bookId=34223944&chapterUid=4&rangeStart=2638&rangeEnd=2679",
      "webLink": "https://weread.qq.com/web/reader/b6232b70720a3748b627734?chapterUid=4&rangeStart=2638&rangeEnd=2679"
    },
    {
      "bookmarkId": "34223944_9_679-703",
      "chapterUid": 9,
      "range": "679-703",
      "markText": "由陈云接任全总党团书记，并参加临时中央政治局常委",
      "totalCount": 36,
      "appLink": "weread://bestbookmark?bookId=34223944&chapterUid=9&rangeStart=679&rangeEnd=703",
      "webLink": "https://weread.qq.com/web/reader/b6232b70720a3748b627734?chapterUid=9&rangeStart=679&rangeEnd=703"
    },
    {
      "bookmarkId": "34223944_20_1528-1589",
      "chapterUid": 20,
      "range": "1528-1589",
      "markText": "主要内容是建议我军撤出沈阳、长春、哈尔滨三大中心城市，到广大乡村和中小城市发动群众建立根据地，同国民党进行长期艰苦的斗争。",
      "totalCount": 36,
      "appLink": "weread://bestbookmark?bookId=34223944&chapterUid=20&rangeStart=1528&rangeEnd=1589",
      "webLink": "https://weread.qq.com/web/reader/b6232b70720a3748b627734?chapterUid=20&rangeStart=1528&rangeEnd=1589"
    },
    {
      "bookmarkId": "34223944_33_2720-2746",
      "chapterUid": 33,
      "range": "2720-2746",
      "markText": "我们要改革，但步子要稳。”“好事要做，又要量力而行。",
      "totalCount": 36,
      "appLink": "weread://bestbookmark?bookId=34223944&chapterUid=33&rangeStart=2720&rangeEnd=2746",
      "webLink": "https://weread.qq.com/web/reader/b6232b70720a3748b627734?chapterUid=33&rangeStart=2720&rangeEnd=2746"
    },
    {
      "bookmarkId": "34223944_6_2335-2396",
      "chapterUid": 6,
      "range": "2335-2396",
      "markText": "不推翻现在社会制度，个人及家庭问题没有出路，只有到了革命成功时每个人可以劳动而得食时，人人家庭都可解放，我的家庭也就解放了",
      "totalCount": 34,
      "appLink": "weread://bestbookmark?bookId=34223944&chapterUid=6&rangeStart=2335&rangeEnd=2396",
      "webLink": "https://weread.qq.com/web/reader/b6232b70720a3748b627734?chapterUid=6&rangeStart=2335&rangeEnd=2396"
    },
    {
      "bookmarkId": "34223944_13_2081-2141",
      "chapterUid": 13,
      "range": "2081-2141",
      "markText": "中组部在党的组织工作上，不仅要面向延安、陕甘宁边区，而且要面向全国各个敌后根据地，面向国统区的党组织、面向敌占区的党组织",
      "totalCount": 34,
      "appLink": "weread://bestbookmark?bookId=34223944&chapterUid=13&rangeStart=2081&rangeEnd=2141",
      "webLink": "https://weread.qq.com/web/reader/b6232b70720a3748b627734?chapterUid=13&rangeStart=2081&rangeEnd=2141"
