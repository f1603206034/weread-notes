        }
      ]
    },
    {
      "chapterUid": 58,
      "chapterTitle": "六 伯伯身为国家总理，仍不忘过去的老战友、老部下，更不忘在他投身革命前的老同学、老朋友。",
      "items": [
        {
          "type": "highlight",
          "bookmarkId": "28276923_58_2834-2959",
          "range": "2834-2959",
          "rangeStart": 2834,
          "rangeEnd": 2959,
          "markText": "大江歌罢掉头东，\n邃密群科济世穷。\n面壁十年图破壁，\n难酬蹈海亦英雄。",
          "colorStyle": 2,
          "colorLabel": "",
          "createTime": 1757690687,
          "createTimeFormatted": "2025-09-12 23:24:47",
          "chapterUid": 58,
          "appLink": "weread://bestbookmark?bookId=28276923&chapterUid=58&rangeStart=2834&rangeEnd=2959",
          "webLink": "https://weread.qq.com/web/reader/9ac3201071af78bb9acb309?chapterUid=58&rangeStart=2834&rangeEnd=2959"
        }
      ]
