      "appLink": "weread://bestbookmark?bookId=3300072386&chapterUid=4&rangeStart=1157&rangeEnd=1199",
      "webLink": "https://weread.qq.com/web/reader/a7f32680813ab82c6g016aa3?chapterUid=4&rangeStart=1157&rangeEnd=1199"
