  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300129119_50_32601-32671",
      "chapterUid": 50,
      "range": "32601-32671",
      "markText": "所以，从根本上说真正阻止中共解放台湾的是中苏同盟条约，朝鲜战争不过是为美国宣布其新的台湾政策提供了机会和借口，不过是压垮骆驼的最后一根稻草。",
      "totalCount": 420,
      "appLink": "weread://bestbookmark?bookId=3300129119&chapterUid=50&rangeStart=32601&rangeEnd=32671",
      "webLink": "https://weread.qq.com/web/reader/275320d0813ab98efg019e4a?chapterUid=50&rangeStart=32601&rangeEnd=32671"
    },
    {
      "bookmarkId": "3300129119_61_20614-20691",
      "chapterUid": 61,
      "range": "20614-20691",
      "markText": "总之，从1950年至1953年，中苏不仅在军事和外交领域全面合作，在经济领域的合作关系也得到了全面发展。所有这一切，都是在中国出兵援助朝鲜的基础上开始的。",
      "totalCount": 368,
      "appLink": "weread://bestbookmark?bookId=3300129119&chapterUid=61&rangeStart=20614&rangeEnd=20691",
      "webLink": "https://weread.qq.com/web/reader/275320d0813ab98efg019e4a?chapterUid=61&rangeStart=20614&rangeEnd=20691"
    },
    {
      "bookmarkId": "3300129119_44_2640-2669",
      "chapterUid": 44,
      "range": "2640-2669",
      "markText": "但是当他真正掌握了政权以后，越来越成为一个典型的民族主义者",
      "totalCount": 360,
      "appLink": "weread://bestbookmark?bookId=3300129119&chapterUid=44&rangeStart=2640&rangeEnd=2669",
      "webLink": "https://weread.qq.com/web/reader/275320d0813ab98efg019e4a?chapterUid=44&rangeStart=2640&rangeEnd=2669"
    },
    {
      "bookmarkId": "3300129119_46_26048-26080",
      "chapterUid": 46,
      "range": "26048-26080",
      "markText": "他甚至学斯大林的做法，也替苏联政府起草了一封回绝国民政府的信函。",
      "totalCount": 306,
      "appLink": "weread://bestbookmark?bookId=3300129119&chapterUid=46&rangeStart=26048&rangeEnd=26080",
      "webLink": "https://weread.qq.com/web/reader/275320d0813ab98efg019e4a?chapterUid=46&rangeStart=26048&rangeEnd=26080"
    },
    {
      "bookmarkId": "3300129119_58_9557-9726",
      "chapterUid": 58,
      "range": "9557-9726",
      "markText": "笔者曾对时任安东市委书记的高扬进行采访，得到的回答是，在中国出兵之前，落在安东市的炸弹只有一两个。根据丹东市的档案记载，1950年11月以前，美国飞机只是偶尔对该市进行过袭击。",
      "totalCount": 306,
      "appLink": "weread://bestbookmark?bookId=3300129119&chapterUid=58&rangeStart=9557&rangeEnd=9726",
      "webLink": "https://weread.qq.com/web/reader/275320d0813ab98efg019e4a?chapterUid=58&rangeStart=9557&rangeEnd=9726"
    },
    {
      "bookmarkId": "3300129119_62_15990-16035",
      "chapterUid": 62,
      "range": "15990-16035",
      "markText": "，结果只会延长战争。你们把战争胜利寄托于侥幸，把人民的事业拿来赌博，只会把战争再次引向失败",
      "totalCount": 288,
      "appLink": "weread://bestbookmark?bookId=3300129119&chapterUid=62&rangeStart=15990&rangeEnd=16035",
      "webLink": "https://weread.qq.com/web/reader/275320d0813ab98efg019e4a?chapterUid=62&rangeStart=15990&rangeEnd=16035"
    },
    {
      "bookmarkId": "3300129119_44_3752-3824",
      "chapterUid": 44,
      "range": "3752-3824",
      "markText": "随着对世界革命路线的偏离以及斯大林在党内独一无二的领导地位的确立，共产国际开始逐步从一个共产党领导革命的世界性组织机构沦落为苏联对外政策的工具。",
      "totalCount": 256,
      "appLink": "weread://bestbookmark?bookId=3300129119&chapterUid=44&rangeStart=3752&rangeEnd=3824",
      "webLink": "https://weread.qq.com/web/reader/275320d0813ab98efg019e4a?chapterUid=44&rangeStart=3752&rangeEnd=3824"
    },
    {
      "bookmarkId": "3300129119_46_14181-14361",
      "chapterUid": 46,
      "range": "14181-14361",
      "markText": "中共开始把希望转向苏联。1945年4月中共召开七大时，毛泽东告诉全党：“苏联，毫无问题是朋友，是中国人民最好的朋友。”言语间透着一种无奈。",
      "totalCount": 256,
      "appLink": "weread://bestbookmark?bookId=3300129119&chapterUid=46&rangeStart=14181&rangeEnd=14361",
      "webLink": "https://weread.qq.com/web/reader/275320d0813ab98efg019e4a?chapterUid=46&rangeStart=14181&rangeEnd=14361"
    },
    {
      "bookmarkId": "3300129119_44_4936-5003",
      "chapterUid": 44,
      "range": "4936-5003",
      "markText": "共产国际指示各国党：对待苏联的态度已“成为衡量为社会主义而斗争的意图的真假试金石”，“凡与此看法抵触的，都要立即修正自己的政治路线”。",
      "totalCount": 252,
      "appLink": "weread://bestbookmark?bookId=3300129119&chapterUid=44&rangeStart=4936&rangeEnd=5003",
      "webLink": "https://weread.qq.com/web/reader/275320d0813ab98efg019e4a?chapterUid=44&rangeStart=4936&rangeEnd=5003"
    },
    {
      "bookmarkId": "3300129119_61_8127-8200",
      "chapterUid": 61,
      "range": "8127-8200",
      "markText": "关于派遣苏联专家的问题，萨布罗夫也提出苏联专家不能太多，更不要由专家包办。中国应多派留学生和技术工人到苏联来学习和实习，逐渐形成中国自己的技术队伍",
      "totalCount": 252,
      "appLink": "weread://bestbookmark?bookId=3300129119&chapterUid=61&rangeStart=8127&rangeEnd=8200",
      "webLink": "https://weread.qq.com/web/reader/275320d0813ab98efg019e4a?chapterUid=61&rangeStart=8127&rangeEnd=8200"
    },
    {
      "bookmarkId": "3300129119_52_18653-18746",
      "chapterUid": 52,
      "range": "18653-18746",
      "markText": "李承晚在三八线不断制造危急局面，不过是为了向美国要更多的军事和经济援助，以加强其统一朝鲜半岛的实力。而他没有想到的是，这些举动同时也强化了金日成的军事实力以及通过军事手段实现统一的信心。",
      "totalCount": 240,
      "appLink": "weread://bestbookmark?bookId=3300129119&chapterUid=52&rangeStart=18653&rangeEnd=18746",
      "webLink": "https://weread.qq.com/web/reader/275320d0813ab98efg019e4a?chapterUid=52&rangeStart=18653&rangeEnd=18746"
    },
    {
      "bookmarkId": "3300129119_62_13899-13955",
      "chapterUid": 62,
      "range": "13899-13955",
      "markText": "同一天，斯大林来电称，为避免国际上对中国的责难，建议由志愿军控制三八线以北及其两侧海岸，而令人民军继续南进追击。",
