  "content": [
    {
      "chapterUid": 46,
      "chapterTitle": "三 苏联在中国的目标和政策转轨",
      "items": [
        {
          "type": "highlight",
          "bookmarkId": "3300129119_46_18384-18739",
          "range": "18384-18739",
          "rangeStart": 18384,
          "rangeEnd": 18739,
          "markText": "放弃了对美国的幻想，又不能相信和依赖苏联的支持，面对愈演愈烈的内战局面，中共不得不破釜沉舟，走上了依靠自己的力量武装夺取政权的道路。",
          "colorStyle": 2,
          "colorLabel": "",
          "createTime": 1752664878,
          "createTimeFormatted": "2025-07-16 19:21:18",
          "chapterUid": 46,
          "appLink": "weread://bestbookmark?bookId=3300129119&chapterUid=46&rangeStart=18384&rangeEnd=18739",
