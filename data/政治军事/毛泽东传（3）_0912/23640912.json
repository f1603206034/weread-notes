      "totalCount": 56,
      "appLink": "weread://bestbookmark?bookId=23640912&chapterUid=6&rangeStart=37383&rangeEnd=37473",
      "webLink": "https://weread.qq.com/web/reader/ed032ec07168bb50ed09b74?chapterUid=6&rangeStart=37383&rangeEnd=37473"
    },
    {
