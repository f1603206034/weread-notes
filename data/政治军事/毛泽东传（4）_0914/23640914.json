  "content": [
    {
      "chapterUid": 10,
      "chapterTitle": "六十、发动“大跃进”（下）",
      "items": [
        {
          "type": "highlight",
          "bookmarkId": "23640914_10_34372-34580",
          "range": "34372-34580",
          "rangeStart": 34372,
          "rangeEnd": 34580,
          "markText": "毛泽东是实事求是思想路线的创立者，调查研究的倡导者。但在“大跃进”中，他背离了这些原则，从主观愿望出发，实行了一些超越历史发展阶段的政策，片面地夸大了主观能动性和人的意志的作用，因而在实际工作中出现很多违反自然规律和经济规律的情况。调查研究不是没有，但大多是走马观花式的观察，或是从各级领导干部的汇报中得到很多并不真实的和虚假的东西。而这些不真实和虚假的东西，归根到底，是从上面（包括毛泽东本人）用行政力量压出来的。",
          "colorStyle": 0,
          "colorLabel": "",
          "createTime": 1709273596,
          "createTimeFormatted": "2024-03-01 14:13:16",
          "chapterUid": 10,
          "appLink": "weread://bestbookmark?bookId=23640914&chapterUid=10&rangeStart=34372&rangeEnd=34580",
          "webLink": "https://weread.qq.com/web/reader/e3e328b07168bb52e3e5f74?chapterUid=10&rangeStart=34372&rangeEnd=34580"
        },
        {
          "type": "highlight",
          "bookmarkId": "23640914_10_34770-34799",
          "range": "34770-34799",
          "rangeStart": 34770,
          "rangeEnd": 34799,
          "markText": "“大跃进”最大的教训是急于求成，违背了经济发展的客观规律。",
          "colorStyle": 5,
          "colorLabel": "",
          "createTime": 1709273564,
          "createTimeFormatted": "2024-03-01 14:12:44",
          "chapterUid": 10,
          "appLink": "weread://bestbookmark?bookId=23640914&chapterUid=10&rangeStart=34770&rangeEnd=34799",
          "webLink": "https://weread.qq.com/web/reader/e3e328b07168bb52e3e5f74?chapterUid=10&rangeStart=34770&rangeEnd=34799"
        }
      ]
    },
    {
