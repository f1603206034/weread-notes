  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300006549_1_1095-1128",
      "chapterUid": 1,
      "range": "1095-1128",
      "markText": "毛的许多精力花在了同那些与他的基本思想相同的同志的不必要的斗争上。",
      "totalCount": 1241,
      "appLink": "weread://bestbookmark?bookId=3300006549&chapterUid=1&rangeStart=1095&rangeEnd=1128",
      "webLink": "https://weread.qq.com/web/reader/856324a0813ab690eg019fc6?chapterUid=1&rangeStart=1095&rangeEnd=1128"
    },
    {
      "bookmarkId": "3300006549_1_1333-1424",
      "chapterUid": 1,
      "range": "1333-1424",
      "markText": "但他的个人生活付出了代价，他不仅不能为其先后3个妻子提供任何真正物质的保证，而且似乎也未能承担感情上的责任。对他那许多孩子，他没有给予适当的保护，也没有给予传统的做父亲应给予的关怀。",
      "totalCount": 992,
      "appLink": "weread://bestbookmark?bookId=3300006549&chapterUid=1&rangeStart=1333&rangeEnd=1424",
      "webLink": "https://weread.qq.com/web/reader/856324a0813ab690eg019fc6?chapterUid=1&rangeStart=1333&rangeEnd=1424"
    },
    {
      "bookmarkId": "3300006549_2_51585-51660",
      "chapterUid": 2,
      "range": "51585-51660",
      "markText": "毛害怕法国之行会使他在文化上成为一个国际主义者，因而失去了他自己国家普通老百姓对他做领袖的支持。他也感觉到在外国环境下，他就不能在他的同伴中出类拔萃。",
      "totalCount": 880,
      "appLink": "weread://bestbookmark?bookId=3300006549&chapterUid=2&rangeStart=51585&rangeEnd=51660",
      "webLink": "https://weread.qq.com/web/reader/856324a0813ab690eg019fc6?chapterUid=2&rangeStart=51585&rangeEnd=51660"
    },
    {
      "bookmarkId": "3300006549_2_68084-68129",
      "chapterUid": 2,
      "range": "68084-68129",
      "markText": "毛说：“如果我们全力以赴，共产党在30年至40年的时间里，就能统治中国。这个预言相当精确。",
      "totalCount": 752,
      "appLink": "weread://bestbookmark?bookId=3300006549&chapterUid=2&rangeStart=68084&rangeEnd=68129",
      "webLink": "https://weread.qq.com/web/reader/856324a0813ab690eg019fc6?chapterUid=2&rangeStart=68084&rangeEnd=68129"
    },
    {
      "bookmarkId": "3300006549_2_51329-51400",
      "chapterUid": 2,
      "range": "51329-51400",
      "markText": "他明白自己是个行动者，自己的未来发展在政治组织上，而不是在学问上，所以他对为学习而出国并不真的感兴趣。学习对毛来说只不过是达到目的的一个手段。",
      "totalCount": 728,
      "appLink": "weread://bestbookmark?bookId=3300006549&chapterUid=2&rangeStart=51329&rangeEnd=51400",
      "webLink": "https://weread.qq.com/web/reader/856324a0813ab690eg019fc6?chapterUid=2&rangeStart=51329&rangeEnd=51400"
    },
    {
      "bookmarkId": "3300006549_1_3215-3259",
      "chapterUid": 1,
      "range": "3215-3259",
      "markText": "穿的衣服有补丁，睡一张既没有弹簧也没有垫子的宽大木床，住着朴素的寓所，吃的也是粗茶淡饭。",
      "totalCount": 684,
      "appLink": "weread://bestbookmark?bookId=3300006549&chapterUid=1&rangeStart=3215&rangeEnd=3259",
      "webLink": "https://weread.qq.com/web/reader/856324a0813ab690eg019fc6?chapterUid=1&rangeStart=3215&rangeEnd=3259"
    },
    {
      "bookmarkId": "3300006549_1_3325-3375",
      "chapterUid": 1,
      "range": "3325-3375",
      "markText": "本书将展示他的那些思想是如何形成的，他如何为此而奋斗—既反对敌人也反对朋友—以及他最后是怎样失败的。",
      "totalCount": 666,
      "appLink": "weread://bestbookmark?bookId=3300006549&chapterUid=1&rangeStart=3325&rangeEnd=3375",
      "webLink": "https://weread.qq.com/web/reader/856324a0813ab690eg019fc6?chapterUid=1&rangeStart=3325&rangeEnd=3375"
    },
    {
      "bookmarkId": "3300006549_2_53176-53240",
      "chapterUid": 2,
      "range": "53176-53240",
      "markText": "这也正是毛的生活哲学：越是被人视为粗俗的乡巴佬，遭人鄙视，他越是坚定了通过艰苦而激烈的政治斗争，强行对社会提出自己的要求的决心。",
      "totalCount": 533,
      "appLink": "weread://bestbookmark?bookId=3300006549&chapterUid=2&rangeStart=53176&rangeEnd=53240",
      "webLink": "https://weread.qq.com/web/reader/856324a0813ab690eg019fc6?chapterUid=2&rangeStart=53176&rangeEnd=53240"
    },
    {
      "bookmarkId": "3300006549_2_41571-41663",
      "chapterUid": 2,
      "range": "41571-41663",
      "markText": "与天奋斗，其乐无穷。 与地奋斗，其乐无穷。 与人奋斗，其乐无穷！",
      "totalCount": 486,
      "appLink": "weread://bestbookmark?bookId=3300006549&chapterUid=2&rangeStart=41571&rangeEnd=41663",
      "webLink": "https://weread.qq.com/web/reader/856324a0813ab690eg019fc6?chapterUid=2&rangeStart=41571&rangeEnd=41663"
    },
    {
      "bookmarkId": "3300006549_1_667-708",
      "chapterUid": 1,
      "range": "667-708",
      "markText": "像毛泽东这样一个统治人类四分之一人口达四分之一世纪之久的伟人，在历史上也是罕见的。",
      "totalCount": 476,
      "appLink": "weread://bestbookmark?bookId=3300006549&chapterUid=1&rangeStart=667&rangeEnd=708",
      "webLink": "https://weread.qq.com/web/reader/856324a0813ab690eg019fc6?chapterUid=1&rangeStart=667&rangeEnd=708"
    },
    {
      "bookmarkId": "3300006549_2_67509-67573",
      "chapterUid": 2,
      "range": "67509-67573",
      "markText": "毛说：“是的，压迫是政治的精髓。如果你压迫得法，说明你的政治是成功的。归根结底，政治的影响力十分简单，不过是经常保持压迫罢了。”",
      "totalCount": 468,
      "appLink": "weread://bestbookmark?bookId=3300006549&chapterUid=2&rangeStart=67509&rangeEnd=67573",
      "webLink": "https://weread.qq.com/web/reader/856324a0813ab690eg019fc6?chapterUid=2&rangeStart=67509&rangeEnd=67573"
    },
    {
      "bookmarkId": "3300006549_2_72776-72800",
      "chapterUid": 2,
      "range": "72776-72800",
      "markText": "毛为他们写了罢工口号：“从前是牛马，现在要做人！",
      "totalCount": 462,
      "appLink": "weread://bestbookmark?bookId=3300006549&chapterUid=2&rangeStart=72776&rangeEnd=72800",
      "webLink": "https://weread.qq.com/web/reader/856324a0813ab690eg019fc6?chapterUid=2&rangeStart=72776&rangeEnd=72800"
    },
    {
      "bookmarkId": "3300006549_2_26857-26938",
      "chapterUid": 2,
      "range": "26857-26938",
      "markText": "他读书时很细心，他所喜欢的句子都圈点起来，而对他不赞成的话则批上诸如“荒谬”、“不通”等评语。每读一本书都这样，甚至第二次读书时还对前一次所作的圈点加上新的评语。",
      "totalCount": 450,
      "appLink": "weread://bestbookmark?bookId=3300006549&chapterUid=2&rangeStart=26857&rangeEnd=26938",
      "webLink": "https://weread.qq.com/web/reader/856324a0813ab690eg019fc6?chapterUid=2&rangeStart=26857&rangeEnd=26938"
    },
    {
      "bookmarkId": "3300006549_2_28015-28042",
      "chapterUid": 2,
      "range": "28015-28042",
      "markText": "一个人如果过不了金钱与女性这两关，这个人就不值得一谈。",
      "totalCount": 434,
      "appLink": "weread://bestbookmark?bookId=3300006549&chapterUid=2&rangeStart=28015&rangeEnd=28042",
      "webLink": "https://weread.qq.com/web/reader/856324a0813ab690eg019fc6?chapterUid=2&rangeStart=28015&rangeEnd=28042"
    },
    {
      "bookmarkId": "3300006549_2_3427-3448",
      "chapterUid": 2,
      "range": "3427-3448",
      "markText": "如果把中国比作德意志，那么湖南就是普鲁士。",
      "totalCount": 432,
      "appLink": "weread://bestbookmark?bookId=3300006549&chapterUid=2&rangeStart=3427&rangeEnd=3448",
      "webLink": "https://weread.qq.com/web/reader/856324a0813ab690eg019fc6?chapterUid=2&rangeStart=3427&rangeEnd=3448"
    },
    {
      "bookmarkId": "3300006549_3_3109-3181",
      "chapterUid": 3,
      "range": "3109-3181",
      "markText": "那天晚上，毛将残存的400余人整编成一个团，在部队中实行民主，由党掌握军队，废止打骂，士兵有开会说话的自由，在另一种意义上说，这才是红军的开端。",
      "totalCount": 432,
      "appLink": "weread://bestbookmark?bookId=3300006549&chapterUid=3&rangeStart=3109&rangeEnd=3181",
      "webLink": "https://weread.qq.com/web/reader/856324a0813ab690eg019fc6?chapterUid=3&rangeStart=3109&rangeEnd=3181"
    },
    {
      "bookmarkId": "3300006549_2_59806-59853",
      "chapterUid": 2,
      "range": "59806-59853",
      "markText": "毛在赵女士事件中表现的激情，能否说是他因违背他自己父母为他安排的婚姻而生出的负疚感的一种反应？",
      "totalCount": 390,
      "appLink": "weread://bestbookmark?bookId=3300006549&chapterUid=2&rangeStart=59806&rangeEnd=59853",
      "webLink": "https://weread.qq.com/web/reader/856324a0813ab690eg019fc6?chapterUid=2&rangeStart=59806&rangeEnd=59853"
    },
    {
      "bookmarkId": "3300006549_1_1689-1717",
