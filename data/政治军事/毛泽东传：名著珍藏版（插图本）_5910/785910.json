      "chapterTitle": "第一章 童年(1893—1910)",
      "items": [
        {
          "type": "highlight",
          "bookmarkId": "785910_32_4661-4678",
          "range": "4661-4678",
          "rangeStart": 4661,
          "rangeEnd": 4678,
          "markText": "“若使中华国果亡，除非湖南人尽死。",
          "colorStyle": 1,
          "colorLabel": "",
          "createTime": 1717597884,
          "createTimeFormatted": "2024-06-05 22:31:24",
          "chapterUid": 32,
          "appLink": "weread://bestbookmark?bookId=785910&chapterUid=32&rangeStart=4661&rangeEnd=4678",
          "webLink": "https://weread.qq.com/web/reader/110322705bfdf6110a98949?chapterUid=32&rangeStart=4661&rangeEnd=4678"
        }
      ]
    },
    {
      "chapterUid": 33,
      "chapterTitle": "第二章 为何求知(1910—1918)",
      "items": [
        {
          "type": "highlight",
          "bookmarkId": "785910_33_25318-25390",
          "range": "25318-25390",
          "rangeStart": 25318,
          "rangeEnd": 25390,
          "markText": "毛泽东认为，组织者的天才就在于，他能够把各种人的长处结合起来。他不应暴露别人的弱点，或者反复指责别人的弱点，而应当鼓励把所有积极的因素联合起来。",
          "colorStyle": 0,
          "colorLabel": "",
          "createTime": 1717550482,
          "createTimeFormatted": "2024-06-05 09:21:22",
          "chapterUid": 33,
          "appLink": "weread://bestbookmark?bookId=785910&chapterUid=33&rangeStart=25318&rangeEnd=25390",
          "webLink": "https://weread.qq.com/web/reader/110322705bfdf6110a98949?chapterUid=33&rangeStart=25318&rangeEnd=25390"
        }
      ]
    },
    {
      "chapterUid": 30,
      "chapterTitle": "中文版序",
      "items": [
