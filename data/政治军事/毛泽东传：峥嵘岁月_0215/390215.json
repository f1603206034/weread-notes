      "totalCount": 72,
      "appLink": "weread://bestbookmark?bookId=390215&chapterUid=12&rangeStart=9642&rangeEnd=9700",
      "webLink": "https://weread.qq.com/web/reader/92a32bf055f44792a170ec3?chapterUid=12&rangeStart=9642&rangeEnd=9700"
    },
    {
