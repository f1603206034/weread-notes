      "appLink": "weread://bestbookmark?bookId=31824849&chapterUid=4&rangeStart=3513&rangeEnd=3606",
      "webLink": "https://weread.qq.com/web/reader/16a3268071e59bd116afa0a?chapterUid=4&rangeStart=3513&rangeEnd=3606"
