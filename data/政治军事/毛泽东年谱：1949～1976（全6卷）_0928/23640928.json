  "content": [
    {
      "chapterUid": 17,
      "chapterTitle": "1961年 六十八岁",
      "items": [
        {
          "type": "highlight",
          "bookmarkId": "23640928_17_37138-37170",
          "range": "37138-37170",
          "rangeStart": 37138,
          "rangeEnd": 37170,
          "markText": "金猴奋起千钧棒，玉宇澄清万里埃。今日欢呼孙大圣，只缘妖雾又重来。",
          "colorStyle": 1,
          "colorLabel": "",
          "createTime": 1778815408,
          "createTimeFormatted": "2026-05-15 11:23:28",
          "chapterUid": 17,
          "appLink": "weread://bestbookmark?bookId=23640928&chapterUid=17&rangeStart=37138&rangeEnd=37170",
          "webLink": "https://weread.qq.com/web/reader/64332c007168bb606432496?chapterUid=17&rangeStart=37138&rangeEnd=37170"
        },
        {
          "type": "highlight",
          "bookmarkId": "23640928_17_47264-47280",
          "range": "47264-47280",
          "rangeStart": 47264,
          "rangeEnd": 47280,
          "markText": "剑南歌接秋风吟，一例氤氲入诗囊。",
          "colorStyle": 2,
          "colorLabel": "",
          "createTime": 1743217923,
          "createTimeFormatted": "2025-03-29 11:12:03",
          "chapterUid": 17,
          "appLink": "weread://bestbookmark?bookId=23640928&chapterUid=17&rangeStart=47264&rangeEnd=47280",
          "webLink": "https://weread.qq.com/web/reader/64332c007168bb606432496?chapterUid=17&rangeStart=47264&rangeEnd=47280"
        },
        {
          "type": "highlight",
          "bookmarkId": "23640928_17_47227-47243",
          "range": "47227-47243",
          "rangeStart": 47227,
          "rangeEnd": 47243,
          "markText": "龙华喋血不眠夜，犹制小诗赋管弦。",
          "colorStyle": 2,
          "colorLabel": "",
          "createTime": 1743217918,
          "createTimeFormatted": "2025-03-29 11:11:58",
          "chapterUid": 17,
          "appLink": "weread://bestbookmark?bookId=23640928&chapterUid=17&rangeStart=47227&rangeEnd=47243",
          "webLink": "https://weread.qq.com/web/reader/64332c007168bb606432496?chapterUid=17&rangeStart=47227&rangeEnd=47243"
        }
      ]
    },
    {
      "chapterUid": 21,
      "chapterTitle": "1965年 七十二岁",
      "items": [
        {
          "type": "highlight",
          "bookmarkId": "23640928_21_51620-51632",
          "range": "51620-51632",
          "rangeStart": 51620,
          "rangeEnd": 51632,
          "markText": "久有凌云志，重上井冈山。",
          "colorStyle": 2,
          "colorLabel": "",
          "createTime": 1777904881,
          "createTimeFormatted": "2026-05-04 22:28:01",
          "chapterUid": 21,
          "appLink": "weread://bestbookmark?bookId=23640928&chapterUid=21&rangeStart=51620&rangeEnd=51632",
          "webLink": "https://weread.qq.com/web/reader/64332c007168bb606432496?chapterUid=21&rangeStart=51620&rangeEnd=51632"
        },
        {
          "type": "highlight",
          "bookmarkId": "23640928_21_51803-51864",
          "range": "51803-51864",
          "rangeStart": 51803,
          "rangeEnd": 51864,
          "markText": "借问君去何方，雀儿答道：有仙山琼阁。不见前年秋月朗，订了三家条约。还有吃的，土豆烧熟了，再加牛肉。不须放屁，试看天地翻覆。",
          "colorStyle": 2,
          "colorLabel": "",
          "createTime": 1746144852,
          "createTimeFormatted": "2025-05-02 08:14:12",
          "chapterUid": 21,
          "appLink": "weread://bestbookmark?bookId=23640928&chapterUid=21&rangeStart=51803&rangeEnd=51864",
          "webLink": "https://weread.qq.com/web/reader/64332c007168bb606432496?chapterUid=21&rangeStart=51803&rangeEnd=51864"
        },
        {
          "type": "highlight",
          "bookmarkId": "23640928_21_51723-51735",
          "range": "51723-51735",
          "rangeStart": 51723,
          "rangeEnd": 51735,
          "markText": "世上无难事，只要肯登攀。",
          "colorStyle": 2,
          "colorLabel": "",
          "createTime": 1743217631,
          "createTimeFormatted": "2025-03-29 11:07:11",
          "chapterUid": 21,
          "appLink": "weread://bestbookmark?bookId=23640928&chapterUid=21&rangeStart=51723&rangeEnd=51735",
          "webLink": "https://weread.qq.com/web/reader/64332c007168bb606432496?chapterUid=21&rangeStart=51723&rangeEnd=51735"
        },
        {
          "type": "review",
          "reviewId": "32618646_88OJaB4hc",
          "range": "24024-24043",
          "chapterName": "1965年 七十二岁",
          "content": "长空又放红核云，怒吼挥拳显巨身。\n横目南天震虎口，寄心北海跃龙门。\n敢向恶鬼争高下，不向霸王让寸分。\n先烈回眸应笑慰，擎旗自有后来人。\n——这是毛泽东1965年5月14日写给第二次核试验的贺词《七律》。",
          "abstract": "他还同意今年五月进行第二次原子弹试验。",
          "star": -1,
          "createTime": 1777775156,
          "createTimeFormatted": "2026-05-03 10:25:56",
