    },
    {
      "bookmarkId": "3300029378_3_1639-1696",
      "chapterUid": 3,
      "range": "1639-1696",
      "markText": "我国人民应该有一个远大的规划，要在几十年内，努力改变我国在经济上和科学文化上的落后状况，迅速达到世界上的先进水平。",
      "totalCount": 54,
      "appLink": "weread://bestbookmark?bookId=3300029378&chapterUid=3&rangeStart=1639&rangeEnd=1696",
