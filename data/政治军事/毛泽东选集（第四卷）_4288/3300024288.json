  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300024288_3_1422-1463",
      "chapterUid": 3,
      "range": "1422-1463",
      "markText": "国民党怎么样？看它的过去，就可以知道它的现在；看它的过去和现在，就可以知道它的将来",
      "totalCount": 280,
      "appLink": "weread://bestbookmark?bookId=3300024288&chapterUid=3&rangeStart=1422&rangeEnd=1463",
      "webLink": "https://weread.qq.com/web/reader/4b732070813ab6ffcg0187f9?chapterUid=3&rangeStart=1422&rangeEnd=1463"
    },
    {
      "bookmarkId": "3300024288_68_4429-4507",
      "chapterUid": 68,
      "range": "4429-4507",
      "markText": "阶级斗争，一些阶级胜利了，一些阶级消灭了。这就是历史，这就是几千年的文明史。拿这个观点解释历史的就叫做历史的唯物主义，站在这个观点的反面的是历史的唯心主义。",
      "totalCount": 208,
      "appLink": "weread://bestbookmark?bookId=3300024288&chapterUid=68&rangeStart=4429&rangeEnd=4507",
      "webLink": "https://weread.qq.com/web/reader/4b732070813ab6ffcg0187f9?chapterUid=68&rangeStart=4429&rangeEnd=4507"
    },
    {
      "bookmarkId": "3300024288_7_2898-3061",
      "chapterUid": 7,
      "range": "2898-3061",
      "markText": "不论何时，又团结，又斗争，以斗争之手段，达团结之目的；有理有利有节；利用矛盾，争取多数，反对少数，各个击破等项原则，必须坚持，不可忘记。",
      "totalCount": 180,
      "appLink": "weread://bestbookmark?bookId=3300024288&chapterUid=7&rangeStart=2898&rangeEnd=3061",
      "webLink": "https://weread.qq.com/web/reader/4b732070813ab6ffcg0187f9?chapterUid=7&rangeStart=2898&rangeEnd=3061"
    },
    {
      "bookmarkId": "3300024288_3_1196-1211",
      "chapterUid": 3,
      "range": "1196-1211",
      "markText": "日本投降的决定因素是苏联参战。",
      "totalCount": 176,
      "appLink": "weread://bestbookmark?bookId=3300024288&chapterUid=3&rangeStart=1196&rangeEnd=1211",
      "webLink": "https://weread.qq.com/web/reader/4b732070813ab6ffcg0187f9?chapterUid=3&rangeStart=1196&rangeEnd=1211"
    },
    {
      "bookmarkId": "3300024288_60_10867-10912",
      "chapterUid": 60,
      "range": "10867-10912",
      "markText": "务必使同志们继续地保持谦虚、谨慎、不骄、不躁的作风，务必使同志们继续地保持艰苦奋斗的作风。",
      "totalCount": 156,
      "appLink": "weread://bestbookmark?bookId=3300024288&chapterUid=60&rangeStart=10867&rangeEnd=10912",
      "webLink": "https://weread.qq.com/web/reader/4b732070813ab6ffcg0187f9?chapterUid=60&rangeStart=10867&rangeEnd=10912"
    },
    {
      "bookmarkId": "3300024288_3_11271-11303",
      "chapterUid": 3,
      "range": "11271-11303",
      "markText": "总而言之，我们要有准备。有了准备，就能恰当地应付各种复杂的局面。",
      "totalCount": 154,
      "appLink": "weread://bestbookmark?bookId=3300024288&chapterUid=3&rangeStart=11271&rangeEnd=11303",
      "webLink": "https://weread.qq.com/web/reader/4b732070813ab6ffcg0187f9?chapterUid=3&rangeStart=11271&rangeEnd=11303"
    },
    {
      "bookmarkId": "3300024288_12_2332-2369",
      "chapterUid": 12,
      "range": "2332-2369",
      "markText": "我党必须给东北人民以看得见的物质利益，群众才会拥护我们，反对国民党的进攻。",
      "totalCount": 150,
      "appLink": "weread://bestbookmark?bookId=3300024288&chapterUid=12&rangeStart=2332&rangeEnd=2369",
      "webLink": "https://weread.qq.com/web/reader/4b732070813ab6ffcg0187f9?chapterUid=12&rangeStart=2332&rangeEnd=2369"
    },
    {
      "bookmarkId": "3300024288_37_7685-7724",
      "chapterUid": 37,
      "range": "7685-7724",
      "markText": "土地改革的目的是消灭封建剥削制度，即消灭封建地主之为阶级，而不是消灭地主个人。",
      "totalCount": 150,
      "appLink": "weread://bestbookmark?bookId=3300024288&chapterUid=37&rangeStart=7685&rangeEnd=7724",
      "webLink": "https://weread.qq.com/web/reader/4b732070813ab6ffcg0187f9?chapterUid=37&rangeStart=7685&rangeEnd=7724"
    },
    {
      "bookmarkId": "3300024288_15_4415-4426",
      "chapterUid": 15,
      "range": "4415-4426",
