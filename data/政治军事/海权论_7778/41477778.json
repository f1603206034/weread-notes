      "bookmarkId": "41477778_3_21634-21663",
      "chapterUid": 3,
      "range": "21634-21663",
      "markText": "欧洲的贵族阶层，从中世纪起就有目空一切地轻视商业贸易的传统",
      "totalCount": 126,
      "appLink": "weread://bestbookmark?bookId=41477778&chapterUid=3&rangeStart=21634&rangeEnd=21663",
