  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "23912348_6_1606-1647",
      "chapterUid": 6,
      "range": "1606-1647",
      "markText": "策论应该深刻阐述国家政策方略，要结合当前的国家政务，提出问题、分析问题、解决问题。",
      "totalCount": 72,
      "appLink": "weread://bestbookmark?bookId=23912348&chapterUid=6&rangeStart=1606&rangeEnd=1647",
      "webLink": "https://weread.qq.com/web/reader/81a32350716cdf9c81adb18?chapterUid=6&rangeStart=1606&rangeEnd=1647"
    },
    {
      "bookmarkId": "23912348_7_5503-5600",
      "chapterUid": 7,
      "range": "5503-5600",
      "markText": "申论考试是多种知识的综合考核，平时要做到“厚积”，考试时才能“薄发”。因此平时要加强思想修养，提高理论造诣；注意观察事物和生活的积累，注重分析综合能力的训练；向他人学习，取长补短，重视知识的积累",
      "totalCount": 51,
      "appLink": "weread://bestbookmark?bookId=23912348&chapterUid=7&rangeStart=5503&rangeEnd=5600",
      "webLink": "https://weread.qq.com/web/reader/81a32350716cdf9c81adb18?chapterUid=7&rangeStart=5503&rangeEnd=5600"
    },
    {
      "bookmarkId": "23912348_7_21281-21330",
      "chapterUid": 7,
      "range": "21281-21330",
      "markText": "一是教育手段；二是行政手段；三是经济手段；四是管理手段；五是法律手段；六是监督手段；七是技术手段。",
      "totalCount": 45,
      "appLink": "weread://bestbookmark?bookId=23912348&chapterUid=7&rangeStart=21281&rangeEnd=21330",
      "webLink": "https://weread.qq.com/web/reader/81a32350716cdf9c81adb18?chapterUid=7&rangeStart=21281&rangeEnd=21330"
    },
    {
      "bookmarkId": "23912348_3_424-465",
      "chapterUid": 3,
      "range": "424-465",
      "markText": "申论是对公务员理论功底和思辨能力的综合测试和专项检验，是公务员考试内容的核心部分。",
      "totalCount": 44,
      "appLink": "weread://bestbookmark?bookId=23912348&chapterUid=3&rangeStart=424&rangeEnd=465",
      "webLink": "https://weread.qq.com/web/reader/81a32350716cdf9c81adb18?chapterUid=3&rangeStart=424&rangeEnd=465"
    },
    {
      "bookmarkId": "23912348_6_544-565",
      "chapterUid": 6,
      "range": "544-565",
      "markText": "“申论”一词取自孔子《论语》的“申而论之”",
      "totalCount": 42,
      "appLink": "weread://bestbookmark?bookId=23912348&chapterUid=6&rangeStart=544&rangeEnd=565",
      "webLink": "https://weread.qq.com/web/reader/81a32350716cdf9c81adb18?chapterUid=6&rangeStart=544&rangeEnd=565"
    },
    {
      "bookmarkId": "23912348_6_1541-1600",
      "chapterUid": 6,
      "range": "1541-1600",
      "markText": "“使事深于政术，理密于时务；酌三五以熔世，而非迂缓之高谈，驭权变以拯俗，而非刻薄之伪论；风恢恢而能远，流洋洋而不溢。”",
      "totalCount": 36,
      "appLink": "weread://bestbookmark?bookId=23912348&chapterUid=6&rangeStart=1541&rangeEnd=1600",
      "webLink": "https://weread.qq.com/web/reader/81a32350716cdf9c81adb18?chapterUid=6&rangeStart=1541&rangeEnd=1600"
    },
    {
      "bookmarkId": "23912348_6_2571-2599",
      "chapterUid": 6,
      "range": "2571-2599",
      "markText": "申论考试除了所给出的材料部分外，其答卷一般由3部分组成。",
      "totalCount": 36,
      "appLink": "weread://bestbookmark?bookId=23912348&chapterUid=6&rangeStart=2571&rangeEnd=2599",
      "webLink": "https://weread.qq.com/web/reader/81a32350716cdf9c81adb18?chapterUid=6&rangeStart=2571&rangeEnd=2599"
    },
    {
      "bookmarkId": "23912348_8_16000-16042",
      "chapterUid": 8,
      "range": "16000-16042",
      "markText": "结构要完整、层次要清楚，既要提出问题、分析原因、阐释解决的必要性，又要提出解决的对策",
      "totalCount": 36,
      "appLink": "weread://bestbookmark?bookId=23912348&chapterUid=8&rangeStart=16000&rangeEnd=16042",
      "webLink": "https://weread.qq.com/web/reader/81a32350716cdf9c81adb18?chapterUid=8&rangeStart=16000&rangeEnd=16042"
    },
    {
      "bookmarkId": "23912348_6_2201-2244",
      "chapterUid": 6,
      "range": "2201-2244",
      "markText": "申论考试给出的资料虽然涉及面广，头绪较多，但一般重点都比较突出，考查的目的也比较明确。",
      "totalCount": 34,
      "appLink": "weread://bestbookmark?bookId=23912348&chapterUid=6&rangeStart=2201&rangeEnd=2244",
      "webLink": "https://weread.qq.com/web/reader/81a32350716cdf9c81adb18?chapterUid=6&rangeStart=2201&rangeEnd=2244"
    },
    {
      "bookmarkId": "23912348_6_4204-4281",
      "chapterUid": 6,
      "range": "4204-4281",
      "markText": "即在阅读理解的过程中，需要考生把具体资料上升到理性高度来认识，把众多资料归纳为分类资料，把分散事物整合成有一定内在联系的事物，由既定事物联想到更多的事物。",
      "totalCount": 34,
      "appLink": "weread://bestbookmark?bookId=23912348&chapterUid=6&rangeStart=4204&rangeEnd=4281",
      "webLink": "https://weread.qq.com/web/reader/81a32350716cdf9c81adb18?chapterUid=6&rangeStart=4204&rangeEnd=4281"
    },
    {
      "bookmarkId": "23912348_6_6260-6320",
      "chapterUid": 6,
      "range": "6260-6320",
      "markText": "首先要确定中心思想与材料之间、整体与部分之间、部分与部分之间的内在逻辑联系，精心安排好各部分、各要素在整个结构中的位置。",
      "totalCount": 32,
      "appLink": "weread://bestbookmark?bookId=23912348&chapterUid=6&rangeStart=6260&rangeEnd=6320",
      "webLink": "https://weread.qq.com/web/reader/81a32350716cdf9c81adb18?chapterUid=6&rangeStart=6260&rangeEnd=6320"
    },
    {
      "bookmarkId": "23912348_7_14093-14134",
      "chapterUid": 7,
      "range": "14093-14134",
      "markText": "材料列举了大量非法违纪的腐败典型案例，对原因进行了分析，提出了杜绝失职渎职的对策。",
      "totalCount": 32,
      "appLink": "weread://bestbookmark?bookId=23912348&chapterUid=7&rangeStart=14093&rangeEnd=14134",
      "webLink": "https://weread.qq.com/web/reader/81a32350716cdf9c81adb18?chapterUid=7&rangeStart=14093&rangeEnd=14134"
    },
    {
      "bookmarkId": "23912348_7_15705-15755",
      "chapterUid": 7,
      "range": "15705-15755",
      "markText": "比如三鹿奶粉事件，一方面反映了行业自律问题，意味着行业监管力度不够；另一方面反映了政府公信力的问题。",
      "totalCount": 32,
      "appLink": "weread://bestbookmark?bookId=23912348&chapterUid=7&rangeStart=15705&rangeEnd=15755",
      "webLink": "https://weread.qq.com/web/reader/81a32350716cdf9c81adb18?chapterUid=7&rangeStart=15705&rangeEnd=15755"
    },
    {
      "bookmarkId": "23912348_11_27283-27328",
      "chapterUid": 11,
      "range": "27283-27328",
      "markText": "但答案往往直接体现在给定资料中，而无须考生自己分析。另外，分析原因往往是和提出对策相联系的",
      "totalCount": 32,
      "appLink": "weread://bestbookmark?bookId=23912348&chapterUid=11&rangeStart=27283&rangeEnd=27328",
      "webLink": "https://weread.qq.com/web/reader/81a32350716cdf9c81adb18?chapterUid=11&rangeStart=27283&rangeEnd=27328"
    },
    {
      "bookmarkId": "23912348_6_4813-4840",
      "chapterUid": 6,
      "range": "4813-4840",
      "markText": "考生必须把提出问题和解决问题的能力作为训练的核心目标。",
      "totalCount": 30,
      "appLink": "weread://bestbookmark?bookId=23912348&chapterUid=6&rangeStart=4813&rangeEnd=4840",
      "webLink": "https://weread.qq.com/web/reader/81a32350716cdf9c81adb18?chapterUid=6&rangeStart=4813&rangeEnd=4840"
    },
    {
      "bookmarkId": "23912348_6_5836-5849",
      "chapterUid": 6,
      "range": "5836-5849",
      "markText": "论述问题的目的在于解决问题",
      "totalCount": 30,
      "appLink": "weread://bestbookmark?bookId=23912348&chapterUid=6&rangeStart=5836&rangeEnd=5849",
      "webLink": "https://weread.qq.com/web/reader/81a32350716cdf9c81adb18?chapterUid=6&rangeStart=5836&rangeEnd=5849"
    },
    {
      "bookmarkId": "23912348_6_7769-7818",
