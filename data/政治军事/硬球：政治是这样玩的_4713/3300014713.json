  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300014713_5_14671-14738",
      "chapterUid": 5,
      "range": "14671-14738",
      "markText": "如果你要和别人一起办公事，千万不要忽略私人方面的东西。新一代的政治家问题就出在这里，他们学会了运用媒体的技巧，但却忘掉了唠家常的艺术。",
      "totalCount": 666,
      "appLink": "weread://bestbookmark?bookId=3300014713&chapterUid=5&rangeStart=14671&rangeEnd=14738",
      "webLink": "https://weread.qq.com/web/reader/81332560813ab6c3fg0134f7?chapterUid=5&rangeStart=14671&rangeEnd=14738"
    },
    {
      "bookmarkId": "3300014713_5_11490-11557",
      "chapterUid": 5,
      "range": "11490-11557",
      "markText": "约翰逊懂得，成功的关键有时并不在于你要想的是大事，而在于要想小事；要喂饱你心中豪情万丈的自我，最佳的办法是先喂饱那些你需要去影响的人。",
      "totalCount": 646,
      "appLink": "weread://bestbookmark?bookId=3300014713&chapterUid=5&rangeStart=11490&rangeEnd=11557",
      "webLink": "https://weread.qq.com/web/reader/81332560813ab6c3fg0134f7?chapterUid=5&rangeStart=11490&rangeEnd=11557"
    },
    {
      "bookmarkId": "3300014713_6_1643-1699",
      "chapterUid": 6,
      "range": "1643-1699",
      "markText": "如果要了解并影响你的同伴，你就不能把注意力集中在宏大而抽象的问题上，而应该密切注意和他们个人关系最大的那些事情。",
      "totalCount": 576,
      "appLink": "weread://bestbookmark?bookId=3300014713&chapterUid=6&rangeStart=1643&rangeEnd=1699",
      "webLink": "https://weread.qq.com/web/reader/81332560813ab6c3fg0134f7?chapterUid=6&rangeStart=1643&rangeEnd=1699"
    },
    {
      "bookmarkId": "3300014713_5_10478-10521",
      "chapterUid": 5,
      "range": "10478-10521",
      "markText": "约翰逊就是这样，一旦他觉得需要和别人建立亲密关系，他就什么都说得出来，什么都做得出来。",
      "totalCount": 540,
      "appLink": "weread://bestbookmark?bookId=3300014713&chapterUid=5&rangeStart=10478&rangeEnd=10521",
      "webLink": "https://weread.qq.com/web/reader/81332560813ab6c3fg0134f7?chapterUid=5&rangeStart=10478&rangeEnd=10521"
    },
    {
      "bookmarkId": "3300014713_5_7084-7173",
      "chapterUid": 5,
      "range": "7084-7173",
      "markText": "要把全部的注意力都集中到对方目前的处境上，这是一种非常罕见的能力。“林登·约翰逊总是能够让你相信，你的问题不管在别人眼里多么微不足道，对林登·约翰逊来说却是世界上最重要的事情。”",
      "totalCount": 495,
      "appLink": "weread://bestbookmark?bookId=3300014713&chapterUid=5&rangeStart=7084&rangeEnd=7173",
      "webLink": "https://weread.qq.com/web/reader/81332560813ab6c3fg0134f7?chapterUid=5&rangeStart=7084&rangeEnd=7173"
    },
    {
      "bookmarkId": "3300014713_3_4551-4622",
      "chapterUid": 3,
      "range": "4551-4622",
      "markText": "活力是一个不可低估的因素，所有伟大的政治家都拥有充沛的精神和活力。但是，真正激发人活力的是不断学习的意愿和为了登峰造极而不惜做任何事情的决心。",
      "totalCount": 464,
      "appLink": "weread://bestbookmark?bookId=3300014713&chapterUid=3&rangeStart=4551&rangeEnd=4622",
      "webLink": "https://weread.qq.com/web/reader/81332560813ab6c3fg0134f7?chapterUid=3&rangeStart=4551&rangeEnd=4622"
    },
    {
      "bookmarkId": "3300014713_5_2808-2836",
      "chapterUid": 5,
      "range": "2808-2836",
      "markText": "他向我们证明，向上爬就意味着结交人，两者事实上是一回事。",
      "totalCount": 408,
      "appLink": "weread://bestbookmark?bookId=3300014713&chapterUid=5&rangeStart=2808&rangeEnd=2836",
      "webLink": "https://weread.qq.com/web/reader/81332560813ab6c3fg0134f7?chapterUid=5&rangeStart=2808&rangeEnd=2836"
    },
    {
      "bookmarkId": "3300014713_8_13802-13859",
      "chapterUid": 8,
      "range": "13802-13859",
      "markText": "一个出色的说客心里会清楚地知道，他的饭碗依赖于他存在的必要性，只有他的任务无法轻而易举地完成，他才不会有失业之虞。",
      "totalCount": 391,
      "appLink": "weread://bestbookmark?bookId=3300014713&chapterUid=8&rangeStart=13802&rangeEnd=13859",
      "webLink": "https://weread.qq.com/web/reader/81332560813ab6c3fg0134f7?chapterUid=8&rangeStart=13802&rangeEnd=13859"
    },
    {
      "bookmarkId": "3300014713_7_948-1032",
      "chapterUid": 7,
      "range": "948-1032",
      "markText": "你在一个人身上付出越多，你对他就会变得越忠诚。赢得一个支持者的最好办法，就是让他为你做点什么。用本杰明·富兰克林的话说就是：“如果你想交一个朋友，那就请他帮你一个忙。”",
      "totalCount": 390,
      "appLink": "weread://bestbookmark?bookId=3300014713&chapterUid=7&rangeStart=948&rangeEnd=1032",
      "webLink": "https://weread.qq.com/web/reader/81332560813ab6c3fg0134f7?chapterUid=7&rangeStart=948&rangeEnd=1032"
    },
    {
      "bookmarkId": "3300014713_6_4022-4068",
      "chapterUid": 6,
      "range": "4022-4068",
      "markText": "仅仅做到多回几次家乡，那其实还是很不够的。重要的是，你首先要让人们感觉到你从来就没有离开过。",
      "totalCount": 340,
      "appLink": "weread://bestbookmark?bookId=3300014713&chapterUid=6&rangeStart=4022&rangeEnd=4068",
      "webLink": "https://weread.qq.com/web/reader/81332560813ab6c3fg0134f7?chapterUid=6&rangeStart=4022&rangeEnd=4068"
    },
    {
      "bookmarkId": "3300014713_5_10983-11005",
      "chapterUid": 5,
      "range": "10983-11005",
      "markText": "约翰逊在有生之年都不知道如何抓住媒体的力量。",
      "totalCount": 315,
      "appLink": "weread://bestbookmark?bookId=3300014713&chapterUid=5&rangeStart=10983&rangeEnd=11005",
      "webLink": "https://weread.qq.com/web/reader/81332560813ab6c3fg0134f7?chapterUid=5&rangeStart=10983&rangeEnd=11005"
    },
    {
      "bookmarkId": "3300014713_5_6936-7006",
      "chapterUid": 5,
      "range": "6936-7006",
      "markText": "正是因为约翰逊乐于将注意力集中在别人和别人关心的事情上，而不论那些事情是多么微不足道，才使得他与那些他试图影响的人能进行几乎无所不谈的沟通。",
      "totalCount": 306,
      "appLink": "weread://bestbookmark?bookId=3300014713&chapterUid=5&rangeStart=6936&rangeEnd=7006",
      "webLink": "https://weread.qq.com/web/reader/81332560813ab6c3fg0134f7?chapterUid=5&rangeStart=6936&rangeEnd=7006"
    },
    {
      "bookmarkId": "3300014713_3_1934-1960",
      "chapterUid": 3,
      "range": "1934-1960",
      "markText": "我们都会同意，你只会对那些你亲自发现的东西确信无疑。",
