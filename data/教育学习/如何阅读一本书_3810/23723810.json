  "content": [
    {
      "chapterUid": 32,
      "chapterTitle": "第一篇 阅读的层次",
      "items": [
        {
          "type": "highlight",
          "bookmarkId": "23723810_32_4039-4123",
          "range": "4039-4123",
          "rangeStart": 4039,
          "rangeEnd": 4123,
          "markText": "只有一种方式是真正地在阅读。没有任何外力的帮助，你就是要读这本书。你什么都没有，只凭着内心的力量，玩味着眼前的字句，慢慢地提升自己，从只有模糊的概念到更清楚地理解为止。",
          "colorStyle": 0,
          "colorLabel": "",
          "createTime": 1752570197,
          "createTimeFormatted": "2025-07-15 17:03:17",
          "chapterUid": 32,
          "appLink": "weread://bestbookmark?bookId=23723810&chapterUid=32&rangeStart=4039&rangeEnd=4123",
          "webLink": "https://weread.qq.com/web/reader/272326407169ff22272934f?chapterUid=32&rangeStart=4039&rangeEnd=4123"
        }
      ]
    },
    {
      "chapterUid": 46,
      "chapterTitle": "第十五章 阅读故事、戏剧与诗的一些建议",
      "items": [
        {
          "type": "highlight",
          "bookmarkId": "23723810_46_4478-4498",
          "range": "4478-4498",
          "rangeStart": 4478,
          "rangeEnd": 4498,
          "markText": "小说能满足我们潜意识或意识中许多的需要。",
          "colorStyle": 2,
          "colorLabel": "",
          "createTime": 1745399063,
          "createTimeFormatted": "2025-04-23 17:04:23",
          "chapterUid": 46,
          "appLink": "weread://bestbookmark?bookId=23723810&chapterUid=46&rangeStart=4478&rangeEnd=4498",
          "webLink": "https://weread.qq.com/web/reader/272326407169ff22272934f?chapterUid=46&rangeStart=4478&rangeEnd=4498"
