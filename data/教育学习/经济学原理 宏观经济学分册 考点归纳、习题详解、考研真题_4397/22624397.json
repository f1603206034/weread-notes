      "appLink": "weread://bestbookmark?bookId=22624397&chapterUid=5&rangeStart=5580&rangeEnd=5610",
      "webLink": "https://weread.qq.com/web/reader/edd321407159388dedd85d7?chapterUid=5&rangeStart=5580&rangeEnd=5610"
