      "webLink": "https://weread.qq.com/web/reader/e2232c6071ff2f3de228fc4?chapterUid=4&rangeStart=47705&rangeEnd=47736"
    },
    {
      "bookmarkId": "33500989_10_10106-10190",
      "chapterUid": 10,
      "range": "10106-10190",
      "markText": "How would you like to see me bring one in that dressed out over a thousand pounds? ”",
      "totalCount": 42,
      "appLink": "weread://bestbookmark?bookId=33500989&chapterUid=10&rangeStart=10106&rangeEnd=10190",
      "webLink": "https://weread.qq.com/web/reader/e2232c6071ff2f3de228fc4?chapterUid=10&rangeStart=10106&rangeEnd=10190"
