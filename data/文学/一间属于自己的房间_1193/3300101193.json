  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300101193_3_2292-2317",
      "chapterUid": 3,
      "range": "2292-2317",
      "markText": "“不必着急，不必耀眼，不必成为别人，做自己就好。”",
      "totalCount": 3495,
      "appLink": "weread://bestbookmark?bookId=3300101193&chapterUid=3&rangeStart=2292&rangeEnd=2317",
      "webLink": "https://weread.qq.com/web/reader/aa0327a0813ab8e07g013eb2?chapterUid=3&rangeStart=2292&rangeEnd=2317"
    },
    {
      "bookmarkId": "3300101193_11_412-467",
      "chapterUid": 11,
      "range": "412-467",
      "markText": "关于阅读，一个人可以向他人提供的唯一指导就是不必听从任何指导，你只需根据自己的直觉和理解来得出自己的结论即可。",
      "totalCount": 1998,
      "appLink": "weread://bestbookmark?bookId=3300101193&chapterUid=11&rangeStart=412&rangeEnd=467",
      "webLink": "https://weread.qq.com/web/reader/aa0327a0813ab8e07g013eb2?chapterUid=11&rangeStart=412&rangeEnd=467"
    },
    {
      "bookmarkId": "3300101193_8_7273-7308",
      "chapterUid": 8,
      "range": "7273-7308",
      "markText": "女性将获得她们长久以来被剥夺的东西——闲暇、金钱和一间属于自己的房间。",
      "totalCount": 1785,
      "appLink": "weread://bestbookmark?bookId=3300101193&chapterUid=8&rangeStart=7273&rangeEnd=7308",
      "webLink": "https://weread.qq.com/web/reader/aa0327a0813ab8e07g013eb2?chapterUid=8&rangeStart=7273&rangeEnd=7308"
    },
    {
      "bookmarkId": "3300101193_18_2001-2098",
      "chapterUid": 18,
      "range": "2001-2098",
      "markText": "思考——我将它诩为，让思绪的渔线垂入河流。让它随着时间一分一秒地流逝，荡漾在倒影和青荇之间，由着水波浮浮沉沉，直到有想法聚集在这条线的末端，再轻轻地一拽，小心翼翼地把它提出水面，放到岸边草地上。",
      "totalCount": 1764,
      "appLink": "weread://bestbookmark?bookId=3300101193&chapterUid=18&rangeStart=2001&rangeEnd=2098",
      "webLink": "https://weread.qq.com/web/reader/aa0327a0813ab8e07g013eb2?chapterUid=18&rangeStart=2001&rangeEnd=2098"
    },
    {
      "bookmarkId": "3300101193_18_5659-5682",
      "chapterUid": 18,
      "range": "5659-5682",
      "markText": "不必着急，不必耀眼，不必成为别人，做自己就好。",
      "totalCount": 1488,
      "appLink": "weread://bestbookmark?bookId=3300101193&chapterUid=18&rangeStart=5659&rangeEnd=5682",
      "webLink": "https://weread.qq.com/web/reader/aa0327a0813ab8e07g013eb2?chapterUid=18&rangeStart=5659&rangeEnd=5682"
    },
    {
      "bookmarkId": "3300101193_3_1525-1559",
      "chapterUid": 3,
      "range": "1525-1559",
      "markText": "女性若想投身创作并实现独立，就必须拥有闲暇、金钱和一间属于自己的房间",
      "totalCount": 1404,
      "appLink": "weread://bestbookmark?bookId=3300101193&chapterUid=3&rangeStart=1525&rangeEnd=1559",
      "webLink": "https://weread.qq.com/web/reader/aa0327a0813ab8e07g013eb2?chapterUid=3&rangeStart=1525&rangeEnd=1559"
    },
    {
      "bookmarkId": "3300101193_5_2841-2872",
      "chapterUid": 5,
      "range": "2841-2872",
      "markText": "于是，在十五岁时，她对别人几乎不抱幻想，对自己则完全不抱幻想。",
      "totalCount": 1368,
      "appLink": "weread://bestbookmark?bookId=3300101193&chapterUid=5&rangeStart=2841&rangeEnd=2872",
      "webLink": "https://weread.qq.com/web/reader/aa0327a0813ab8e07g013eb2?chapterUid=5&rangeStart=2841&rangeEnd=2872"
    },
    {
      "bookmarkId": "3300101193_23_8969-9062",
      "chapterUid": 23,
      "range": "8969-9062",
      "markText": "因此，我希望你写出各种各样的书，无论书的主题多么琐碎或宏大都毫不犹豫地去写。我希望你能有足够的财富去旅行和消遣，去思考世界的过去和未来，去书中梦想，去街头闲逛，让思绪的渔线深深垂入河流。",
      "totalCount": 1309,
      "appLink": "weread://bestbookmark?bookId=3300101193&chapterUid=23&rangeStart=8969&rangeEnd=9062",
      "webLink": "https://weread.qq.com/web/reader/aa0327a0813ab8e07g013eb2?chapterUid=23&rangeStart=8969&rangeEnd=9062"
    },
    {
      "bookmarkId": "3300101193_8_2355-2432",
      "chapterUid": 8,
      "range": "2355-2432",
      "markText": "值得我们注意的是，四位伟大的女性作家——简·奥斯丁、艾米莉·勃朗特、夏洛蒂·勃朗特和乔治·艾略特——没有一个生过孩子，其中两人未婚，这个事实具有重要意义。",
      "totalCount": 1170,
      "appLink": "weread://bestbookmark?bookId=3300101193&chapterUid=8&rangeStart=2355&rangeEnd=2432",
      "webLink": "https://weread.qq.com/web/reader/aa0327a0813ab8e07g013eb2?chapterUid=8&rangeStart=2355&rangeEnd=2432"
    },
    {
      "bookmarkId": "3300101193_23_10173-10234",
      "chapterUid": 23,
      "range": "10173-10234",
      "markText": "我发现自己想说的话简单又平淡，那就是，做自己是最重要的。如果要说得更高尚一点，那就是，不要梦想着影响他人，要思考事物本身。",
      "totalCount": 1170,
      "appLink": "weread://bestbookmark?bookId=3300101193&chapterUid=23&rangeStart=10173&rangeEnd=10234",
      "webLink": "https://weread.qq.com/web/reader/aa0327a0813ab8e07g013eb2?chapterUid=23&rangeStart=10173&rangeEnd=10234"
    },
    {
      "bookmarkId": "3300101193_18_1116-1140",
      "chapterUid": 18,
      "range": "1116-1140",
      "markText": "女性如果要写小说，就必须拥有钱和一间自己的房间。",
      "totalCount": 1150,
      "appLink": "weread://bestbookmark?bookId=3300101193&chapterUid=18&rangeStart=1116&rangeEnd=1140",
      "webLink": "https://weread.qq.com/web/reader/aa0327a0813ab8e07g013eb2?chapterUid=18&rangeStart=1116&rangeEnd=1140"
    },
    {
      "bookmarkId": "3300101193_19_9939-10011",
      "chapterUid": 19,
      "range": "9939-10011",
      "markText": "弥尔顿建议女人觅一位绅士，并将自己的崇拜永远寄托于其高大伟岸的身影，但我姑姑的遗产取代了这条建议，为我揭开了天空的面纱，让我得以纵览开阔的天景。",
      "totalCount": 1003,
      "appLink": "weread://bestbookmark?bookId=3300101193&chapterUid=19&rangeStart=9939&rangeEnd=10011",
      "webLink": "https://weread.qq.com/web/reader/aa0327a0813ab8e07g013eb2?chapterUid=19&rangeStart=9939&rangeEnd=10011"
    },
    {
      "bookmarkId": "3300101193_18_4125-4191",
      "chapterUid": 18,
      "range": "4125-4191",
      "markText": "当我靠在墙上时，发现大学校园看起来确实像是一个庇护所，保护着这些罕见类型的人，如果他们被丢在斯特兰德大街上自谋生路，很快就会被淘汰。",
      "totalCount": 972,
      "appLink": "weread://bestbookmark?bookId=3300101193&chapterUid=18&rangeStart=4125&rangeEnd=4191",
      "webLink": "https://weread.qq.com/web/reader/aa0327a0813ab8e07g013eb2?chapterUid=18&rangeStart=4125&rangeEnd=4191"
    },
    {
      "bookmarkId": "3300101193_3_1919-1931",
      "chapterUid": 3,
      "range": "1919-1931",
