  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300102958_4_16098-16177",
      "chapterUid": 4,
      "range": "16098-16177",
      "markText": "我站起来。我要回家过夜。我会在密歇根闭眼休息——也许甚至在德国或中国，此刻我还不知道。我开始走路，但我并不害怕。我感觉我的恐惧如涟漪扩散，荡漾过百万年的时光。",
      "totalCount": 144,
      "appLink": "weread://bestbookmark?bookId=3300102958&chapterUid=4&rangeStart=16098&rangeEnd=16177",
      "webLink": "https://weread.qq.com/web/reader/90a32c80813ab8eb7g018a8f?chapterUid=4&rangeStart=16098&rangeEnd=16177"
    },
    {
      "bookmarkId": "3300102958_5_13603-13631",
      "chapterUid": 5,
      "range": "13603-13631",
      "markText": "狗群跑过山脊上的一个土丘，山猫蹲在土丘上，等待男人离开。",
      "totalCount": 72,
      "appLink": "weread://bestbookmark?bookId=3300102958&chapterUid=5&rangeStart=13603&rangeEnd=13631",
      "webLink": "https://weread.qq.com/web/reader/90a32c80813ab8eb7g018a8f?chapterUid=5&rangeStart=13603&rangeEnd=13631"
    },
    {
      "bookmarkId": "3300102958_3_2125-2208",
      "chapterUid": 3,
      "range": "2125-2208",
      "markText": "友谊，若是建立在彼此疏离和自觉迎合他人看法的基础上，就往往没有经历过真正的考验。它缺乏健康关系所需要的共同处境：一种共同或“正常”的基础，适合信任和对彼此兴趣的生长。",
      "totalCount": 70,
      "appLink": "weread://bestbookmark?bookId=3300102958&chapterUid=3&rangeStart=2125&rangeEnd=2208",
      "webLink": "https://weread.qq.com/web/reader/90a32c80813ab8eb7g018a8f?chapterUid=3&rangeStart=2125&rangeEnd=2208"
    },
    {
      "bookmarkId": "3300102958_3_7706-7772",
      "chapterUid": 3,
      "range": "7706-7772",
      "markText": "他喜欢有格调的人。他会轻蔑地谈论第一次约会就和他睡觉的上等阶层女人，会全心全意赞美在几次约会后才允许他亲吻脸颊的女人。“她是淑女。”",
      "totalCount": 39,
      "appLink": "weread://bestbookmark?bookId=3300102958&chapterUid=3&rangeStart=7706&rangeEnd=7772",
      "webLink": "https://weread.qq.com/web/reader/90a32c80813ab8eb7g018a8f?chapterUid=3&rangeStart=7706&rangeEnd=7772"
    },
    {
      "bookmarkId": "3300102958_3_3714-3818",
      "chapterUid": 3,
      "range": "3714-3818",
      "markText": "他问我喝不喝啤酒，玩不玩弹球游戏，有没有枪，喜不喜欢打猎或钓鱼。这些重要的文化背景问题确定之后，他问——就好像突然想起来了似的——他能不能和我做独立研究。",
      "totalCount": 36,
      "appLink": "weread://bestbookmark?bookId=3300102958&chapterUid=3&rangeStart=3714&rangeEnd=3818",
      "webLink": "https://weread.qq.com/web/reader/90a32c80813ab8eb7g018a8f?chapterUid=3&rangeStart=3714&rangeEnd=3818"
    },
    {
      "bookmarkId": "3300102958_3_11280-11375",
      "chapterUid": 3,
      "range": "11280-11375",
      "markText": "我相信布里斯确实喝了几杯，然后发现自己被锁进了他随身携带的那个密室。我认为，他在夏洛茨维尔送出了那么多礼物，向那么多人发出了信号，那个夜晚对他来说肯定很难熬，他觉得他应该有资格向其他人求助。",
      "totalCount": 36,
      "appLink": "weread://bestbookmark?bookId=3300102958&chapterUid=3&rangeStart=11280&rangeEnd=11375",
      "webLink": "https://weread.qq.com/web/reader/90a32c80813ab8eb7g018a8f?chapterUid=3&rangeStart=11280&rangeEnd=11375"
    },
    {
      "bookmarkId": "3300102958_8_2037-2058",
      "chapterUid": 8,
      "range": "2037-2058",
      "markText": "只要死一头猪，其他猪很快就会吃掉它的尸体。",
      "totalCount": 36,
      "appLink": "weread://bestbookmark?bookId=3300102958&chapterUid=8&rangeStart=2037&rangeEnd=2058",
      "webLink": "https://weread.qq.com/web/reader/90a32c80813ab8eb7g018a8f?chapterUid=8&rangeStart=2037&rangeEnd=2058"
    },
    {
      "bookmarkId": "3300102958_9_7942-7955",
      "chapterUid": 9,
      "range": "7942-7955",
      "markText": "语调很专业，但渗出了厌倦。",
      "totalCount": 36,
      "appLink": "weread://bestbookmark?bookId=3300102958&chapterUid=9&rangeStart=7942&rangeEnd=7955",
      "webLink": "https://weread.qq.com/web/reader/90a32c80813ab8eb7g018a8f?chapterUid=9&rangeStart=7942&rangeEnd=7955"
    },
    {
      "bookmarkId": "3300102958_3_8919-9083",
      "chapterUid": 3,
      "range": "8919-9083",
      "markText": "疯狂的导演知道自由不会让你无所牵绊， 再说这和我有什么关系？ 我宣布战争已经结束。已经结束。已经结束。 ——菲尔·奥克斯《战争已经结束》",
      "totalCount": 34,
      "appLink": "weread://bestbookmark?bookId=3300102958&chapterUid=3&rangeStart=8919&rangeEnd=9083",
      "webLink": "https://weread.qq.com/web/reader/90a32c80813ab8eb7g018a8f?chapterUid=3&rangeStart=8919&rangeEnd=9083"
    },
    {
      "bookmarkId": "3300102958_12_5299-5323",
      "chapterUid": 12,
      "range": "5299-5323",
      "markText": "那就谈谈吧。”他的手擦过左轮手枪，去拿另一支烟。",
      "totalCount": 34,
      "appLink": "weread://bestbookmark?bookId=3300102958&chapterUid=12&rangeStart=5299&rangeEnd=5323",
      "webLink": "https://weread.qq.com/web/reader/90a32c80813ab8eb7g018a8f?chapterUid=12&rangeStart=5299&rangeEnd=5323"
    },
    {
      "bookmarkId": "3300102958_14_12570-12705",
      "chapterUid": 14,
      "range": "12570-12705",
      "markText": "“哎，亲爱的，枯干的树该怎么办呢？” “让风吹走吧，我猜。” “对，”她说，贴近他，“尘归尘，土归土。”",
      "totalCount": 34,
      "appLink": "weread://bestbookmark?bookId=3300102958&chapterUid=14&rangeStart=12570&rangeEnd=12705",
      "webLink": "https://weread.qq.com/web/reader/90a32c80813ab8eb7g018a8f?chapterUid=14&rangeStart=12570&rangeEnd=12705"
    },
    {
      "bookmarkId": "3300102958_4_2118-2142",
      "chapterUid": 4,
      "range": "2118-2142",
      "markText": "干净是因为他还在用，但它和另外三个一起挂在那儿。",
      "totalCount": 32,
      "appLink": "weread://bestbookmark?bookId=3300102958&chapterUid=4&rangeStart=2118&rangeEnd=2142",
      "webLink": "https://weread.qq.com/web/reader/90a32c80813ab8eb7g018a8f?chapterUid=4&rangeStart=2118&rangeEnd=2142"
    },
    {
      "bookmarkId": "3300102958_3_7617-7634",
      "chapterUid": 3,
      "range": "7617-7634",
      "markText": "他喜欢用自我毁灭的方式去打动别人。",
      "totalCount": 30,
      "appLink": "weread://bestbookmark?bookId=3300102958&chapterUid=3&rangeStart=7617&rangeEnd=7634",
      "webLink": "https://weread.qq.com/web/reader/90a32c80813ab8eb7g018a8f?chapterUid=3&rangeStart=7617&rangeEnd=7634"
    },
    {
      "bookmarkId": "3300102958_3_11841-11885",
      "chapterUid": 3,
      "range": "11841-11885",
      "markText": "信的第一句话就说清了整个故事：“你没有义务非要回信不可。”但他无论如何还是希望我能回信。",
      "totalCount": 30,
      "appLink": "weread://bestbookmark?bookId=3300102958&chapterUid=3&rangeStart=11841&rangeEnd=11885",
      "webLink": "https://weread.qq.com/web/reader/90a32c80813ab8eb7g018a8f?chapterUid=3&rangeStart=11841&rangeEnd=11885"
    },
    {
      "bookmarkId": "3300102958_4_15044-15058",
      "chapterUid": 4,
      "range": "15044-15058",
      "markText": "她是我很久以前认识的某个人。",
      "totalCount": 28,
      "appLink": "weread://bestbookmark?bookId=3300102958&chapterUid=4&rangeStart=15044&rangeEnd=15058",
      "webLink": "https://weread.qq.com/web/reader/90a32c80813ab8eb7g018a8f?chapterUid=4&rangeStart=15044&rangeEnd=15058"
    },
    {
      "bookmarkId": "3300102958_11_2776-2840",
      "chapterUid": 11,
      "range": "2776-2840",
      "markText": "那年我坐在这儿，手握一条肥皂，心想要是我把它塞到腋窝里，血压就能升高到合格的范围内。我的血压本来就高，但这条肥皂能让我轻松过关。",
      "totalCount": 28,
      "appLink": "weread://bestbookmark?bookId=3300102958&chapterUid=11&rangeStart=2776&rangeEnd=2840",
      "webLink": "https://weread.qq.com/web/reader/90a32c80813ab8eb7g018a8f?chapterUid=11&rangeStart=2776&rangeEnd=2840"
    },
    {
      "bookmarkId": "3300102958_3_1355-1404",
      "chapterUid": 3,
      "range": "1355-1404",
      "markText": "接受弗吉尼亚大学的邀请有职业和个人两方面的原因：我想教更有动力的学生，另外从精神角度说，我想回家。",
      "totalCount": 26,
      "appLink": "weread://bestbookmark?bookId=3300102958&chapterUid=3&rangeStart=1355&rangeEnd=1404",
      "webLink": "https://weread.qq.com/web/reader/90a32c80813ab8eb7g018a8f?chapterUid=3&rangeStart=1355&rangeEnd=1404"
    },
    {
      "bookmarkId": "3300102958_3_6457-6528",
      "chapterUid": 3,
      "range": "6457-6528",
      "markText": "他送给我的那些书也许能够证明他的探索范围：杰克·伦敦的一本传记，尤金·奥尼尔关于大海的戏剧——这些作品关注的是人们以原始视角直面自然时的感受。",
      "totalCount": 26,
      "appLink": "weread://bestbookmark?bookId=3300102958&chapterUid=3&rangeStart=6457&rangeEnd=6528",
      "webLink": "https://weread.qq.com/web/reader/90a32c80813ab8eb7g018a8f?chapterUid=3&rangeStart=6457&rangeEnd=6528"
    },
