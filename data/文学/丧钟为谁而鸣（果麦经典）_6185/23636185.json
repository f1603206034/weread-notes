    {
      "bookmarkId": "23636185_6_16505-16526",
      "chapterUid": 6,
      "range": "16505-16526",
      "markText": "“男人。是我们女人生下了男人，这真是耻辱。",
      "totalCount": 180,
      "appLink": "weread://bestbookmark?bookId=23636185&chapterUid=6&rangeStart=16505&rangeEnd=16526",
