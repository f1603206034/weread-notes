      "appLink": "weread://bestbookmark?bookId=3300037467&chapterUid=7&rangeStart=37828&rangeEnd=37924",
      "webLink": "https://weread.qq.com/web/reader/5d432d00813ab7522g0179b0?chapterUid=7&rangeStart=37828&rangeEnd=37924"
    },
    {
