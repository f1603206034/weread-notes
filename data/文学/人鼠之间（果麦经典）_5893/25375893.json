      "totalCount": 780,
      "appLink": "weread://bestbookmark?bookId=25375893&chapterUid=7&rangeStart=14179&rangeEnd=14256",
      "webLink": "https://weread.qq.com/web/reader/a923275071833495a92c5a9?chapterUid=7&rangeStart=14179&rangeEnd=14256"
    },
    {
