      "appLink": "weread://bestbookmark?bookId=25375893&chapterUid=8&rangeStart=8940&rangeEnd=8988",
      "webLink": "https://weread.qq.com/web/reader/a923275071833495a92c5a9?chapterUid=8&rangeStart=8940&rangeEnd=8988"
