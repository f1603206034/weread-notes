      "appLink": "weread://bestbookmark?bookId=3300054932&chapterUid=6&rangeStart=15389&rangeEnd=15432",
      "webLink": "https://weread.qq.com/web/reader/1c732b80813ab7bf5g012052?chapterUid=6&rangeStart=15389&rangeEnd=15432"
    },
    {
