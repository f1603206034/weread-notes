  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300067359_7_1381-1425",
      "chapterUid": 7,
      "range": "1381-1425",
      "markText": "他告诉比尔，人类只配惨死，因为人类在一个这么美好的星球上干了这么狠毒、这么暴殄天物的事。",
      "totalCount": 270,
      "appLink": "weread://bestbookmark?bookId=3300067359&chapterUid=7&rangeStart=1381&rangeEnd=1425",
      "webLink": "https://weread.qq.com/web/reader/aaa328d0813ab80cfg019b50?chapterUid=7&rangeStart=1381&rangeEnd=1425"
    },
    {
      "bookmarkId": "3300067359_8_3982-4029",
      "chapterUid": 8,
      "range": "3982-4029",
      "markText": "他上的中学以一个奴隶主的名字命名，这个奴隶主也是世界上关于人类自由这一问题最伟大的理论家之一。",
      "totalCount": 252,
      "appLink": "weread://bestbookmark?bookId=3300067359&chapterUid=8&rangeStart=3982&rangeEnd=4029",
      "webLink": "https://weread.qq.com/web/reader/aaa328d0813ab80cfg019b50?chapterUid=8&rangeStart=3982&rangeEnd=4029"
    },
    {
      "bookmarkId": "3300067359_6_2868-2956",
      "chapterUid": 6,
      "range": "2868-2956",
      "markText": "教师们告诉学童，这是他们的大陆被人类发现的年份。实际上，在一四九二年早已有几百万人类在这个大陆上过着充实而且丰富多彩的生活了。这个年份不过是海盗开始欺骗、抢劫和杀戮他们的年份。",
      "totalCount": 225,
      "appLink": "weread://bestbookmark?bookId=3300067359&chapterUid=6&rangeStart=2868&rangeEnd=2956",
      "webLink": "https://weread.qq.com/web/reader/aaa328d0813ab80cfg019b50?chapterUid=6&rangeStart=2868&rangeEnd=2956"
    },
    {
      "bookmarkId": "3300067359_5_3016-3053",
      "chapterUid": 5,
      "range": "3016-3053",
      "markText": "为了使你对我为这本书作的插图的成熟程度有个大致了解，这里是我画的一个屁眼：",
      "totalCount": 221,
      "appLink": "weread://bestbookmark?bookId=3300067359&chapterUid=5&rangeStart=3016&rangeEnd=3053",
      "webLink": "https://weread.qq.com/web/reader/aaa328d0813ab80cfg019b50?chapterUid=5&rangeStart=3016&rangeEnd=3053"
    },
    {
      "bookmarkId": "3300067359_24_6942-7029",
      "chapterUid": 24,
      "range": "6942-7029",
      "markText": "基尔戈·特劳特曾经写过一篇小说，那是两个酵母之间的对话。它们在一边吃糖，一边被自己的排泄物窒息致死时，讨论生命的可能意义。由于它们智力有限，它们从来没有想到自己在制造香槟酒。",
      "totalCount": 170,
      "appLink": "weread://bestbookmark?bookId=3300067359&chapterUid=24&rangeStart=6942&rangeEnd=7029",
      "webLink": "https://weread.qq.com/web/reader/aaa328d0813ab80cfg019b50?chapterUid=24&rangeStart=6942&rangeEnd=7029"
    },
    {
      "bookmarkId": "3300067359_5_865-900",
      "chapterUid": 5,
      "range": "865-900",
      "markText": "她为夏末草帽大减价写了这么一则广告：“价廉至此，可给马戴，可铺花坛。”",
      "totalCount": 136,
      "appLink": "weread://bestbookmark?bookId=3300067359&chapterUid=5&rangeStart=865&rangeEnd=900",
      "webLink": "https://weread.qq.com/web/reader/aaa328d0813ab80cfg019b50?chapterUid=5&rangeStart=865&rangeEnd=900"
    },
    {
      "bookmarkId": "3300067359_13_2496-2543",
      "chapterUid": 13,
      "range": "2496-2543",
      "markText": "每一只气球系着一根吊带，下面悬着铁砣。夏威夷人因此可以继续住在岛上而双脚不用踏在别人的地产上。",
      "totalCount": 128,
      "appLink": "weread://bestbookmark?bookId=3300067359&chapterUid=13&rangeStart=2496&rangeEnd=2543",
      "webLink": "https://weread.qq.com/web/reader/aaa328d0813ab80cfg019b50?chapterUid=13&rangeStart=2496&rangeEnd=2543"
    },
    {
      "bookmarkId": "3300067359_5_3634-3666",
      "chapterUid": 5,
      "range": "3634-3666",
      "markText": "我的脑子里没有文化，没有人性的和谐。我不能再过没有文化的生活了。",
      "totalCount": 126,
      "appLink": "weread://bestbookmark?bookId=3300067359&chapterUid=5&rangeStart=3634&rangeEnd=3666",
      "webLink": "https://weread.qq.com/web/reader/aaa328d0813ab80cfg019b50?chapterUid=5&rangeStart=3634&rangeEnd=3666"
    },
    {
      "bookmarkId": "3300067359_6_5887-5901",
      "chapterUid": 6,
      "range": "5887-5901",
      "markText": "只有德韦恩·胡佛有自由意志。",
      "totalCount": 126,
      "appLink": "weread://bestbookmark?bookId=3300067359&chapterUid=6&rangeStart=5887&rangeEnd=5901",
      "webLink": "https://weread.qq.com/web/reader/aaa328d0813ab80cfg019b50?chapterUid=6&rangeStart=5887&rangeEnd=5901"
    },
    {
      "bookmarkId": "3300067359_7_534-595",
      "chapterUid": 7,
      "range": "534-595",
      "markText": "斯巴基不能摇尾巴，多年以前它出了车祸，因此它无法让别的狗知道它是多么友善。它不得不同它们不断打架，耳朵被咬破，全身是伤疤。",
      "totalCount": 119,
      "appLink": "weread://bestbookmark?bookId=3300067359&chapterUid=7&rangeStart=534&rangeEnd=595",
      "webLink": "https://weread.qq.com/web/reader/aaa328d0813ab80cfg019b50?chapterUid=7&rangeStart=534&rangeEnd=595"
    },
    {
      "bookmarkId": "3300067359_8_604-657",
