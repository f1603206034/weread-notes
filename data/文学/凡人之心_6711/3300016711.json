  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300016711_3_2899-2929",
      "chapterUid": 3,
      "range": "2899-2929",
      "markText": "我爱大海，可我只爱在海滩上看着它；我的双脚必须始终站在岸上。",
      "totalCount": 228,
      "appLink": "weread://bestbookmark?bookId=3300016711&chapterUid=3&rangeStart=2899&rangeEnd=2929",
      "webLink": "https://weread.qq.com/web/reader/b8732f10813ab6d07g011b88?chapterUid=3&rangeStart=2899&rangeEnd=2929"
    },
    {
      "bookmarkId": "3300016711_8_1543-1611",
      "chapterUid": 8,
      "range": "1543-1611",
      "markText": "一九四五年一月底，芙蕾雅发现自己怀孕了。两天后，在从幼儿园走回家的路上，她和史黛拉被一枚V-2火箭弹炸死。在爆炸中丧生的还有另外十三人。",
      "totalCount": 208,
      "appLink": "weread://bestbookmark?bookId=3300016711&chapterUid=8&rangeStart=1543&rangeEnd=1611",
      "webLink": "https://weread.qq.com/web/reader/b8732f10813ab6d07g011b88?chapterUid=8&rangeStart=1543&rangeEnd=1611"
    },
    {
      "bookmarkId": "3300016711_3_2200-2234",
      "chapterUid": 3,
      "range": "2200-2234",
      "markText": "我们写日记，是为了记录不同自我的集合——它构成了我们每一个不同的人。",
      "totalCount": 160,
      "appLink": "weread://bestbookmark?bookId=3300016711&chapterUid=3&rangeStart=2200&rangeEnd=2234",
      "webLink": "https://weread.qq.com/web/reader/b8732f10813ab6d07g011b88?chapterUid=3&rangeStart=2200&rangeEnd=2234"
    },
    {
      "bookmarkId": "3300016711_4_38208-38237",
      "chapterUid": 4,
      "range": "38208-38237",
      "markText": "天哪，我必须尽快开始真正的生活了，在我死于无聊和沮丧之前。",
      "totalCount": 144,
      "appLink": "weread://bestbookmark?bookId=3300016711&chapterUid=4&rangeStart=38208&rangeEnd=38237",
      "webLink": "https://weread.qq.com/web/reader/b8732f10813ab6d07g011b88?chapterUid=4&rangeStart=38208&rangeEnd=38237"
    },
    {
      "bookmarkId": "3300016711_4_1951-1984",
      "chapterUid": 4,
      "range": "1951-1984",
      "markText": "那天晚上在寝室，我在对露西的美好想象中手淫。本学期第一百二十七次。",
      "totalCount": 135,
      "appLink": "weread://bestbookmark?bookId=3300016711&chapterUid=4&rangeStart=1951&rangeEnd=1984",
      "webLink": "https://weread.qq.com/web/reader/b8732f10813ab6d07g011b88?chapterUid=4&rangeStart=1951&rangeEnd=1984"
    },
    {
      "bookmarkId": "3300016711_3_1934-1993",
      "chapterUid": 3,
      "range": "1934-1993",
      "markText": "我们生活中真的有些东西——有些所做、所感、所想——是我们不敢承认的吗？即便是对我们自己，即便是在绝对隐秘的私人日记中？",
      "totalCount": 130,
      "appLink": "weread://bestbookmark?bookId=3300016711&chapterUid=3&rangeStart=1934&rangeEnd=1993",
      "webLink": "https://weread.qq.com/web/reader/b8732f10813ab6d07g011b88?chapterUid=3&rangeStart=1934&rangeEnd=1993"
    },
    {
      "bookmarkId": "3300016711_3_2634-2669",
      "chapterUid": 3,
      "range": "2634-2669",
      "markText": "每个人的人生既平凡也不凡，是这两种类别各自的比例让人生显得有趣或无趣。",
      "totalCount": 126,
      "appLink": "weread://bestbookmark?bookId=3300016711&chapterUid=3&rangeStart=2634&rangeEnd=2669",
      "webLink": "https://weread.qq.com/web/reader/b8732f10813ab6d07g011b88?chapterUid=3&rangeStart=2634&rangeEnd=2669"
    },
    {
      "bookmarkId": "3300016711_4_4858-4913",
      "chapterUid": 4,
      "range": "4858-4913",
      "markText": "露西：没关系。我知道你现在在想这件事。我就是想让你知道，我永远不会嫁人的。永远。不会嫁给你，也不会嫁给任何人。",
      "totalCount": 126,
      "appLink": "weread://bestbookmark?bookId=3300016711&chapterUid=4&rangeStart=4858&rangeEnd=4913",
      "webLink": "https://weread.qq.com/web/reader/b8732f10813ab6d07g011b88?chapterUid=4&rangeStart=4858&rangeEnd=4913"
    },
    {
      "bookmarkId": "3300016711_11_20531-20612",
      "chapterUid": 11,
      "range": "20531-20612",
      "markText": "现在，我都去逛宠物食品的货架，比较各种价格和优惠商品。当我开始厌倦一种肉类后，我就换一种。通常我不会选牛肉——猪肝、鸡肉和兔肉是我的最爱。我的节俭已到了一定程度。",
      "totalCount": 126,
      "appLink": "weread://bestbookmark?bookId=3300016711&chapterUid=11&rangeStart=20531&rangeEnd=20612",
      "webLink": "https://weread.qq.com/web/reader/b8732f10813ab6d07g011b88?chapterUid=11&rangeStart=20531&rangeEnd=20612"
    },
    {
      "bookmarkId": "3300016711_6_33330-33406",
      "chapterUid": 6,
      "range": "33330-33406",
      "markText": "原来，没有明显的理由，人与人也会逐渐疏远：这是真的。我们都很忙，我们不可能把时间都用来保持联络。对友谊的考验就是要看它能否经受得住这些不可避免的间隔期。",
      "totalCount": 110,
      "appLink": "weread://bestbookmark?bookId=3300016711&chapterUid=6&rangeStart=33330&rangeEnd=33406",
      "webLink": "https://weread.qq.com/web/reader/b8732f10813ab6d07g011b88?chapterUid=6&rangeStart=33330&rangeEnd=33406"
    },
    {
      "bookmarkId": "3300016711_4_17232-17256",
      "chapterUid": 4,
      "range": "17232-17256",
      "markText": "我们为什么要把生命中宝贵的三年浪费在这种地方呢？",
      "totalCount": 102,
      "appLink": "weread://bestbookmark?bookId=3300016711&chapterUid=4&rangeStart=17232&rangeEnd=17256",
      "webLink": "https://weread.qq.com/web/reader/b8732f10813ab6d07g011b88?chapterUid=4&rangeStart=17232&rangeEnd=17256"
    },
    {
      "bookmarkId": "3300016711_4_7696-7755",
      "chapterUid": 4,
      "range": "7696-7755",
      "markText": "我敏锐地察觉到自己的弱点和缺陷，我感觉我需要露西的坚强来弥补——来帮助我茁壮成长，帮助我实现我知道自己能够实现的一切。",
      "totalCount": 85,
      "appLink": "weread://bestbookmark?bookId=3300016711&chapterUid=4&rangeStart=7696&rangeEnd=7755",
      "webLink": "https://weread.qq.com/web/reader/b8732f10813ab6d07g011b88?chapterUid=4&rangeStart=7696&rangeEnd=7755"
    },
    {
      "bookmarkId": "3300016711_12_9516-9582",
      "chapterUid": 12,
      "range": "9516-9582",
      "markText": "重读以前的日记让我既意外又震惊。我找不到昔日那个学生和今天的我之间的联系。我曾是个多么孤僻、多么惆怅、多么困惑的人。那不是我，是吗？",
      "totalCount": 85,
