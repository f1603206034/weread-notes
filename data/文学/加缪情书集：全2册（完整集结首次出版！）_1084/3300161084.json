  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300161084_5_973-1064",
      "chapterUid": 5,
      "range": "973-1064",
      "markText": "待到一九四四年十月，弗朗辛·富尔终于得以与丈夫团聚时，玛丽亚·卡萨雷斯与阿尔贝·加缪选择了分手。一九四八年六月六日，二人重逢于一次圣日耳曼大道上的偶遇。从此，他们再也没有离开过对方。",
      "totalCount": 765,
      "appLink": "weread://bestbookmark?bookId=3300161084&chapterUid=5&rangeStart=973&rangeEnd=1064",
      "webLink": "https://weread.qq.com/web/reader/b3332350813aba56cg014512?chapterUid=5&rangeStart=973&rangeEnd=1064"
    },
    {
      "bookmarkId": "3300161084_6_15375-15444",
      "chapterUid": 6,
      "range": "15375-15444",
      "markText": "你是给我写信了，没错——但你给我身边其他人也写了，写得一样多。你还（在信中）亲吻他们，叫他们的名字，就像你对我一样。所以说，区别在哪里呢？",
      "totalCount": 486,
      "appLink": "weread://bestbookmark?bookId=3300161084&chapterUid=6&rangeStart=15375&rangeEnd=15444",
      "webLink": "https://weread.qq.com/web/reader/b3332350813aba56cg014512?chapterUid=6&rangeStart=15375&rangeEnd=15444"
    },
    {
      "bookmarkId": "3300161084_5_2773-2824",
      "chapterUid": 5,
      "range": "2773-2824",
      "markText": "不论我们在工作和生活中需要做些什么，总归不会是独自一人去做，总有一种旁人感知不到的存在陪伴在我们身边。",
      "totalCount": 459,
      "appLink": "weread://bestbookmark?bookId=3300161084&chapterUid=5&rangeStart=2773&rangeEnd=2824",
      "webLink": "https://weread.qq.com/web/reader/b3332350813aba56cg014512?chapterUid=5&rangeStart=2773&rangeEnd=2824"
    },
    {
      "bookmarkId": "3300161084_6_2773-2800",
      "chapterUid": 6,
      "range": "2773-2800",
      "markText": "晚安，我亲爱的。好好睡一觉，要用力想我。吻你直到天明。",
      "totalCount": 420,
      "appLink": "weread://bestbookmark?bookId=3300161084&chapterUid=6&rangeStart=2773&rangeEnd=2800",
      "webLink": "https://weread.qq.com/web/reader/b3332350813aba56cg014512?chapterUid=6&rangeStart=2773&rangeEnd=2800"
    },
    {
      "bookmarkId": "3300161084_6_3333-3402",
      "chapterUid": 6,
      "range": "3333-3402",
      "markText": "谁有一颗心，谁就会容易把让人失望的东西称作清醒，把妨碍人的东西叫作现实。可这种清醒也是盲目短视的。世上只有一种远见，那就是追求幸福的远见。",
      "totalCount": 405,
      "appLink": "weread://bestbookmark?bookId=3300161084&chapterUid=6&rangeStart=3333&rangeEnd=3402",
      "webLink": "https://weread.qq.com/web/reader/b3332350813aba56cg014512?chapterUid=6&rangeStart=3333&rangeEnd=3402"
    },
    {
      "bookmarkId": "3300161084_5_388-415",
      "chapterUid": 5,
      "range": "388-415",
      "markText": "纵然有种种苦痛，终有一日，我们能轻盈、快乐，彼此坦诚。",
      "totalCount": 400,
      "appLink": "weread://bestbookmark?bookId=3300161084&chapterUid=5&rangeStart=388&rangeEnd=415",
      "webLink": "https://weread.qq.com/web/reader/b3332350813aba56cg014512?chapterUid=5&rangeStart=388&rangeEnd=415"
    },
    {
      "bookmarkId": "3300161084_6_10879-10933",
      "chapterUid": 6,
      "range": "10879-10933",
      "markText": "直到现在你爱的都是我身上最好的一面。或许这还不能叫作爱。或许只有当你也爱我的软弱和缺陷的时候，你才真正爱我。",
      "totalCount": 392,
      "appLink": "weread://bestbookmark?bookId=3300161084&chapterUid=6&rangeStart=10879&rangeEnd=10933",
      "webLink": "https://weread.qq.com/web/reader/b3332350813aba56cg014512?chapterUid=6&rangeStart=10879&rangeEnd=10933"
    },
    {
      "bookmarkId": "3300161084_5_1907-1969",
      "chapterUid": 5,
      "range": "1907-1969",
      "markText": "她像海洋一样澎湃，破碎成浪花，就重新聚形，以惊人的生命力再次出发。她以同等的强度经历幸运与厄运，全然且深刻地将自己交付其中。",
      "totalCount": 320,
      "appLink": "weread://bestbookmark?bookId=3300161084&chapterUid=5&rangeStart=1907&rangeEnd=1969",
      "webLink": "https://weread.qq.com/web/reader/b3332350813aba56cg014512?chapterUid=5&rangeStart=1907&rangeEnd=1969"
    },
    {
      "bookmarkId": "3300161084_3_582-598",
      "chapterUid": 3,
      "range": "582-598",
      "markText": "周二见，到时候我们一切重新开始！",
      "totalCount": 286,
      "appLink": "weread://bestbookmark?bookId=3300161084&chapterUid=3&rangeStart=582&rangeEnd=598",
      "webLink": "https://weread.qq.com/web/reader/b3332350813aba56cg014512?chapterUid=3&rangeStart=582&rangeEnd=598"
    },
    {
      "bookmarkId": "3300161084_6_9345-9380",
      "chapterUid": 6,
      "range": "9345-9380",
      "markText": "我爱你的方式有很多，但尤其爱你被幸福照亮的脸，那生命的光彩总让我感动。",
      "totalCount": 260,
      "appLink": "weread://bestbookmark?bookId=3300161084&chapterUid=6&rangeStart=9345&rangeEnd=9380",
      "webLink": "https://weread.qq.com/web/reader/b3332350813aba56cg014512?chapterUid=6&rangeStart=9345&rangeEnd=9380"
    },
    {
      "bookmarkId": "3300161084_6_13936-14018",
      "chapterUid": 6,
      "range": "13936-14018",
      "markText": "我可以对你说，设想一下，万一我出了什么事，我们会多遗憾——让这么多日子白白溜走。这个时代有太多不确定，看不到明天。此刻流逝的分分秒秒，将会成为我们流着泪的愤懑回忆。",
