  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "38818247_3_4254-4308",
      "chapterUid": 3,
      "range": "4254-4308",
      "markText": "生命是短暂的，浪费时间是犯罪。我一天天地浪费时间，人们却说我很勤劳。今天，是一次休息，我的心朝着它自己走去。",
      "totalCount": 1665,
      "appLink": "weread://bestbookmark?bookId=38818247&chapterUid=3&rangeStart=4254&rangeEnd=4308",
      "webLink": "https://weread.qq.com/web/reader/cf2320d0725051c7cf2ae1d?chapterUid=3&rangeStart=4254&rangeEnd=4308"
    },
    {
      "bookmarkId": "38818247_3_2599-2678",
      "chapterUid": 3,
      "range": "2599-2678",
      "markText": "在东方，一条蓝色的带子，轻淡、透明。不能直视。对于眼睛和灵魂来说，它的出现是一种折磨。因为美是难以容忍的。它使我们绝望，我们希望一瞬即为永恒，拉长全部的时间。",
      "totalCount": 1464,
      "appLink": "weread://bestbookmark?bookId=38818247&chapterUid=3&rangeStart=2599&rangeEnd=2678",
      "webLink": "https://weread.qq.com/web/reader/cf2320d0725051c7cf2ae1d?chapterUid=3&rangeStart=2599&rangeEnd=2678"
    },
    {
      "bookmarkId": "38818247_3_2453-2513",
      "chapterUid": 3,
      "range": "2453-2513",
      "markText": "她狂热地希望不是一个人孤独地死去——要拖着她最亲密的朋友和她一起死。她要一个人死了。她要以一种最可怕的仇恨培育她的友谊。",
      "totalCount": 1392,
      "appLink": "weread://bestbookmark?bookId=38818247&chapterUid=3&rangeStart=2453&rangeEnd=2513",
      "webLink": "https://weread.qq.com/web/reader/cf2320d0725051c7cf2ae1d?chapterUid=3&rangeStart=2453&rangeEnd=2513"
    },
    {
      "bookmarkId": "38818247_3_8965-8974",
      "chapterUid": 3,
      "range": "8965-8974",
      "markText": "我的快乐没有尽头。",
      "totalCount": 1386,
      "appLink": "weread://bestbookmark?bookId=38818247&chapterUid=3&rangeStart=8965&rangeEnd=8974",
      "webLink": "https://weread.qq.com/web/reader/cf2320d0725051c7cf2ae1d?chapterUid=3&rangeStart=8965&rangeEnd=8974"
    },
    {
      "bookmarkId": "38818247_3_17183-17198",
      "chapterUid": 3,
      "range": "17183-17198",
      "markText": "需要正确，这是庸俗的人的标志。",
      "totalCount": 1254,
      "appLink": "weread://bestbookmark?bookId=38818247&chapterUid=3&rangeStart=17183&rangeEnd=17198",
      "webLink": "https://weread.qq.com/web/reader/cf2320d0725051c7cf2ae1d?chapterUid=3&rangeStart=17183&rangeEnd=17198"
    },
    {
      "bookmarkId": "38818247_3_1659-1706",
      "chapterUid": 3,
      "range": "1659-1706",
      "markText": "我们总是看不起自己。贫穷，疾病，孤独：我们意识到我们的不朽。“必须将我们逼到退无可退的程度。”",
      "totalCount": 1170,
      "appLink": "weread://bestbookmark?bookId=38818247&chapterUid=3&rangeStart=1659&rangeEnd=1706",
      "webLink": "https://weread.qq.com/web/reader/cf2320d0725051c7cf2ae1d?chapterUid=3&rangeStart=1659&rangeEnd=1706"
    },
    {
      "bookmarkId": "38818247_3_957-1036",
      "chapterUid": 3,
      "range": "957-1036",
      "markText": "正是在这种贫穷的生活中，在这些卑微的或虚荣的人中，我最稳妥地抓住我觉得“是”的生活的真实意义。艺术作品是不够的。对我来说，艺术并非一切。至少，艺术是一种手段。",
      "totalCount": 1080,
      "appLink": "weread://bestbookmark?bookId=38818247&chapterUid=3&rangeStart=957&rangeEnd=1036",
      "webLink": "https://weread.qq.com/web/reader/cf2320d0725051c7cf2ae1d?chapterUid=3&rangeStart=957&rangeEnd=1036"
    },
    {
      "bookmarkId": "38818247_3_7856-7875",
      "chapterUid": 3,
      "range": "7856-7875",
      "markText": "死亡给予游戏和英雄主义以其真正的意义。",
      "totalCount": 1067,
      "appLink": "weread://bestbookmark?bookId=38818247&chapterUid=3&rangeStart=7856&rangeEnd=7875",
      "webLink": "https://weread.qq.com/web/reader/cf2320d0725051c7cf2ae1d?chapterUid=3&rangeStart=7856&rangeEnd=7875"
    },
    {
      "bookmarkId": "38818247_3_8794-8835",
      "chapterUid": 3,
      "range": "8794-8835",
      "markText": "青年时代一年年过得如此漫长，就是因为很充实，老年的日子如此短暂，就是因为循规蹈矩。",
      "totalCount": 1054,
      "appLink": "weread://bestbookmark?bookId=38818247&chapterUid=3&rangeStart=8794&rangeEnd=8835",
      "webLink": "https://weread.qq.com/web/reader/cf2320d0725051c7cf2ae1d?chapterUid=3&rangeStart=8794&rangeEnd=8835"
    },
    {
      "bookmarkId": "38818247_3_12236-12335",
      "chapterUid": 3,
      "range": "12236-12335",
      "markText": "不要脱离世界。当人们把生命置于光明之中的时候，是不会虚度光阴的。在所有的处境、不幸、失望中，我全部的努力在于重新接触世界。甚至在我的这种悲伤中有如此爱的欲望，如此只需在夜风中看到山丘就会感到的沉醉。",
      "totalCount": 1032,
      "appLink": "weread://bestbookmark?bookId=38818247&chapterUid=3&rangeStart=12236&rangeEnd=12335",
      "webLink": "https://weread.qq.com/web/reader/cf2320d0725051c7cf2ae1d?chapterUid=3&rangeStart=12236&rangeEnd=12335"
    },
    {
      "bookmarkId": "38818247_4_9490-9512",
      "chapterUid": 4,
      "range": "9490-9512",
      "markText": "我们没有时间成为我们自己。我们只有时间幸福。",
      "totalCount": 1008,
      "appLink": "weread://bestbookmark?bookId=38818247&chapterUid=4&rangeStart=9490&rangeEnd=9512",
      "webLink": "https://weread.qq.com/web/reader/cf2320d0725051c7cf2ae1d?chapterUid=4&rangeStart=9490&rangeEnd=9512"
    },
    {
      "bookmarkId": "38818247_3_19473-19501",
      "chapterUid": 3,
      "range": "19473-19501",
      "markText": "哲学的价值取决于哲学家的价值。人越是伟大，哲学越是真实。",
      "totalCount": 990,
      "appLink": "weread://bestbookmark?bookId=38818247&chapterUid=3&rangeStart=19473&rangeEnd=19501",
      "webLink": "https://weread.qq.com/web/reader/cf2320d0725051c7cf2ae1d?chapterUid=3&rangeStart=19473&rangeEnd=19501"
    },
    {
      "bookmarkId": "38818247_3_1813-1861",
      "chapterUid": 3,
      "range": "1813-1861",
      "markText": "经验这个词的虚妄。经验是不可实验的。不能引起它。而是遭受它。经验不如忍耐。我们忍耐——我们受难。",
      "totalCount": 946,
      "appLink": "weread://bestbookmark?bookId=38818247&chapterUid=3&rangeStart=1813&rangeEnd=1861",
      "webLink": "https://weread.qq.com/web/reader/cf2320d0725051c7cf2ae1d?chapterUid=3&rangeStart=1813&rangeEnd=1861"
    },
    {
      "bookmarkId": "38818247_3_4986-5013",
      "chapterUid": 3,
      "range": "4986-5013",
      "markText": "人们只通过形象来思考。如果你想当哲学家，那就写小说吧。",
      "totalCount": 918,
      "appLink": "weread://bestbookmark?bookId=38818247&chapterUid=3&rangeStart=4986&rangeEnd=5013",
      "webLink": "https://weread.qq.com/web/reader/cf2320d0725051c7cf2ae1d?chapterUid=3&rangeStart=4986&rangeEnd=5013"
    },
    {
      "bookmarkId": "38818247_4_17534-17601",
      "chapterUid": 4,
      "range": "17534-17601",
      "markText": "这个世界的灾难与伟大：它绝不贡献真理，只贡献爱。 荒诞统治世界，而爱拯救之。",
      "totalCount": 901,
      "appLink": "weread://bestbookmark?bookId=38818247&chapterUid=4&rangeStart=17534&rangeEnd=17601",
      "webLink": "https://weread.qq.com/web/reader/cf2320d0725051c7cf2ae1d?chapterUid=4&rangeStart=17534&rangeEnd=17601"
    },
    {
      "bookmarkId": "38818247_4_25622-25686",
      "chapterUid": 4,
      "range": "25622-25686",
      "markText": "小夫妻在火车上。两位都丑。她靠着他，笑着，卖俏，诱惑着他。他呢，眼睛半死不活，不习惯一个他并不引以为荣的女人在所有人的面前爱他。",
      "totalCount": 882,
      "appLink": "weread://bestbookmark?bookId=38818247&chapterUid=4&rangeStart=25622&rangeEnd=25686",
      "webLink": "https://weread.qq.com/web/reader/cf2320d0725051c7cf2ae1d?chapterUid=4&rangeStart=25622&rangeEnd=25686"
    },
    {
      "bookmarkId": "38818247_3_835-885",
      "chapterUid": 3,
      "range": "835-885",
      "markText": "对于这些富人来说，天空是额外的，就好像一种自然的馈赠。对于穷人，天空无限慈悲的性质就在他身上释放了。",
      "totalCount": 770,
      "appLink": "weread://bestbookmark?bookId=38818247&chapterUid=3&rangeStart=835&rangeEnd=885",
      "webLink": "https://weread.qq.com/web/reader/cf2320d0725051c7cf2ae1d?chapterUid=3&rangeStart=835&rangeEnd=885"
    },
    {
      "bookmarkId": "38818247_3_14278-14318",
      "chapterUid": 3,
      "range": "14278-14318",
      "markText": "如果人们确信他的绝望，他就应该像怀有希望一样地行动——或自杀。痛苦不会带来权利。",
      "totalCount": 765,
      "appLink": "weread://bestbookmark?bookId=38818247&chapterUid=3&rangeStart=14278&rangeEnd=14318",
      "webLink": "https://weread.qq.com/web/reader/cf2320d0725051c7cf2ae1d?chapterUid=3&rangeStart=14278&rangeEnd=14318"
    },
    {
      "bookmarkId": "38818247_3_18579-18640",
      "chapterUid": 3,
      "range": "18579-18640",
      "markText": "年轻的时候，我们钟情于一片风景更甚于一个人。 因为前者需要阐释。",
      "totalCount": 731,
      "appLink": "weread://bestbookmark?bookId=38818247&chapterUid=3&rangeStart=18579&rangeEnd=18640",
      "webLink": "https://weread.qq.com/web/reader/cf2320d0725051c7cf2ae1d?chapterUid=3&rangeStart=18579&rangeEnd=18640"
    },
    {
      "bookmarkId": "38818247_4_4184-4264",
      "chapterUid": 4,
      "range": "4184-4264",
      "markText": "有价值或没有价值。创造或不创造。在第一种情况下，一切都是正确的。一切，没有例外。在第二种情况下，就是完全的荒诞。剩下的就是选择最美的自杀：婚姻+朝九晚五或手枪。",
      "totalCount": 728,
      "appLink": "weread://bestbookmark?bookId=38818247&chapterUid=4&rangeStart=4184&rangeEnd=4264",
      "webLink": "https://weread.qq.com/web/reader/cf2320d0725051c7cf2ae1d?chapterUid=4&rangeStart=4184&rangeEnd=4264"
