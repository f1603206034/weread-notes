  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "41128964_2_779-850",
      "chapterUid": 2,
      "range": "779-850",
      "markText": "建国以来的历史教训深刻地说明，情况一顺利就容易头脑发热，形势一好转就容易胡乱折腾，办事情、想问题，习惯于带政治运动色彩，这是一个顽固的老毛病。",
      "totalCount": 224,
      "appLink": "weread://bestbookmark?bookId=41128964&chapterUid=2&rangeStart=779&rangeEnd=850",
      "webLink": "https://weread.qq.com/web/reader/a3c322d072739404a3c2570?chapterUid=2&rangeStart=779&rangeEnd=850"
    },
    {
      "bookmarkId": "41128964_1_2889-2941",
      "chapterUid": 1,
      "range": "2889-2941",
      "markText": "文章是思想认识的载体。客观事物在不断变化，人的认识也有一个过程，认识总有一定的局限性，文章自然也不例外。",
      "totalCount": 182,
      "appLink": "weread://bestbookmark?bookId=41128964&chapterUid=1&rangeStart=2889&rangeEnd=2941",
      "webLink": "https://weread.qq.com/web/reader/a3c322d072739404a3c2570?chapterUid=1&rangeStart=2889&rangeEnd=2941"
    },
    {
      "bookmarkId": "41128964_1_2343-2441",
      "chapterUid": 1,
      "range": "2343-2441",
      "markText": "对我来说，从来没有无用的时间，包括零碎时间。每次睡觉以前，我总是要想一个题目，总怕早睡着了。碰到大的难的问题，不是趴在桌上想，而是躺在床上想。我的若干篇讲话、文章的提纲，几乎都是躺在床上想出来的。",
      "totalCount": 169,
      "appLink": "weread://bestbookmark?bookId=41128964&chapterUid=1&rangeStart=2343&rangeEnd=2441",
      "webLink": "https://weread.qq.com/web/reader/a3c322d072739404a3c2570?chapterUid=1&rangeStart=2343&rangeEnd=2441"
    },
    {
      "bookmarkId": "41128964_1_2811-2836",
      "chapterUid": 1,
      "range": "2811-2836",
      "markText": "成绩是大家共同努力的结果，不足不管大小都和我有关。",
      "totalCount": 169,
      "appLink": "weread://bestbookmark?bookId=41128964&chapterUid=1&rangeStart=2811&rangeEnd=2836",
      "webLink": "https://weread.qq.com/web/reader/a3c322d072739404a3c2570?chapterUid=1&rangeStart=2811&rangeEnd=2836"
    },
    {
      "bookmarkId": "41128964_1_1625-1682",
      "chapterUid": 1,
      "range": "1625-1682",
      "markText": "夜里，母亲还是把我找回去了，她拉着我的手，掉着眼泪说，妈妈知道你喜欢书，喜欢书是好事，可是咱们家哪有钱给你买书呀？",
      "totalCount": 120,
      "appLink": "weread://bestbookmark?bookId=41128964&chapterUid=1&rangeStart=1625&rangeEnd=1682",
      "webLink": "https://weread.qq.com/web/reader/a3c322d072739404a3c2570?chapterUid=1&rangeStart=1625&rangeEnd=1682"
    },
    {
      "bookmarkId": "41128964_1_1024-1044",
      "chapterUid": 1,
      "range": "1024-1044",
      "markText": "地位高高，贡献小小，责任重大，常感不安。",
      "totalCount": 119,
      "appLink": "weread://bestbookmark?bookId=41128964&chapterUid=1&rangeStart=1024&rangeEnd=1044",
      "webLink": "https://weread.qq.com/web/reader/a3c322d072739404a3c2570?chapterUid=1&rangeStart=1024&rangeEnd=1044"
    },
    {
      "bookmarkId": "41128964_1_2988-3039",
      "chapterUid": 1,
      "range": "2988-3039",
      "markText": "但有一点我感到欣慰，我的所有讲话、文章，都是从工作出发的，都是经过自己认真思考的，都是本人亲自动手的。",
      "totalCount": 117,
      "appLink": "weread://bestbookmark?bookId=41128964&chapterUid=1&rangeStart=2988&rangeEnd=3039",
      "webLink": "https://weread.qq.com/web/reader/a3c322d072739404a3c2570?chapterUid=1&rangeStart=2988&rangeEnd=3039"
    },
    {
      "bookmarkId": "41128964_2_1468-1529",
      "chapterUid": 2,
      "range": "1468-1529",
      "markText": "真想快，就必须按客观规律办事，稳步前进，不能急于求成，盲目行动，草率决策，操切从事。否则，只能是欲速则不达，想快反而更慢。",
      "totalCount": 105,
      "appLink": "weread://bestbookmark?bookId=41128964&chapterUid=2&rangeStart=1468&rangeEnd=1529",
      "webLink": "https://weread.qq.com/web/reader/a3c322d072739404a3c2570?chapterUid=2&rangeStart=1468&rangeEnd=1529"
    },
    {
      "bookmarkId": "41128964_1_337-427",
      "chapterUid": 1,
      "range": "337-427",
      "markText": "17岁时，我到北京做小工。一次偶然的机会，我去给木工班扫刨花，当时有个木工工长，名叫王锡田，他说我很灵巧，让我学木匠。我就这样从一个普通的木匠开始，一步步成长为党和国家的领导干部。",
      "totalCount": 102,
      "appLink": "weread://bestbookmark?bookId=41128964&chapterUid=1&rangeStart=337&rangeEnd=427",
      "webLink": "https://weread.qq.com/web/reader/a3c322d072739404a3c2570?chapterUid=1&rangeStart=337&rangeEnd=427"
    },
    {
      "bookmarkId": "41128964_2_1828-1859",
      "chapterUid": 2,
      "range": "1828-1859",
      "markText": "稳定与协调密不可分，稳定必须协调，协调才能稳定，稳定就是协调。",
      "totalCount": 98,
      "appLink": "weread://bestbookmark?bookId=41128964&chapterUid=2&rangeStart=1828&rangeEnd=1859",
      "webLink": "https://weread.qq.com/web/reader/a3c322d072739404a3c2570?chapterUid=2&rangeStart=1828&rangeEnd=1859"
    },
    {
      "bookmarkId": "41128964_1_2441-2495",
      "chapterUid": 1,
      "range": "2441-2495",
      "markText": "我这一生为学习吃的苦实在太多，我确实很累，需要休息，需要轻轻松松地读一点自己想读的书。这是我长久以来的愿望。",
      "totalCount": 96,
      "appLink": "weread://bestbookmark?bookId=41128964&chapterUid=1&rangeStart=2441&rangeEnd=2495",
      "webLink": "https://weread.qq.com/web/reader/a3c322d072739404a3c2570?chapterUid=1&rangeStart=2441&rangeEnd=2495"
    },
    {
      "bookmarkId": "41128964_2_15297-15336",
      "chapterUid": 2,
      "range": "15297-15336",
      "markText": "实践、总结，再实践、再总结，这既是我国改革发展的过程，也是我们认识深化的过程。",
      "totalCount": 96,
      "appLink": "weread://bestbookmark?bookId=41128964&chapterUid=2&rangeStart=15297&rangeEnd=15336",
      "webLink": "https://weread.qq.com/web/reader/a3c322d072739404a3c2570?chapterUid=2&rangeStart=15297&rangeEnd=15336"
    },
    {
      "bookmarkId": "41128964_1_3138-3185",
      "chapterUid": 1,
      "range": "3138-3185",
      "markText": "我没有和哪个人特别的近，也没有和哪个人特别的远；没有和哪个人特别的亲，也没有和哪个人特别的疏。",
      "totalCount": 88,
      "appLink": "weread://bestbookmark?bookId=41128964&chapterUid=1&rangeStart=3138&rangeEnd=3185",
      "webLink": "https://weread.qq.com/web/reader/a3c322d072739404a3c2570?chapterUid=1&rangeStart=3138&rangeEnd=3185"
    },
    {
      "bookmarkId": "41128964_2_526-547",
      "chapterUid": 2,
      "range": "526-547",
      "markText": "稳定发展的方针，是正确把握和驾驭形势的方针",
      "totalCount": 85,
      "appLink": "weread://bestbookmark?bookId=41128964&chapterUid=2&rangeStart=526&rangeEnd=547",
      "webLink": "https://weread.qq.com/web/reader/a3c322d072739404a3c2570?chapterUid=2&rangeStart=526&rangeEnd=547"
    },
    {
      "bookmarkId": "41128964_5_12764-12822",
      "chapterUid": 5,
      "range": "12764-12822",
      "markText": "高明的领导之所以高明，主要不在于他的脑袋比别人聪明，而在于他善于综合，善于概括，善于汲取更多人的实践经验和聪明才智。",
      "totalCount": 85,
      "appLink": "weread://bestbookmark?bookId=41128964&chapterUid=5&rangeStart=12764&rangeEnd=12822",
      "webLink": "https://weread.qq.com/web/reader/a3c322d072739404a3c2570?chapterUid=5&rangeStart=12764&rangeEnd=12822"
    },
    {
      "bookmarkId": "41128964_1_1985-2036",
      "chapterUid": 1,
      "range": "1985-2036",
      "markText": "我的初中、高中和大学的课程，我的文化知识、建筑专业知识和社会科学理论知识，几乎都是利用业余时间自学的。",
      "totalCount": 84,
      "appLink": "weread://bestbookmark?bookId=41128964&chapterUid=1&rangeStart=1985&rangeEnd=2036",
      "webLink": "https://weread.qq.com/web/reader/a3c322d072739404a3c2570?chapterUid=1&rangeStart=1985&rangeEnd=2036"
    },
    {
      "bookmarkId": "41128964_2_1055-1111",
      "chapterUid": 2,
      "range": "1055-1111",
      "markText": "保持稳定发展，并不是轻而易举的事情，而必须做大量艰苦细致的工作，决不可以慢慢腾腾、拖拖拉拉、散散漫漫、冷冷清清。",
      "totalCount": 75,
      "appLink": "weread://bestbookmark?bookId=41128964&chapterUid=2&rangeStart=1055&rangeEnd=1111",
      "webLink": "https://weread.qq.com/web/reader/a3c322d072739404a3c2570?chapterUid=2&rangeStart=1055&rangeEnd=1111"
    },
    {
      "bookmarkId": "41128964_7_7373-7457",
