  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300065808_5_573-899",
      "chapterUid": 5,
      "range": "573-899",
      "markText": "日出而作，日入而息； 凿井而饮，耕田而食。 帝力于我何有哉！",
      "totalCount": 638,
      "appLink": "weread://bestbookmark?bookId=3300065808&chapterUid=5&rangeStart=573&rangeEnd=899",
      "webLink": "https://weread.qq.com/web/reader/1a532a50813ab8034g0181c4?chapterUid=5&rangeStart=573&rangeEnd=899"
    },
    {
      "bookmarkId": "3300065808_7_2939-2983",
      "chapterUid": 7,
      "range": "2939-2983",
      "markText": "当然，从二人的思想认知与行为来看，其违背历史发展潮流的观点与自杀殉道的做法都是不足取的。",
      "totalCount": 320,
      "appLink": "weread://bestbookmark?bookId=3300065808&chapterUid=7&rangeStart=2939&rangeEnd=2983",
      "webLink": "https://weread.qq.com/web/reader/1a532a50813ab8034g0181c4?chapterUid=7&rangeStart=2939&rangeEnd=2983"
    },
    {
      "bookmarkId": "3300065808_6_512-823",
      "chapterUid": 6,
      "range": "512-823",
      "markText": "唐尧作戒自警曰： 颤颤栗栗，日谨一日。 人莫踬于山，而踬于垤。",
      "totalCount": 299,
      "appLink": "weread://bestbookmark?bookId=3300065808&chapterUid=6&rangeStart=512&rangeEnd=823",
      "webLink": "https://weread.qq.com/web/reader/1a532a50813ab8034g0181c4?chapterUid=6&rangeStart=512&rangeEnd=823"
    },
    {
      "bookmarkId": "3300065808_13_435-955",
      "chapterUid": 13,
      "range": "435-955",
      "markText": "上邪！我欲与君相知，长命无绝衰。 山无陵，江水为竭； 冬雷震震，夏雨雪； 天地合，乃敢与君绝！",
      "totalCount": 196,
      "appLink": "weread://bestbookmark?bookId=3300065808&chapterUid=13&rangeStart=435&rangeEnd=955",
      "webLink": "https://weread.qq.com/web/reader/1a532a50813ab8034g0181c4?chapterUid=13&rangeStart=435&rangeEnd=955"
    },
    {
      "bookmarkId": "3300065808_10_436-878",
      "chapterUid": 10,
      "range": "436-878",
      "markText": "风萧萧兮易水寒，壮士一去兮不复还。 探虎穴兮入蛟宫，仰天呼气兮成白虹。",
      "totalCount": 168,
      "appLink": "weread://bestbookmark?bookId=3300065808&chapterUid=10&rangeStart=436&rangeEnd=878",
      "webLink": "https://weread.qq.com/web/reader/1a532a50813ab8034g0181c4?chapterUid=10&rangeStart=436&rangeEnd=878"
    },
    {
      "bookmarkId": "3300065808_5_1809-1851",
      "chapterUid": 5,
      "range": "1809-1851",
      "markText": "《击壤歌》当为中国歌谣之祖，无具体作者，大约流传于距今4000多年前的原始社会时期。",
      "totalCount": 144,
      "appLink": "weread://bestbookmark?bookId=3300065808&chapterUid=5&rangeStart=1809&rangeEnd=1851",
      "webLink": "https://weread.qq.com/web/reader/1a532a50813ab8034g0181c4?chapterUid=5&rangeStart=1809&rangeEnd=1851"
    },
    {
      "bookmarkId": "3300065808_14_3989-4077",
      "chapterUid": 14,
      "range": "3989-4077",
      "markText": "卓文君用自己的智慧挽回了丈夫的背弃。她用心经营着自己的爱情和婚姻，终于苦尽甘来。他们之间最终没有背弃最初的爱恋和最后的坚守，这也使得他们的故事千转百回，成为流传千古的爱情佳话。",
      "totalCount": 130,
      "appLink": "weread://bestbookmark?bookId=3300065808&chapterUid=14&rangeStart=3989&rangeEnd=4077",
      "webLink": "https://weread.qq.com/web/reader/1a532a50813ab8034g0181c4?chapterUid=14&rangeStart=3989&rangeEnd=4077"
    },
    {
      "bookmarkId": "3300065808_6_1404-1456",
      "chapterUid": 6,
      "range": "1404-1456",
      "markText": "要治理好一方水土，管理好臣民，就要谨慎处理好任何一件小事，不要等其积成大祸后才引起重视，到那时候已经晚了",
      "totalCount": 128,
      "appLink": "weread://bestbookmark?bookId=3300065808&chapterUid=6&rangeStart=1404&rangeEnd=1456",
      "webLink": "https://weread.qq.com/web/reader/1a532a50813ab8034g0181c4?chapterUid=6&rangeStart=1404&rangeEnd=1456"
    },
    {
      "bookmarkId": "3300065808_5_354-505",
      "chapterUid": 5,
      "range": "354-505",
      "markText": "击壤歌——歌谣之祖，天下太和",
