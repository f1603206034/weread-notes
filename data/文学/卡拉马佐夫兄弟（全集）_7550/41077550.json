          "appLink": "weread://bestbookmark?bookId=41077550&chapterUid=5&rangeStart=20262&rangeEnd=20582",
          "webLink": "https://weread.qq.com/web/reader/4a0328f07272cb2e4a0e1b2?chapterUid=5&rangeStart=20262&rangeEnd=20582"
        },
