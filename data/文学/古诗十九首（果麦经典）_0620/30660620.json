      "appLink": "weread://bestbookmark?bookId=30660620&chapterUid=4&rangeStart=1605&rangeEnd=1645",
      "webLink": "https://weread.qq.com/web/reader/e5c32bd071d3d80ce5c7d1e?chapterUid=4&rangeStart=1605&rangeEnd=1645"
    },
    {
