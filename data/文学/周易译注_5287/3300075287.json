  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300075287_4_2223-2279",
      "chapterUid": 4,
      "range": "2223-2279",
      "markText": "八卦各有不同的名称、形式，分别是：乾（☰）、坤（☷）、震（☳）、巽（☴）、坎（☵）、离（☲）、艮（☶）、兑（☱）",
      "totalCount": 180,
      "appLink": "weread://bestbookmark?bookId=3300075287&chapterUid=4&rangeStart=2223&rangeEnd=2279",
      "webLink": "https://weread.qq.com/web/reader/85832ec0813ab83e8g0173ff?chapterUid=4&rangeStart=2223&rangeEnd=2279"
    },
    {
      "bookmarkId": "3300075287_6_3663-3835",
      "chapterUid": 6,
      "range": "3663-3835",
      "markText": "九四，或跃在渊，无咎。",
      "totalCount": 136,
      "appLink": "weread://bestbookmark?bookId=3300075287&chapterUid=6&rangeStart=3663&rangeEnd=3835",
      "webLink": "https://weread.qq.com/web/reader/85832ec0813ab83e8g0173ff?chapterUid=6&rangeStart=3663&rangeEnd=3835"
    },
    {
      "bookmarkId": "3300075287_6_2094-2370",
      "chapterUid": 6,
      "range": "2094-2370",
      "markText": "九二，见龙在田，利见大人。",
      "totalCount": 128,
      "appLink": "weread://bestbookmark?bookId=3300075287&chapterUid=6&rangeStart=2094&rangeEnd=2370",
      "webLink": "https://weread.qq.com/web/reader/85832ec0813ab83e8g0173ff?chapterUid=6&rangeStart=2094&rangeEnd=2370"
    },
    {
      "bookmarkId": "3300075287_4_1221-1263",
      "chapterUid": 4,
      "range": "1221-1263",
      "markText": "《周易》“经”部分的创作过程经历三大阶段：阴阳概念的产生、八卦创立、重卦并撰成卦爻辞",
      "totalCount": 126,
      "appLink": "weread://bestbookmark?bookId=3300075287&chapterUid=4&rangeStart=1221&rangeEnd=1263",
      "webLink": "https://weread.qq.com/web/reader/85832ec0813ab83e8g0173ff?chapterUid=4&rangeStart=1221&rangeEnd=1263"
    },
    {
      "bookmarkId": "3300075287_20_657-982",
      "chapterUid": 20,
      "range": "657-982",
      "markText": "谦：亨，君子有终。",
      "totalCount": 126,
      "appLink": "weread://bestbookmark?bookId=3300075287&chapterUid=20&rangeStart=657&rangeEnd=982",
      "webLink": "https://weread.qq.com/web/reader/85832ec0813ab83e8g0173ff?chapterUid=20&rangeStart=657&rangeEnd=982"
    },
    {
      "bookmarkId": "3300075287_4_2518-2585",
      "chapterUid": 4,
      "range": "2518-2585",
      "markText": "古者包牺氏之王天下也，仰则观象于天，俯则观法于地，观鸟兽之文，与地之宜，近取诸身，远取诸物，于是始作八卦，以通神明之德，以类万物之情。",
      "totalCount": 121,
      "appLink": "weread://bestbookmark?bookId=3300075287&chapterUid=4&rangeStart=2518&rangeEnd=2585",
      "webLink": "https://weread.qq.com/web/reader/85832ec0813ab83e8g0173ff?chapterUid=4&rangeStart=2518&rangeEnd=2585"
    },
    {
      "bookmarkId": "3300075287_6_5779-5869",
      "chapterUid": 6,
      "range": "5779-5869",
      "markText": "王弼释“用九”，指出“以刚健而居人之首，则物之所不与”（《王注》），是直接应用《老子》“后其身而身先”及“贵以贱为本”的观点。有合《易》理，并与《象传》“天德不可为首”的说法相符。",
      "totalCount": 119,
      "appLink": "weread://bestbookmark?bookId=3300075287&chapterUid=6&rangeStart=5779&rangeEnd=5869",
      "webLink": "https://weread.qq.com/web/reader/85832ec0813ab83e8g0173ff?chapterUid=6&rangeStart=5779&rangeEnd=5869"
    },
    {
      "bookmarkId": "3300075287_4_2321-2346",
      "chapterUid": 4,
      "range": "2321-2346",
      "markText": "这八种基本物质是：天、地、雷、风、水、火、山、泽。",
      "totalCount": 112,
      "appLink": "weread://bestbookmark?bookId=3300075287&chapterUid=4&rangeStart=2321&rangeEnd=2346",
      "webLink": "https://weread.qq.com/web/reader/85832ec0813ab83e8g0173ff?chapterUid=4&rangeStart=2321&rangeEnd=2346"
    },
    {
      "bookmarkId": "3300075287_6_4179-4395",
      "chapterUid": 6,
      "range": "4179-4395",
      "markText": "九五，飞龙在天，利见大人。",
      "totalCount": 110,
      "appLink": "weread://bestbookmark?bookId=3300075287&chapterUid=6&rangeStart=4179&rangeEnd=4395",
      "webLink": "https://weread.qq.com/web/reader/85832ec0813ab83e8g0173ff?chapterUid=6&rangeStart=4179&rangeEnd=4395"
    },
    {
      "bookmarkId": "3300075287_6_4626-4633",
      "chapterUid": 6,
      "range": "4626-4633",
