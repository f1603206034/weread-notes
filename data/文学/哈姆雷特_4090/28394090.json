  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "28394090_31_597-682",
      "chapterUid": 31,
      "range": "597-682",
      "markText": "我们所要做的事，应当一想到就做。 因为人的想法是会变化的，有多少舌头、多少手、多少意外，就会有多少犹豫、多少延迟。",
      "totalCount": 11362,
      "appLink": "weread://bestbookmark?bookId=28394090&chapterUid=31&rangeStart=597&rangeEnd=682",
      "webLink": "https://weread.qq.com/web/reader/a2f3260071b1426aa2f592a?chapterUid=31&rangeStart=597&rangeEnd=682"
    },
    {
      "bookmarkId": "28394090_43_2550-2620",
      "chapterUid": 43,
      "range": "2550-2620",
      "markText": "生存还是毁灭，这是一个值得考虑的问题。默然忍受命运的暴虐的毒箭，或是挺身反抗人世的无涯的苦难，通过斗争把它们扫清，这两种行为，哪一种更勇敢？",
      "totalCount": 6272,
      "appLink": "weread://bestbookmark?bookId=28394090&chapterUid=43&rangeStart=2550&rangeEnd=2620",
      "webLink": "https://weread.qq.com/web/reader/a2f3260071b1426aa2f592a?chapterUid=43&rangeStart=2550&rangeEnd=2620"
    },
    {
      "bookmarkId": "28394090_36_3682-3767",
      "chapterUid": 36,
      "range": "3682-3767",
      "markText": "嗯，这些都是捕捉愚蠢的山鹬的圈套。我知道在热情燃烧的时候，一个人无论什么盟誓都能说出口来。这些火焰，女儿，是光多于热的，刚刚说出口就会光消焰灭，你不能把它们当作真火看待。",
      "totalCount": 4068,
      "appLink": "weread://bestbookmark?bookId=28394090&chapterUid=36&rangeStart=3682&rangeEnd=3767",
      "webLink": "https://weread.qq.com/web/reader/a2f3260071b1426aa2f592a?chapterUid=36&rangeStart=3682&rangeEnd=3767"
    },
    {
      "bookmarkId": "28394090_43_2146-2186",
      "chapterUid": 43,
      "range": "2146-2186",
      "markText": "人们往往用至诚的外表和虔敬的行动，掩饰一颗魔鬼般的内心，这样的例子实在是太多了。",
      "totalCount": 3855,
      "appLink": "weread://bestbookmark?bookId=28394090&chapterUid=43&rangeStart=2146&rangeEnd=2186",
      "webLink": "https://weread.qq.com/web/reader/a2f3260071b1426aa2f592a?chapterUid=43&rangeStart=2146&rangeEnd=2186"
    },
    {
      "bookmarkId": "28394090_37_1456-1481",
      "chapterUid": 37,
      "range": "1456-1481",
      "markText": "少量的邪恶足以勾销全部高贵的品质，害得人声名狼藉。",
      "totalCount": 3542,
      "appLink": "weread://bestbookmark?bookId=28394090&chapterUid=37&rangeStart=1456&rangeEnd=1481",
      "webLink": "https://weread.qq.com/web/reader/a2f3260071b1426aa2f592a?chapterUid=37&rangeStart=1456&rangeEnd=1481"
    },
    {
      "bookmarkId": "28394090_51_2103-2144",
      "chapterUid": 51,
      "range": "2103-2144",
      "markText": "一个人要是把生活的幸福和目的，只看作吃吃睡睡，他还算是个什么东西？简直是一头畜生！",
      "totalCount": 3417,
      "appLink": "weread://bestbookmark?bookId=28394090&chapterUid=51&rangeStart=2103&rangeEnd=2144",
      "webLink": "https://weread.qq.com/web/reader/a2f3260071b1426aa2f592a?chapterUid=51&rangeStart=2103&rangeEnd=2144"
    },
    {
      "bookmarkId": "28394090_50_1522-1584",
      "chapterUid": 50,
      "range": "1522-1584",
      "markText": "我们喂肥了各种牲畜给自己受用，再喂肥了自己去给蛆虫受用。胖胖的国王跟瘦瘦的乞丐是一张桌子上两道不同的菜——不过是这么一回事。",
      "totalCount": 3408,
      "appLink": "weread://bestbookmark?bookId=28394090&chapterUid=50&rangeStart=1522&rangeEnd=1584",
      "webLink": "https://weread.qq.com/web/reader/a2f3260071b1426aa2f592a?chapterUid=50&rangeStart=1522&rangeEnd=1584"
    },
    {
      "bookmarkId": "28394090_35_3840-3853",
      "chapterUid": 35,
      "range": "3840-3853",
      "markText": "脆弱啊，你的名字就是女人！",
