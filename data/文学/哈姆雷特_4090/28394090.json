      "appLink": "weread://bestbookmark?bookId=28394090&chapterUid=35&rangeStart=3840&rangeEnd=3853",
      "webLink": "https://weread.qq.com/web/reader/a2f3260071b1426aa2f592a?chapterUid=35&rangeStart=3840&rangeEnd=3853"
