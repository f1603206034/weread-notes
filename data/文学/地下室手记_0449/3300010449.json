  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300010449_5_385-438",
      "chapterUid": 5,
      "range": "385-438",
      "markText": "“人是一个奥秘。应该解开它，如果你毕生都在解开它，那你不要说损失了时间；我在研究这个奥秘，因为我想做人。”",
      "totalCount": 360,
      "appLink": "weread://bestbookmark?bookId=3300010449&chapterUid=5&rangeStart=385&rangeEnd=438",
      "webLink": "https://weread.qq.com/web/reader/7e232910813ab6a94g019d02?chapterUid=5&rangeStart=385&rangeEnd=438"
    },
    {
      "bookmarkId": "3300010449_10_567-588",
      "chapterUid": 10,
      "range": "567-588",
      "markText": "我受过足够的教育能让我不迷信，可我还是迷信",
      "totalCount": 308,
      "appLink": "weread://bestbookmark?bookId=3300010449&chapterUid=10&rangeStart=567&rangeEnd=588",
      "webLink": "https://weread.qq.com/web/reader/7e232910813ab6a94g019d02?chapterUid=10&rangeStart=567&rangeEnd=588"
    },
    {
      "bookmarkId": "3300010449_19_1107-1181",
      "chapterUid": 19,
      "range": "1107-1181",
      "markText": "也许你们会说，不值得同我打交道；若是这样，我也可以用同样的话回敬你们。我们在严肃地谈论，而你们却不愿理睬我，那我也不会卑躬屈膝的。我有自己的地下室。",
      "totalCount": 260,
      "appLink": "weread://bestbookmark?bookId=3300010449&chapterUid=19&rangeStart=1107&rangeEnd=1181",
      "webLink": "https://weread.qq.com/web/reader/7e232910813ab6a94g019d02?chapterUid=19&rangeStart=1107&rangeEnd=1181"
    },
    {
      "bookmarkId": "3300010449_10_829-928",
      "chapterUid": 10,
      "range": "829-928",
      "markText": "也许，单凭这一点，我就该奖励自己。（一句蹩脚的俏皮话，可我却不打算将它抹去。我把这句话写了出来，认为它一定会是非常好笑的；而此刻，我自己也已看出来了，我不过是在卑鄙地炫耀自己——可我偏不将它抹去！）",
      "totalCount": 225,
      "appLink": "weread://bestbookmark?bookId=3300010449&chapterUid=10&rangeStart=829&rangeEnd=928",
      "webLink": "https://weread.qq.com/web/reader/7e232910813ab6a94g019d02?chapterUid=10&rangeStart=829&rangeEnd=928"
    },
    {
      "bookmarkId": "3300010449_10_1717-1755",
      "chapterUid": 10,
      "range": "1717-1755",
      "markText": "一个聪明人是无法真的成为一种什么样的人的，而能成为一种什么样的人的只有傻瓜。",
