  "content": [
    {
      "chapterUid": 16,
      "chapterTitle": "七",
      "items": [
        {
          "type": "highlight",
          "bookmarkId": "3300010449_16_2436-2486",
          "range": "2436-2486",
          "rangeStart": 2436,
          "rangeEnd": 2486,
          "markText": "人过分热衷于体系和抽象的结论，就会甘愿有意歪曲真理，甘愿视而不见、充耳不闻，而一味地为自己的逻辑辩护",
          "colorStyle": 2,
          "colorLabel": "",
          "createTime": 1730939426,
          "createTimeFormatted": "2024-11-07 08:30:26",
          "chapterUid": 16,
          "appLink": "weread://bestbookmark?bookId=3300010449&chapterUid=16&rangeStart=2436&rangeEnd=2486",
          "webLink": "https://weread.qq.com/web/reader/7e232910813ab6a94g019d02?chapterUid=16&rangeStart=2436&rangeEnd=2486"
