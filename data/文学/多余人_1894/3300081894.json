  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300081894_13_5977-6021",
      "chapterUid": 13,
      "range": "5977-6021",
      "markText": "“我才不管呢。我都不想正眼看你或劳伦斯一眼。你们两个人肯定爱上了对方，你们都给我滚开。”",
      "totalCount": 368,
      "appLink": "weread://bestbookmark?bookId=3300081894&chapterUid=13&rangeStart=5977&rangeEnd=6021",
      "webLink": "https://weread.qq.com/web/reader/720320b0813ab867dg014a16?chapterUid=13&rangeStart=5977&rangeEnd=6021"
    },
    {
      "bookmarkId": "3300081894_5_376-417",
      "chapterUid": 5,
      "range": "376-417",
      "markText": "第一次见到他时，我就想：他在这里待不长的。",
      "totalCount": 288,
      "appLink": "weread://bestbookmark?bookId=3300081894&chapterUid=5&rangeStart=376&rangeEnd=417",
      "webLink": "https://weread.qq.com/web/reader/720320b0813ab867dg014a16?chapterUid=5&rangeStart=376&rangeEnd=417"
    },
    {
      "bookmarkId": "3300081894_5_2544-2619",
      "chapterUid": 5,
      "range": "2544-2619",
      "markText": "我让他一个人待着，自己先回到了办公室。他感到震惊，心情沮丧。我感同身受，初来乍到的时候自己也有这种感觉：你满怀希望而来，现实却呈现给你完全不同的东西。",
      "totalCount": 252,
      "appLink": "weread://bestbookmark?bookId=3300081894&chapterUid=5&rangeStart=2544&rangeEnd=2619",
      "webLink": "https://weread.qq.com/web/reader/720320b0813ab867dg014a16?chapterUid=5&rangeStart=2544&rangeEnd=2619"
    },
    {
      "bookmarkId": "3300081894_12_376-443",
      "chapterUid": 12,
      "range": "376-443",
      "markText": "一切如旧。这里的日子就是这样的。日复一日，每天都是同样的目标，同样平庸的夙愿。我早已习惯。我想让一切都一成不变，在原地扎根，永远如此。",
      "totalCount": 168,
      "appLink": "weread://bestbookmark?bookId=3300081894&chapterUid=12&rangeStart=376&rangeEnd=443",
      "webLink": "https://weread.qq.com/web/reader/720320b0813ab867dg014a16?chapterUid=12&rangeStart=376&rangeEnd=443"
    },
    {
      "bookmarkId": "3300081894_8_8926-8947",
      "chapterUid": 8,
      "range": "8926-8947",
      "markText": "不过从另一个角度看，这让我对他越发怨恨了。",
      "totalCount": 165,
      "appLink": "weread://bestbookmark?bookId=3300081894&chapterUid=8&rangeStart=8926&rangeEnd=8947",
      "webLink": "https://weread.qq.com/web/reader/720320b0813ab867dg014a16?chapterUid=8&rangeStart=8926&rangeEnd=8947"
    },
    {
      "bookmarkId": "3300081894_6_4505-4595",
      "chapterUid": 6,
      "range": "4505-4595",
      "markText": "劳伦斯站在那里，喜笑颜开，满怀期待，眼睛闪闪发光，很显然他认为终于有事可做了。他的报到、等待、和我闲聊，所有这些事都只是为此准备的。他已经见到了院长，他的人生将会被赋予责任和意义。",
      "totalCount": 160,
      "appLink": "weread://bestbookmark?bookId=3300081894&chapterUid=6&rangeStart=4505&rangeEnd=4595",
      "webLink": "https://weread.qq.com/web/reader/720320b0813ab867dg014a16?chapterUid=6&rangeStart=4505&rangeEnd=4595"
    },
    {
      "bookmarkId": "3300081894_9_3340-3390",
      "chapterUid": 9,
      "range": "3340-3390",
      "markText": "他就是这样的人。人生的一切皆由宏伟蓝图设计而成。他恍然大悟的那一刻是反复演练过的、讲给自己听的故事。",
      "totalCount": 160,
      "appLink": "weread://bestbookmark?bookId=3300081894&chapterUid=9&rangeStart=3340&rangeEnd=3390",
      "webLink": "https://weread.qq.com/web/reader/720320b0813ab867dg014a16?chapterUid=9&rangeStart=3340&rangeEnd=3390"
    },
    {
      "bookmarkId": "3300081894_14_510-567",
      "chapterUid": 14,
      "range": "510-567",
      "markText": "当晚我感受到的是对他产生了一种违背常情的亲近感，仿佛达成了一项协议，仿佛我和他之间签订了合同，而她则是其中的工具。",
      "totalCount": 156,
      "appLink": "weread://bestbookmark?bookId=3300081894&chapterUid=14&rangeStart=510&rangeEnd=567",
      "webLink": "https://weread.qq.com/web/reader/720320b0813ab867dg014a16?chapterUid=14&rangeStart=510&rangeEnd=567"
    },
    {
      "bookmarkId": "3300081894_15_12194-12232",
      "chapterUid": 15,
      "range": "12194-12232",
      "markText": "凯伦和我都没有特别突出的才能，这并不重要。我们的生活可以因为金钱而变得突出。",
      "totalCount": 156,
      "appLink": "weread://bestbookmark?bookId=3300081894&chapterUid=15&rangeStart=12194&rangeEnd=12232",
      "webLink": "https://weread.qq.com/web/reader/720320b0813ab867dg014a16?chapterUid=15&rangeStart=12194&rangeEnd=12232"
    },
    {
      "bookmarkId": "3300081894_8_8041-8077",
      "chapterUid": 8,
      "range": "8041-8077",
      "markText": "“我想，我要和他们不一样。我要去最小的地方，最偏远的地方。我要去吃苦。”",
      "totalCount": 153,
      "appLink": "weread://bestbookmark?bookId=3300081894&chapterUid=8&rangeStart=8041&rangeEnd=8077",
      "webLink": "https://weread.qq.com/web/reader/720320b0813ab867dg014a16?chapterUid=8&rangeStart=8041&rangeEnd=8077"
    },
    {
      "bookmarkId": "3300081894_10_10368-10569",
      "chapterUid": 10,
      "range": "10368-10569",
      "markText": "我的苦楚只持续了几天。第二天早上我就尝试着去埋葬它：结果不会有什么不同。你别无选择。你只是回答了他的问题",
      "totalCount": 153,
      "appLink": "weread://bestbookmark?bookId=3300081894&chapterUid=10&rangeStart=10368&rangeEnd=10569",
      "webLink": "https://weread.qq.com/web/reader/720320b0813ab867dg014a16?chapterUid=10&rangeStart=10368&rangeEnd=10569"
    },
    {
      "bookmarkId": "3300081894_6_3863-3900",
      "chapterUid": 6,
      "range": "3863-3900",
      "markText": "我生命中的多少岁月，都染上咖啡因的酸腐味，在这间房子里被一点一点吮吸尽了。",
      "totalCount": 144,
      "appLink": "weread://bestbookmark?bookId=3300081894&chapterUid=6&rangeStart=3863&rangeEnd=3900",
      "webLink": "https://weread.qq.com/web/reader/720320b0813ab867dg014a16?chapterUid=6&rangeStart=3863&rangeEnd=3900"
    },
    {
      "bookmarkId": "3300081894_10_9821-9885",
      "chapterUid": 10,
      "range": "9821-9885",
      "markText": "这些问题荒唐至极，它们衡量并定义了一个黑白颠倒的世界，而医生是来这里治愈和补救的，不是沦为这种对精神与肉体的精心摧残行为的帮凶。",
      "totalCount": 144,
      "appLink": "weread://bestbookmark?bookId=3300081894&chapterUid=10&rangeStart=9821&rangeEnd=9885",
      "webLink": "https://weread.qq.com/web/reader/720320b0813ab867dg014a16?chapterUid=10&rangeStart=9821&rangeEnd=9885"
    },
    {
      "bookmarkId": "3300081894_12_13895-13914",
      "chapterUid": 12,
      "range": "13895-13914",
      "markText": "地板上有一些污渍，永远也不可能擦干净。",
      "totalCount": 143,
