  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300125194_5_2044-2068",
      "chapterUid": 5,
      "range": "2044-2068",
      "markText": "耻辱本身就是一种用于迫使受压迫者闭嘴的政治工具。",
      "totalCount": 680,
      "appLink": "weread://bestbookmark?bookId=3300125194&chapterUid=5&rangeStart=2044&rangeEnd=2068",
      "webLink": "https://weread.qq.com/web/reader/8cd32cd0813ab9767g014f3b?chapterUid=5&rangeStart=2044&rangeEnd=2068"
    },
    {
      "bookmarkId": "3300125194_12_13031-13069",
      "chapterUid": 12,
      "range": "13031-13069",
      "markText": "一旦你把这种思想内化为你自己的想法，你便意识不到这件事其实是别人希望你做的。",
      "totalCount": 288,
      "appLink": "weread://bestbookmark?bookId=3300125194&chapterUid=12&rangeStart=13031&rangeEnd=13069",
      "webLink": "https://weread.qq.com/web/reader/8cd32cd0813ab9767g014f3b?chapterUid=12&rangeStart=13031&rangeEnd=13069"
    },
    {
      "bookmarkId": "3300125194_8_6917-6989",
      "chapterUid": 8,
      "range": "6917-6989",
      "markText": "她在选择吃或不吃某种食物时，似乎总是花了很大的心思。随着时间的推移，我认识到这些选择是在表达一种独立选择的能力，是对巨大权力结构的微小反叛行为。",
      "totalCount": 272,
      "appLink": "weread://bestbookmark?bookId=3300125194&chapterUid=8&rangeStart=6917&rangeEnd=6989",
      "webLink": "https://weread.qq.com/web/reader/8cd32cd0813ab9767g014f3b?chapterUid=8&rangeStart=6917&rangeEnd=6989"
    },
    {
      "bookmarkId": "3300125194_12_4595-4657",
      "chapterUid": 12,
      "range": "4595-4657",
      "markText": "如果她自己没能得到更多，那么她就想确保我能得到。我用了一生才弄懂：我的成功可能证明了她的价值，我接受教育等于她的第二次机会。",
      "totalCount": 272,
      "appLink": "weread://bestbookmark?bookId=3300125194&chapterUid=12&rangeStart=4595&rangeEnd=4657",
      "webLink": "https://weread.qq.com/web/reader/8cd32cd0813ab9767g014f3b?chapterUid=12&rangeStart=4595&rangeEnd=4657"
    },
    {
      "bookmarkId": "3300125194_5_4002-4098",
      "chapterUid": 5,
      "range": "4002-4098",
      "markText": "这两位出生于匈牙利的精神分析学家曾对纳粹大屠杀幸存者的成年子女进行研究，此概念指出，一代人无法言说的创伤，会变成幽灵留存在下一代的潜意识中。困扰人们的并非创伤本身，而是人们对创伤所秉持的沉默。",
      "totalCount": 255,
      "appLink": "weread://bestbookmark?bookId=3300125194&chapterUid=5&rangeStart=4002&rangeEnd=4098",
      "webLink": "https://weread.qq.com/web/reader/8cd32cd0813ab9767g014f3b?chapterUid=5&rangeStart=4002&rangeEnd=4098"
    },
    {
      "bookmarkId": "3300125194_25_9854-9896",
      "chapterUid": 25,
      "range": "9854-9896",
      "markText": "“妈妈，你想想看，等下次我来看你时，就是春天了。”我说，“到时候就是芝士汉堡季了。”",
      "totalCount": 252,
      "appLink": "weread://bestbookmark?bookId=3300125194&chapterUid=25&rangeStart=9854&rangeEnd=9896",
      "webLink": "https://weread.qq.com/web/reader/8cd32cd0813ab9767g014f3b?chapterUid=25&rangeStart=9854&rangeEnd=9896"
    },
    {
      "bookmarkId": "3300125194_10_4849-4873",
      "chapterUid": 10,
      "range": "4849-4873",
      "markText": "珍妮成了我最好的朋友，我应对未来冲击的精神盔甲。",
      "totalCount": 224,
      "appLink": "weread://bestbookmark?bookId=3300125194&chapterUid=10&rangeStart=4849&rangeEnd=4873",
      "webLink": "https://weread.qq.com/web/reader/8cd32cd0813ab9767g014f3b?chapterUid=10&rangeStart=4849&rangeEnd=4873"
    },
    {
      "bookmarkId": "3300125194_14_6033-6094",
      "chapterUid": 14,
      "range": "6033-6094",
      "markText": "但母亲没有被吓到。她给自己买了一把.38特种转轮手枪，好让那些猎人知道她在这片游戏场地已经一马平川。任何东西都无法阻拦她。",
      "totalCount": 220,
      "appLink": "weread://bestbookmark?bookId=3300125194&chapterUid=14&rangeStart=6033&rangeEnd=6094",
      "webLink": "https://weread.qq.com/web/reader/8cd32cd0813ab9767g014f3b?chapterUid=14&rangeStart=6033&rangeEnd=6094"
    },
    {
      "bookmarkId": "3300125194_7_2242-2518",
      "chapterUid": 7,
      "range": "2242-2518",
      "markText": "说话时，我们害怕 话语无人听见， 也不受欢迎。 但沉默时， 我们依然害怕。 所以还是发声吧， 记住 生存从来不是天注定。",
      "totalCount": 204,
      "appLink": "weread://bestbookmark?bookId=3300125194&chapterUid=7&rangeStart=2242&rangeEnd=2518",
      "webLink": "https://weread.qq.com/web/reader/8cd32cd0813ab9767g014f3b?chapterUid=7&rangeStart=2242&rangeEnd=2518"
    },
    {
      "bookmarkId": "3300125194_5_1656-1737",
      "chapterUid": 5,
      "range": "1656-1737",
      "markText": "我之所以会选择理论，是因为我很痛苦——我内心的痛苦太强烈，甚至到了我无法继续生存的地步。我在绝望中选择了求助于理论，希望能够理解——弄懂我周围及内心所发生的事……",
      "totalCount": 192,
      "appLink": "weread://bestbookmark?bookId=3300125194&chapterUid=5&rangeStart=1656&rangeEnd=1737",
      "webLink": "https://weread.qq.com/web/reader/8cd32cd0813ab9767g014f3b?chapterUid=5&rangeStart=1656&rangeEnd=1737"
    },
    {
      "bookmarkId": "3300125194_9_10324-10408",
