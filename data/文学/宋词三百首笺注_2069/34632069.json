  "hotBookmarks": [
    {
      "bookmarkId": "34632069_13_5757-5778",
      "chapterUid": 13,
      "range": "5757-5778",
      "markText": "今年花胜去年红，可惜明年花更好，知与谁同？",
      "totalCount": 98,
      "appLink": "weread://bestbookmark?bookId=34632069&chapterUid=13&rangeStart=5757&rangeEnd=5778",
      "webLink": "https://weread.qq.com/web/reader/603329c072107185603119f?chapterUid=13&rangeStart=5757&rangeEnd=5778"
    },
    {
      "bookmarkId": "34632069_39_1610-1690",
      "chapterUid": 39,
      "range": "1610-1690",
      "markText": "子瞻“与谁同坐？明月清风我”，“明月几时有？把酒问青天”，快语也；“大江东去，浪淘尽千古风流人物”，壮语也；“杏花疏影里，吹笛到天明”，爽语也。此词在浓与淡之间",
      "totalCount": 70,
      "appLink": "weread://bestbookmark?bookId=34632069&chapterUid=39&rangeStart=1610&rangeEnd=1690",
      "webLink": "https://weread.qq.com/web/reader/603329c072107185603119f?chapterUid=39&rangeStart=1610&rangeEnd=1690"
    },
    {
      "bookmarkId": "34632069_13_3257-3325",
      "chapterUid": 13,
      "range": "3257-3325",
      "markText": "杨慎云：一句中连三字者，如“夜夜夜深闻子规”，又“日日日斜空醉归”，又“更更更漏月明中”，又“树树树梢啼晓莺”，皆用叠字也。（《词品》）",
      "totalCount": 65,
      "appLink": "weread://bestbookmark?bookId=34632069&chapterUid=13&rangeStart=3257&rangeEnd=3325",
      "webLink": "https://weread.qq.com/web/reader/603329c072107185603119f?chapterUid=13&rangeStart=3257&rangeEnd=3325"
    },
    {
      "bookmarkId": "34632069_8_581-799",
      "chapterUid": 8,
      "range": "581-799",
      "markText": "碧云天，黄叶地，秋色连波，波上寒烟翠。山映斜阳天接水，芳草无情，更在斜阳外。　　黯[1]乡魂，追旅思[2]，夜夜除非，好梦留人睡。明月楼高休独倚，酒入愁肠，化作相思泪。",
      "totalCount": 60,
      "appLink": "weread://bestbookmark?bookId=34632069&chapterUid=8&rangeStart=581&rangeEnd=799",
      "webLink": "https://weread.qq.com/web/reader/603329c072107185603119f?chapterUid=8&rangeStart=581&rangeEnd=799"
    },
    {
      "bookmarkId": "34632069_9_2300-2312",
      "chapterUid": 9,
      "range": "2300-2312",
      "markText": "昨日乱山昏，来时衣上云。",
      "totalCount": 60,
      "appLink": "weread://bestbookmark?bookId=34632069&chapterUid=9&rangeStart=2300&rangeEnd=2312",
      "webLink": "https://weread.qq.com/web/reader/603329c072107185603119f?chapterUid=9&rangeStart=2300&rangeEnd=2312"
    },
    {
      "bookmarkId": "34632069_10_2629-2731",
      "chapterUid": 10,
      "range": "2629-2731",
      "markText": "闻琴解佩[5]神仙侣，挽断罗衣留不住。劝君莫作独醒人，烂醉花间应有数。",
      "totalCount": 60,
      "appLink": "weread://bestbookmark?bookId=34632069&chapterUid=10&rangeStart=2629&rangeEnd=2731",
      "webLink": "https://weread.qq.com/web/reader/603329c072107185603119f?chapterUid=10&rangeStart=2629&rangeEnd=2731"
    },
    {
      "bookmarkId": "34632069_13_6198-6361",
      "chapterUid": 13,
      "range": "6198-6361",
      "markText": "买花载酒长安市，又争似[20]家山[21]见桃李？",
      "totalCount": 54,
      "appLink": "weread://bestbookmark?bookId=34632069&chapterUid=13&rangeStart=6198&rangeEnd=6361",
      "webLink": "https://weread.qq.com/web/reader/603329c072107185603119f?chapterUid=13&rangeStart=6198&rangeEnd=6361"
    },
    {
      "bookmarkId": "34632069_69_3261-3350",
      "chapterUid": 69,
      "range": "3261-3350",
