      "appLink": "weread://bestbookmark?bookId=855754&chapterUid=58&rangeStart=3277&rangeEnd=3309",
      "webLink": "https://weread.qq.com/web/reader/8b5325005d0eca8b53fcf90?chapterUid=58&rangeStart=3277&rangeEnd=3309"
