    {
      "bookmarkId": "855754_72_1081-1137",
      "chapterUid": 72,
      "range": "1081-1137",
      "markText": "她深深体会到有些宝贵的东西是无法用金钱买到的——爱、平安、健康和真正的人生幸福，自己以前能拥有这一切是多么富足。",
      "totalCount": 2044,
      "appLink": "weread://bestbookmark?bookId=855754&chapterUid=72&rangeStart=1081&rangeEnd=1137",
      "webLink": "https://weread.qq.com/web/reader/8b5325005d0eca8b53fcf90?chapterUid=72&rangeStart=1081&rangeEnd=1137"
