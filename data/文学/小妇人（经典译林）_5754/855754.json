      "appLink": "weread://bestbookmark?bookId=855754&chapterUid=90&rangeStart=10509&rangeEnd=10539",
      "webLink": "https://weread.qq.com/web/reader/8b5325005d0eca8b53fcf90?chapterUid=90&rangeStart=10509&rangeEnd=10539"
