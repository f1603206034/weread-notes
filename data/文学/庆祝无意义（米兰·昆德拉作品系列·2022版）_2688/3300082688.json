    },
    {
      "bookmarkId": "3300082688_4_1092-1139",
      "chapterUid": 4,
      "range": "1092-1139",
      "markText": "但是怎样定义一个男人（或者一个时代）的情色，当他（或它）在人体中央肚脐上看到女人的诱惑中心呢？",
      "totalCount": 672,
      "appLink": "weread://bestbookmark?bookId=3300082688&chapterUid=4&rangeStart=1092&rangeEnd=1139",
