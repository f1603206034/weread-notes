      "appLink": "weread://bestbookmark?bookId=3300082688&chapterUid=5&rangeStart=949&rangeEnd=987",
      "webLink": "https://weread.qq.com/web/reader/dbe32a40813ab86ccg018ae7?chapterUid=5&rangeStart=949&rangeEnd=987"
