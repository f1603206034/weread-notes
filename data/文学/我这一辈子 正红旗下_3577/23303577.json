  "hotBookmarks": [
    {
      "bookmarkId": "23303577_4_991-1024",
      "chapterUid": 4,
      "range": "991-1024",
      "markText": "学手艺，一辈子逃不出手艺人去，即使能大发财源，也高不过大官儿不是？",
