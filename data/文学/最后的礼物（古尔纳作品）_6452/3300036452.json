      "totalCount": 225,
      "appLink": "weread://bestbookmark?bookId=3300036452&chapterUid=4&rangeStart=42678&rangeEnd=42778",
      "webLink": "https://weread.qq.com/web/reader/f6932fe0813ab74bdg012e98?chapterUid=4&rangeStart=42678&rangeEnd=42778"
