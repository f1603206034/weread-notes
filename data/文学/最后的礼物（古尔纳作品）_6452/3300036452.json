      "appLink": "weread://bestbookmark?bookId=3300036452&chapterUid=4&rangeStart=1357&rangeEnd=1428",
      "webLink": "https://weread.qq.com/web/reader/f6932fe0813ab74bdg012e98?chapterUid=4&rangeStart=1357&rangeEnd=1428"
    },
    {
      "bookmarkId": "3300036452_4_1595-1619",
      "chapterUid": 4,
      "range": "1595-1619",
      "markText": "他从来都不知道心痛何时会来，从何而来，要待多久。",
