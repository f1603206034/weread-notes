  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300047443_46_3726-3764",
      "chapterUid": 46,
      "range": "3726-3764",
      "markText": "“女人可以原谅男人对她的伤害，”他说，“但是永远不能原谅他对她做出的牺牲。”",
      "totalCount": 480,
      "appLink": "weread://bestbookmark?bookId=3300047443&chapterUid=46&rangeStart=3726&rangeEnd=3764",
      "webLink": "https://weread.qq.com/web/reader/6e332740813ab7908g0131ea?chapterUid=46&rangeStart=3726&rangeEnd=3764"
    },
    {
      "bookmarkId": "3300047443_16_748-803",
      "chapterUid": 16,
      "range": "748-803",
      "markText": "我那时还不了解人性多么矛盾，我不知道真挚中含有多少做作，高尚中蕴藏着多少卑鄙，或者，即使在邪恶里也找得着美德。",
      "totalCount": 450,
      "appLink": "weread://bestbookmark?bookId=3300047443&chapterUid=16&rangeStart=748&rangeEnd=803",
      "webLink": "https://weread.qq.com/web/reader/6e332740813ab7908g0131ea?chapterUid=16&rangeStart=748&rangeEnd=803"
    },
    {
      "bookmarkId": "3300047443_4_2554-2579",
      "chapterUid": 4,
      "range": "2554-2579",
      "markText": "让我们都去追求一个崇高的理想，而鄙弃六便士银币吧！",
      "totalCount": 360,
      "appLink": "weread://bestbookmark?bookId=3300047443&chapterUid=4&rangeStart=2554&rangeEnd=2579",
      "webLink": "https://weread.qq.com/web/reader/6e332740813ab7908g0131ea?chapterUid=4&rangeStart=2554&rangeEnd=2579"
    },
    {
      "bookmarkId": "3300047443_22_1834-1905",
      "chapterUid": 22,
      "range": "1834-1905",
      "markText": "有人说灾难不幸可以使人性高贵，这句话并不对；叫人做出高尚行动的有时候反而是幸福得意，灾难不幸在大多数情况下只能使人们变得心胸狭小、报复心更强。",
      "totalCount": 352,
      "appLink": "weread://bestbookmark?bookId=3300047443&chapterUid=22&rangeStart=1834&rangeEnd=1905",
      "webLink": "https://weread.qq.com/web/reader/6e332740813ab7908g0131ea?chapterUid=22&rangeStart=1834&rangeEnd=1905"
    },
    {
      "bookmarkId": "3300047443_20_4939-5018",
      "chapterUid": 20,
      "range": "4939-5018",
      "markText": "女人们总是喜欢在她们所爱的人临终前表现得宽宏大量，她们的这种偏好叫我实在难以忍受。有时候我甚至觉得她们不愿意男人寿命太长，就是怕把演出这幕好戏的机会拖得太晚。",
      "totalCount": 315,
      "appLink": "weread://bestbookmark?bookId=3300047443&chapterUid=20&rangeStart=4939&rangeEnd=5018",
      "webLink": "https://weread.qq.com/web/reader/6e332740813ab7908g0131ea?chapterUid=20&rangeStart=4939&rangeEnd=5018"
    },
    {
      "bookmarkId": "3300047443_63_5053-5093",
      "chapterUid": 63,
      "range": "5053-5093",
      "markText": "魔鬼要干坏事总可以引证《圣经》。他一直忘不了一个先令就可以买十三只大牡蛎的日子。",
      "totalCount": 289,
      "appLink": "weread://bestbookmark?bookId=3300047443&chapterUid=63&rangeStart=5053&rangeEnd=5093",
      "webLink": "https://weread.qq.com/web/reader/6e332740813ab7908g0131ea?chapterUid=63&rangeStart=5053&rangeEnd=5093"
    },
    {
      "bookmarkId": "3300047443_48_5235-5270",
      "chapterUid": 48,
      "range": "5235-5270",
      "markText": "思特里克兰德是个惹人嫌的人，但是尽管如此，我还是认为他是一个伟大的人。",
      "totalCount": 288,
      "appLink": "weread://bestbookmark?bookId=3300047443&chapterUid=48&rangeStart=5235&rangeEnd=5270",
      "webLink": "https://weread.qq.com/web/reader/6e332740813ab7908g0131ea?chapterUid=48&rangeStart=5235&rangeEnd=5270"
    },
    {
      "bookmarkId": "3300047443_11_1043-1079",
      "chapterUid": 11,
      "range": "1043-1079",
      "markText": "文明社会这样消磨自己的心智，把短促的生命浪费在无聊的应酬上实在令人莫解。",
      "totalCount": 270,
      "appLink": "weread://bestbookmark?bookId=3300047443&chapterUid=11&rangeStart=1043&rangeEnd=1079",
      "webLink": "https://weread.qq.com/web/reader/6e332740813ab7908g0131ea?chapterUid=11&rangeStart=1043&rangeEnd=1079"
    },
    {
      "bookmarkId": "3300047443_20_5503-5538",
      "chapterUid": 20,
      "range": "5503-5538",
      "markText": "卑鄙与伟大、恶毒与善良、仇恨与热爱是可以互不排斥地并存在同一颗心里的。",
      "totalCount": 270,
      "appLink": "weread://bestbookmark?bookId=3300047443&chapterUid=20&rangeStart=5503&rangeEnd=5538",
      "webLink": "https://weread.qq.com/web/reader/6e332740813ab7908g0131ea?chapterUid=20&rangeStart=5503&rangeEnd=5538"
    },
    {
      "bookmarkId": "3300047443_6_865-919",
      "chapterUid": 6,
      "range": "865-919",
      "markText": "在我看来，艺术中最令人感兴趣的就是艺术家的个性；如果艺术家赋有独特的性格，尽管他有一千个缺点，我也可以原谅。",
      "totalCount": 264,
      "appLink": "weread://bestbookmark?bookId=3300047443&chapterUid=6&rangeStart=865&rangeEnd=919",
      "webLink": "https://weread.qq.com/web/reader/6e332740813ab7908g0131ea?chapterUid=6&rangeStart=865&rangeEnd=919"
    },
    {
      "bookmarkId": "3300047443_7_1221-1294",
      "chapterUid": 7,
      "range": "1221-1294",
      "markText": "作者应该从写作的乐趣中，从郁积在他心头的思想的发泄中取得写书的酬报；对于其他一切都不应该介意，作品成功或失败，受到称誉或是诋毁，他都应该淡然处之。",
      "totalCount": 255,
      "appLink": "weread://bestbookmark?bookId=3300047443&chapterUid=7&rangeStart=1221&rangeEnd=1294",
      "webLink": "https://weread.qq.com/web/reader/6e332740813ab7908g0131ea?chapterUid=7&rangeStart=1221&rangeEnd=1294"
    },
    {
      "bookmarkId": "3300047443_36_650-701",
      "chapterUid": 36,
      "range": "650-701",
      "markText": "我发现他不论碰到哪个相识的人都把自己的不幸遭遇唠叨给大家听；他希望别人同情他，但是却只引起人们的嘲笑。",
      "totalCount": 255,
      "appLink": "weread://bestbookmark?bookId=3300047443&chapterUid=36&rangeStart=650&rangeEnd=701",
      "webLink": "https://weread.qq.com/web/reader/6e332740813ab7908g0131ea?chapterUid=36&rangeStart=650&rangeEnd=701"
    },
    {
      "bookmarkId": "3300047443_46_6683-6721",
      "chapterUid": 46,
      "range": "6683-6721",
      "markText": "勃朗什·施特略夫自杀并不是因为我抛弃了她，而是因为她太傻，因为她精神不健全。",
      "totalCount": 255,
      "appLink": "weread://bestbookmark?bookId=3300047443&chapterUid=46&rangeStart=6683&rangeEnd=6721",
      "webLink": "https://weread.qq.com/web/reader/6e332740813ab7908g0131ea?chapterUid=46&rangeStart=6683&rangeEnd=6721"
    },
    {
      "bookmarkId": "3300047443_17_7279-7341",
      "chapterUid": 17,
      "range": "7279-7341",
      "markText": "“我告诉你我必须画画儿。我由不了我自己。一个人要是跌进水里，他游泳游得好不好是无关紧要的，反正他得挣扎出去，不然就得淹死。”",
      "totalCount": 252,
      "appLink": "weread://bestbookmark?bookId=3300047443&chapterUid=17&rangeStart=7279&rangeEnd=7341",
      "webLink": "https://weread.qq.com/web/reader/6e332740813ab7908g0131ea?chapterUid=17&rangeStart=7279&rangeEnd=7341"
    },
    {
      "bookmarkId": "3300047443_34_1351-1391",
      "chapterUid": 34,
      "range": "1351-1391",
      "markText": "我觉得，在爱情的事上如果考虑起自尊心来，那只能有一个原因：实际上你还是最爱自己。",
      "totalCount": 240,
      "appLink": "weread://bestbookmark?bookId=3300047443&chapterUid=34&rangeStart=1351&rangeEnd=1391",
      "webLink": "https://weread.qq.com/web/reader/6e332740813ab7908g0131ea?chapterUid=34&rangeStart=1351&rangeEnd=1391"
    },
    {
      "bookmarkId": "3300047443_46_1482-1502",
      "chapterUid": 46,
      "range": "1482-1502",
      "markText": "作家更关心的是了解人性，而不是判断人性。",
      "totalCount": 238,
      "appLink": "weread://bestbookmark?bookId=3300047443&chapterUid=46&rangeStart=1482&rangeEnd=1502",
      "webLink": "https://weread.qq.com/web/reader/6e332740813ab7908g0131ea?chapterUid=46&rangeStart=1482&rangeEnd=1502"
    },
    {
      "bookmarkId": "3300047443_46_5306-5387",
      "chapterUid": 46,
      "range": "5306-5387",
      "markText": "实际上爱情是生活中无足轻重的一部分。我只懂得情欲。这是正常的，健康的。爱情是一种疾病。女人是我享乐的工具，我对她们提出什么事业的助手、生活的侣伴这些要求非常讨厌。",
      "totalCount": 234,
      "appLink": "weread://bestbookmark?bookId=3300047443&chapterUid=46&rangeStart=5306&rangeEnd=5387",
      "webLink": "https://weread.qq.com/web/reader/6e332740813ab7908g0131ea?chapterUid=46&rangeStart=5306&rangeEnd=5387"
    },
    {
      "bookmarkId": "3300047443_19_1861-1895",
      "chapterUid": 19,
      "range": "1861-1895",
      "markText": "但是我总觉得事事要邀获别人批准，或许是文明人类最根深蒂固的一种天性。",
      "totalCount": 225,
      "appLink": "weread://bestbookmark?bookId=3300047443&chapterUid=19&rangeStart=1861&rangeEnd=1895",
      "webLink": "https://weread.qq.com/web/reader/6e332740813ab7908g0131ea?chapterUid=19&rangeStart=1861&rangeEnd=1895"
    },
    {
      "bookmarkId": "3300047443_24_2268-2304",
      "chapterUid": 24,
      "range": "2268-2304",
      "markText": "她只差一点儿就称得起是个美人，但是正因为差这一点儿，却连漂亮也算不上了。",
      "totalCount": 221,
      "appLink": "weread://bestbookmark?bookId=3300047443&chapterUid=24&rangeStart=2268&rangeEnd=2304",
      "webLink": "https://weread.qq.com/web/reader/6e332740813ab7908g0131ea?chapterUid=24&rangeStart=2268&rangeEnd=2304"
    },
    {
      "bookmarkId": "3300047443_26_4145-4167",
      "chapterUid": 26,
      "range": "4145-4167",
      "markText": "我不想过去。对我说来，最重要的是永恒的现在。",
      "totalCount": 221,
      "appLink": "weread://bestbookmark?bookId=3300047443&chapterUid=26&rangeStart=4145&rangeEnd=4167",
      "webLink": "https://weread.qq.com/web/reader/6e332740813ab7908g0131ea?chapterUid=26&rangeStart=4145&rangeEnd=4167"
    }
  ],
