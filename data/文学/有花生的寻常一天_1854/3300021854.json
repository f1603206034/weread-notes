      "chapterUid": 16,
      "range": "4383-4404",
      "markText": "“我也不想这样。”她一边说一边抡起烟灰缸。",
      "totalCount": 1200,
      "appLink": "weread://bestbookmark?bookId=3300021854&chapterUid=16&rangeStart=4383&rangeEnd=4404",
      "webLink": "https://weread.qq.com/web/reader/0da32f60813ab6f09g014c5c?chapterUid=16&rangeStart=4383&rangeEnd=4404"
    },
    {
