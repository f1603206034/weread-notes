      "totalCount": 154,
      "appLink": "weread://bestbookmark?bookId=3300017871&chapterUid=5&rangeStart=6765&rangeEnd=6828",
      "webLink": "https://weread.qq.com/web/reader/c1132650813ab6d7bg011ce7?chapterUid=5&rangeStart=6765&rangeEnd=6828"
    },
    {
      "bookmarkId": "3300017871_3_572-650",
