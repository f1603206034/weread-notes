      "appLink": "weread://bestbookmark?bookId=3300017871&chapterUid=5&rangeStart=6018&rangeEnd=6053",
      "webLink": "https://weread.qq.com/web/reader/c1132650813ab6d7bg011ce7?chapterUid=5&rangeStart=6018&rangeEnd=6053"
