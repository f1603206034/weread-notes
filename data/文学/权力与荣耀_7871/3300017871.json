      "appLink": "weread://bestbookmark?bookId=3300017871&chapterUid=3&rangeStart=6594&rangeEnd=6630",
      "webLink": "https://weread.qq.com/web/reader/c1132650813ab6d7bg011ce7?chapterUid=3&rangeStart=6594&rangeEnd=6630"
