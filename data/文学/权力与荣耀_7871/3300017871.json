      "totalCount": 112,
      "appLink": "weread://bestbookmark?bookId=3300017871&chapterUid=3&rangeStart=572&rangeEnd=650",
      "webLink": "https://weread.qq.com/web/reader/c1132650813ab6d7bg011ce7?chapterUid=3&rangeStart=572&rangeEnd=650"
    },
    {
      "bookmarkId": "3300017871_5_6018-6053",
      "chapterUid": 5,
      "range": "6018-6053",
      "markText": "他非常看不上外国人的这种不同的生活方式，舒适、安全、宽容、自满自足……",
