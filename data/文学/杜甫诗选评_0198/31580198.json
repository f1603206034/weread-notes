  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "31580198_5_986-1081",
      "chapterUid": 5,
      "range": "986-1081",
      "markText": "盛唐文人生逢盛世，意气风发，几乎人人都有以天下为己任的远大抱负。但他们对理想的追求是与个人的功名富贵联系在一起的。杜甫却终其一生都把个人看得极其渺小，而将国家和人民的命运视为人生的终极关怀。",
      "totalCount": 72,
      "appLink": "weread://bestbookmark?bookId=31580198&chapterUid=5&rangeStart=986&rangeEnd=1081",
      "webLink": "https://weread.qq.com/web/reader/88b3286071e1e02688bfe2c?chapterUid=5&rangeStart=986&rangeEnd=1081"
    },
    {
      "bookmarkId": "31580198_7_1837-1894",
      "chapterUid": 7,
      "range": "1837-1894",
      "markText": "全诗寄托虽然深远，但通篇只见登览名山之兴会，丝毫不见刻意比兴之痕迹。若论气骨峥嵘，体势雄浑，更为后出之作难以企及。",
      "totalCount": 68,
      "appLink": "weread://bestbookmark?bookId=31580198&chapterUid=7&rangeStart=1837&rangeEnd=1894",
      "webLink": "https://weread.qq.com/web/reader/88b3286071e1e02688bfe2c?chapterUid=7&rangeStart=1837&rangeEnd=1894"
    },
    {
      "bookmarkId": "31580198_5_415-426",
      "chapterUid": 5,
      "range": "415-426",
      "markText": "江汉思归客，乾坤一腐儒",
      "totalCount": 65,
      "appLink": "weread://bestbookmark?bookId=31580198&chapterUid=5&rangeStart=415&rangeEnd=426",
      "webLink": "https://weread.qq.com/web/reader/88b3286071e1e02688bfe2c?chapterUid=5&rangeStart=415&rangeEnd=426"
    },
    {
      "bookmarkId": "31580198_52_1121-1294",
      "chapterUid": 52,
      "range": "1121-1294",
      "markText": "大庇天下寒士俱欢颜， 风雨不动安如山。 呜呼！ 何时眼前突兀见此屋③， 吾庐独破受冻死亦足！",
      "totalCount": 60,
      "appLink": "weread://bestbookmark?bookId=31580198&chapterUid=52&rangeStart=1121&rangeEnd=1294",
      "webLink": "https://weread.qq.com/web/reader/88b3286071e1e02688bfe2c?chapterUid=52&rangeStart=1121&rangeEnd=1294"
    },
    {
      "bookmarkId": "31580198_14_443-569",
      "chapterUid": 14,
      "range": "443-569",
      "markText": "挽弓当挽强，用剑当用长。 射人先射马，擒贼先擒王。 杀人亦有限，列国自有疆。 苟能制侵凌，岂在多杀伤？",
      "totalCount": 54,
      "appLink": "weread://bestbookmark?bookId=31580198&chapterUid=14&rangeStart=443&rangeEnd=569",
      "webLink": "https://weread.qq.com/web/reader/88b3286071e1e02688bfe2c?chapterUid=14&rangeStart=443&rangeEnd=569"
    },
    {
      "bookmarkId": "31580198_29_648-688",
      "chapterUid": 29,
      "range": "648-688",
      "markText": "明朝有封事⑤，数问夜如何。",
      "totalCount": 54,
      "appLink": "weread://bestbookmark?bookId=31580198&chapterUid=29&rangeStart=648&rangeEnd=688",
      "webLink": "https://weread.qq.com/web/reader/88b3286071e1e02688bfe2c?chapterUid=29&rangeStart=648&rangeEnd=688"
    },
    {
      "bookmarkId": "31580198_48_549-561",
      "chapterUid": 48,
      "range": "549-561",
      "markText": "细雨鱼儿出，微风燕子斜。",
      "totalCount": 54,
