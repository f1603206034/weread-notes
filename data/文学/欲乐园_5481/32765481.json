      "totalCount": 406,
      "appLink": "weread://bestbookmark?bookId=32765481&chapterUid=5&rangeStart=18572&rangeEnd=18653",
      "webLink": "https://weread.qq.com/web/reader/ded3238071f3f629ded3cbe?chapterUid=5&rangeStart=18572&rangeEnd=18653"
