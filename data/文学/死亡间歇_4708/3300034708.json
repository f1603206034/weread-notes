      "appLink": "weread://bestbookmark?bookId=3300034708&chapterUid=6&rangeStart=1785&rangeEnd=1821",
      "webLink": "https://weread.qq.com/web/reader/fea32ff0813ab740eg01829e?chapterUid=6&rangeStart=1785&rangeEnd=1821"
    },
