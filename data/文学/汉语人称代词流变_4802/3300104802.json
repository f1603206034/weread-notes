  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300104802_6_514-639",
      "chapterUid": 6,
      "range": "514-639",
      "markText": "崔希亮《人称代词及其称谓功能》也认为：“其实人称可以作为一种特殊的称谓形式看待，第一个理由是人称代词除了具有指代功能以外还具有称谓功能，第二个理由是在汉语人称代词的发展史上我们可以看到许多人称代词与称谓有密切的关系，有些人称代词就是称谓词语变来的。”",
      "totalCount": 42,
      "appLink": "weread://bestbookmark?bookId=3300104802&chapterUid=6&rangeStart=514&rangeEnd=639",
      "webLink": "https://weread.qq.com/web/reader/a1e32af0813ab8f70g012c43?chapterUid=6&rangeStart=514&rangeEnd=639"
    },
    {
      "bookmarkId": "3300104802_34_702-776",
      "chapterUid": 34,
      "range": "702-776",
      "markText": "这三大类十一小类人称代词形成了汉语人称代词词汇意义表达功能、语法功能和语用功能完善互补的庞大系统，较好地满足了汉语中不同时期、不同语境下称代的需要。",
      "totalCount": 42,
      "appLink": "weread://bestbookmark?bookId=3300104802&chapterUid=34&rangeStart=702&rangeEnd=776",
      "webLink": "https://weread.qq.com/web/reader/a1e32af0813ab8f70g012c43?chapterUid=34&rangeStart=702&rangeEnd=776"
    },
    {
      "bookmarkId": "3300104802_13_5949-5996",
      "chapterUid": 13,
      "range": "5949-5996",
      "markText": "（三）“咱(zan)”，方言，用为“这咱、那咱、多咱、这咱晚”等，表示时间，是“早晚”的合音。",
      "totalCount": 41,
      "appLink": "weread://bestbookmark?bookId=3300104802&chapterUid=13&rangeStart=5949&rangeEnd=5996",
      "webLink": "https://weread.qq.com/web/reader/a1e32af0813ab8f70g012c43?chapterUid=13&rangeStart=5949&rangeEnd=5996"
    },
    {
      "bookmarkId": "3300104802_15_1041-1076",
      "chapterUid": 15,
      "range": "1041-1076",
      "markText": "“某”一词的归类有些分歧，有的把它归为人称代词，有的把它归入指示代词。",
      "totalCount": 41,
      "appLink": "weread://bestbookmark?bookId=3300104802&chapterUid=15&rangeStart=1041&rangeEnd=1076",
      "webLink": "https://weread.qq.com/web/reader/a1e32af0813ab8f70g012c43?chapterUid=15&rangeStart=1041&rangeEnd=1076"
    },
    {
      "bookmarkId": "3300104802_24_1593-1635",
      "chapterUid": 24,
      "range": "1593-1635",
      "markText": "“莫”“无”为否定性无定代词，相当于现代汉语的“没有谁”或“没有什么东西（事情）”。",
      "totalCount": 41,
      "appLink": "weread://bestbookmark?bookId=3300104802&chapterUid=24&rangeStart=1593&rangeEnd=1635",
      "webLink": "https://weread.qq.com/web/reader/a1e32af0813ab8f70g012c43?chapterUid=24&rangeStart=1593&rangeEnd=1635"
    },
    {
      "bookmarkId": "3300104802_25_1108-1129",
      "chapterUid": 25,
      "range": "1108-1129",
      "markText": "傲称代词主要有尔公、乃公、老子、老娘几个。",
      "totalCount": 41,
      "appLink": "weread://bestbookmark?bookId=3300104802&chapterUid=25&rangeStart=1108&rangeEnd=1129",
      "webLink": "https://weread.qq.com/web/reader/a1e32af0813ab8f70g012c43?chapterUid=25&rangeStart=1108&rangeEnd=1129"
    },
    {
      "bookmarkId": "3300104802_25_1609-1702",
      "chapterUid": 25,
      "range": "1609-1702",
      "markText": "不仅对他人称自己用谦称，对他人称自己的妻子也用谦称，如“拙荆、贱内、内人、山荆、荆屋、山妻”，谦称自己的儿子则用“小儿、犬子、息男”，称女儿用“息女、小女”等，主要用于口语，常见于戏剧。",
      "totalCount": 41,
      "appLink": "weread://bestbookmark?bookId=3300104802&chapterUid=25&rangeStart=1609&rangeEnd=1702",
      "webLink": "https://weread.qq.com/web/reader/a1e32af0813ab8f70g012c43?chapterUid=25&rangeStart=1609&rangeEnd=1702"
    },
    {
      "bookmarkId": "3300104802_27_24349-24381",
      "chapterUid": 27,
      "range": "24349-24381",
      "markText": "“执事、左右”则是以对方职责对称听话人，表示对对方的体贴与敬重。",
      "totalCount": 41,
      "appLink": "weread://bestbookmark?bookId=3300104802&chapterUid=27&rangeStart=24349&rangeEnd=24381",
      "webLink": "https://weread.qq.com/web/reader/a1e32af0813ab8f70g012c43?chapterUid=27&rangeStart=24349&rangeEnd=24381"
    },
    {
      "bookmarkId": "3300104802_29_403-513",
      "chapterUid": 29,
      "range": "403-513",
      "markText": "语法化(grammaticalization)指的是语法范畴和语法成分产生和形成的过程或现象，最典型的表现是语言中意义实在的词汇或结构式演变成无实在意义、仅表语法功能的语法成分，或者一个较虚的语法成分变成更虚的语法成分。",
      "totalCount": 41,
      "appLink": "weread://bestbookmark?bookId=3300104802&chapterUid=29&rangeStart=403&rangeEnd=513",
      "webLink": "https://weread.qq.com/web/reader/a1e32af0813ab8f70g012c43?chapterUid=29&rangeStart=403&rangeEnd=513"
    },
    {
      "bookmarkId": "3300104802_9_64874-64928",
      "chapterUid": 9,
      "range": "64874-64928",
      "markText": "尽管郭璞注“古者贵贱皆自称朕”，我们通过研究还是发现了一个事实：并非“贵贱皆自称朕”，而是“自称朕者皆贵”。",
      "totalCount": 40,
      "appLink": "weread://bestbookmark?bookId=3300104802&chapterUid=9&rangeStart=64874&rangeEnd=64928",
      "webLink": "https://weread.qq.com/web/reader/a1e32af0813ab8f70g012c43?chapterUid=9&rangeStart=64874&rangeEnd=64928"
    },
    {
      "bookmarkId": "3300104802_17_38565-38616",
      "chapterUid": 17,
      "range": "38565-38616",
      "markText": "此后，“专职”对称代词“你”就在白话的肥沃土壤中迅速发展壮大，逐步成为至今仍然一枝独秀的通用对称代词。",
      "totalCount": 39,
      "appLink": "weread://bestbookmark?bookId=3300104802&chapterUid=17&rangeStart=38565&rangeEnd=38616",
      "webLink": "https://weread.qq.com/web/reader/a1e32af0813ab8f70g012c43?chapterUid=17&rangeStart=38565&rangeEnd=38616"
    },
    {
      "bookmarkId": "3300104802_24_916-973",
      "chapterUid": 24,
      "range": "916-973",
      "markText": "旁称代词主要有“人、人家、别人（旁人）”，指代说话人或说话双方以外的其他人和事，强调的是与自称“我”“己”的对立。",
      "totalCount": 39,
      "appLink": "weread://bestbookmark?bookId=3300104802&chapterUid=24&rangeStart=916&rangeEnd=973",
      "webLink": "https://weread.qq.com/web/reader/a1e32af0813ab8f70g012c43?chapterUid=24&rangeStart=916&rangeEnd=973"
    },
    {
      "bookmarkId": "3300104802_34_19418-19448",
      "chapterUid": 34,
      "range": "19418-19448",
      "markText": "汉语研究对汉语语料库的依赖是很强的，人称代词的研究也不例外。",
      "totalCount": 39,
      "appLink": "weread://bestbookmark?bookId=3300104802&chapterUid=34&rangeStart=19418&rangeEnd=19448",
      "webLink": "https://weread.qq.com/web/reader/a1e32af0813ab8f70g012c43?chapterUid=34&rangeStart=19418&rangeEnd=19448"
    },
    {
      "bookmarkId": "3300104802_7_1808-1849",
      "chapterUid": 7,
      "range": "1808-1849",
      "markText": "敬辞表示对交际的对方的尊敬，其语用意图也是抬高对方以确保交际更加圆满、顺利地进行。",
      "totalCount": 38,
      "appLink": "weread://bestbookmark?bookId=3300104802&chapterUid=7&rangeStart=1808&rangeEnd=1849",
      "webLink": "https://weread.qq.com/web/reader/a1e32af0813ab8f70g012c43?chapterUid=7&rangeStart=1808&rangeEnd=1849"
    },
    {
      "bookmarkId": "3300104802_24_1125-1189",
      "chapterUid": 24,
      "range": "1125-1189",
      "markText": "其中“人家”是一个比较特殊的旁称代词，其最为特别之处在于它浓郁的泛指色彩和在无定与有定之间的游移性，很多时候貌似无定而其实有定。",
      "totalCount": 38,
      "appLink": "weread://bestbookmark?bookId=3300104802&chapterUid=24&rangeStart=1125&rangeEnd=1189",
      "webLink": "https://weread.qq.com/web/reader/a1e32af0813ab8f70g012c43?chapterUid=24&rangeStart=1125&rangeEnd=1189"
    },
    {
      "bookmarkId": "3300104802_6_444-514",
      "chapterUid": 6,
      "range": "444-514",
      "markText": "不少研究者将一些人称代词纳入称谓形式来研究，如程邦雄《论语中的称谓与避讳研究》把语言中的称谓分为“名字称”“代词称”和“其他称”三类来考察。",
      "totalCount": 37,
      "appLink": "weread://bestbookmark?bookId=3300104802&chapterUid=6&rangeStart=444&rangeEnd=514",
      "webLink": "https://weread.qq.com/web/reader/a1e32af0813ab8f70g012c43?chapterUid=6&rangeStart=444&rangeEnd=514"
    },
    {
      "bookmarkId": "3300104802_20_2683-2762",
      "chapterUid": 20,
      "range": "2683-2762",
      "markText": "根据《现代汉语词典》的解释，“人家”指“说话人和听话人以外的人”，“别人”指“自己或某人以外的人”，而“他称代词”称代的是“自己和对方以外的人”。",
      "totalCount": 37,
      "appLink": "weread://bestbookmark?bookId=3300104802&chapterUid=20&rangeStart=2683&rangeEnd=2762",
      "webLink": "https://weread.qq.com/web/reader/a1e32af0813ab8f70g012c43?chapterUid=20&rangeStart=2683&rangeEnd=2762"
    },
    {
      "bookmarkId": "3300104802_24_1218-1277",
      "chapterUid": 24,
      "range": "1218-1277",
      "markText": "“人家”和“别人”是一对意义和用法相当的旁称代词，当它们泛指说话人和听话人以外的人，并与“自己”相对时，二者可以互换。",
      "totalCount": 37,
      "appLink": "weread://bestbookmark?bookId=3300104802&chapterUid=24&rangeStart=1218&rangeEnd=1277",
      "webLink": "https://weread.qq.com/web/reader/a1e32af0813ab8f70g012c43?chapterUid=24&rangeStart=1218&rangeEnd=1277"
    },
    {
      "bookmarkId": "3300104802_27_10520-10544",
      "chapterUid": 27,
      "range": "10520-10544",
      "markText": "“吾子”，最初是一个偏正式名词短语，即我的儿子。",
      "totalCount": 37,
      "appLink": "weread://bestbookmark?bookId=3300104802&chapterUid=27&rangeStart=10520&rangeEnd=10544",
      "webLink": "https://weread.qq.com/web/reader/a1e32af0813ab8f70g012c43?chapterUid=27&rangeStart=10520&rangeEnd=10544"
    },
    {
      "bookmarkId": "3300104802_34_4883-4947",
      "chapterUid": 34,
      "range": "4883-4947",
      "markText": "典型他称代词所称代对象不在交际现场，发话人和受话人对其称呼不用太多考虑情感、态度、语气等因素，因此他称代词系统较为单纯而不繁复。",
      "totalCount": 37,
      "appLink": "weread://bestbookmark?bookId=3300104802&chapterUid=34&rangeStart=4883&rangeEnd=4947",
      "webLink": "https://weread.qq.com/web/reader/a1e32af0813ab8f70g012c43?chapterUid=34&rangeStart=4883&rangeEnd=4947"
    }
  ],
