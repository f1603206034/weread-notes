      "appLink": "weread://bestbookmark?bookId=3300007114&chapterUid=3&rangeStart=13558&rangeEnd=13620",
      "webLink": "https://weread.qq.com/web/reader/d69322b0813ab6947g01416e?chapterUid=3&rangeStart=13558&rangeEnd=13620"
    },
    {
      "bookmarkId": "3300007114_5_19214-19247",
      "chapterUid": 5,
      "range": "19214-19247",
      "markText": "人到了超经验的景色之前，往往找不到合适的语言，就只好狗一样地乱叫。",
      "totalCount": 228,
      "appLink": "weread://bestbookmark?bookId=3300007114&chapterUid=5&rangeStart=19214&rangeEnd=19247",
      "webLink": "https://weread.qq.com/web/reader/d69322b0813ab6947g01416e?chapterUid=5&rangeStart=19214&rangeEnd=19247"
    },
    {
      "bookmarkId": "3300007114_3_9913-9978",
      "chapterUid": 3,
      "range": "9913-9978",
