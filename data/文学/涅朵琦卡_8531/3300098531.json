  "bookReviews": [
    {
      "type": "review",
      "reviewId": "32618646_7RfBPlQ2k",
      "range": "",
      "chapterName": "",
      "content": "怎么毁掉一个人？\n涅朵奇卡：童年的暴雨，会弄得一生的潮湿。\n叶菲莫夫：给他一点天赋b。这点天赋会使他自负，停滞不前，抱怨生活。",
      "abstract": "",
      "star": 100,
      "createTime": 1715912972,
      "createTimeFormatted": "2024-05-17 10:29:32",
      "isFinish": 1,
      "chapterUid": 0
    }
  ],
