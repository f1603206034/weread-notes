      "chapterUid": 8,
      "range": "17431-17455",
      "markText": "我平生只有一次忘了我自己的母亲，那就是昨天晚上。",
      "totalCount": 324,
      "appLink": "weread://bestbookmark?bookId=3300102923&chapterUid=8&rangeStart=17431&rangeEnd=17455",
      "webLink": "https://weread.qq.com/web/reader/3cc32780813ab8eb4g01319a?chapterUid=8&rangeStart=17431&rangeEnd=17455"
