  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300075597_5_1919-1939",
      "chapterUid": 5,
      "range": "1919-1939",
      "markText": "两个人的爱：这是“最小的共产主义单位”。",
      "totalCount": 774,
      "appLink": "weread://bestbookmark?bookId=3300075597&chapterUid=5&rangeStart=1919&rangeEnd=1939",
      "webLink": "https://weread.qq.com/web/reader/ae832b70813ab8407g017230?chapterUid=5&rangeStart=1919&rangeEnd=1939"
    },
    {
      "bookmarkId": "3300075597_5_827-923",
      "chapterUid": 5,
      "range": "827-923",
      "markText": "让我们去爱上垃圾，爱上我们这个将要完蛋的世界，爱它们到尽头，一直挺下来，熬出头，带着勇气忍受，在不可能中实践可能，站到命运的另一边去，直到让我们自己都惊奇为止。只有爱的贯穿，行动才能如此彻底。",
      "totalCount": 636,
      "appLink": "weread://bestbookmark?bookId=3300075597&chapterUid=5&rangeStart=827&rangeEnd=923",
      "webLink": "https://weread.qq.com/web/reader/ae832b70813ab8407g017230?chapterUid=5&rangeStart=827&rangeEnd=923"
    },
    {
      "bookmarkId": "3300075597_22_2800-2856",
      "chapterUid": 22,
      "range": "2800-2856",
      "markText": "我们甚至可以观察到，在实践中，婚姻不曾激发什么伟大的作品。艺术家和文学家很少从婚姻生活中汲取灵感，这是一个事实。",
      "totalCount": 396,
      "appLink": "weread://bestbookmark?bookId=3300075597&chapterUid=22&rangeStart=2800&rangeEnd=2856",
      "webLink": "https://weread.qq.com/web/reader/ae832b70813ab8407g017230?chapterUid=22&rangeStart=2800&rangeEnd=2856"
    },
    {
      "bookmarkId": "3300075597_6_815-871",
      "chapterUid": 6,
      "range": "815-871",
      "markText": "爱是突如其来的事件，不可预料，也不可能用任何的实用理性来加以考量。想要给爱情加上一个“安全阀”，往往会徒劳无功。",
      "totalCount": 363,
      "appLink": "weread://bestbookmark?bookId=3300075597&chapterUid=6&rangeStart=815&rangeEnd=871",
      "webLink": "https://weread.qq.com/web/reader/ae832b70813ab8407g017230?chapterUid=6&rangeStart=815&rangeEnd=871"
    },
    {
      "bookmarkId": "3300075597_11_1486-1642",
      "chapterUid": 11,
      "range": "1486-1642",
      "markText": "当相爱的人，彼此躺在对方的怀中，爱的温柔，在此际就如同挪亚的大衣，覆盖在这些令人不安的想法之上。",
      "totalCount": 360,
      "appLink": "weread://bestbookmark?bookId=3300075597&chapterUid=11&rangeStart=1486&rangeEnd=1642",
      "webLink": "https://weread.qq.com/web/reader/ae832b70813ab8407g017230?chapterUid=11&rangeStart=1486&rangeEnd=1642"
    },
    {
      "bookmarkId": "3300075597_10_1435-1485",
      "chapterUid": 10,
      "range": "1435-1485",
      "markText": "婚姻不是被视作为对抗变幻不定的爱情而进行的社会关系的强化，而是被视作可以把真正的爱转向其本真的使命。",
      "totalCount": 340,
      "appLink": "weread://bestbookmark?bookId=3300075597&chapterUid=10&rangeStart=1435&rangeEnd=1485",
      "webLink": "https://weread.qq.com/web/reader/ae832b70813ab8407g017230?chapterUid=10&rangeStart=1435&rangeEnd=1485"
    },
    {
      "bookmarkId": "3300075597_5_1013-1075",
      "chapterUid": 5,
      "range": "1013-1075",
      "markText": "巴迪欧认为，艺术、科学、爱和政治，是我们人类走向真理的四种途径。在这四条道路上的每一种追求，都会把我们升华到更高的命运刻度。",
      "totalCount": 330,
      "appLink": "weread://bestbookmark?bookId=3300075597&chapterUid=5&rangeStart=1013&rangeEnd=1075",
      "webLink": "https://weread.qq.com/web/reader/ae832b70813ab8407g017230?chapterUid=5&rangeStart=1013&rangeEnd=1075"
    },
    {
      "bookmarkId": "3300075597_6_7472-7519",
      "chapterUid": 6,
      "range": "7472-7519",
      "markText": "真正的爱是持续多年的相濡以沫，是快乐与痛苦交织的共同生活，是彼此改变对方、适应对方的艰难磨合。",
      "totalCount": 320,
      "appLink": "weread://bestbookmark?bookId=3300075597&chapterUid=6&rangeStart=7472&rangeEnd=7519",
      "webLink": "https://weread.qq.com/web/reader/ae832b70813ab8407g017230?chapterUid=6&rangeStart=7472&rangeEnd=7519"
    },
    {
      "bookmarkId": "3300075597_8_1351-1619",
      "chapterUid": 8,
      "range": "1351-1619",
      "markText": "第一句是这样的：“无需风险，您将拥有爱情”（来自于对一出著名戏剧中的对白的改写）。还有一句口号：“无需坠入爱河，亦可相爱”。再来一句：“无需心痛，完美相爱”。",
      "totalCount": 315,
      "appLink": "weread://bestbookmark?bookId=3300075597&chapterUid=8&rangeStart=1351&rangeEnd=1619",
      "webLink": "https://weread.qq.com/web/reader/ae832b70813ab8407g017230?chapterUid=8&rangeStart=1351&rangeEnd=1619"
    },
    {
      "bookmarkId": "3300075597_4_517-536",
      "chapterUid": 4,
      "range": "517-536",
      "markText": "“我们知道，爱就是去不断地重新创造。”",
      "totalCount": 308,
      "appLink": "weread://bestbookmark?bookId=3300075597&chapterUid=4&rangeStart=517&rangeEnd=536",
      "webLink": "https://weread.qq.com/web/reader/ae832b70813ab8407g017230?chapterUid=4&rangeStart=517&rangeEnd=536"
    },
    {
      "bookmarkId": "3300075597_16_2593-2633",
      "chapterUid": 16,
      "range": "2593-2633",
      "markText": "忠诚，恰恰意味着一种过渡，从一种偶然到一种坚定的建构，从而这种偶然变成一种命运。",
      "totalCount": 306,
      "appLink": "weread://bestbookmark?bookId=3300075597&chapterUid=16&rangeStart=2593&rangeEnd=2633",
      "webLink": "https://weread.qq.com/web/reader/ae832b70813ab8407g017230?chapterUid=16&rangeStart=2593&rangeEnd=2633"
    },
    {
      "bookmarkId": "3300075597_13_2226-2264",
      "chapterUid": 13,
      "range": "2226-2264",
      "markText": "一种真正的爱，是一种持之以恒的胜利，不断地跨越空间、时间、世界所造成的障碍。",
      "totalCount": 288,
      "appLink": "weread://bestbookmark?bookId=3300075597&chapterUid=13&rangeStart=2226&rangeEnd=2264",
      "webLink": "https://weread.qq.com/web/reader/ae832b70813ab8407g017230?chapterUid=13&rangeStart=2226&rangeEnd=2264"
    },
    {
      "bookmarkId": "3300075597_5_2510-2595",
      "chapterUid": 5,
      "range": "2510-2595",
      "markText": "政治像爱，也是人类的共同筹划和共同冒险，是把赌注押到了很高、很远。共产主义？那是：去爱，为了去爱，而需要爱，集体地去爱：那是无数个俩们的使命：那开始于两件乐器之间的重奏。",
      "totalCount": 280,
      "appLink": "weread://bestbookmark?bookId=3300075597&chapterUid=5&rangeStart=2510&rangeEnd=2595",
      "webLink": "https://weread.qq.com/web/reader/ae832b70813ab8407g017230?chapterUid=5&rangeStart=2510&rangeEnd=2595"
    },
    {
      "bookmarkId": "3300075597_6_8068-8167",
      "chapterUid": 6,
      "range": "8068-8167",
      "markText": "我们形成了共同的经验世界真理的方式，经验到了唯一的人类的真理。于是这就是爱。所以，在巴迪欧这里，爱是相互差异的两个个体形成的一个“两”。但这个“两”并不会融合为“一”，而是永远在不断差异又不断靠近。",
