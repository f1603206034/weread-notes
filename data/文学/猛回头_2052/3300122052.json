  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300122052_4_454-485",
      "chapterUid": 4,
      "range": "454-485",
      "markText": "受过了多少压制，做过了数朝奴隶，转瞬间又要为牛为马，断送躯躬。",
      "totalCount": 1235,
      "appLink": "weread://bestbookmark?bookId=3300122052&chapterUid=4&rangeStart=454&rangeEnd=485",
      "webLink": "https://weread.qq.com/web/reader/00f326c0813ab962dg012a16?chapterUid=4&rangeStart=454&rangeEnd=485"
    },
    {
      "bookmarkId": "3300122052_3_432-477",
      "chapterUid": 3,
      "range": "432-477",
      "markText": "俺也曾，洒了几点国民泪，俺也曾，受了几日文明气，俺也曾，拔了一段杀人机，代同胞愿把头颅碎。",
      "totalCount": 994,
      "appLink": "weread://bestbookmark?bookId=3300122052&chapterUid=3&rangeStart=432&rangeEnd=477",
      "webLink": "https://weread.qq.com/web/reader/00f326c0813ab962dg012a16?chapterUid=3&rangeStart=432&rangeEnd=477"
    },
    {
      "bookmarkId": "3300122052_25_4681-4695",
      "chapterUid": 25,
      "range": "4681-4695",
      "markText": "要知后事如何，且看下回分解。",
      "totalCount": 629,
      "appLink": "weread://bestbookmark?bookId=3300122052&chapterUid=25&rangeStart=4681&rangeEnd=4695",
      "webLink": "https://weread.qq.com/web/reader/00f326c0813ab962dg012a16?chapterUid=25&rangeStart=4681&rangeEnd=4695"
    },
    {
      "bookmarkId": "3300122052_4_558-574",
      "chapterUid": 4,
      "range": "558-574",
      "markText": "望皇祖告诉苍穹，为汉种速降下英雄",
      "totalCount": 570,
      "appLink": "weread://bestbookmark?bookId=3300122052&chapterUid=4&rangeStart=558&rangeEnd=574",
      "webLink": "https://weread.qq.com/web/reader/00f326c0813ab962dg012a16?chapterUid=4&rangeStart=558&rangeEnd=574"
    },
    {
      "bookmarkId": "3300122052_7_13807-13895",
      "chapterUid": 7,
      "range": "13807-13895",
      "markText": "依了鄙人的愚见，不如大家合做一个大党，凡是我汉族的人，无论是为士、为农、为工、为商，都不可丝毫扰害，都要极力保护。不使一个受外族的欺凌，方可对得祖宗住，岂不是大豪杰所做的事吗？",
      "totalCount": 525,
      "appLink": "weread://bestbookmark?bookId=3300122052&chapterUid=7&rangeStart=13807&rangeEnd=13895",
      "webLink": "https://weread.qq.com/web/reader/00f326c0813ab962dg012a16?chapterUid=7&rangeStart=13807&rangeEnd=13895"
    },
    {
      "bookmarkId": "3300122052_7_16280-16337",
      "chapterUid": 7,
      "range": "16280-16337",
      "markText": "天下事，怕的是，不肯去做， 断没有，做不到，有志莫偿。",
      "totalCount": 476,
      "appLink": "weread://bestbookmark?bookId=3300122052&chapterUid=7&rangeStart=16280&rangeEnd=16337",
      "webLink": "https://weread.qq.com/web/reader/00f326c0813ab962dg012a16?chapterUid=7&rangeStart=16280&rangeEnd=16337"
    },
    {
      "bookmarkId": "3300122052_4_836-878",
      "chapterUid": 4,
      "range": "836-878",
      "markText": "我饮我食兮，无非始祖之所经营，誓死以守之兮，决不令他族之我争。子子孙孙兮，同此血诚。",
      "totalCount": 460,
      "appLink": "weread://bestbookmark?bookId=3300122052&chapterUid=4&rangeStart=836&rangeEnd=878",
      "webLink": "https://weread.qq.com/web/reader/00f326c0813ab962dg012a16?chapterUid=4&rangeStart=836&rangeEnd=878"
    },
    {
      "bookmarkId": "3300122052_17_2258-2355",
      "chapterUid": 17,
      "range": "2258-2355",
      "markText": "乃是一个极大的都会，街广十丈，都是白石，洁净无尘；屋宇皆是七层，十二分的华美；街上的电汽车，往来如织；半空中修着铁桥，在上行走火车，底下又穿着地洞，也有火车行走。讲不尽富贵繁华，说不尽奇丽巧妙。",
      "totalCount": 435,
      "appLink": "weread://bestbookmark?bookId=3300122052&chapterUid=17&rangeStart=2258&rangeEnd=2355",
      "webLink": "https://weread.qq.com/web/reader/00f326c0813ab962dg012a16?chapterUid=17&rangeStart=2258&rangeEnd=2355"
    },
    {
      "bookmarkId": "3300122052_7_1183-1233",
      "chapterUid": 7,
      "range": "1183-1233",
      "markText": "义和团不懂这个道理，所以弄出天大的祸来，把我们中国害得上不上，下不下。义和团真真是我们中国的罪人了！",
      "totalCount": 410,
      "appLink": "weread://bestbookmark?bookId=3300122052&chapterUid=7&rangeStart=1183&rangeEnd=1233",
      "webLink": "https://weread.qq.com/web/reader/00f326c0813ab962dg012a16?chapterUid=7&rangeStart=1183&rangeEnd=1233"
    },
    {
      "bookmarkId": "3300122052_7_1755-1797",
      "chapterUid": 7,
      "range": "1755-1797",
      "markText": "你看满洲的政府，只图苟全一己，不顾汉人永世翻不得身，件件依了洋人的，你道可恨不可恨！",
      "totalCount": 408,
      "appLink": "weread://bestbookmark?bookId=3300122052&chapterUid=7&rangeStart=1755&rangeEnd=1797",
      "webLink": "https://weread.qq.com/web/reader/00f326c0813ab962dg012a16?chapterUid=7&rangeStart=1755&rangeEnd=1797"
    },
    {
      "bookmarkId": "3300122052_16_6025-6099",
      "chapterUid": 16,
