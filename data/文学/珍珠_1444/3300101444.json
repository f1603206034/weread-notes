      "appLink": "weread://bestbookmark?bookId=3300101444&chapterUid=7&rangeStart=3491&rangeEnd=3506",
      "webLink": "https://weread.qq.com/web/reader/70432e80813ab8e20g014ad1?chapterUid=7&rangeStart=3491&rangeEnd=3506"
    },
    {
      "bookmarkId": "3300101444_4_2512-2541",
      "chapterUid": 4,
      "range": "2512-2541",
      "markText": "这是像其他早晨一样的一个早晨，然而又是一个特别美好的早晨。",
      "totalCount": 432,
      "appLink": "weread://bestbookmark?bookId=3300101444&chapterUid=4&rangeStart=2512&rangeEnd=2541",
