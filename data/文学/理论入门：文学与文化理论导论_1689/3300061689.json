  ],
  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300061689_4_7984-8023",
      "chapterUid": 4,
      "range": "7984-8023",
      "markText": "1.当初是什么让你决定学习英语语言文学？你希望获得什么？你当初的希望实现了吗？",
      "totalCount": 432,
      "appLink": "weread://bestbookmark?bookId=3300061689&chapterUid=4&rangeStart=7984&rangeEnd=8023",
      "webLink": "https://weread.qq.com/web/reader/0ad32f70813ab7e98g019115?chapterUid=4&rangeStart=7984&rangeEnd=8023"
    },
    {
      "bookmarkId": "3300061689_5_25946-26106",
      "chapterUid": 5,
      "range": "25946-26106",
      "markText": "政治无所不在， 语言构建现实， 真理非无条件， 意义有偶发性， 普遍人性是神话。",
      "totalCount": 306,
      "appLink": "weread://bestbookmark?bookId=3300061689&chapterUid=5&rangeStart=25946&rangeEnd=26106",
      "webLink": "https://weread.qq.com/web/reader/0ad32f70813ab7e98g019115?chapterUid=5&rangeStart=25946&rangeEnd=26106"
    },
    {
      "bookmarkId": "3300061689_3_689-750",
      "chapterUid": 3,
      "range": "689-750",
      "markText": "我一直觉得，理论经常使文本黯然失色，就像月亮的影子在日食中遮住了太阳的光辉，文本就这样失去了自己的声音，成为理论的应声虫。",
      "totalCount": 304,
      "appLink": "weread://bestbookmark?bookId=3300061689&chapterUid=3&rangeStart=689&rangeEnd=750",
      "webLink": "https://weread.qq.com/web/reader/0ad32f70813ab7e98g019115?chapterUid=3&rangeStart=689&rangeEnd=750"
    },
    {
      "bookmarkId": "3300061689_3_1780-1848",
      "chapterUid": 3,
      "range": "1780-1848",
      "markText": "理论也一样：理论有趣之处不在于权威性、确定性和一致性，而在于盲点、切入点、模糊的边缘，也在于连续不断的重新表述，哪怕前后的表述自相矛盾。",
      "totalCount": 272,
      "appLink": "weread://bestbookmark?bookId=3300061689&chapterUid=3&rangeStart=1780&rangeEnd=1848",
      "webLink": "https://weread.qq.com/web/reader/0ad32f70813ab7e98g019115?chapterUid=3&rangeStart=1780&rangeEnd=1848"
    },
    {
      "bookmarkId": "3300061689_4_8175-8228",
      "chapterUid": 4,
      "range": "8175-8228",
      "markText": "4.概言之，之前的学习给了你什么？（比如说，关于“人生”的态度；又比如说，关于个人的行为；或者文学本身。）",
      "totalCount": 216,
      "appLink": "weread://bestbookmark?bookId=3300061689&chapterUid=4&rangeStart=8175&rangeEnd=8228",
      "webLink": "https://weread.qq.com/web/reader/0ad32f70813ab7e98g019115?chapterUid=4&rangeStart=8175&rangeEnd=8228"
    },
    {
      "bookmarkId": "3300061689_3_2073-2108",
      "chapterUid": 3,
      "range": "2073-2108",
      "markText": "理论最大的用处是牢牢抓住我们，不是让我们膜拜皈依，而是让我们百家争鸣。",
      "totalCount": 192,
      "appLink": "weread://bestbookmark?bookId=3300061689&chapterUid=3&rangeStart=2073&rangeEnd=2108",
      "webLink": "https://weread.qq.com/web/reader/0ad32f70813ab7e98g019115?chapterUid=3&rangeStart=2073&rangeEnd=2108"
    },
    {
      "bookmarkId": "3300061689_5_5493-5588",
      "chapterUid": 5,
      "range": "5493-5588",
      "markText": "第一次世界大战后，爱国主义热潮开启了美国文学的正式研究，“新批评”在20世纪20年代兴起，首次为“作为文学”而不是“作为语言”的文学研究建立了连贯的理论基础，天平才由语言研究倾向于文学研究。",
      "totalCount": 192,
      "appLink": "weread://bestbookmark?bookId=3300061689&chapterUid=5&rangeStart=5493&rangeEnd=5588",
      "webLink": "https://weread.qq.com/web/reader/0ad32f70813ab7e98g019115?chapterUid=5&rangeStart=5493&rangeEnd=5588"
    },
    {
      "bookmarkId": "3300061689_4_7291-7358",
      "chapterUid": 4,
      "range": "7291-7358",
      "markText": "最后，也是非常关键的一点，绝不能认为艰涩的理论文章背后必然隐藏着深刻的思想，实际情况并非总是如此。",
      "totalCount": 180,
      "appLink": "weread://bestbookmark?bookId=3300061689&chapterUid=4&rangeStart=7291&rangeEnd=7358",
      "webLink": "https://weread.qq.com/web/reader/0ad32f70813ab7e98g019115?chapterUid=4&rangeStart=7291&rangeEnd=7358"
    },
    {
      "bookmarkId": "3300061689_14_7116-7186",
      "chapterUid": 14,
      "range": "7116-7186",
      "markText": "对某个议题的真正兴趣只能兴起于自己的生活感受。你的观点不可能像衣服一样穿了又脱。只有当真正感到某种迫切需要时，它们才会出现，发出自己的声音。",
      "totalCount": 180,
      "appLink": "weread://bestbookmark?bookId=3300061689&chapterUid=14&rangeStart=7116&rangeEnd=7186",
      "webLink": "https://weread.qq.com/web/reader/0ad32f70813ab7e98g019115?chapterUid=14&rangeStart=7116&rangeEnd=7186"
    },
    {
      "bookmarkId": "3300061689_6_3920-3997",
      "chapterUid": 6,
      "range": "3920-3997",
      "markText": "最后，在索绪尔看来，语言不单记录世界或给世界贴上标签，更构成了世界。意义总是由人类心灵赋予事物或思想，它被语言构建，并由语言表达，并非已经蕴含于事物之内。",
      "totalCount": 170,
      "appLink": "weread://bestbookmark?bookId=3300061689&chapterUid=6&rangeStart=3920&rangeEnd=3997",
      "webLink": "https://weread.qq.com/web/reader/0ad32f70813ab7e98g019115?chapterUid=6&rangeStart=3920&rangeEnd=3997"
    },
    {
      "bookmarkId": "3300061689_4_8782-8814",
      "chapterUid": 4,
      "range": "8782-8814",
      "markText": "改进还是有的。其中之一就是终于意识到了世界上原来还存在着美国文学",
      "totalCount": 168,
      "appLink": "weread://bestbookmark?bookId=3300061689&chapterUid=4&rangeStart=8782&rangeEnd=8814",
      "webLink": "https://weread.qq.com/web/reader/0ad32f70813ab7e98g019115?chapterUid=4&rangeStart=8782&rangeEnd=8814"
    },
    {
      "bookmarkId": "3300061689_5_2710-2753",
      "chapterUid": 5,
      "range": "2710-2753",
      "markText": "学习英语语言文学可以令人们满足于维持政治现状，从而令财富无重新分配之虞。",
      "totalCount": 168,
      "appLink": "weread://bestbookmark?bookId=3300061689&chapterUid=5&rangeStart=2710&rangeEnd=2753",
      "webLink": "https://weread.qq.com/web/reader/0ad32f70813ab7e98g019115?chapterUid=5&rangeStart=2710&rangeEnd=2753"
    },
    {
      "bookmarkId": "3300061689_5_7329-7362",
      "chapterUid": 5,
      "range": "7329-7362",
      "markText": "利维斯的想法是：够格的读者理应凭借自身之力发现利维斯所发现的东西。",
      "totalCount": 165,
      "appLink": "weread://bestbookmark?bookId=3300061689&chapterUid=5&rangeStart=7329&rangeEnd=7362",
      "webLink": "https://weread.qq.com/web/reader/0ad32f70813ab7e98g019115?chapterUid=5&rangeStart=7329&rangeEnd=7362"
    },
    {
      "bookmarkId": "3300061689_6_5349-5378",
      "chapterUid": 6,
      "range": "5349-5378",
      "markText": "能不能想出语言构建现实而不仅仅给已存在事物命名的其他例子？",
      "totalCount": 165,
      "appLink": "weread://bestbookmark?bookId=3300061689&chapterUid=6&rangeStart=5349&rangeEnd=5378",
      "webLink": "https://weread.qq.com/web/reader/0ad32f70813ab7e98g019115?chapterUid=6&rangeStart=5349&rangeEnd=5378"
    },
    {
      "bookmarkId": "3300061689_5_18473-18519",
      "chapterUid": 5,
      "range": "18473-18519",
      "markText": "他更倾向不把诗歌视为个人情感和经验的倾泻，而是以传统超越个人，诗人个人仅仅是传达传统的媒介。",
