  "content": [
    {
      "chapterUid": 3,
      "chapterTitle": "“描绘人内心的全部深度”",
      "items": [
        {
          "type": "highlight",
          "bookmarkId": "31808217_3_1084-1143",
          "range": "1084-1143",
          "rangeStart": 1084,
          "rangeEnd": 1143,
          "markText": "当一个人物成了大众的话题，他就成为各种思想的载体、对话的平台，人们会借他的名声来说自己的话，使它成为话题的注释或旁证。",
          "colorStyle": 0,
          "colorLabel": "",
          "createTime": 1733965186,
          "createTimeFormatted": "2024-12-12 08:59:46",
          "chapterUid": 3,
          "appLink": "weread://bestbookmark?bookId=31808217&chapterUid=3&rangeStart=1084&rangeEnd=1143",
          "webLink": "https://weread.qq.com/web/reader/fc63252071e55ad9fc6f8d7?chapterUid=3&rangeStart=1084&rangeEnd=1143"
