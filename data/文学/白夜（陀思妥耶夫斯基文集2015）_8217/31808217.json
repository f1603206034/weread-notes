  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "31808217_13_2601-2638",
      "chapterUid": 13,
      "range": "2601-2638",
      "markText": "我的上帝！那是足足一分钟的欣悦啊！这难道还不够一个人受用整整一辈子吗？……",
      "totalCount": 6743,
      "appLink": "weread://bestbookmark?bookId=31808217&chapterUid=13&rangeStart=2601&rangeEnd=2638",
      "webLink": "https://weread.qq.com/web/reader/fc63252071e55ad9fc6f8d7?chapterUid=13&rangeStart=2601&rangeEnd=2638"
    },
    {
      "bookmarkId": "31808217_31_8844-8857",
      "chapterUid": 31,
      "range": "8844-8857",
      "markText": "明天，明天一切都将见分晓！",
      "totalCount": 5148,
      "appLink": "weread://bestbookmark?bookId=31808217&chapterUid=31&rangeStart=8844&rangeEnd=8857",
      "webLink": "https://weread.qq.com/web/reader/fc63252071e55ad9fc6f8d7?chapterUid=31&rangeStart=8844&rangeEnd=8857"
    },
    {
      "bookmarkId": "31808217_8_367-459",
      "chapterUid": 8,
      "range": "367-459",
      "markText": "那是一个奇妙的夜晚，亲爱的读者，只有当我们年轻的时候，才能有这样的夜晚。星珠错落的天空如此明亮，只要仰首一望，便情不自禁地要问一问自己：在这样的天空下，难道会有各种发脾气、使性子的人？",
      "totalCount": 3094,
      "appLink": "weread://bestbookmark?bookId=31808217&chapterUid=8&rangeStart=367&rangeEnd=459",
      "webLink": "https://weread.qq.com/web/reader/fc63252071e55ad9fc6f8d7?chapterUid=8&rangeStart=367&rangeEnd=459"
    },
    {
      "bookmarkId": "31808217_6_36893-36924",
      "chapterUid": 6,
      "range": "36893-36924",
      "markText": "不幸是一种传染病。不幸的穷人就得互相避开，免得让病再传来传去。",
      "totalCount": 2752,
      "appLink": "weread://bestbookmark?bookId=31808217&chapterUid=6&rangeStart=36893&rangeEnd=36924",
      "webLink": "https://weread.qq.com/web/reader/fc63252071e55ad9fc6f8d7?chapterUid=6&rangeStart=36893&rangeEnd=36924"
    },
    {
      "bookmarkId": "31808217_8_7903-7990",
      "chapterUid": 8,
      "range": "7903-7990",
      "markText": "我是个幻想家；我在现实生活中拥有的太少了，所以我把像现在这样的时刻看得非常珍贵，不可能不在幻想中重温这几分钟。我将在幻想中怀念您，在幻想中度过整整一夜、整整一星期、整整一年。",
      "totalCount": 2748,
      "appLink": "weread://bestbookmark?bookId=31808217&chapterUid=8&rangeStart=7903&rangeEnd=7990",
      "webLink": "https://weread.qq.com/web/reader/fc63252071e55ad9fc6f8d7?chapterUid=8&rangeStart=7903&rangeEnd=7990"
    },
    {
      "bookmarkId": "31808217_12_8383-8413",
      "chapterUid": 12,
      "range": "8383-8413",
      "markText": "我久久地站在那里目送着他们……最后，他俩都从我的视野中消失。",
      "totalCount": 2350,
      "appLink": "weread://bestbookmark?bookId=31808217&chapterUid=12&rangeStart=8383&rangeEnd=8413",
      "webLink": "https://weread.qq.com/web/reader/fc63252071e55ad9fc6f8d7?chapterUid=12&rangeStart=8383&rangeEnd=8413"
    },
    {
      "bookmarkId": "31808217_6_14196-14216",
      "chapterUid": 6,
      "range": "14196-14216",
      "markText": "我的不幸是从波克罗夫斯基的病和死开始的。",
      "totalCount": 2223,
      "appLink": "weread://bestbookmark?bookId=31808217&chapterUid=6&rangeStart=14196&rangeEnd=14216",
      "webLink": "https://weread.qq.com/web/reader/fc63252071e55ad9fc6f8d7?chapterUid=6&rangeStart=14196&rangeEnd=14216"
    },
    {
      "bookmarkId": "31808217_11_1345-1390",
      "chapterUid": 11,
      "range": "1345-1390",
      "markText": "的确，当我们自己不幸的时候，我们对别人的不幸感受更加深切；感情的趋向不是分散，而是集中……",
      "totalCount": 2088,
      "appLink": "weread://bestbookmark?bookId=31808217&chapterUid=11&rangeStart=1345&rangeEnd=1390",
      "webLink": "https://weread.qq.com/web/reader/fc63252071e55ad9fc6f8d7?chapterUid=11&rangeStart=1345&rangeEnd=1390"
    },
    {
      "bookmarkId": "31808217_12_4967-5036",
      "chapterUid": 12,
      "range": "4967-5036",
      "markText": "是的，我爱您！像您爱我一样地爱您；以前我自己就明明对您说过这话，您亲耳听到的，——我爱您，因为您比他好，因为您比他高尚，因为，因为他……”",
      "totalCount": 2070,
      "appLink": "weread://bestbookmark?bookId=31808217&chapterUid=12&rangeStart=4967&rangeEnd=5036",
      "webLink": "https://weread.qq.com/web/reader/fc63252071e55ad9fc6f8d7?chapterUid=12&rangeStart=4967&rangeEnd=5036"
