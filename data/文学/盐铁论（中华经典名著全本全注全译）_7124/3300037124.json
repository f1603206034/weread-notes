  ],
  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300037124_3_3833-3928",
      "chapterUid": 3,
      "range": "3833-3928",
      "markText": "这说明即使是在汉武帝尊儒之后，汉家官方学术思想并不是一刀切，君主往往会出于朝政的需要而进行调整，台面上所说和台下所行并非完全一致。或许汉宣帝所说的“汉家霸王道杂之”更符合汉家官方思想的实际。",
      "totalCount": 1152,
      "appLink": "weread://bestbookmark?bookId=3300037124&chapterUid=3&rangeStart=3833&rangeEnd=3928",
      "webLink": "https://weread.qq.com/web/reader/f6632810813ab7500g014bed?chapterUid=3&rangeStart=3833&rangeEnd=3928"
    },
    {
      "bookmarkId": "3300037124_3_3048-3119",
      "chapterUid": 3,
      "range": "3048-3119",
      "markText": "文学、贤良高举孔子修文德以来远的旗帜，主张朝廷放弃武力，运用文教德化的方法来感化远方异族，与匈奴和亲，用道德感化的力量使匈奴主动前来归附汉家。",
      "totalCount": 1128,
      "appLink": "weread://bestbookmark?bookId=3300037124&chapterUid=3&rangeStart=3048&rangeEnd=3119",
      "webLink": "https://weread.qq.com/web/reader/f6632810813ab7500g014bed?chapterUid=3&rangeStart=3048&rangeEnd=3119"
    },
    {
      "bookmarkId": "3300037124_3_1166-1252",
      "chapterUid": 3,
      "range": "1166-1252",
      "markText": "所谓均输，是在郡国设置均输官，负责收取各地民众向朝廷进贡的土特产品，再拿到附近价高的地方出售，将钱交给中央。所谓平准，是中央设置平准官，用价低买进、价高卖出的方法平抑物价。",
      "totalCount": 960,
      "appLink": "weread://bestbookmark?bookId=3300037124&chapterUid=3&rangeStart=1166&rangeEnd=1252",
      "webLink": "https://weread.qq.com/web/reader/f6632810813ab7500g014bed?chapterUid=3&rangeStart=1166&rangeEnd=1252"
    },
    {
      "bookmarkId": "3300037124_4_5788-5805",
      "chapterUid": 4,
      "range": "5788-5805",
      "markText": "王者行仁政，无敌于天下，恶用费哉？",
      "totalCount": 765,
      "appLink": "weread://bestbookmark?bookId=3300037124&chapterUid=4&rangeStart=5788&rangeEnd=5805",
      "webLink": "https://weread.qq.com/web/reader/f6632810813ab7500g014bed?chapterUid=4&rangeStart=5788&rangeEnd=5805"
    },
    {
      "bookmarkId": "3300037124_4_3355-3430",
      "chapterUid": 4,
      "range": "3355-3430",
      "markText": "铁官营、酒类专卖和均输官署，与老百姓争利益。这样做会破坏老百姓敦朴忠厚的自然天性，形成贪婪卑鄙的风气。所以老百姓从事农业根本的人少，追逐工商末利的人多",
      "totalCount": 576,
      "appLink": "weread://bestbookmark?bookId=3300037124&chapterUid=4&rangeStart=3355&rangeEnd=3430",
      "webLink": "https://weread.qq.com/web/reader/f6632810813ab7500g014bed?chapterUid=4&rangeStart=3355&rangeEnd=3430"
    },
    {
      "bookmarkId": "3300037124_4_702-743",
      "chapterUid": 4,
      "range": "702-743",
      "markText": "文学对此提出反驳，认为朝廷应该运用文教和德化的方法来感化远方异族，而不能诉诸武力。",
      "totalCount": 528,
      "appLink": "weread://bestbookmark?bookId=3300037124&chapterUid=4&rangeStart=702&rangeEnd=743",
      "webLink": "https://weread.qq.com/web/reader/f6632810813ab7500g014bed?chapterUid=4&rangeStart=702&rangeEnd=743"
