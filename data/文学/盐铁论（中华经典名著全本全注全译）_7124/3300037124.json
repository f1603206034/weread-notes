      "chapterUid": 4,
      "chapterTitle": "卷一",
      "items": [
        {
          "type": "highlight",
          "bookmarkId": "3300037124_4_5411-5438",
          "range": "5411-5438",
          "rangeStart": 5411,
          "rangeEnd": 5438,
          "markText": "孔子曰：‘有国有家者，不患贫而患不均，不患寡而患不安。",
          "colorStyle": 2,
          "colorLabel": "",
          "createTime": 1758769777,
          "createTimeFormatted": "2025-09-25 11:09:37",
