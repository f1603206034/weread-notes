      "appLink": "weread://bestbookmark?bookId=23796430&chapterUid=34&rangeStart=2326&rangeEnd=2404",
      "webLink": "https://weread.qq.com/web/reader/72732010716b1ace727c0f1?chapterUid=34&rangeStart=2326&rangeEnd=2404"
    },
    {
