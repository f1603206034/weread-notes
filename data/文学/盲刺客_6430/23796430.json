      "appLink": "weread://bestbookmark?bookId=23796430&chapterUid=10&rangeStart=4159&rangeEnd=4220",
      "webLink": "https://weread.qq.com/web/reader/72732010716b1ace727c0f1?chapterUid=10&rangeStart=4159&rangeEnd=4220"
    },
    {
