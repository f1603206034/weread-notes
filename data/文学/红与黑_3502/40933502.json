  "content": [
    {
      "chapterUid": 187,
      "chapterTitle": "第28章 人间贫富",
      "items": [
        {
          "type": "highlight",
          "bookmarkId": "40933502_29_1162-1271",
          "range": "1183-1292",
          "rangeStart": 1183,
          "rangeEnd": 1292,
          "markText": "我们的主角自以为考虑周到，其实他所走的第一步都有点冒失，像选忏悔神甫一样。善于想象的人很自负，常常迷失方向，把意愿当成现实，以为自己口是心非，工夫已经很到家了。他甚至愚蠢到了这个地步，居然责备自己表现软弱而取得的胜利。",
          "colorStyle": 1,
          "colorLabel": "",
          "createTime": 1692598463,
          "createTimeFormatted": "2023-08-21 14:14:23",
          "chapterUid": 187,
          "appLink": "weread://bestbookmark?bookId=40933502&chapterUid=187&rangeStart=1183&rangeEnd=1292",
          "webLink": "https://weread.qq.com/web/reader/71d32c107270987e71dd9a5?chapterUid=187&rangeStart=1183&rangeEnd=1292"
        }
      ]
    },
    {
      "chapterUid": 183,
      "chapterTitle": "第24章 一八三〇年的风气",
      "items": [
        {
          "type": "highlight",
          "bookmarkId": "40933502_25_419-430",
          "range": "440-451",
          "rangeStart": 440,
          "rangeEnd": 451,
          "markText": "语言是用来掩盖思想的。",
          "colorStyle": 1,
          "colorLabel": "",
          "createTime": 1692598462,
          "createTimeFormatted": "2023-08-21 14:14:22",
          "chapterUid": 183,
          "appLink": "weread://bestbookmark?bookId=40933502&chapterUid=183&rangeStart=440&rangeEnd=451",
          "webLink": "https://weread.qq.com/web/reader/71d32c107270987e71dd9a5?chapterUid=183&rangeStart=440&rangeEnd=451"
        }
      ]
    },
    {
      "chapterUid": 188,
      "chapterTitle": "第29章 初入人世",
      "items": [
        {
          "type": "highlight",
          "bookmarkId": "40933502_30_2567-2728",
          "range": "2588-2749",
          "rangeStart": 2588,
          "rangeEnd": 2749,
          "markText": "大约就在这个时候，于连以为可以利用德·梅斯特的《教皇论》，来使人看重自己了。说实话，他的确使同学们大吃一惊，但这又活该他自己倒霉。谁叫他讲他们的意见，讲得比他们自己还清楚呢！谢朗先生对于连、对自己都忽略了一件事。在培养了于连正确推理、不说空话的习惯之后，忘了告诉他，地位不高的人有这种习惯就有罪，因为正确推理总会得罪人的。",
          "colorStyle": 1,
          "colorLabel": "",
          "createTime": 1692598461,
          "createTimeFormatted": "2023-08-21 14:14:21",
          "chapterUid": 188,
          "appLink": "weread://bestbookmark?bookId=40933502&chapterUid=188&rangeStart=2588&rangeEnd=2749",
          "webLink": "https://weread.qq.com/web/reader/71d32c107270987e71dd9a5?chapterUid=188&rangeStart=2588&rangeEnd=2749"
        }
      ]
    }
  ],
  "bookReviews": [],
  "hotBookmarks": [
