  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "928623_2_0-21",
      "chapterUid": 2,
      "range": "0-21",
      "markText": "谁能够与自己的痛苦和孤寂毫无遗憾地分手呢？",
      "totalCount": 1512,
      "appLink": "",
      "webLink": ""
    },
    {
      "bookmarkId": "928623_2_3053-3110",
      "chapterUid": 2,
      "range": "3053-3110",
      "markText": "爱，除了自己，既不给予，也不索取。 爱，既不占有，也不被任何人占有。 爱，仅仅满足于自己而已。",
      "totalCount": 864,
      "appLink": "weread://bestbookmark?bookId=928623&chapterUid=2&rangeStart=3053&rangeEnd=3110",
      "webLink": "https://weread.qq.com/web/reader/037329b05e2b6f037163b57?chapterUid=2&rangeStart=3053&rangeEnd=3110"
    },
    {
      "bookmarkId": "928623_2_1820-1841",
      "chapterUid": 2,
      "range": "1820-1841",
      "markText": "爱总是这样，不知其深，除非到了别离的时辰。",
      "totalCount": 810,
      "appLink": "weread://bestbookmark?bookId=928623&chapterUid=2&rangeStart=1820&rangeEnd=1841",
      "webLink": "https://weread.qq.com/web/reader/037329b05e2b6f037163b57?chapterUid=2&rangeStart=1820&rangeEnd=1841"
    },
    {
      "bookmarkId": "928623_46_14990-15013",
      "chapterUid": 46,
      "range": "14990-15013",
      "markText": "你的欢乐或忧伤一变大，世界在你的眼里就变小了。",
      "totalCount": 576,
      "appLink": "weread://bestbookmark?bookId=928623&chapterUid=46&rangeStart=14990&rangeEnd=15013",
      "webLink": "https://weread.qq.com/web/reader/037329b05e2b6f037163b57?chapterUid=46&rangeStart=14990&rangeEnd=15013"
    },
    {
      "bookmarkId": "928623_2_252-306",
      "chapterUid": 2,
      "range": "252-306",
      "markText": "我在这座城郭里度过的痛苦白天是漫长的，我所度过的孤寂之夜是漫长的。谁能够与自己的痛苦和孤寂毫无遗憾地分手呢？",
      "totalCount": 470,
      "appLink": "weread://bestbookmark?bookId=928623&chapterUid=2&rangeStart=252&rangeEnd=306",
      "webLink": "https://weread.qq.com/web/reader/037329b05e2b6f037163b57?chapterUid=2&rangeStart=252&rangeEnd=306"
    },
    {
      "bookmarkId": "928623_2_4908-4944",
      "chapterUid": 2,
      "range": "4908-4944",
      "markText": "你真有什么必须保留的东西吗？ 终有一天，你的一切所有都要给人。",
      "totalCount": 432,
      "appLink": "weread://bestbookmark?bookId=928623&chapterUid=2&rangeStart=4908&rangeEnd=4944",
      "webLink": "https://weread.qq.com/web/reader/037329b05e2b6f037163b57?chapterUid=2&rangeStart=4908&rangeEnd=4944"
    },
    {
      "bookmarkId": "928623_2_1077-1115",
      "chapterUid": 2,
      "range": "1077-1115",
      "markText": "莫非离别之日正是聚会之时？ 我的夕阳西下之时，果真是朝阳东升之时？",
