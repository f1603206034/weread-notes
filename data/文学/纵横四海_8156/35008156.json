      "appLink": "weread://bestbookmark?bookId=35008156&chapterUid=10&rangeStart=3417&rangeEnd=3484",
      "webLink": "https://weread.qq.com/web/reader/fbc3233072162e9cfbc8e79?chapterUid=10&rangeStart=3417&rangeEnd=3484"
