  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300092182_3_3888-3966",
      "chapterUid": 3,
      "range": "3888-3966",
      "markText": "另一方面，埃热先生比他的第二位夫人小五岁；那所学校看来又是这位夫人的资产；如此“屈居人下”，如果他感到“压抑”的话，便很有可能主动接近夏洛蒂，引为红粉知己。",
      "totalCount": 576,
      "appLink": "weread://bestbookmark?bookId=3300092182&chapterUid=3&rangeStart=3888&rangeEnd=3966",
      "webLink": "https://weread.qq.com/web/reader/65c32620813ab8a82g01257a?chapterUid=3&rangeStart=3888&rangeEnd=3966"
    },
    {
      "bookmarkId": "3300092182_5_1403-1464",
      "chapterUid": 5,
      "range": "1403-1464",
      "markText": "在我的教母的身边，时间总是平静地流过——并不是哗哗地、迅速地流，而是平淡无奇地流，好比一条水位高涨的河静静地流过一个平原。",
      "totalCount": 240,
      "appLink": "weread://bestbookmark?bookId=3300092182&chapterUid=5&rangeStart=1403&rangeEnd=1464",
      "webLink": "https://weread.qq.com/web/reader/65c32620813ab8a82g01257a?chapterUid=5&rangeStart=1403&rangeEnd=1464"
    },
    {
      "bookmarkId": "3300092182_6_581-743",
      "chapterUid": 6,
      "range": "581-743",
      "markText": "没有一个待在欧洲的对跖地而怀念着欧洲的背井离乡的成年人那愁眉深锁的脸上曾经挂着比她那稚嫩的脸上更多明显可见的乡愁之情。",
      "totalCount": 216,
      "appLink": "weread://bestbookmark?bookId=3300092182&chapterUid=6&rangeStart=581&rangeEnd=743",
      "webLink": "https://weread.qq.com/web/reader/65c32620813ab8a82g01257a?chapterUid=6&rangeStart=581&rangeEnd=743"
    },
    {
      "bookmarkId": "3300092182_3_6999-7046",
      "chapterUid": 3,
      "range": "6999-7046",
      "markText": "把《维莱特》看做是一部李代桃僵的作者心心念念要奉献给她的老师埃热先生的一部作品，大概并不为过。",
      "totalCount": 208,
      "appLink": "weread://bestbookmark?bookId=3300092182&chapterUid=3&rangeStart=6999&rangeEnd=7046",
      "webLink": "https://weread.qq.com/web/reader/65c32620813ab8a82g01257a?chapterUid=3&rangeStart=6999&rangeEnd=7046"
    },
    {
      "bookmarkId": "3300092182_3_1472-1527",
      "chapterUid": 3,
      "range": "1472-1527",
      "markText": "却不料从1848年的秋天到1849年的春天的八个月之内，勃兰威尔、艾米莉和安妮三人相继在青春年少时死于结核病。",
      "totalCount": 198,
      "appLink": "weread://bestbookmark?bookId=3300092182&chapterUid=3&rangeStart=1472&rangeEnd=1527",
      "webLink": "https://weread.qq.com/web/reader/65c32620813ab8a82g01257a?chapterUid=3&rangeStart=1472&rangeEnd=1527"
    },
    {
      "bookmarkId": "3300092182_5_1186-1218",
      "chapterUid": 5,
      "range": "1186-1218",
      "markText": "她的那种状态和同等情况的精神，这对于拥有者说来，比一笔财产更好。",
      "totalCount": 195,
      "appLink": "weread://bestbookmark?bookId=3300092182&chapterUid=5&rangeStart=1186&rangeEnd=1218",
      "webLink": "https://weread.qq.com/web/reader/65c32620813ab8a82g01257a?chapterUid=5&rangeStart=1186&rangeEnd=1218"
    },
    {
      "bookmarkId": "3300092182_25_903-964",
      "chapterUid": 25,
      "range": "903-964",
      "markText": "我认为自己一定不能穿；我认为没有哪个人能够有力量迫使我穿上它。一件粉红色的连衣裙哪！我不认识它。它也不认识我。我不要穿它。",
      "totalCount": 192,
      "appLink": "weread://bestbookmark?bookId=3300092182&chapterUid=25&rangeStart=903&rangeEnd=964",
      "webLink": "https://weread.qq.com/web/reader/65c32620813ab8a82g01257a?chapterUid=25&rangeStart=903&rangeEnd=964"
    },
    {
      "bookmarkId": "3300092182_3_1830-1878",
      "chapterUid": 3,
      "range": "1830-1878",
      "markText": "她们三姐妹原来有个习惯，在晚饭后绕着餐桌踱步，一个跟着一个，一面走，一面交流写作心得，互提意见。",
      "totalCount": 187,
      "appLink": "weread://bestbookmark?bookId=3300092182&chapterUid=3&rangeStart=1830&rangeEnd=1878",
      "webLink": "https://weread.qq.com/web/reader/65c32620813ab8a82g01257a?chapterUid=3&rangeStart=1830&rangeEnd=1878"
    },
    {
      "bookmarkId": "3300092182_16_4113-4156",
      "chapterUid": 16,
      "range": "4113-4156",
      "markText": "我的希望不是热衷于得到，不是饥不择食，而只不过是想冷眼旁观新事物的一种平静的愿望而已。",
      "totalCount": 187,
      "appLink": "weread://bestbookmark?bookId=3300092182&chapterUid=16&rangeStart=4113&rangeEnd=4156",
      "webLink": "https://weread.qq.com/web/reader/65c32620813ab8a82g01257a?chapterUid=16&rangeStart=4113&rangeEnd=4156"
    },
    {
      "bookmarkId": "3300092182_18_2286-2353",
      "chapterUid": 18,
      "range": "2286-2353",
      "markText": "教会努力把它的孩子们教养成躯体健壮、灵魂柔弱、脑满肠肥、红光满面、精神抖擞、喜气洋洋、愚昧无知、没有思想、不会提问的人。",
      "totalCount": 180,
      "appLink": "weread://bestbookmark?bookId=3300092182&chapterUid=18&rangeStart=2286&rangeEnd=2353",
      "webLink": "https://weread.qq.com/web/reader/65c32620813ab8a82g01257a?chapterUid=18&rangeStart=2286&rangeEnd=2353"
    },
    {
      "bookmarkId": "3300092182_3_829-894",
      "chapterUid": 3,
      "range": "829-894",
      "markText": "结婚前后动笔写小说《爱玛》，未能完成，婚后只九个月便受疾病折磨，留下几章残篇，于春寒料峭的3月31日匆匆离开了人世，年仅三十九岁。",
      "totalCount": 169,
      "appLink": "weread://bestbookmark?bookId=3300092182&chapterUid=3&rangeStart=829&rangeEnd=894",
      "webLink": "https://weread.qq.com/web/reader/65c32620813ab8a82g01257a?chapterUid=3&rangeStart=829&rangeEnd=894"
    },
    {
      "bookmarkId": "3300092182_3_1307-1407",
      "chapterUid": 3,
      "range": "1307-1407",
      "markText": "夏洛蒂的《简·爱》于1847年由史密斯—埃尔德公司出版以后，艾米莉的名著《呼啸山庄》和安妮的《艾格妮丝·格雷》也于同年由纽比公司以作者负担一部分费用的苛刻条件出版。第二年，安妮又出版了小说《女房客》。",
      "totalCount": 165,
      "appLink": "weread://bestbookmark?bookId=3300092182&chapterUid=3&rangeStart=1307&rangeEnd=1407",
      "webLink": "https://weread.qq.com/web/reader/65c32620813ab8a82g01257a?chapterUid=3&rangeStart=1307&rangeEnd=1407"
    },
    {
      "bookmarkId": "3300092182_10_970-1009",
      "chapterUid": 10,
      "range": "970-1009",
      "markText": "除了懦夫，还有谁愿意在小村庄里度过一生，让自己的才能在默默无闻之中腐蚀锈烂呢？",
      "totalCount": 162,
      "appLink": "weread://bestbookmark?bookId=3300092182&chapterUid=10&rangeStart=970&rangeEnd=1009",
      "webLink": "https://weread.qq.com/web/reader/65c32620813ab8a82g01257a?chapterUid=10&rangeStart=970&rangeEnd=1009"
    },
    {
      "bookmarkId": "3300092182_3_1166-1199",
      "chapterUid": 3,
      "range": "1166-1199",
      "markText": "弟弟后来一事无成，自甘堕落，浪掷了自己的才华，也辜负了家人的希望。",
      "totalCount": 160,
      "appLink": "weread://bestbookmark?bookId=3300092182&chapterUid=3&rangeStart=1166&rangeEnd=1199",
      "webLink": "https://weread.qq.com/web/reader/65c32620813ab8a82g01257a?chapterUid=3&rangeStart=1166&rangeEnd=1199"
    },
    {
      "bookmarkId": "3300092182_3_4265-4320",
      "chapterUid": 3,
      "range": "4265-4320",
      "markText": "夏洛蒂身材娇小瘦弱，但是性格坚韧刚毅，很有主见，再加上长期艰难和孤独生活的磨练，她是一位深情而又不易动情的人。",
      "totalCount": 160,
      "appLink": "weread://bestbookmark?bookId=3300092182&chapterUid=3&rangeStart=4265&rangeEnd=4320",
      "webLink": "https://weread.qq.com/web/reader/65c32620813ab8a82g01257a?chapterUid=3&rangeStart=4265&rangeEnd=4320"
    },
    {
      "bookmarkId": "3300092182_3_6057-6111",
      "chapterUid": 3,
      "range": "6057-6111",
      "markText": "弗洛伊德派心理学者认为文艺是被压抑欲望的升华。厨川白村认为：“生命力受了压抑而生的苦闷懊恼乃是文艺的根底。”",
      "totalCount": 156,
      "appLink": "weread://bestbookmark?bookId=3300092182&chapterUid=3&rangeStart=6057&rangeEnd=6111",
      "webLink": "https://weread.qq.com/web/reader/65c32620813ab8a82g01257a?chapterUid=3&rangeStart=6057&rangeEnd=6111"
    },
    {
      "bookmarkId": "3300092182_43_19695-19952",
      "chapterUid": 43,
      "range": "19695-19952",
      "markText": "总而言之，格雷厄姆和波琳娜这两位的生活幸福美满，就像雅各所喜欢的儿子那样，有“天上所有的福，地里所藏的福”，我这样说的时候，不过是说出了真情实况而已。事情正是如此，因为上帝认为这样好。",
      "totalCount": 153,
      "appLink": "weread://bestbookmark?bookId=3300092182&chapterUid=43&rangeStart=19695&rangeEnd=19952",
      "webLink": "https://weread.qq.com/web/reader/65c32620813ab8a82g01257a?chapterUid=43&rangeStart=19695&rangeEnd=19952"
    },
    {
      "bookmarkId": "3300092182_6_7463-7482",
      "chapterUid": 6,
      "range": "7463-7482",
      "markText": "不过也许你迟迟不睡是为了期待看见我吧？",
      "totalCount": 150,
      "appLink": "weread://bestbookmark?bookId=3300092182&chapterUid=6&rangeStart=7463&rangeEnd=7482",
      "webLink": "https://weread.qq.com/web/reader/65c32620813ab8a82g01257a?chapterUid=6&rangeStart=7463&rangeEnd=7482"
    },
    {
      "bookmarkId": "3300092182_8_1328-1384",
      "chapterUid": 8,
      "range": "1328-1384",
      "markText": "我不认为自己具有一种自力更生或者主动活跃的性格；可是环境逼迫我去自力更生和努力奋斗，就像逼迫千万个其他的人一样。",
      "totalCount": 150,
      "appLink": "weread://bestbookmark?bookId=3300092182&chapterUid=8&rangeStart=1328&rangeEnd=1384",
      "webLink": "https://weread.qq.com/web/reader/65c32620813ab8a82g01257a?chapterUid=8&rangeStart=1328&rangeEnd=1384"
    },
    {
