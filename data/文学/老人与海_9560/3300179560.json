      "appLink": "weread://bestbookmark?bookId=3300179560&chapterUid=6&rangeStart=19113&rangeEnd=19212",
      "webLink": "https://weread.qq.com/web/reader/46532e00813abaca4g010be6?chapterUid=6&rangeStart=19113&rangeEnd=19212"
    },
    {
