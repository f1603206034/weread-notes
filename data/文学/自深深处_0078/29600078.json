  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "29600078_4_4029-4102",
      "chapterUid": 4,
      "range": "4029-4102",
      "markText": "一切人际纽带（不管是婚姻还是友谊）说到底都是一场交谈，而交谈必须有共同基础，在文化修养程度极不对等的两个人之间，唯一可能的基础就是最低层次的一种。",
      "totalCount": 1360,
      "appLink": "weread://bestbookmark?bookId=29600078&chapterUid=4&rangeStart=4029&rangeEnd=4102",
      "webLink": "https://weread.qq.com/web/reader/2133298071c3a94e2131b61?chapterUid=4&rangeStart=4029&rangeEnd=4102"
    },
    {
      "bookmarkId": "29600078_4_375-428",
      "chapterUid": 4,
      "range": "375-428",
      "markText": "但我自责最甚的是任由你把我带到精神高度荡然无存的境地。人格的基础是意志力，我却让自己的意志力完全臣服于你。",
      "totalCount": 1335,
      "appLink": "weread://bestbookmark?bookId=29600078&chapterUid=4&rangeStart=375&rangeEnd=428",
      "webLink": "https://weread.qq.com/web/reader/2133298071c3a94e2131b61?chapterUid=4&rangeStart=375&rangeEnd=428"
    },
    {
      "bookmarkId": "29600078_13_856-930",
      "chapterUid": 13,
      "range": "856-930",
      "markText": "我不能容许你因为毁了像我这样一个人而一辈子背负着良心的包袱。这包袱有可能会让你变成行尸走肉，或是让你惨痛不堪。我必须把它从你那儿挪走，往自己肩上扛。",
      "totalCount": 1328,
      "appLink": "weread://bestbookmark?bookId=29600078&chapterUid=13&rangeStart=856&rangeEnd=930",
      "webLink": "https://weread.qq.com/web/reader/2133298071c3a94e2131b61?chapterUid=13&rangeStart=856&rangeEnd=930"
    },
    {
      "bookmarkId": "29600078_5_4412-4469",
      "chapterUid": 5,
      "range": "4412-4469",
      "markText": "因为你绝对相信，不管你干了些什么，总是会得到我的原谅（说真的，这是我最喜欢你的地方，或许也是你身上最美好的部分）。",
      "totalCount": 1312,
      "appLink": "weread://bestbookmark?bookId=29600078&chapterUid=5&rangeStart=4412&rangeEnd=4469",
      "webLink": "https://weread.qq.com/web/reader/2133298071c3a94e2131b61?chapterUid=5&rangeStart=4412&rangeEnd=4469"
    },
    {
      "bookmarkId": "29600078_3_2542-2565",
      "chapterUid": 3,
      "range": "2542-2565",
      "markText": "有你在我身边的全部时间里，我不曾创作出一行字。",
      "totalCount": 1230,
      "appLink": "weread://bestbookmark?bookId=29600078&chapterUid=3&rangeStart=2542&rangeEnd=2565",
      "webLink": "https://weread.qq.com/web/reader/2133298071c3a94e2131b61?chapterUid=3&rangeStart=2542&rangeEnd=2565"
    },
    {
      "bookmarkId": "29600078_3_1319-1341",
      "chapterUid": 3,
      "range": "1319-1341",
      "markText": "你的人生毫无动机可言，有的只是吃喝玩乐之思。",
      "totalCount": 1215,
      "appLink": "weread://bestbookmark?bookId=29600078&chapterUid=3&rangeStart=1319&rangeEnd=1341",
      "webLink": "https://weread.qq.com/web/reader/2133298071c3a94e2131b61?chapterUid=3&rangeStart=1319&rangeEnd=1341"
    },
    {
      "bookmarkId": "29600078_9_3320-3389",
      "chapterUid": 9,
      "range": "3320-3389",
      "markText": "但爱不是市场里的买卖品，不能用小贩的秤来论斤算两。就像知性之乐一样，爱会因为感受到自身的存在而喜乐。爱的目的——不多也不少——就是付出爱。",
      "totalCount": 1056,
      "appLink": "weread://bestbookmark?bookId=29600078&chapterUid=9&rangeStart=3320&rangeEnd=3389",
      "webLink": "https://weread.qq.com/web/reader/2133298071c3a94e2131b61?chapterUid=9&rangeStart=3320&rangeEnd=3389"
    },
    {
      "bookmarkId": "29600078_8_686-758",
      "chapterUid": 8,
      "range": "686-758",
      "markText": "我会回忆起那些我们散步走过的街道或桥梁，回忆起曾围绕我们的每一片墙壁或树林，回忆起大钟指针指着某个数字，回忆起风吹的方向，还有月亮的形状和颜色。",
      "totalCount": 990,
      "appLink": "weread://bestbookmark?bookId=29600078&chapterUid=8&rangeStart=686&rangeEnd=758",
      "webLink": "https://weread.qq.com/web/reader/2133298071c3a94e2131b61?chapterUid=8&rangeStart=686&rangeEnd=758"
    },
    {
      "bookmarkId": "29600078_11_2145-2224",
      "chapterUid": 11,
      "range": "2145-2224",
      "markText": "痛苦是一个长长的瞬间，它不知道何谓季节，它只由种种心绪构成，而这些心绪总是回环往复。在我们这种人身上，时间是不会向前前进的。它只会旋转，绕着一个痛苦中心打转。",
      "totalCount": 912,
      "appLink": "weread://bestbookmark?bookId=29600078&chapterUid=11&rangeStart=2145&rangeEnd=2224",
      "webLink": "https://weread.qq.com/web/reader/2133298071c3a94e2131b61?chapterUid=11&rangeStart=2145&rangeEnd=2224"
    },
    {
      "bookmarkId": "29600078_3_473-573",
      "chapterUid": 3,
      "range": "473-573",
      "markText": "经过漫长和徒劳的等待之后，我决定主动写信给你。此举既是为你着想，也是为我自己着想，因为我不乐于看到，在漫长的两年监禁期满后，还是收不到你写的一行字，或是得不到任何你的消息或口信（那些让我伤心的不算）。",
      "totalCount": 885,
      "appLink": "weread://bestbookmark?bookId=29600078&chapterUid=3&rangeStart=473&rangeEnd=573",
      "webLink": "https://weread.qq.com/web/reader/2133298071c3a94e2131b61?chapterUid=3&rangeStart=473&rangeEnd=573"
    },
    {
      "bookmarkId": "29600078_3_1222-1259",
      "chapterUid": 3,
      "range": "1222-1259",
      "markText": "如果你现在找到一个借口，便很快会找到一百个借口，让自己安于当那个原来的你。",
      "totalCount": 884,
      "appLink": "weread://bestbookmark?bookId=29600078&chapterUid=3&rangeStart=1222&rangeEnd=1259",
      "webLink": "https://weread.qq.com/web/reader/2133298071c3a94e2131b61?chapterUid=3&rangeStart=1222&rangeEnd=1259"
    },
    {
      "bookmarkId": "29600078_3_2263-2320",
      "chapterUid": 3,
      "range": "2263-2320",
      "markText": "我怪自己任由一段毫无知性成分的友谊主宰我的人生，任由一段不是以创造和沉思美丽事物为首要目标的友谊完全主宰我的人生。",
      "totalCount": 884,
      "appLink": "weread://bestbookmark?bookId=29600078&chapterUid=3&rangeStart=2263&rangeEnd=2320",
      "webLink": "https://weread.qq.com/web/reader/2133298071c3a94e2131b61?chapterUid=3&rangeStart=2263&rangeEnd=2320"
    },
    {
      "bookmarkId": "29600078_3_1705-1765",
      "chapterUid": 3,
      "range": "1705-1765",
      "markText": "真正的蠢材是缺乏自知之明的人（诸神专嘲笑或加害这种人）。我有很长一段时间曾是这种人。你当这种人迄今已很长时间，别再当了。",
      "totalCount": 840,
      "appLink": "weread://bestbookmark?bookId=29600078&chapterUid=3&rangeStart=1705&rangeEnd=1765",
      "webLink": "https://weread.qq.com/web/reader/2133298071c3a94e2131b61?chapterUid=3&rangeStart=1705&rangeEnd=1765"
    },
    {
      "bookmarkId": "29600078_4_1758-1789",
      "chapterUid": 4,
      "range": "1758-1789",
      "markText": "人生其实无所谓大事小事之分，每件事都是同等的价值和同等的规模。",
      "totalCount": 742,
      "appLink": "weread://bestbookmark?bookId=29600078&chapterUid=4&rangeStart=1758&rangeEnd=1789",
      "webLink": "https://weread.qq.com/web/reader/2133298071c3a94e2131b61?chapterUid=4&rangeStart=1758&rangeEnd=1789"
    },
    {
      "bookmarkId": "29600078_6_1426-1459",
      "chapterUid": 6,
      "range": "1426-1459",
      "markText": "你固然在我病中对我不仁，但我不容许自己在你处于丧兄之痛中对你不义。",
      "totalCount": 720,
      "appLink": "weread://bestbookmark?bookId=29600078&chapterUid=6&rangeStart=1426&rangeEnd=1459",
      "webLink": "https://weread.qq.com/web/reader/2133298071c3a94e2131b61?chapterUid=6&rangeStart=1426&rangeEnd=1459"
    },
    {
      "bookmarkId": "29600078_4_3033-3055",
      "chapterUid": 4,
      "range": "3033-3055",
      "markText": "但我的错不在没有离开你，而在离开过你太多次。",
      "totalCount": 688,
      "appLink": "weread://bestbookmark?bookId=29600078&chapterUid=4&rangeStart=3033&rangeEnd=3055",
      "webLink": "https://weread.qq.com/web/reader/2133298071c3a94e2131b61?chapterUid=4&rangeStart=3033&rangeEnd=3055"
    },
    {
      "bookmarkId": "29600078_5_3326-3404",
      "chapterUid": 5,
      "range": "3326-3404",
      "markText": "因为你不爱吃饭店提供的水果，我便跑到伦敦买来上好的葡萄。我还编些故事说给你听，使你解颐，要睡也是睡你旁边或隔壁房间。每个晚上我都坐在旁边陪你哄你，让你安心。",
      "totalCount": 688,
      "appLink": "weread://bestbookmark?bookId=29600078&chapterUid=5&rangeStart=3326&rangeEnd=3404",
      "webLink": "https://weread.qq.com/web/reader/2133298071c3a94e2131b61?chapterUid=5&rangeStart=3326&rangeEnd=3404"
