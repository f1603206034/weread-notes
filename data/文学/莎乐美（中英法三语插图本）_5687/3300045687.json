  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300045687_14_18949-18965",
      "chapterUid": 14,
      "range": "18949-18965",
      "markText": "邪恶就是通过女人才来到这世上的。",
      "totalCount": 234,
      "appLink": "weread://bestbookmark?bookId=3300045687&chapterUid=14&rangeStart=18949&rangeEnd=18965",
      "webLink": "https://weread.qq.com/web/reader/886322f0813ab7858g017333?chapterUid=14&rangeStart=18949&rangeEnd=18965"
    },
    {
      "bookmarkId": "3300045687_7_410-508",
      "chapterUid": 7,
      "range": "410-508",
      "markText": "王尔德的艺术功力还体现在他把自己的思想观念、艺术主张和艺术手法与一个现成的故事进行了巧妙的嫁接，塑造出了真实可信的故事与生动丰满的人物，让人在看完此剧之后，生出了“事情或人物本来就是这样”的幻觉。",
      "totalCount": 119,
      "appLink": "weread://bestbookmark?bookId=3300045687&chapterUid=7&rangeStart=410&rangeEnd=508",
      "webLink": "https://weread.qq.com/web/reader/886322f0813ab7858g017333?chapterUid=7&rangeStart=410&rangeEnd=508"
    },
    {
      "bookmarkId": "3300045687_14_34319-34387",
      "chapterUid": 14,
      "range": "34319-34387",
      "markText": "我可不想让他做出这种事来。我不许他做这种事。我不允许任何人将死了的人活转过来。给我找到这个人，告诉他我不允许他让死人复活。他现在在哪儿？",
      "totalCount": 112,
      "appLink": "weread://bestbookmark?bookId=3300045687&chapterUid=14&rangeStart=34319&rangeEnd=34387",
      "webLink": "https://weread.qq.com/web/reader/886322f0813ab7858g017333?chapterUid=14&rangeStart=34319&rangeEnd=34387"
    },
    {
      "bookmarkId": "3300045687_14_18369-18428",
      "chapterUid": 14,
      "range": "18369-18428",
      "markText": "上帝的天使啊，你们为什么带着剑出现在这里？你们到这罪恶的宫殿里来寻找谁？……那位将穿着银袍死去的人，他的死期还未至呢。",
      "totalCount": 105,
      "appLink": "weread://bestbookmark?bookId=3300045687&chapterUid=14&rangeStart=18369&rangeEnd=18428",
      "webLink": "https://weread.qq.com/web/reader/886322f0813ab7858g017333?chapterUid=14&rangeStart=18369&rangeEnd=18428"
    },
    {
      "bookmarkId": "3300045687_14_14781-14820",
      "chapterUid": 14,
      "range": "14781-14820",
      "markText": "哦，月亮的样子多奇怪啊！就像一位死了的妇人伸出手来，要找一块裹尸布来盖住自己。",
      "totalCount": 80,
      "appLink": "weread://bestbookmark?bookId=3300045687&chapterUid=14&rangeStart=14781&rangeEnd=14820",
      "webLink": "https://weread.qq.com/web/reader/886322f0813ab7858g017333?chapterUid=14&rangeStart=14781&rangeEnd=14820"
    },
    {
      "bookmarkId": "3300045687_14_22037-22050",
      "chapterUid": 14,
      "range": "22037-22050",
      "markText": "我会吻到你的嘴唇的，约翰。",
      "totalCount": 75,
      "appLink": "weread://bestbookmark?bookId=3300045687&chapterUid=14&rangeStart=22037&rangeEnd=22050",
      "webLink": "https://weread.qq.com/web/reader/886322f0813ab7858g017333?chapterUid=14&rangeStart=22037&rangeEnd=22050"
    },
    {
      "bookmarkId": "3300045687_14_24925-24948",
      "chapterUid": 14,
      "range": "24925-24948",
      "markText": "真奇怪，我还以为只有罗马的哲学家们才会自杀呢。",
      "totalCount": 72,
      "appLink": "weread://bestbookmark?bookId=3300045687&chapterUid=14&rangeStart=24925&rangeEnd=24948",
      "webLink": "https://weread.qq.com/web/reader/886322f0813ab7858g017333?chapterUid=14&rangeStart=24925&rangeEnd=24948"
    },
    {
      "bookmarkId": "3300045687_14_30023-30060",
      "chapterUid": 14,
      "range": "30023-30060",
      "markText": "上帝的确是强大的，他对弱者和强者一视同仁地予以摧毁，从不对任何人另眼相看。",
      "totalCount": 72,
      "appLink": "weread://bestbookmark?bookId=3300045687&chapterUid=14&rangeStart=30023&rangeEnd=30060",
      "webLink": "https://weread.qq.com/web/reader/886322f0813ab7858g017333?chapterUid=14&rangeStart=30023&rangeEnd=30060"
    },
    {
      "bookmarkId": "3300045687_14_1269-1316",
      "chapterUid": 14,
      "range": "1269-1316",
      "markText": "你看这月亮啊，今晚的月亮瞧上去有点怪，她就像是一个从坟墓里爬起来的女人，像一个已经死了的女人。",
      "totalCount": 70,
      "appLink": "weread://bestbookmark?bookId=3300045687&chapterUid=14&rangeStart=1269&rangeEnd=1316",
      "webLink": "https://weread.qq.com/web/reader/886322f0813ab7858g017333?chapterUid=14&rangeStart=1269&rangeEnd=1316"
    },
    {
      "bookmarkId": "3300045687_14_19688-19697",
      "chapterUid": 14,
      "range": "19688-19697",
      "markText": "不许你玷污主的庙宇",
      "totalCount": 70,
      "appLink": "weread://bestbookmark?bookId=3300045687&chapterUid=14&rangeStart=19688&rangeEnd=19697",
      "webLink": "https://weread.qq.com/web/reader/886322f0813ab7858g017333?chapterUid=14&rangeStart=19688&rangeEnd=19697"
    },
    {
      "bookmarkId": "3300045687_14_18710-18742",
      "chapterUid": 14,
      "range": "18710-18742",
      "markText": "约翰！你的身体洁白无瑕，就像刈割者从未光顾过的田地上种着的百合。",
      "totalCount": 68,
      "appLink": "weread://bestbookmark?bookId=3300045687&chapterUid=14&rangeStart=18710&rangeEnd=18742",
      "webLink": "https://weread.qq.com/web/reader/886322f0813ab7858g017333?chapterUid=14&rangeStart=18710&rangeEnd=18742"
    },
    {
      "bookmarkId": "3300045687_14_22301-22324",
      "chapterUid": 14,
      "range": "22301-22324",
      "markText": "我会吻到你的嘴唇的，约翰。我会吻到你的嘴唇的。",
      "totalCount": 68,
      "appLink": "weread://bestbookmark?bookId=3300045687&chapterUid=14&rangeStart=22301&rangeEnd=22324",
      "webLink": "https://weread.qq.com/web/reader/886322f0813ab7858g017333?chapterUid=14&rangeStart=22301&rangeEnd=22324"
    },
    {
      "bookmarkId": "3300045687_14_53362-53424",
      "chapterUid": 14,
      "range": "53362-53424",
      "markText": "啊！你为什么不看我呢，约翰？你把自己的脸藏在了你的双手和你满口的诅咒后面。你满心想着见你的上帝，这使你的双眼犹如蒙上了绑带。",
      "totalCount": 68,
      "appLink": "weread://bestbookmark?bookId=3300045687&chapterUid=14&rangeStart=53362&rangeEnd=53424",
      "webLink": "https://weread.qq.com/web/reader/886322f0813ab7858g017333?chapterUid=14&rangeStart=53362&rangeEnd=53424"
    },
    {
      "bookmarkId": "3300045687_14_9555-9623",
      "chapterUid": 14,
      "range": "9555-9623",
      "markText": "……我敢肯定她依旧是处子之身，因为她有着一种处子的美……对，她是一位处子，从未被人玷污过。她就像其他的女神一样，从来都没有让男人染指过。",
      "totalCount": 65,
      "appLink": "weread://bestbookmark?bookId=3300045687&chapterUid=14&rangeStart=9555&rangeEnd=9623",
      "webLink": "https://weread.qq.com/web/reader/886322f0813ab7858g017333?chapterUid=14&rangeStart=9555&rangeEnd=9623"
    },
    {
      "bookmarkId": "3300045687_14_35978-35988",
      "chapterUid": 14,
      "range": "35978-35988",
      "markText": "可他没提你的名字啊。",
      "totalCount": 65,
      "appLink": "weread://bestbookmark?bookId=3300045687&chapterUid=14&rangeStart=35978&rangeEnd=35988",
      "webLink": "https://weread.qq.com/web/reader/886322f0813ab7858g017333?chapterUid=14&rangeStart=35978&rangeEnd=35988"
    },
    {
      "bookmarkId": "3300045687_14_8541-8575",
      "chapterUid": 14,
      "range": "8541-8575",
      "markText": "她就像一只迷路的鸽子……一朵绽放在风中的水仙花……一朵银白色的花朵。",
      "totalCount": 64,
      "appLink": "weread://bestbookmark?bookId=3300045687&chapterUid=14&rangeStart=8541&rangeEnd=8575",
      "webLink": "https://weread.qq.com/web/reader/886322f0813ab7858g017333?chapterUid=14&rangeStart=8541&rangeEnd=8575"
    },
    {
      "bookmarkId": "3300045687_14_26053-26135",
      "chapterUid": 14,
      "range": "26053-26135",
      "markText": "希律王： 我跟你们说有风……我还听到空中有翅膀扇动的声音，像是很大的翅膀在扇动。你们听见了吗？",
      "totalCount": 64,
      "appLink": "weread://bestbookmark?bookId=3300045687&chapterUid=14&rangeStart=26053&rangeEnd=26135",
      "webLink": "https://weread.qq.com/web/reader/886322f0813ab7858g017333?chapterUid=14&rangeStart=26053&rangeEnd=26135"
    },
    {
      "bookmarkId": "3300045687_14_35286-35346",
      "chapterUid": 14,
      "range": "35286-35346",
      "markText": "啊！淫妇！娼妓！啊！那有着金色眼睛，画着金色眼睑的巴比伦的女儿！上帝这样说，让她遇到一大群人，让他们都拿起石头向她掷来。",
      "totalCount": 64,
      "appLink": "weread://bestbookmark?bookId=3300045687&chapterUid=14&rangeStart=35286&rangeEnd=35346",
      "webLink": "https://weread.qq.com/web/reader/886322f0813ab7858g017333?chapterUid=14&rangeStart=35286&rangeEnd=35346"
    },
    {
      "bookmarkId": "3300045687_7_1046-1135",
