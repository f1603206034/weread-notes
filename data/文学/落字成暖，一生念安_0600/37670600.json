    },
    {
      "bookmarkId": "37670600_44_5916-5947",
      "chapterUid": 44,
      "range": "5916-5947",
      "markText": "春天不是读书天，夏日炎炎正好眠，秋有蚊虫冬有雪，收拾书包好过年",
      "totalCount": 2312,
      "appLink": "weread://bestbookmark?bookId=37670600&chapterUid=44&rangeStart=5916&rangeEnd=5947",
