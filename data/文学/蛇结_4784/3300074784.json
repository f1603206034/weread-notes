  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300074784_8_5680-5751",
      "chapterUid": 8,
      "range": "5680-5751",
      "markText": "他不让会你幸福，是因为他帅、他有魅力、他人见人爱。也就是说，幸亏我长着一张不争气的脸，外表看起来不好相处、拒人于千里之外，所以能给你带来安心。",
      "totalCount": 3555,
      "appLink": "weread://bestbookmark?bookId=3300074784&chapterUid=8&rangeStart=5680&rangeEnd=5751",
      "webLink": "https://weread.qq.com/web/reader/e77328b0813ab83b6g014aea?chapterUid=8&rangeStart=5680&rangeEnd=5751"
    },
    {
      "bookmarkId": "3300074784_6_951-982",
      "chapterUid": 6,
      "range": "951-982",
      "markText": "于是我二十一岁就坐拥两千公顷蓬勃生长并已经能够出产矿柱的森林。",
      "totalCount": 3495,
      "appLink": "weread://bestbookmark?bookId=3300074784&chapterUid=6&rangeStart=951&rangeEnd=982",
      "webLink": "https://weread.qq.com/web/reader/e77328b0813ab83b6g014aea?chapterUid=6&rangeStart=951&rangeEnd=982"
    },
    {
      "bookmarkId": "3300074784_8_3712-3747",
      "chapterUid": 8,
      "range": "3712-3747",
      "markText": "你没有向我描述他的长相，但我一下子便将我自身不具备的所有魅力赋予了他。",
      "totalCount": 2772,
      "appLink": "weread://bestbookmark?bookId=3300074784&chapterUid=8&rangeStart=3712&rangeEnd=3747",
      "webLink": "https://weread.qq.com/web/reader/e77328b0813ab83b6g014aea?chapterUid=8&rangeStart=3712&rangeEnd=3747"
    },
    {
      "bookmarkId": "3300074784_5_1401-1440",
      "chapterUid": 5,
      "range": "1401-1440",
      "markText": "我这一生都在做出牺牲，这些记忆腐蚀着我，滋养并壮大着我心中与日俱增的那种怨恨。",
      "totalCount": 2702,
      "appLink": "weread://bestbookmark?bookId=3300074784&chapterUid=5&rangeStart=1401&rangeEnd=1440",
      "webLink": "https://weread.qq.com/web/reader/e77328b0813ab83b6g014aea?chapterUid=5&rangeStart=1401&rangeEnd=1440"
    },
    {
      "bookmarkId": "3300074784_5_5302-5356",
      "chapterUid": 5,
      "range": "5302-5356",
      "markText": "我最后再试一次。或许，我死了比活着时更能拿住你，至少在我死后的几个星期里，我会在你的生命里重新占有一席之地。",
      "totalCount": 2541,
      "appLink": "weread://bestbookmark?bookId=3300074784&chapterUid=5&rangeStart=5302&rangeEnd=5356",
      "webLink": "https://weread.qq.com/web/reader/e77328b0813ab83b6g014aea?chapterUid=5&rangeStart=5302&rangeEnd=5356"
    },
    {
      "bookmarkId": "3300074784_5_3448-3513",
      "chapterUid": 5,
      "range": "3448-3513",
      "markText": "只有为数不多的人有机会于当下的现实和目光所及之处重现昨日的世界。大多数人即便有足够的勇气与耐心，也只能在脑海里苦苦追忆旧日的光景。",
      "totalCount": 2340,
      "appLink": "weread://bestbookmark?bookId=3300074784&chapterUid=5&rangeStart=3448&rangeEnd=3513",
      "webLink": "https://weread.qq.com/web/reader/e77328b0813ab83b6g014aea?chapterUid=5&rangeStart=3448&rangeEnd=3513"
    },
    {
      "bookmarkId": "3300074784_8_5444-5539",
      "chapterUid": 8,
      "range": "5444-5539",
      "markText": "你曾多次对我表示自己当然无怨无悔。我任由你说下去。我屏住呼吸。即使跟那个鲁道夫在一起，你也不会幸福的，你很肯定地说。他太帅了，他不爱别人，他只有被爱的份儿。随便一个女人就能把他从你手里抢走。",
      "totalCount": 2261,
      "appLink": "weread://bestbookmark?bookId=3300074784&chapterUid=8&rangeStart=5444&rangeEnd=5539",
      "webLink": "https://weread.qq.com/web/reader/e77328b0813ab83b6g014aea?chapterUid=8&rangeStart=5444&rangeEnd=5539"
    },
    {
      "bookmarkId": "3300074784_7_4438-4537",
      "chapterUid": 7,
      "range": "4438-4537",
      "markText": "很是奇怪，在我们人生之初刚刚得到一点儿幸福的眷顾时，竟不会有人给我们提个醒，告诉我们：“不管你活到多少岁，你也不过只享有这几个小时的快乐。好好品味吧，品味得一点儿渣滓不剩，因为过后什么都将荡然无存。",
      "totalCount": 2142,
      "appLink": "weread://bestbookmark?bookId=3300074784&chapterUid=7&rangeStart=4438&rangeEnd=4537",
      "webLink": "https://weread.qq.com/web/reader/e77328b0813ab83b6g014aea?chapterUid=7&rangeStart=4438&rangeEnd=4537"
    },
    {
      "bookmarkId": "3300074784_5_800-837",
      "chapterUid": 5,
      "range": "800-837",
      "markText": "很长一段时间，我一直都觉得自己身上最有活力的，就数对你们咬牙切齿的恨意了。",
      "totalCount": 1970,
      "appLink": "weread://bestbookmark?bookId=3300074784&chapterUid=5&rangeStart=800&rangeEnd=837",
      "webLink": "https://weread.qq.com/web/reader/e77328b0813ab83b6g014aea?chapterUid=5&rangeStart=800&rangeEnd=837"
    },
    {
      "bookmarkId": "3300074784_5_1678-1758",
      "chapterUid": 5,
      "range": "1678-1758",
      "markText": "但是，想想有多少家庭，夫妻二人每日相互恼怒，相互憎恶，却还要在同张桌子上吃饭，对着同一个洗手池洗漱，在同一床被褥下入睡，反正就是鲜少有人离婚，真是令人啧啧称奇。",
      "totalCount": 1950,
      "appLink": "weread://bestbookmark?bookId=3300074784&chapterUid=5&rangeStart=1678&rangeEnd=1758",
      "webLink": "https://weread.qq.com/web/reader/e77328b0813ab83b6g014aea?chapterUid=5&rangeStart=1678&rangeEnd=1758"
    },
    {
      "bookmarkId": "3300074784_7_1897-1917",
      "chapterUid": 7,
      "range": "1897-1917",
      "markText": "我最初偷偷喜欢的并不是你，而是你的母亲。",
      "totalCount": 1860,
      "appLink": "weread://bestbookmark?bookId=3300074784&chapterUid=7&rangeStart=1897&rangeEnd=1917",
      "webLink": "https://weread.qq.com/web/reader/e77328b0813ab83b6g014aea?chapterUid=7&rangeStart=1897&rangeEnd=1917"
    },
