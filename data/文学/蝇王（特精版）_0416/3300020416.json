      "totalCount": 255,
      "appLink": "weread://bestbookmark?bookId=3300020416&chapterUid=13&rangeStart=10250&rangeEnd=10270",
      "webLink": "https://weread.qq.com/web/reader/f83321b0813ab6e79g016622?chapterUid=13&rangeStart=10250&rangeEnd=10270"
    },
    {
