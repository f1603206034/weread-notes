    {
      "chapterUid": 14,
      "chapterTitle": "魏风",
      "items": [
        {
          "type": "highlight",
          "bookmarkId": "31580169_14_17152-18240",
          "range": "17152-18229",
          "rangeStart": 17152,
          "rangeEnd": 18229,
          "markText": "硕鼠硕鼠，\n无食我黍！\n三岁贯女，\n莫我肯顾。\n逝将去女，\n适彼乐土。\n乐土乐土，\n爰得我所！\n硕鼠硕鼠，\n无食我麦！\n三岁贯女，\n莫我肯德。\n逝将去女，\n适彼乐国。\n乐国乐国，\n爰得我直！\n硕鼠硕鼠，\n无食我苗！\n三岁贯女，\n莫我肯劳。\n逝将去女，\n适彼乐郊。\n乐郊乐郊，\n谁之永号！",
          "colorStyle": 2,
          "colorLabel": "",
          "createTime": 1746504125,
          "createTimeFormatted": "2025-05-06 12:02:05",
          "chapterUid": 14,
          "appLink": "weread://bestbookmark?bookId=31580169&chapterUid=14&rangeStart=17152&rangeEnd=18229",
          "webLink": "https://weread.qq.com/web/reader/4703254071e1e00947050bc?chapterUid=14&rangeStart=17152&rangeEnd=18229"
        }
