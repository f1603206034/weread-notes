          "colorLabel": "",
          "createTime": 1758942050,
          "createTimeFormatted": "2025-09-27 11:00:50",
          "chapterUid": 22,
          "appLink": "weread://bestbookmark?bookId=31580169&chapterUid=22&rangeStart=95068&rangeEnd=95295",
