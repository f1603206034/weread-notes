  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "24275321_3_1725-1773",
      "chapterUid": 3,
      "range": "1725-1773",
      "markText": "我大体上欢喜冷静、沉着、稳重、刚毅，以出世精神做入世事业，尊崇理性和意志，却也不菲薄情感和想象。",
      "totalCount": 855,
      "appLink": "weread://bestbookmark?bookId=24275321&chapterUid=3&rangeStart=1725&rangeEnd=1773",
      "webLink": "https://weread.qq.com/web/reader/66032910717269796609561?chapterUid=3&rangeStart=1725&rangeEnd=1773"
    },
    {
      "bookmarkId": "24275321_4_1232-1262",
      "chapterUid": 4,
      "range": "1232-1262",
      "markText": "今日有理想的青年到明日往往变成屈服于事实而抛弃理想的堕落者。",
      "totalCount": 782,
      "appLink": "weread://bestbookmark?bookId=24275321&chapterUid=4&rangeStart=1232&rangeEnd=1262",
      "webLink": "https://weread.qq.com/web/reader/66032910717269796609561?chapterUid=4&rangeStart=1232&rangeEnd=1262"
    },
    {
      "bookmarkId": "24275321_4_2189-2282",
      "chapterUid": 4,
      "range": "2189-2282",
      "markText": "世间事之难就难在人们不知道或是不能够转一个念头，或是转了念头而没有力量坚持到底。幸福的世界里绝没有愚蠢者、怯懦者和懒惰者的地位。你要合理地生存，你就要有觉悟、有决心、有奋斗的精神和能力。",
      "totalCount": 780,
      "appLink": "weread://bestbookmark?bookId=24275321&chapterUid=4&rangeStart=2189&rangeEnd=2282",
      "webLink": "https://weread.qq.com/web/reader/66032910717269796609561?chapterUid=4&rangeStart=2189&rangeEnd=2282"
    },
    {
      "bookmarkId": "24275321_4_4426-4513",
      "chapterUid": 4,
      "range": "4426-4513",
      "markText": "第二，个人在社会中如果不能成为有力的分子，则个人无出路，国家民族也无出路。要个人在社会中成为有力的分子，必须有德、有学、有才，而德行、学问、才具都须经过艰苦的努力才可以得到。",
      "totalCount": 450,
      "appLink": "weread://bestbookmark?bookId=24275321&chapterUid=4&rangeStart=4426&rangeEnd=4513",
      "webLink": "https://weread.qq.com/web/reader/66032910717269796609561?chapterUid=4&rangeStart=4426&rangeEnd=4513"
    },
    {
      "bookmarkId": "24275321_4_1131-1199",
      "chapterUid": 4,
      "range": "1131-1199",
      "markText": "青年们常欢喜把社会一切毛病归咎于站在台上的人们，其实在台上的人们也还是受过同样的教育，经过同样的青年阶段，他们也曾同样地埋怨过前一辈人。",
      "totalCount": 425,
      "appLink": "weread://bestbookmark?bookId=24275321&chapterUid=4&rangeStart=1131&rangeEnd=1199",
      "webLink": "https://weread.qq.com/web/reader/66032910717269796609561?chapterUid=4&rangeStart=1131&rangeEnd=1199"
    },
    {
      "bookmarkId": "24275321_8_531-554",
      "chapterUid": 8,
      "range": "531-554",
      "markText": "大学教育在使人有正确的价值意识，知道权衡轻重。",
      "totalCount": 406,
      "appLink": "weread://bestbookmark?bookId=24275321&chapterUid=8&rangeStart=531&rangeEnd=554",
      "webLink": "https://weread.qq.com/web/reader/66032910717269796609561?chapterUid=8&rangeStart=531&rangeEnd=554"
    },
    {
      "bookmarkId": "24275321_4_1473-1533",
      "chapterUid": 4,
      "range": "1473-1533",
      "markText": "这一辈人睁着眼睛蹈前一辈人的覆辙，下一辈人仍然睁着眼睛蹈这一辈人的覆辙，如此循环辗转，一报还一报，“长夜漫漫何时旦”呢？",
      "totalCount": 396,
      "appLink": "weread://bestbookmark?bookId=24275321&chapterUid=4&rangeStart=1473&rangeEnd=1533",
      "webLink": "https://weread.qq.com/web/reader/66032910717269796609561?chapterUid=4&rangeStart=1473&rangeEnd=1533"
    },
    {
      "bookmarkId": "24275321_5_1539-1556",
      "chapterUid": 5,
      "range": "1539-1556",
      "markText": "普通人的毛病在责人太严，责己太宽。",
      "totalCount": 396,
      "appLink": "weread://bestbookmark?bookId=24275321&chapterUid=5&rangeStart=1539&rangeEnd=1556",
      "webLink": "https://weread.qq.com/web/reader/66032910717269796609561?chapterUid=5&rangeStart=1539&rangeEnd=1556"
    },
    {
      "bookmarkId": "24275321_5_2236-2295",
      "chapterUid": 5,
      "range": "2236-2295",
      "markText": "“有志者事竟成”的“志”，须包含这三种意义在内：第一要起念头，其次要认清目的和达到目的之方法，第三是抱必达目的之决心。",
      "totalCount": 390,
      "appLink": "weread://bestbookmark?bookId=24275321&chapterUid=5&rangeStart=2236&rangeEnd=2295",
      "webLink": "https://weread.qq.com/web/reader/66032910717269796609561?chapterUid=5&rangeStart=2236&rangeEnd=2295"
    },
    {
      "bookmarkId": "24275321_9_1162-1179",
      "chapterUid": 9,
      "range": "1162-1179",
      "markText": "“是非只因多开口，烦恼皆由强出头”",
      "totalCount": 352,
      "appLink": "weread://bestbookmark?bookId=24275321&chapterUid=9&rangeStart=1162&rangeEnd=1179",
      "webLink": "https://weread.qq.com/web/reader/66032910717269796609561?chapterUid=9&rangeStart=1162&rangeEnd=1179"
    },
    {
      "bookmarkId": "24275321_19_1924-1994",
      "chapterUid": 19,
      "range": "1924-1994",
      "markText": "在30岁以前，一个人假如不受爱情的搅扰，对男女间事不发生很大的兴趣，专心致志地去做他的学问，那是再好没有的事，他可以多得些成就，少得些苦恼。",
      "totalCount": 330,
      "appLink": "weread://bestbookmark?bookId=24275321&chapterUid=19&rangeStart=1924&rangeEnd=1994",
      "webLink": "https://weread.qq.com/web/reader/66032910717269796609561?chapterUid=19&rangeStart=1924&rangeEnd=1994"
    },
    {
      "bookmarkId": "24275321_19_3162-3219",
      "chapterUid": 19,
      "range": "3162-3219",
      "markText": "一个青年如果有亲热的家庭生活，加上温暖的团体生活，不感觉到孤寂，他虽然还有“遇”恋爱的可能，却无“谋”恋爱的必要。",
      "totalCount": 324,
      "appLink": "weread://bestbookmark?bookId=24275321&chapterUid=19&rangeStart=3162&rangeEnd=3219",
      "webLink": "https://weread.qq.com/web/reader/66032910717269796609561?chapterUid=19&rangeStart=3162&rangeEnd=3219"
    },
    {
      "bookmarkId": "24275321_7_4420-4505",
      "chapterUid": 7,
      "range": "4420-4505",
      "markText": "我并不敢菲薄现代青年，我总觉得现代青年大半仍在鼓里过日子，没有明白自己的责任，更不肯出死力去尽自己的责任，多数人徒以学校为进身干禄之阶，品格固不砥砺，学问也止于浅尝肤受。",
      "totalCount": 312,
      "appLink": "weread://bestbookmark?bookId=24275321&chapterUid=7&rangeStart=4420&rangeEnd=4505",
      "webLink": "https://weread.qq.com/web/reader/66032910717269796609561?chapterUid=7&rangeStart=4420&rangeEnd=4505"
    },
    {
      "bookmarkId": "24275321_15_4578-4659",
      "chapterUid": 15,
      "range": "4578-4659",
      "markText": "学校教育，在我想，只有两个重要的功用：第一是启发兴趣，其次就是指点门径。现在一般学校不在这两方面努力，只尽量灌输死板的知识。这种教育对于学问不仅无裨益而且是障碍！",
      "totalCount": 308,
      "appLink": "weread://bestbookmark?bookId=24275321&chapterUid=15&rangeStart=4578&rangeEnd=4659",
      "webLink": "https://weread.qq.com/web/reader/66032910717269796609561?chapterUid=15&rangeStart=4578&rangeEnd=4659"
    },
    {
      "bookmarkId": "24275321_9_7348-7388",
      "chapterUid": 9,
      "range": "7348-7388",
      "markText": "我始终坚信苏格拉底的一句老话：“知识即德行。”凡是德行缺陷，必定由于知识不彻底。",
