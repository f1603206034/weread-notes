  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300016951_4_18846-18873",
      "chapterUid": 4,
      "range": "18846-18873",
      "markText": "此人性至察而心不明。夫心暗则照有不通，至察则多疑于物。",
      "totalCount": 36,
      "appLink": "weread://bestbookmark?bookId=3300016951&chapterUid=4&rangeStart=18846&rangeEnd=18873",
      "webLink": "https://weread.qq.com/web/reader/ea032f70813ab6d1fg0111ca?chapterUid=4&rangeStart=18846&rangeEnd=18873"
    },
    {
      "bookmarkId": "3300016951_4_23727-23763",
      "chapterUid": 4,
      "range": "23727-23763",
      "markText": "玉虽有美质，在于石间，不值良工琢磨，与瓦砾不别。若遇良工，即为万代之宝。",
      "totalCount": 34,
      "appLink": "weread://bestbookmark?bookId=3300016951&chapterUid=4&rangeStart=23727&rangeEnd=23763",
      "webLink": "https://weread.qq.com/web/reader/ea032f70813ab6d1fg0111ca?chapterUid=4&rangeStart=23727&rangeEnd=23763"
    },
    {
      "bookmarkId": "3300016951_5_6120-6175",
      "chapterUid": 5,
      "range": "6120-6175",
      "markText": "公独不见金之在矿，何足贵哉？良冶锻而为器，便为人所宝。朕方自比于金，以卿为良工。虽有疾，未为衰老，岂得便尔耶？",
      "totalCount": 34,
      "appLink": "weread://bestbookmark?bookId=3300016951&chapterUid=5&rangeStart=6120&rangeEnd=6175",
      "webLink": "https://weread.qq.com/web/reader/ea032f70813ab6d1fg0111ca?chapterUid=5&rangeStart=6120&rangeEnd=6175"
    },
    {
      "bookmarkId": "3300016951_4_23076-23116",
      "chapterUid": 4,
      "range": "23076-23116",
      "markText": "凡人在危困，则忧死亡。忧死亡，则思化。思化，则易教，然则乱后易教，犹饥人易食也。",
      "totalCount": 26,
      "appLink": "weread://bestbookmark?bookId=3300016951&chapterUid=4&rangeStart=23076&rangeEnd=23116",
      "webLink": "https://weread.qq.com/web/reader/ea032f70813ab6d1fg0111ca?chapterUid=4&rangeStart=23076&rangeEnd=23116"
    },
    {
      "bookmarkId": "3300016951_4_1436-1533",
      "chapterUid": 4,
      "range": "1436-1533",
      "markText": "如果一味讲究吃喝，沉溺于音乐女色，欲望越多，损害也就越大，既妨碍政事，又扰害百姓。如果再说出一些不合事理的话来，就会弄得人心涣散，怨言四起，众叛亲离。每当我想到这些，就不敢放纵取乐、贪图安逸了。",
      "totalCount": 24,
      "appLink": "weread://bestbookmark?bookId=3300016951&chapterUid=4&rangeStart=1436&rangeEnd=1533",
      "webLink": "https://weread.qq.com/web/reader/ea032f70813ab6d1fg0111ca?chapterUid=4&rangeStart=1436&rangeEnd=1533"
    },
    {
      "bookmarkId": "3300016951_4_18236-18263",
      "chapterUid": 4,
      "range": "18236-18263",
      "markText": "若唯署诏敕、行文书而已，人谁不堪？何烦简择，以相委付？",
      "totalCount": 24,
      "appLink": "weread://bestbookmark?bookId=3300016951&chapterUid=4&rangeStart=18236&rangeEnd=18263",
      "webLink": "https://weread.qq.com/web/reader/ea032f70813ab6d1fg0111ca?chapterUid=4&rangeStart=18236&rangeEnd=18263"
    },
    {
      "bookmarkId": "3300016951_5_58884-58974",
      "chapterUid": 5,
      "range": "58884-58974",
      "markText": "但愿陛下使臣为良臣，勿使臣为忠臣。”太宗曰：“忠良有异乎？”徵曰：“良臣使身获美名，君受显号。子孙传世，福禄无疆。忠臣身受诛夷，君陷大恶。家国并丧，独有其名。以此而言，相去远矣。”",
      "totalCount": 24,
      "appLink": "weread://bestbookmark?bookId=3300016951&chapterUid=5&rangeStart=58884&rangeEnd=58974",
      "webLink": "https://weread.qq.com/web/reader/ea032f70813ab6d1fg0111ca?chapterUid=5&rangeStart=58884&rangeEnd=58974"
    },
    {
      "bookmarkId": "3300016951_4_1722-1743",
      "chapterUid": 4,
      "range": "1722-1743",
      "markText": "君之所以明者，兼听也；其所以暗者，偏信也。",
      "totalCount": 22,
      "appLink": "weread://bestbookmark?bookId=3300016951&chapterUid=4&rangeStart=1722&rangeEnd=1743",
      "webLink": "https://weread.qq.com/web/reader/ea032f70813ab6d1fg0111ca?chapterUid=4&rangeStart=1722&rangeEnd=1743"
    },
    {
      "bookmarkId": "3300016951_4_9672-9696",
      "chapterUid": 4,
      "range": "9672-9696",
      "markText": "奔车朽索〔8〕，其可忽乎！",
      "totalCount": 22,
      "appLink": "weread://bestbookmark?bookId=3300016951&chapterUid=4&rangeStart=9672&rangeEnd=9696",
      "webLink": "https://weread.qq.com/web/reader/ea032f70813ab6d1fg0111ca?chapterUid=4&rangeStart=9672&rangeEnd=9696"
    },
    {
      "bookmarkId": "3300016951_4_10016-10043",
      "chapterUid": 4,
      "range": "10016-10043",
      "markText": "何必劳神苦思，代下司职，役聪明之耳目，亏无为之大道哉！",
      "totalCount": 22,
      "appLink": "weread://bestbookmark?bookId=3300016951&chapterUid=4&rangeStart=10016&rangeEnd=10043",
      "webLink": "https://weread.qq.com/web/reader/ea032f70813ab6d1fg0111ca?chapterUid=4&rangeStart=10016&rangeEnd=10043"
