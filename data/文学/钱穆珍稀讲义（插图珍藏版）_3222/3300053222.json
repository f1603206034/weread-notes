  ],
  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300053222_9_11914-11983",
      "chapterUid": 9,
      "range": "11914-11983",
      "markText": "中国人要立国，东南方并不可怕，汉、唐、宋、清历朝以来，永久的大敌在西北。故此后仍应注意西北方。林则徐流放新疆时，说将来大敌非美国而是俄国。",
      "totalCount": 51,
      "appLink": "weread://bestbookmark?bookId=3300053222&chapterUid=9&rangeStart=11914&rangeEnd=11983",
      "webLink": "https://weread.qq.com/web/reader/4ea32bd0813ab7b4ag0128ba?chapterUid=9&rangeStart=11914&rangeEnd=11983"
    },
    {
      "bookmarkId": "3300053222_8_5927-5997",
      "chapterUid": 8,
      "range": "5927-5997",
      "markText": "封建是周公所发明，没有封建，就无周朝。尊王攘夷霸诸侯是管仲发明。故今日需要有一个人出来讲一句话打开时代的僵局。只要能发明一句，便是大政治家。",
      "totalCount": 48,
      "appLink": "weread://bestbookmark?bookId=3300053222&chapterUid=8&rangeStart=5927&rangeEnd=5997",
      "webLink": "https://weread.qq.com/web/reader/4ea32bd0813ab7b4ag0128ba?chapterUid=8&rangeStart=5927&rangeEnd=5997"
    },
    {
      "bookmarkId": "3300053222_9_17409-17443",
      "chapterUid": 9,
      "range": "17409-17443",
      "markText": "我们的大文学家杜工部有两千万人读他的作品，读莎士比亚的不过一百万而已",
      "totalCount": 48,
      "appLink": "weread://bestbookmark?bookId=3300053222&chapterUid=9&rangeStart=17409&rangeEnd=17443",
      "webLink": "https://weread.qq.com/web/reader/4ea32bd0813ab7b4ag0128ba?chapterUid=9&rangeStart=17409&rangeEnd=17443"
    },
    {
      "bookmarkId": "3300053222_9_15338-15350",
      "chapterUid": 9,
      "range": "15338-15350",
      "markText": "所以中国的皇帝并非专制。",
      "totalCount": 42,
      "appLink": "weread://bestbookmark?bookId=3300053222&chapterUid=9&rangeStart=15338&rangeEnd=15350",
      "webLink": "https://weread.qq.com/web/reader/4ea32bd0813ab7b4ag0128ba?chapterUid=9&rangeStart=15338&rangeEnd=15350"
    },
    {
      "bookmarkId": "3300053222_9_7964-7976",
      "chapterUid": 9,
      "range": "7964-7976",
      "markText": "故天下最伟大的是读书人。",
      "totalCount": 40,
      "appLink": "weread://bestbookmark?bookId=3300053222&chapterUid=9&rangeStart=7964&rangeEnd=7976",
      "webLink": "https://weread.qq.com/web/reader/4ea32bd0813ab7b4ag0128ba?chapterUid=9&rangeStart=7964&rangeEnd=7976"
    },
    {
      "bookmarkId": "3300053222_8_4851-4881",
      "chapterUid": 8,
      "range": "4851-4881",
      "markText": "美国罗斯福提出海洋自由，即美国可通商，因小国没有船可自由航行",
      "totalCount": 36,
      "appLink": "weread://bestbookmark?bookId=3300053222&chapterUid=8&rangeStart=4851&rangeEnd=4881",
      "webLink": "https://weread.qq.com/web/reader/4ea32bd0813ab7b4ag0128ba?chapterUid=8&rangeStart=4851&rangeEnd=4881"
    },
    {
      "bookmarkId": "3300053222_14_2980-3000",
      "chapterUid": 14,
      "range": "2980-3000",
      "markText": "总之，明代君王昏惰，明代政情安得不乱也。",
      "totalCount": 36,
      "appLink": "weread://bestbookmark?bookId=3300053222&chapterUid=14&rangeStart=2980&rangeEnd=3000",
      "webLink": "https://weread.qq.com/web/reader/4ea32bd0813ab7b4ag0128ba?chapterUid=14&rangeStart=2980&rangeEnd=3000"
    },
    {
      "bookmarkId": "3300053222_8_911-933",
      "chapterUid": 8,
      "range": "911-933",
      "markText": "（一）因《殷本纪》可信，故《夏本纪》亦可信。",
      "totalCount": 34,
      "appLink": "weread://bestbookmark?bookId=3300053222&chapterUid=8&rangeStart=911&rangeEnd=933",
      "webLink": "https://weread.qq.com/web/reader/4ea32bd0813ab7b4ag0128ba?chapterUid=8&rangeStart=911&rangeEnd=933"
    },
    {
      "bookmarkId": "3300053222_8_6976-7017",
      "chapterUid": 8,
      "range": "6976-7017",
      "markText": "当时秦、楚反周。齐是周之外戚，田姓一出，与周无关了。故此时已无“尊王攘夷”之口号了",
      "totalCount": 34,
      "appLink": "weread://bestbookmark?bookId=3300053222&chapterUid=8&rangeStart=6976&rangeEnd=7017",
      "webLink": "https://weread.qq.com/web/reader/4ea32bd0813ab7b4ag0128ba?chapterUid=8&rangeStart=6976&rangeEnd=7017"
    },
    {
      "bookmarkId": "3300053222_9_5541-5553",
      "chapterUid": 9,
      "range": "5541-5553",
      "markText": "此举汉高祖实不如秦王高明",
      "totalCount": 34,
      "appLink": "weread://bestbookmark?bookId=3300053222&chapterUid=9&rangeStart=5541&rangeEnd=5553",
      "webLink": "https://weread.qq.com/web/reader/4ea32bd0813ab7b4ag0128ba?chapterUid=9&rangeStart=5541&rangeEnd=5553"
    },
    {
      "bookmarkId": "3300053222_9_8562-8576",
      "chapterUid": 9,
      "range": "8562-8576",
      "markText": "均有苗人，是被华夏赶出来的。",
