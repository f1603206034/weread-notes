  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300075602_10_514-582",
      "chapterUid": 10,
      "range": "514-582",
      "markText": "要阻止人心归向仇敌，焦灼忧虑是绝佳的街垒路障。祂希望人们专注于他们现在做的事，我们要做的则是使他们不断猜想将来会有什么事发生在他们身上。",
      "totalCount": 384,
      "appLink": "weread://bestbookmark?bookId=3300075602&chapterUid=10&rangeStart=514&rangeEnd=582",
      "webLink": "https://weread.qq.com/web/reader/427322e0813ab8408g012cea?chapterUid=10&rangeStart=514&rangeEnd=582"
    },
    {
      "bookmarkId": "3300075602_5_2078-2147",
      "chapterUid": 5,
      "range": "2078-2147",
      "markText": "不过，最好能让他一点科学文献不读，就笼统地认为自己什么都懂，要让他把所有那些道听途说和从碰巧读过的文章中所得的知识当成是“现代研究成果”。",
      "totalCount": 378,
      "appLink": "weread://bestbookmark?bookId=3300075602&chapterUid=5&rangeStart=2078&rangeEnd=2147",
      "webLink": "https://weread.qq.com/web/reader/427322e0813ab8408g012cea?chapterUid=5&rangeStart=2078&rangeEnd=2147"
    },
    {
      "bookmarkId": "3300075602_12_2279-2367",
      "chapterUid": 12,
      "range": "2279-2367",
      "markText": "当一个人不再向往却仍旧有心去完成我们仇敌的旨意，当一个人仰望茫茫宇宙，似乎祂所有痕迹都消失殆尽，于是问自己为何被离弃，却仍旧遵行祂的命令，那时候，我们的事业就会陷入最大的危机。",
      "totalCount": 368,
      "appLink": "weread://bestbookmark?bookId=3300075602&chapterUid=12&rangeStart=2279&rangeEnd=2367",
      "webLink": "https://weread.qq.com/web/reader/427322e0813ab8408g012cea?chapterUid=12&rangeStart=2279&rangeEnd=2367"
    },
    {
      "bookmarkId": "3300075602_6_490-572",
