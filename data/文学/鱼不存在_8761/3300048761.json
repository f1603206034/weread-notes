      "totalCount": 5130,
      "appLink": "weread://bestbookmark?bookId=3300048761&chapterUid=5&rangeStart=2908&rangeEnd=2989",
      "webLink": "https://weread.qq.com/web/reader/0af32760813ab798cg01135c?chapterUid=5&rangeStart=2908&rangeEnd=2989"
    },
    {
      "bookmarkId": "3300048761_4_1634-1729",
