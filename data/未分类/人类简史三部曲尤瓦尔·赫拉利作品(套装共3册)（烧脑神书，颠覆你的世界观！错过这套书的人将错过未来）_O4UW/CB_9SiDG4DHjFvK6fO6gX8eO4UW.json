          "range": "3998-4024",
          "rangeStart": 3998,
          "rangeEnd": 4024,
          "markText": "2.以观察和数学为中心。 ",
          "colorStyle": 1,
          "colorLabel": "",
          "createTime": 1681429936,
          "createTimeFormatted": "2023-04-14 07:52:16",
          "chapterUid": 32,
          "appLink": "weread://bestbookmark?bookId=CB_9SiDG4DHjFvK6fO6gX8eO4UW&chapterUid=32&rangeStart=3998&rangeEnd=4024",
          "webLink": "https://weread.qq.com/web/reader/ffe427d3643425f39536944473444486a46764b36664f36675838654f345557f72?chapterUid=32&rangeStart=3998&rangeEnd=4024"
        },
        {
          "type": "highlight",
