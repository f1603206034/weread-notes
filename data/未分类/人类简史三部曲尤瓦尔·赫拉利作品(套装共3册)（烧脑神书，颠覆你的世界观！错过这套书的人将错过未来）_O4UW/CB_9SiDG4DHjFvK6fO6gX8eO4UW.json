          "appLink": "weread://bestbookmark?bookId=CB_9SiDG4DHjFvK6fO6gX8eO4UW&chapterUid=28&rangeStart=32697&rangeEnd=32701",
          "webLink": "https://weread.qq.com/web/reader/ffe427d3643425f39536944473444486a46764b36664f36675838654f345557f72?chapterUid=28&rangeStart=32697&rangeEnd=32701"
