          "chapterUid": 32,
          "appLink": "weread://bestbookmark?bookId=CB_9SiDG4DHjFvK6fO6gX8eO4UW&chapterUid=32&rangeStart=4115&rangeEnd=4137",
          "webLink": "https://weread.qq.com/web/reader/ffe427d3643425f39536944473444486a46764b36664f36675838654f345557f72?chapterUid=32&rangeStart=4115&rangeEnd=4137"
