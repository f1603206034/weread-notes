  "content": [
    {
      "chapterUid": 11,
      "chapterTitle": "第五部分 生存下去",
      "items": [
        {
          "type": "highlight",
          "bookmarkId": "CB_9SiDG4DHjFvK6fO6gX8eO4UW_11_13651-13693",
          "range": "13651-13693",
          "rangeStart": 13651,
          "rangeEnd": 13693,
          "markText": "第二，一个好的故事所讨论的范畴不一定要无穷无尽，但至少要能够延伸到超出我自己的视界。",
          "colorStyle": 1,
          "colorLabel": "",
          "createTime": 1689251329,
          "createTimeFormatted": "2023-07-13 20:28:49",
          "chapterUid": 11,
          "appLink": "weread://bestbookmark?bookId=CB_9SiDG4DHjFvK6fO6gX8eO4UW&chapterUid=11&rangeStart=13651&rangeEnd=13693",
          "webLink": "https://weread.qq.com/web/reader/ffe427d3643425f39536944473444486a46764b36664f36675838654f345557f72?chapterUid=11&rangeStart=13651&rangeEnd=13693"
        },
        {
          "type": "highlight",
