          "range": "13523-13542",
          "rangeStart": 13523,
          "rangeEnd": 13542,
          "markText": "第一，我在这个故事里至少要扮演某种角色",
          "colorStyle": 1,
          "colorLabel": "",
          "createTime": 1689251306,
          "createTimeFormatted": "2023-07-13 20:28:26",
          "chapterUid": 11,
