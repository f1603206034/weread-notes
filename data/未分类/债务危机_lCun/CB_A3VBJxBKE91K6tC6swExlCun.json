    {
      "chapterUid": 22,
      "chapterTitle": "核心经济术语表",
      "items": [
        {
          "type": "review",
          "reviewId": "32618646_7X8YRhpeY",
          "range": "2933-2938",
          "chapterName": "",
          "content": "GDP quē kǒu\n亦称“产量缺口”。实际生产的国内生产总值和潜在国内生产总值之间的差距。实际国内生产总值低于潜在国内生产总值，这一缺口可衡量社会放弃了多少本来可以生产的产品和劳务。这些产品和劳务是有能力生产的，只是因为有效的总需求不足，产品销路不好，因而未能被生产出来。因而GDP缺口可以反映经济萧条时资源闲置的情况。",
          "abstract": "GDP缺口",
          "star": -1,
          "createTime": 1736666158,
          "createTimeFormatted": "2025-01-12 15:15:58",
          "isFinish": false,
          "chapterUid": 22
        }
      ]
    },
    {
      "chapterUid": 5,
