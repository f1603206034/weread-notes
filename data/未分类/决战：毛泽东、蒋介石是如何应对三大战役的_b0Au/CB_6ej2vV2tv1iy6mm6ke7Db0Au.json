          "createTimeFormatted": "2024-03-14 10:32:19",
          "chapterUid": 19,
          "appLink": "weread://bestbookmark?bookId=CB_6ej2vV2tv1iy6mm6ke7Db0Au&chapterUid=19&rangeStart=5291&rangeEnd=5386",
          "webLink": "https://weread.qq.com/web/reader/08c42c83643425f36656a327656327476316979366d6d366b653744623041753a4?chapterUid=19&rangeStart=5291&rangeEnd=5386"
        },
