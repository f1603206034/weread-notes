  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300095232_13_2162-2179",
      "chapterUid": 13,
      "range": "2162-2179",
      "markText": "毕竟生了两个孩子，痛经明显减轻了！",
      "totalCount": 1188,
      "appLink": "weread://bestbookmark?bookId=3300095232&chapterUid=13&rangeStart=2162&rangeEnd=2179",
      "webLink": "https://weread.qq.com/web/reader/a6732370813ab8bb3g012206?chapterUid=13&rangeStart=2162&rangeEnd=2179"
    },
    {
      "bookmarkId": "3300095232_10_5377-5412",
      "chapterUid": 10,
      "range": "5377-5412",
      "markText": "朋友的爸爸发来了一条短信，内容很长。看到短信后，我又嘤嘤嘤地哭了起来。",
      "totalCount": 912,
      "appLink": "weread://bestbookmark?bookId=3300095232&chapterUid=10&rangeStart=5377&rangeEnd=5412",
      "webLink": "https://weread.qq.com/web/reader/a6732370813ab8bb3g012206?chapterUid=10&rangeStart=5377&rangeEnd=5412"
    },
    {
      "bookmarkId": "3300095232_5_1521-1571",
      "chapterUid": 5,
      "range": "1521-1571",
      "markText": "就这样，这些“能把卫生巾借给敌人”的女人，以“血”为纽带联系在了一起。很温暖，每个人都像是我的母亲。",
      "totalCount": 864,
      "appLink": "weread://bestbookmark?bookId=3300095232&chapterUid=5&rangeStart=1521&rangeEnd=1571",
      "webLink": "https://weread.qq.com/web/reader/a6732370813ab8bb3g012206?chapterUid=5&rangeStart=1521&rangeEnd=1571"
    },
    {
      "bookmarkId": "3300095232_19_2201-2250",
      "chapterUid": 19,
      "range": "2201-2250",
      "markText": "身体上的症状：乳房疼痛、腹部膨满、头痛、肌肉痛等。精神上的症状：抑郁、焦虑、敏感、注意力不集中等。",
      "totalCount": 738,
      "appLink": "weread://bestbookmark?bookId=3300095232&chapterUid=19&rangeStart=2201&rangeEnd=2250",
      "webLink": "https://weread.qq.com/web/reader/a6732370813ab8bb3g012206?chapterUid=19&rangeStart=2201&rangeEnd=2250"
    },
    {
      "bookmarkId": "3300095232_17_4263-4308",
      "chapterUid": 17,
      "range": "4263-4308",
      "markText": "若是没有等来受精卵，将会拆除所有的“装饰”。如此来看，所谓的月经，岂不是子宫流下的血泪吗？",
      "totalCount": 702,
      "appLink": "weread://bestbookmark?bookId=3300095232&chapterUid=17&rangeStart=4263&rangeEnd=4308",
      "webLink": "https://weread.qq.com/web/reader/a6732370813ab8bb3g012206?chapterUid=17&rangeStart=4263&rangeEnd=4308"
    },
    {
      "bookmarkId": "3300095232_7_700-727",
      "chapterUid": 7,
      "range": "700-727",
      "markText": "到了那一天，我会和马桶融为一体，但绝对不是因为大小便。",
      "totalCount": 608,
      "appLink": "weread://bestbookmark?bookId=3300095232&chapterUid=7&rangeStart=700&rangeEnd=727",
      "webLink": "https://weread.qq.com/web/reader/a6732370813ab8bb3g012206?chapterUid=7&rangeStart=700&rangeEnd=727"
    },
    {
      "bookmarkId": "3300095232_44_2338-2374",
      "chapterUid": 44,
      "range": "2338-2374",
      "markText": "虽然是句玩笑话，但对青少年患者口无遮拦地提起怀孕的事情，会令人感到郁闷。",
      "totalCount": 570,
      "appLink": "weread://bestbookmark?bookId=3300095232&chapterUid=44&rangeStart=2338&rangeEnd=2374",
      "webLink": "https://weread.qq.com/web/reader/a6732370813ab8bb3g012206?chapterUid=44&rangeStart=2338&rangeEnd=2374"
    },
    {
      "bookmarkId": "3300095232_15_454-490",
      "chapterUid": 15,
      "range": "454-490",
      "markText": "来月经时，我非常讨厌去上班。于是，发了辞职短信。呵呵……成了无业游民……",
      "totalCount": 544,
      "appLink": "weread://bestbookmark?bookId=3300095232&chapterUid=15&rangeStart=454&rangeEnd=490",
      "webLink": "https://weread.qq.com/web/reader/a6732370813ab8bb3g012206?chapterUid=15&rangeStart=454&rangeEnd=490"
    },
    {
      "bookmarkId": "3300095232_11_960-1052",
      "chapterUid": 11,
      "range": "960-1052",
      "markText": "生理期进行运动，有助于缓解痛经和压力，但应避免长时间或过度运动。受月经期间产生的松弛素影响，肌肉和韧带松弛，受伤的风险增大。如果进行60分钟以上的高强度运动，可能会引发运动诱发性炎症。",
      "totalCount": 496,
      "appLink": "weread://bestbookmark?bookId=3300095232&chapterUid=11&rangeStart=960&rangeEnd=1052",
      "webLink": "https://weread.qq.com/web/reader/a6732370813ab8bb3g012206?chapterUid=11&rangeStart=960&rangeEnd=1052"
    },
    {
      "bookmarkId": "3300095232_29_5221-5263",
      "chapterUid": 29,
      "range": "5221-5263",
      "markText": "这是为了保护女性健康，防止工作效率低下，同时，也是为了确保下一代的健康而制定的法律。",
      "totalCount": 464,
      "appLink": "weread://bestbookmark?bookId=3300095232&chapterUid=29&rangeStart=5221&rangeEnd=5263",
      "webLink": "https://weread.qq.com/web/reader/a6732370813ab8bb3g012206?chapterUid=29&rangeStart=5221&rangeEnd=5263"
    },
    {
      "bookmarkId": "3300095232_5_472-536",
      "chapterUid": 5,
      "range": "472-536",
      "markText": "。她们中间，有的痛经比我严重，也有人看到我抱着肚子打滚时，眼神中充满错愕。每个月一次，生理期如期而至，很快就成了我生活的一部分。",
      "totalCount": 448,
      "appLink": "weread://bestbookmark?bookId=3300095232&chapterUid=5&rangeStart=472&rangeEnd=536",
      "webLink": "https://weread.qq.com/web/reader/a6732370813ab8bb3g012206?chapterUid=5&rangeStart=472&rangeEnd=536"
    },
    {
      "bookmarkId": "3300095232_8_2875-2911",
      "chapterUid": 8,
      "range": "2875-2911",
      "markText": "托这种“能把卫生巾借给敌人”的“血缘关系”之福，我们又成了最亲密的朋友！",
      "totalCount": 434,
      "appLink": "weread://bestbookmark?bookId=3300095232&chapterUid=8&rangeStart=2875&rangeEnd=2911",
      "webLink": "https://weread.qq.com/web/reader/a6732370813ab8bb3g012206?chapterUid=8&rangeStart=2875&rangeEnd=2911"
    },
    {
      "bookmarkId": "3300095232_6_654-676",
      "chapterUid": 6,
      "range": "654-676",
      "markText": "男人即使死而复生，也无法理解的女性生理期共鸣",
      "totalCount": 430,
      "appLink": "weread://bestbookmark?bookId=3300095232&chapterUid=6&rangeStart=654&rangeEnd=676",
      "webLink": "https://weread.qq.com/web/reader/a6732370813ab8bb3g012206?chapterUid=6&rangeStart=654&rangeEnd=676"
    },
    {
      "bookmarkId": "3300095232_19_440-460",
      "chapterUid": 19,
      "range": "440-460",
      "markText": "在来月经之前，我反而感觉更加疼痛和烦躁。",
      "totalCount": 416,
      "appLink": "weread://bestbookmark?bookId=3300095232&chapterUid=19&rangeStart=440&rangeEnd=460",
      "webLink": "https://weread.qq.com/web/reader/a6732370813ab8bb3g012206?chapterUid=19&rangeStart=440&rangeEnd=460"
    },
    {
      "bookmarkId": "3300095232_36_2948-2996",
      "chapterUid": 36,
      "range": "2948-2996",
      "markText": "虽然卫生巾逐步升级换代，但有些孩子因为没钱，买不起卫生巾，只能用鞋垫代替。这个消息震惊了全社会。",
      "totalCount": 414,
      "appLink": "weread://bestbookmark?bookId=3300095232&chapterUid=36&rangeStart=2948&rangeEnd=2996",
      "webLink": "https://weread.qq.com/web/reader/a6732370813ab8bb3g012206?chapterUid=36&rangeStart=2948&rangeEnd=2996"
    },
    {
      "bookmarkId": "3300095232_41_1802-1837",
      "chapterUid": 41,
      "range": "1802-1837",
      "markText": "绝经，只是身体不能再生孩子的一种自然变化，意味着女性的生活将获得解放。",
      "totalCount": 414,
      "appLink": "weread://bestbookmark?bookId=3300095232&chapterUid=41&rangeStart=1802&rangeEnd=1837",
      "webLink": "https://weread.qq.com/web/reader/a6732370813ab8bb3g012206?chapterUid=41&rangeStart=1802&rangeEnd=1837"
    },
    {
      "bookmarkId": "3300095232_28_4298-4337",
      "chapterUid": 28,
      "range": "4298-4337",
      "markText": "从2006年起，韩国的小学、初中、高中女生若因月经“旷课”，不会被认定为缺勤。",
      "totalCount": 407,
      "appLink": "weread://bestbookmark?bookId=3300095232&chapterUid=28&rangeStart=4298&rangeEnd=4337",
      "webLink": "https://weread.qq.com/web/reader/a6732370813ab8bb3g012206?chapterUid=28&rangeStart=4298&rangeEnd=4337"
