    },
    {
      "bookmarkId": "30181899_14_28566-28611",
      "chapterUid": 14,
      "range": "28566-28611",
      "markText": "将一种优质蛋白质（比如乳清蛋白）与碳水化合物和液体相结合，比单独的成分更能促进肌肉的恢复。",
      "totalCount": 180,
      "appLink": "weread://bestbookmark?bookId=30181899&chapterUid=14&rangeStart=28566&rangeEnd=28611",
      "webLink": "https://weread.qq.com/web/reader/7a332d8071cc8a0b7a31e96?chapterUid=14&rangeStart=28566&rangeEnd=28611"
    },
    {
      "bookmarkId": "30181899_13_4069-4114",
      "chapterUid": 13,
      "range": "4069-4114",
      "markText": "更多的糖原储备量与更多的液体储备量相关，其比例一般是储存1 g糖原需要额外储存3 g的水。",
      "totalCount": 170,
      "appLink": "weread://bestbookmark?bookId=30181899&chapterUid=13&rangeStart=4069&rangeEnd=4114",
      "webLink": "https://weread.qq.com/web/reader/7a332d8071cc8a0b7a31e96?chapterUid=13&rangeStart=4069&rangeEnd=4114"
