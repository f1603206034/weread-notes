  ],
  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "37349530_4_2994-3044",
      "chapterUid": 4,
      "range": "2994-3044",
      "markText": "董仲舒青年时代潜心读书，据说他曾在窗上垂帷，三年不曾向窗外眺望，最后终于完成了《春秋繁露》这部巨著。",
      "totalCount": 336,
      "appLink": "weread://bestbookmark?bookId=37349530&chapterUid=4&rangeStart=2994&rangeEnd=3044",
      "webLink": "https://weread.qq.com/web/reader/18e32d307239e89a18e9e28?chapterUid=4&rangeStart=2994&rangeEnd=3044"
    },
    {
      "bookmarkId": "37349530_4_1916-1974",
      "chapterUid": 4,
      "range": "1916-1974",
      "markText": "道是万物之所由来。既然物从来自在，道就从来自在，道这个指称也就从来自在。它是一切起源的起源，因此它见到了一切的起源。",
      "totalCount": 315,
      "appLink": "weread://bestbookmark?bookId=37349530&chapterUid=4&rangeStart=1916&rangeEnd=1974",
      "webLink": "https://weread.qq.com/web/reader/18e32d307239e89a18e9e28?chapterUid=4&rangeStart=1916&rangeEnd=1974"
    },
    {
      "bookmarkId": "37349530_6_1526-1539",
      "chapterUid": 6,
      "range": "1526-1539",
      "markText": "哲学是对人生的系统的反思。",
      "totalCount": 312,
      "appLink": "weread://bestbookmark?bookId=37349530&chapterUid=6&rangeStart=1526&rangeEnd=1539",
      "webLink": "https://weread.qq.com/web/reader/18e32d307239e89a18e9e28?chapterUid=6&rangeStart=1526&rangeEnd=1539"
    },
    {
      "bookmarkId": "37349530_5_1135-1180",
      "chapterUid": 5,
      "range": "1135-1180",
      "markText": "历稽载籍，良史必有三长：才，学，识。学者，史料精熟也；识者，选材精当也；才者，文笔精妙也。",
      "totalCount": 304,
      "appLink": "weread://bestbookmark?bookId=37349530&chapterUid=5&rangeStart=1135&rangeEnd=1180",
      "webLink": "https://weread.qq.com/web/reader/18e32d307239e89a18e9e28?chapterUid=5&rangeStart=1135&rangeEnd=1180"
    },
    {
      "bookmarkId": "37349530_6_2407-2458",
      "chapterUid": 6,
      "range": "2407-2458",
      "markText": "事实上，每一种大的宗教就是某种哲学加上一定的上层建筑，包括迷信、教义、礼仪和体制。这是我对宗教的认识。",
      "totalCount": 270,
      "appLink": "weread://bestbookmark?bookId=37349530&chapterUid=6&rangeStart=2407&rangeEnd=2458",
      "webLink": "https://weread.qq.com/web/reader/18e32d307239e89a18e9e28?chapterUid=6&rangeStart=2407&rangeEnd=2458"
    },
    {
      "bookmarkId": "37349530_4_1556-1621",
      "chapterUid": 4,
      "range": "1556-1621",
      "markText": "照墨子的主张，“是”就是“交相兼”，“非”就是“交相别”。墨子指望通过这样的政治规范，再加上宗教的规范，可以使天下之人都实行兼爱。",
      "totalCount": 255,
      "appLink": "weread://bestbookmark?bookId=37349530&chapterUid=4&rangeStart=1556&rangeEnd=1621",
      "webLink": "https://weread.qq.com/web/reader/18e32d307239e89a18e9e28?chapterUid=4&rangeStart=1556&rangeEnd=1621"
    },
    {
      "bookmarkId": "37349530_4_1178-1261",
      "chapterUid": 4,
      "range": "1178-1261",
      "markText": "中国美术作品中的许多杰作都是写山水、花鸟、树木、竹枝。在许多山水画里，山脚下、溪水边，往往能看见一个人，静坐沉醉在天地的大美之中，从中领会超越于自然和人生之上的妙道。",
      "totalCount": 253,
      "appLink": "weread://bestbookmark?bookId=37349530&chapterUid=4&rangeStart=1178&rangeEnd=1261",
      "webLink": "https://weread.qq.com/web/reader/18e32d307239e89a18e9e28?chapterUid=4&rangeStart=1178&rangeEnd=1261"
    },
    {
      "bookmarkId": "37349530_6_3341-3392",
      "chapterUid": 6,
      "range": "3341-3392",
      "markText": "中国文化的精神基础不是宗教，而是伦理，这是否意味着中国人不曾意识到，在道德伦理之上，还有更高的价值呢？",
      "totalCount": 238,
      "appLink": "weread://bestbookmark?bookId=37349530&chapterUid=6&rangeStart=3341&rangeEnd=3392",
      "webLink": "https://weread.qq.com/web/reader/18e32d307239e89a18e9e28?chapterUid=6&rangeStart=3341&rangeEnd=3392"
    },
    {
      "bookmarkId": "37349530_6_4060-4070",
      "chapterUid": 6,
      "range": "4060-4070",
      "markText": "为学日益，为道日损。",
      "totalCount": 216,
      "appLink": "weread://bestbookmark?bookId=37349530&chapterUid=6&rangeStart=4060&rangeEnd=4070",
      "webLink": "https://weread.qq.com/web/reader/18e32d307239e89a18e9e28?chapterUid=6&rangeStart=4060&rangeEnd=4070"
    },
    {
      "bookmarkId": "37349530_6_2862-2883",
      "chapterUid": 6,
      "range": "2862-2883",
      "markText": "中国人对待宗教的态度，也是充满哲学意味的。",
      "totalCount": 198,
      "appLink": "weread://bestbookmark?bookId=37349530&chapterUid=6&rangeStart=2862&rangeEnd=2883",
      "webLink": "https://weread.qq.com/web/reader/18e32d307239e89a18e9e28?chapterUid=6&rangeStart=2862&rangeEnd=2883"
    },
    {
      "bookmarkId": "37349530_6_8895-8922",
      "chapterUid": 6,
      "range": "8895-8922",
      "markText": "读哲学是为了使人得以成为人，而不是为了成为某种特殊的人",
      "totalCount": 198,
      "appLink": "weread://bestbookmark?bookId=37349530&chapterUid=6&rangeStart=8895&rangeEnd=8922",
      "webLink": "https://weread.qq.com/web/reader/18e32d307239e89a18e9e28?chapterUid=6&rangeStart=8895&rangeEnd=8922"
    },
    {
      "bookmarkId": "37349530_6_1184-1215",
      "chapterUid": 6,
      "range": "1184-1215",
      "markText": "《三字经》的第一句“人之初，性本善”，便是孟子哲学的基本思想。",
      "totalCount": 192,
      "appLink": "weread://bestbookmark?bookId=37349530&chapterUid=6&rangeStart=1184&rangeEnd=1215",
      "webLink": "https://weread.qq.com/web/reader/18e32d307239e89a18e9e28?chapterUid=6&rangeStart=1184&rangeEnd=1215"
    },
    {
      "bookmarkId": "37349530_6_9595-9668",
      "chapterUid": 6,
      "range": "9595-9668",
      "markText": "富于暗示而不是一泻无余，这是中国诗歌、绘画等各种艺术所追求的目标。在诗歌中，诗人往往意在言外。在中国文学传统中，一首好诗往往是“言有尽而意无穷”。",
      "totalCount": 180,
      "appLink": "weread://bestbookmark?bookId=37349530&chapterUid=6&rangeStart=9595&rangeEnd=9668",
      "webLink": "https://weread.qq.com/web/reader/18e32d307239e89a18e9e28?chapterUid=6&rangeStart=9595&rangeEnd=9668"
    },
    {
      "bookmarkId": "37349530_6_11442-11494",
      "chapterUid": 6,
      "range": "11442-11494",
      "markText": "翻译工作恰如嚼饭喂人。如果一个人自己不能吃饭，要吃别人的唾余，所吃到嘴里的当然没有原来那饭的香味和鲜味。",
      "totalCount": 168,
      "appLink": "weread://bestbookmark?bookId=37349530&chapterUid=6&rangeStart=11442&rangeEnd=11494",
      "webLink": "https://weread.qq.com/web/reader/18e32d307239e89a18e9e28?chapterUid=6&rangeStart=11442&rangeEnd=11494"
    },
    {
      "bookmarkId": "37349530_6_2621-2719",
      "chapterUid": 6,
      "range": "2621-2719",
      "markText": "道家哲学教导人顺乎自然，道教却教导人逆乎自然。举例来说，按老庄思想，万物有生必有死，人对于死，顺应自然，完全不必介意，而道教的宗旨却是教导长生术，这不是反乎自然吗？道教含有一种征服自然的科学精神。",
      "totalCount": 162,
      "appLink": "weread://bestbookmark?bookId=37349530&chapterUid=6&rangeStart=2621&rangeEnd=2719",
      "webLink": "https://weread.qq.com/web/reader/18e32d307239e89a18e9e28?chapterUid=6&rangeStart=2621&rangeEnd=2719"
    },
    {
      "bookmarkId": "37349530_10_2607-2699",
      "chapterUid": 10,
      "range": "2607-2699",
      "markText": "如果这段故事属实，它对今日世界倒是一个好榜样，两个敌对国家不必在战场上厮杀，只要双方的科学家、工程师来到一起，把各自实验室里的攻击防御武器都展示出来，不需要走上战场，便可以决定胜负了。",
      "totalCount": 160,
      "appLink": "weread://bestbookmark?bookId=37349530&chapterUid=10&rangeStart=2607&rangeEnd=2699",
      "webLink": "https://weread.qq.com/web/reader/18e32d307239e89a18e9e28?chapterUid=10&rangeStart=2607&rangeEnd=2699"
    },
    {
      "bookmarkId": "37349530_6_956-991",
      "chapterUid": 6,
      "range": "956-991",
      "markText": "哲学在中国文化中的地位，历来被看为可以和宗教在其他文化中的地位相比拟。",
      "totalCount": 150,
      "appLink": "weread://bestbookmark?bookId=37349530&chapterUid=6&rangeStart=956&rangeEnd=991",
      "webLink": "https://weread.qq.com/web/reader/18e32d307239e89a18e9e28?chapterUid=6&rangeStart=956&rangeEnd=991"
    },
    {
      "bookmarkId": "37349530_6_9813-9866",
      "chapterUid": 6,
      "range": "9813-9866",
      "markText": "荃者所以在鱼，得鱼而忘荃；蹄者所以在兔，得兔而忘蹄；言者所以在意，得意而忘言。吾安得夫忘言之人而与之言哉！",
      "totalCount": 150,
      "appLink": "weread://bestbookmark?bookId=37349530&chapterUid=6&rangeStart=9813&rangeEnd=9866",
      "webLink": "https://weread.qq.com/web/reader/18e32d307239e89a18e9e28?chapterUid=6&rangeStart=9813&rangeEnd=9866"
    },
    {
      "bookmarkId": "37349530_6_1802-1849",
      "chapterUid": 6,
      "range": "1802-1849",
      "markText": "人要思想，首先要弄清楚人能够思考什么，这就是说，在对人生进行思考之前，我们先要对思想进行思考。",
      "totalCount": 143,
      "appLink": "weread://bestbookmark?bookId=37349530&chapterUid=6&rangeStart=1802&rangeEnd=1849",
      "webLink": "https://weread.qq.com/web/reader/18e32d307239e89a18e9e28?chapterUid=6&rangeStart=1802&rangeEnd=1849"
    },
    {
      "bookmarkId": "37349530_6_5717-5803",
      "chapterUid": 6,
      "range": "5717-5803",
      "markText": "中国无论哪一派哲学，都直接或间接关切政治和伦理道德。因此，它主要关心的是社会，而不关心宇宙；关心的是人际关系的日常功能，而不关心地狱或天堂；关心人的今生，而不关心他的来生。",
      "totalCount": 143,
      "appLink": "weread://bestbookmark?bookId=37349530&chapterUid=6&rangeStart=5717&rangeEnd=5803",
      "webLink": "https://weread.qq.com/web/reader/18e32d307239e89a18e9e28?chapterUid=6&rangeStart=5717&rangeEnd=5803"
    }
  ],
