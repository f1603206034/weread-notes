    {
      "chapterUid": 94,
      "chapterTitle": "第一章 天文",
      "items": [
        {
          "type": "highlight",
          "bookmarkId": "23364890_49_4799-4839",
          "range": "7646-7686",
          "rangeStart": 7646,
          "rangeEnd": 7686,
