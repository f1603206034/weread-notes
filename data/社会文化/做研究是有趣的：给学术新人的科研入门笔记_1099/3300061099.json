  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300061099_12_6012-6033",
      "chapterUid": 12,
      "range": "6012-6033",
      "markText": "不用怕，没读文献读哭过的人，不足以谈人生！",
      "totalCount": 833,
      "appLink": "weread://bestbookmark?bookId=3300061099&chapterUid=12&rangeStart=6012&rangeEnd=6033",
      "webLink": "https://weread.qq.com/web/reader/cd4326f0813ab7e5dg0196be?chapterUid=12&rangeStart=6012&rangeEnd=6033"
    },
    {
      "bookmarkId": "3300061099_53_1696-1784",
      "chapterUid": 53,
      "range": "1696-1784",
      "markText": "为什么你应该做学术？因为你将从人类知识链的顶端为你在乎的人和群体做出贡献，因为你将影响其他的研究者和教育者，而他们又将影响更多的研究者、教育者和实践者，最终影响到一个个的个体。",
      "totalCount": 816,
      "appLink": "weread://bestbookmark?bookId=3300061099&chapterUid=53&rangeStart=1696&rangeEnd=1784",
      "webLink": "https://weread.qq.com/web/reader/cd4326f0813ab7e5dg0196be?chapterUid=53&rangeStart=1696&rangeEnd=1784"
    },
    {
      "bookmarkId": "3300061099_12_566-617",
      "chapterUid": 12,
      "range": "566-617",
      "markText": "美国的社科类博士生平均每星期的阅读作业量在500页左右，其中主要包括教科书章节和期刊文章两种阅读材料。",
      "totalCount": 705,
      "appLink": "weread://bestbookmark?bookId=3300061099&chapterUid=12&rangeStart=566&rangeEnd=617",
      "webLink": "https://weread.qq.com/web/reader/cd4326f0813ab7e5dg0196be?chapterUid=12&rangeStart=566&rangeEnd=617"
    },
    {
      "bookmarkId": "3300061099_53_2954-3047",
      "chapterUid": 53,
      "range": "2954-3047",
      "markText": "如果我不得不找出适合做研究者的人身上必备的一个特点，那么我会说是“对未知事物的强烈好奇心”，是想学习、想知道、想挖掘更深的真相、想明了更多未知、忍不住去发问、忍不住对既有知识存疑的动力。",
      "totalCount": 648,
      "appLink": "weread://bestbookmark?bookId=3300061099&chapterUid=53&rangeStart=2954&rangeEnd=3047",
      "webLink": "https://weread.qq.com/web/reader/cd4326f0813ab7e5dg0196be?chapterUid=53&rangeStart=2954&rangeEnd=3047"
    },
    {
      "bookmarkId": "3300061099_18_1051-1133",
      "chapterUid": 18,
      "range": "1051-1133",
      "markText": "更多时候，大部分人在积累到某一个量之前就放弃了，却归结于自己的方法有问题，又去寻找新的方法。其实不是你方法不对，只是你挖井挖得不够深，动作不够勤快，弯腰弯得不够久。",
      "totalCount": 600,
      "appLink": "weread://bestbookmark?bookId=3300061099&chapterUid=18&rangeStart=1051&rangeEnd=1133",
      "webLink": "https://weread.qq.com/web/reader/cd4326f0813ab7e5dg0196be?chapterUid=18&rangeStart=1051&rangeEnd=1133"
    },
    {
      "bookmarkId": "3300061099_54_4391-4399",
      "chapterUid": 54,
      "range": "4391-4399",
      "markText": "那我们就开始吧。",
      "totalCount": 546,
      "appLink": "weread://bestbookmark?bookId=3300061099&chapterUid=54&rangeStart=4391&rangeEnd=4399",
      "webLink": "https://weread.qq.com/web/reader/cd4326f0813ab7e5dg0196be?chapterUid=54&rangeStart=4391&rangeEnd=4399"
    },
    {
      "bookmarkId": "3300061099_56_754-843",
      "chapterUid": 56,
      "range": "754-843",
      "markText": "阅读量出奇的大也就算了，我一度非常不服气的就是为什么学术文章非要写得这么晦涩难懂，就好像不写得结构复杂、用语深奥就不好意思称自己是正规的学术文章似的（有过相同困扰的同学请举手）。",
      "totalCount": 528,
      "appLink": "weread://bestbookmark?bookId=3300061099&chapterUid=56&rangeStart=754&rangeEnd=843",
      "webLink": "https://weread.qq.com/web/reader/cd4326f0813ab7e5dg0196be?chapterUid=56&rangeStart=754&rangeEnd=843"
    },
    {
      "bookmarkId": "3300061099_12_5771-5851",
      "chapterUid": 12,
      "range": "5771-5851",
      "markText": "她笑眯眯地看了我一眼，右手指了一下自己的脑袋说：“Weird brain”（古怪的大脑）。 简直帅到爆。",
      "totalCount": 495,
      "appLink": "weread://bestbookmark?bookId=3300061099&chapterUid=12&rangeStart=5771&rangeEnd=5851",
      "webLink": "https://weread.qq.com/web/reader/cd4326f0813ab7e5dg0196be?chapterUid=12&rangeStart=5771&rangeEnd=5851"
    },
    {
      "bookmarkId": "3300061099_53_2044-2078",
      "chapterUid": 53,
      "range": "2044-2078",
      "markText": "做学术研究，是“你”成为“你”的过程，是你可以成为更好的自己的过程。",
      "totalCount": 465,
      "appLink": "weread://bestbookmark?bookId=3300061099&chapterUid=53&rangeStart=2044&rangeEnd=2078",
      "webLink": "https://weread.qq.com/web/reader/cd4326f0813ab7e5dg0196be?chapterUid=53&rangeStart=2044&rangeEnd=2078"
    },
    {
      "bookmarkId": "3300061099_54_2386-2457",
      "chapterUid": 54,
      "range": "2386-2457",
      "markText": "事实上，问出一个好的问题对社会科学研究来说是一件非常重要的事情，可以说几乎从根本上决定了一个研究到底有没有价值、如何操作、能否指导实践等方面。",
      "totalCount": 440,
      "appLink": "weread://bestbookmark?bookId=3300061099&chapterUid=54&rangeStart=2386&rangeEnd=2457",
      "webLink": "https://weread.qq.com/web/reader/cd4326f0813ab7e5dg0196be?chapterUid=54&rangeStart=2386&rangeEnd=2457"
    },
    {
      "bookmarkId": "3300061099_55_1395-1432",
      "chapterUid": 55,
      "range": "1395-1432",
      "markText": "任何一个成熟的学者都有一套自己的文献记录和管理系统，这个系统越早建立越好。",
      "totalCount": 420,
      "appLink": "weread://bestbookmark?bookId=3300061099&chapterUid=55&rangeStart=1395&rangeEnd=1432",
      "webLink": "https://weread.qq.com/web/reader/cd4326f0813ab7e5dg0196be?chapterUid=55&rangeStart=1395&rangeEnd=1432"
    },
    {
      "bookmarkId": "3300061099_6_455-508",
      "chapterUid": 6,
      "range": "455-508",
      "markText": "这本书不是教材，是伴书(companion)。教材很多，伴书很少，诚恳友好的伴书寥若晨星，正如人间的益友。",
      "totalCount": 396,
      "appLink": "weread://bestbookmark?bookId=3300061099&chapterUid=6&rangeStart=455&rangeEnd=508",
      "webLink": "https://weread.qq.com/web/reader/cd4326f0813ab7e5dg0196be?chapterUid=6&rangeStart=455&rangeEnd=508"
    },
    {
      "bookmarkId": "3300061099_12_5159-5210",
      "chapterUid": 12,
      "range": "5159-5210",
      "markText": "你每读完一篇文献，你脑中的体系就更完备一些，知识地图就又点亮了一片区域，我把这种状态叫“构造性阅读”。",
      "totalCount": 396,
      "appLink": "weread://bestbookmark?bookId=3300061099&chapterUid=12&rangeStart=5159&rangeEnd=5210",
      "webLink": "https://weread.qq.com/web/reader/cd4326f0813ab7e5dg0196be?chapterUid=12&rangeStart=5159&rangeEnd=5210"
    },
    {
      "bookmarkId": "3300061099_12_1267-1352",
      "chapterUid": 12,
      "range": "1267-1352",
      "markText": "现有的文献就是前人为你探索过、试错过、验证过的各种轮子，有时候你需要从中汲取理论，有时你需要从中找到新方向，其他时候你需要从中借鉴具体的研究设计、测量方法或数据分析方法。",
      "totalCount": 375,
      "appLink": "weread://bestbookmark?bookId=3300061099&chapterUid=12&rangeStart=1267&rangeEnd=1352",
      "webLink": "https://weread.qq.com/web/reader/cd4326f0813ab7e5dg0196be?chapterUid=12&rangeStart=1267&rangeEnd=1352"
    },
    {
      "bookmarkId": "3300061099_12_2037-2072",
      "chapterUid": 12,
      "range": "2037-2072",
      "markText": "读文献能力的晋升可以分这么三个阶段：逐字阅读、目的性阅读、构造性阅读。",
      "totalCount": 368,
      "appLink": "weread://bestbookmark?bookId=3300061099&chapterUid=12&rangeStart=2037&rangeEnd=2072",
      "webLink": "https://weread.qq.com/web/reader/cd4326f0813ab7e5dg0196be?chapterUid=12&rangeStart=2037&rangeEnd=2072"
    },
    {
      "bookmarkId": "3300061099_42_2244-2317",
      "chapterUid": 42,
      "range": "2244-2317",
      "markText": "把所有需要做的事情列在纸上，从你最愿意做的事情做起，往最不想做的事情上慢慢移动。躲避写论文的动力说不定会促成你把欠下两个月的书单全看了。亲测有效。",
      "totalCount": 360,
      "appLink": "weread://bestbookmark?bookId=3300061099&chapterUid=42&rangeStart=2244&rangeEnd=2317",
      "webLink": "https://weread.qq.com/web/reader/cd4326f0813ab7e5dg0196be?chapterUid=42&rangeStart=2244&rangeEnd=2317"
    },
    {
      "bookmarkId": "3300061099_53_1311-1358",
      "chapterUid": 53,
      "range": "1311-1358",
      "markText": "看研究人员就觉得他们是在做脱离于现实的“纸上谈兵”，做研究和发文章仿佛只有提升职称这一个功用。",
      "totalCount": 357,
      "appLink": "weread://bestbookmark?bookId=3300061099&chapterUid=53&rangeStart=1311&rangeEnd=1358",
      "webLink": "https://weread.qq.com/web/reader/cd4326f0813ab7e5dg0196be?chapterUid=53&rangeStart=1311&rangeEnd=1358"
    },
    {
      "bookmarkId": "3300061099_53_2284-2344",
      "chapterUid": 53,
      "range": "2284-2344",
      "markText": "一旦体验过思维激荡带来的乐趣，你也许就很难再随便将它放走，你就找到了抵抗生活无意义感的最好办法，并且取之不尽、用之不竭。",
      "totalCount": 351,
      "appLink": "weread://bestbookmark?bookId=3300061099&chapterUid=53&rangeStart=2284&rangeEnd=2344",
      "webLink": "https://weread.qq.com/web/reader/cd4326f0813ab7e5dg0196be?chapterUid=53&rangeStart=2284&rangeEnd=2344"
    },
    {
      "bookmarkId": "3300061099_12_1600-1630",
      "chapterUid": 12,
      "range": "1600-1630",
      "markText": "你读得越多、练得越早，你就越能更快升级、更好地解决研究问题。",
      "totalCount": 342,
      "appLink": "weread://bestbookmark?bookId=3300061099&chapterUid=12&rangeStart=1600&rangeEnd=1630",
      "webLink": "https://weread.qq.com/web/reader/cd4326f0813ab7e5dg0196be?chapterUid=12&rangeStart=1600&rangeEnd=1630"
    },
    {
      "bookmarkId": "3300061099_57_7202-7275",
      "chapterUid": 57,
      "range": "7202-7275",
      "markText": "所以很多时候并不是准备得万无一失了才上战场，而是在战场上边向目标努力边利用实战的机会进一步积累。不断学习新的分析工具本身就是做实证研究的一大乐事。",
      "totalCount": 338,
      "appLink": "weread://bestbookmark?bookId=3300061099&chapterUid=57&rangeStart=7202&rangeEnd=7275",
      "webLink": "https://weread.qq.com/web/reader/cd4326f0813ab7e5dg0196be?chapterUid=57&rangeStart=7202&rangeEnd=7275"
    }
