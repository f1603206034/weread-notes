    {
      "chapterUid": 7,
      "chapterTitle": "立：颠覆性思维",
      "items": [
        {
          "type": "highlight",
          "bookmarkId": "41787997_7_13856-13904",
          "range": "13856-13904",
          "rangeStart": 13856,
          "rangeEnd": 13904,
          "markText": "我们在针对公诉人的指控逻辑时，可以考虑把它比较简单的证据链条分解开，然后加进去更多、更细的环节。",
          "colorStyle": 1,
          "colorLabel": "",
          "createTime": 1723107964,
          "createTimeFormatted": "2024-08-08 17:06:04",
          "chapterUid": 7,
          "appLink": "weread://bestbookmark?bookId=41787997&chapterUid=7&rangeStart=13856&rangeEnd=13904",
          "webLink": "https://weread.qq.com/web/reader/f0232330727da25df025d59?chapterUid=7&rangeStart=13856&rangeEnd=13904"
        },
        {
