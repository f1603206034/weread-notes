    {
      "bookmarkId": "3300153003_5_3467-3488",
      "chapterUid": 5,
      "range": "3467-3488",
      "markText": "但女性是否应该仅仅追求男性所创造的价值观？",
      "totalCount": 585,
      "appLink": "weread://bestbookmark?bookId=3300153003&chapterUid=5&rangeStart=3467&rangeEnd=3488",
