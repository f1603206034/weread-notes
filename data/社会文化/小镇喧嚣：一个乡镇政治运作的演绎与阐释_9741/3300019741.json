  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300019741_65_5161-5257",
      "chapterUid": 65,
      "range": "5161-5257",
      "markText": "看来，这“酒精（久经）考验”和“把肠胃交给党”的政治民谚可真不只是基层干部们茶余饭后的消闲幽默，它的确是乡镇基层工作的一种真实写照，这即是如赵树凯所分析的乡镇政府的“应酬政治”的一个重要内容。",
      "totalCount": 4716,
      "appLink": "weread://bestbookmark?bookId=3300019741&chapterUid=65&rangeStart=5161&rangeEnd=5257",
      "webLink": "https://weread.qq.com/web/reader/59432150813ab6e36g011e75?chapterUid=65&rangeStart=5161&rangeEnd=5257"
    },
    {
      "bookmarkId": "3300019741_66_13631-13726",
      "chapterUid": 66,
      "range": "13631-13726",
