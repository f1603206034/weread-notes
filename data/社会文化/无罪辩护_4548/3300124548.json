  ],
  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300124548_8_13571-13637",
      "chapterUid": 8,
      "range": "13571-13637",
      "markText": "纪委在查了几个月之后居然没发现马金兰在担任村干部几十年期间一分钱的贪污受贿问题，反而账上还多了8分钱，最后也只好不了了之，放他回家。",
      "totalCount": 1674,
      "appLink": "weread://bestbookmark?bookId=3300124548&chapterUid=8&rangeStart=13571&rangeEnd=13637",
      "webLink": "https://weread.qq.com/web/reader/2c232da0813ab9726g01820e?chapterUid=8&rangeStart=13571&rangeEnd=13637"
    },
    {
      "bookmarkId": "3300124548_8_39989-40055",
      "chapterUid": 8,
      "range": "39989-40055",
      "markText": "我还记得有一年中秋节，我没回去陪70多岁的老爷子，而去了看守所陪马廷新，我知道中秋佳节，他所思念的人他都看不到，而只有我可以看到他。",
      "totalCount": 1495,
      "appLink": "weread://bestbookmark?bookId=3300124548&chapterUid=8&rangeStart=39989&rangeEnd=40055",
      "webLink": "https://weread.qq.com/web/reader/2c232da0813ab9726g01820e?chapterUid=8&rangeStart=39989&rangeEnd=40055"
    },
    {
      "bookmarkId": "3300124548_11_43011-43038",
      "chapterUid": 11,
      "range": "43011-43038",
      "markText": "正义虽然迟到，但没有缺席，正义就在眼前，历史不会重演。",
      "totalCount": 1440,
      "appLink": "weread://bestbookmark?bookId=3300124548&chapterUid=11&rangeStart=43011&rangeEnd=43038",
      "webLink": "https://weread.qq.com/web/reader/2c232da0813ab9726g01820e?chapterUid=11&rangeStart=43011&rangeEnd=43038"
    },
    {
      "bookmarkId": "3300124548_8_36746-36840",
      "chapterUid": 8,
      "range": "36746-36840",
      "markText": "司法理念的碰撞，人文伦理的冲突，立功受奖的诱惑，丝丝入扣的“案情”，神眼、神探的忽悠，狱侦耳目的邪恶，法官的冷漠，检察官的失察，律师的坚守，证人的无奈。这一切都带给我们对于整个人性的思考。",
      "totalCount": 1343,
      "appLink": "weread://bestbookmark?bookId=3300124548&chapterUid=8&rangeStart=36746&rangeEnd=36840",
      "webLink": "https://weread.qq.com/web/reader/2c232da0813ab9726g01820e?chapterUid=8&rangeStart=36746&rangeEnd=36840"
    },
    {
      "bookmarkId": "3300124548_8_4209-4284",
      "chapterUid": 8,
      "range": "4209-4284",
      "markText": "一时间浚县东马庄村似乎阴云洞开，公安机关也大开庆功宴，各级立功授奖的活动也开始逐级申报。后来的消息证实，当年参与办理本案的侦查人员几乎全部立功、升职。",
      "totalCount": 1248,
      "appLink": "weread://bestbookmark?bookId=3300124548&chapterUid=8&rangeStart=4209&rangeEnd=4284",
      "webLink": "https://weread.qq.com/web/reader/2c232da0813ab9726g01820e?chapterUid=8&rangeStart=4209&rangeEnd=4284"
    },
    {
      "bookmarkId": "3300124548_8_13280-13343",
      "chapterUid": 8,
      "range": "13280-13343",
      "markText": "为了彻底迫使马廷新家人放弃为其申冤的行动，公安机关先后抓了马廷新的妻子、儿子、父亲，后来家里仅仅剩下一个四岁的小女儿无人照看。",
      "totalCount": 1242,
      "appLink": "weread://bestbookmark?bookId=3300124548&chapterUid=8&rangeStart=13280&rangeEnd=13343",
      "webLink": "https://weread.qq.com/web/reader/2c232da0813ab9726g01820e?chapterUid=8&rangeStart=13280&rangeEnd=13343"
    },
    {
      "bookmarkId": "3300124548_11_12904-12976",
      "chapterUid": 11,
      "range": "12904-12976",
      "markText": "他更不知道的是在这场“无懈可击”的侦查预审中，背后的操盘手正是公安系统唯一的“全国三八红旗手”，号称“浙江神探”的杭州市公安局预审大队长聂海芬。",
      "totalCount": 1184,
      "appLink": "weread://bestbookmark?bookId=3300124548&chapterUid=11&rangeStart=12904&rangeEnd=12976",
      "webLink": "https://weread.qq.com/web/reader/2c232da0813ab9726g01820e?chapterUid=11&rangeStart=12904&rangeEnd=12976"
    },
    {
      "bookmarkId": "3300124548_8_37687-37739",
      "chapterUid": 8,
      "range": "37687-37739",
      "markText": "但是对于那些“破案”的人，庆功酒也喝了、办案人员也提拔升官了，要毁灭这一切的确不是一般的人所具有的胆识。",
      "totalCount": 972,
      "appLink": "weread://bestbookmark?bookId=3300124548&chapterUid=8&rangeStart=37687&rangeEnd=37739",
      "webLink": "https://weread.qq.com/web/reader/2c232da0813ab9726g01820e?chapterUid=8&rangeStart=37687&rangeEnd=37739"
    },
    {
      "bookmarkId": "3300124548_6_1806-1829",
      "chapterUid": 6,
      "range": "1806-1829",
      "markText": "北京的春天又来了，我们的书稿是不是也该发芽了。",
      "totalCount": 924,
      "appLink": "weread://bestbookmark?bookId=3300124548&chapterUid=6&rangeStart=1806&rangeEnd=1829",
      "webLink": "https://weread.qq.com/web/reader/2c232da0813ab9726g01820e?chapterUid=6&rangeStart=1806&rangeEnd=1829"
    },
    {
      "bookmarkId": "3300124548_16_26053-26120",
      "chapterUid": 16,
      "range": "26053-26120",
      "markText": "现在是法庭上，不仅仅有国徽，上还有天，下还有地，你不承认我也没办法，那我们就将老婆孩子拿来赌咒。审判长一脸尴尬，慌忙之下敲下法槌休庭。",
      "totalCount": 901,
      "appLink": "weread://bestbookmark?bookId=3300124548&chapterUid=16&rangeStart=26053&rangeEnd=26120",
      "webLink": "https://weread.qq.com/web/reader/2c232da0813ab9726g01820e?chapterUid=16&rangeStart=26053&rangeEnd=26120"
    },
    {
      "bookmarkId": "3300124548_8_4100-4147",
      "chapterUid": 8,
      "range": "4100-4147",
      "markText": "于是马廷新当即被收押，巧合的是那一天时间节点正好是公安局长立下三个月破案的“军令状”的最后一天",
      "totalCount": 896,
      "appLink": "weread://bestbookmark?bookId=3300124548&chapterUid=8&rangeStart=4100&rangeEnd=4147",
      "webLink": "https://weread.qq.com/web/reader/2c232da0813ab9726g01820e?chapterUid=8&rangeStart=4100&rangeEnd=4147"
    },
    {
      "bookmarkId": "3300124548_11_28386-28430",
      "chapterUid": 11,
      "range": "28386-28430",
      "markText": "“中国历史上最大的冤案，杨乃武与小白菜就是你们那里出的。”科长魏刚毫不客气地挂掉了电话。",
      "totalCount": 884,
      "appLink": "weread://bestbookmark?bookId=3300124548&chapterUid=11&rangeStart=28386&rangeEnd=28430",
      "webLink": "https://weread.qq.com/web/reader/2c232da0813ab9726g01820e?chapterUid=11&rangeStart=28386&rangeEnd=28430"
    },
    {
      "bookmarkId": "3300124548_8_10962-11009",
      "chapterUid": 8,
      "range": "10962-11009",
      "markText": "他们分别在看守所被关押了几天至四十几天不等后才被放回。但是他们出看守所的条件就是必须改变证言。",
      "totalCount": 852,
      "appLink": "weread://bestbookmark?bookId=3300124548&chapterUid=8&rangeStart=10962&rangeEnd=11009",
      "webLink": "https://weread.qq.com/web/reader/2c232da0813ab9726g01820e?chapterUid=8&rangeStart=10962&rangeEnd=11009"
    },
    {
      "bookmarkId": "3300124548_11_45432-45489",
      "chapterUid": 11,
      "range": "45432-45489",
      "markText": "事实上，更多的故事并不能写在纸上，我们似乎都认可，张氏叔侄在十年炼狱之后得以平冤恰恰是一连串的巧合彰显的天命轮回。",
