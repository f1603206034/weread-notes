          "colorStyle": 0,
          "colorLabel": "",
          "createTime": 1738738429,
          "createTimeFormatted": "2025-02-05 14:53:49",
          "chapterUid": 11,
          "appLink": "weread://bestbookmark?bookId=3300124548&chapterUid=11&rangeStart=43011&rangeEnd=43038",
