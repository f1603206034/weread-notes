          "bookmarkId": "3300077979_4_1550-1561",
          "range": "1550-1561",
          "rangeStart": 1550,
          "rangeEnd": 1561,
          "markText": "（三）李克用与士人研究",
          "colorStyle": 1,
          "colorLabel": "",
          "createTime": 1777527850,
