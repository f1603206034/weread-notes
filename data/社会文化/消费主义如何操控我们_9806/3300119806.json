  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300119806_24_413-486",
      "chapterUid": 24,
      "range": "413-486",
      "markText": "争取承认，争取获得社会承认的社会存在，概言之，争取人性，在这样的符号斗争中，失败者所遭到的剥夺或许是最糟糕的剥夺，所经历的丧失或许是最糟糕的丧失。",
      "totalCount": 238,
      "appLink": "weread://bestbookmark?bookId=3300119806&chapterUid=24&rangeStart=413&rangeEnd=486",
      "webLink": "https://weread.qq.com/web/reader/8f932710813ab954cg016adf?chapterUid=24&rangeStart=413&rangeEnd=486"
    },
    {
      "bookmarkId": "3300119806_24_7983-8074",
      "chapterUid": 24,
      "range": "7983-8074",
      "markText": "如果说资本主义社会要实现再生产，就是通过作为买方角色的资本和作为商品角色的劳动力之间无休止的、重复的交易往来，那么资本主义国家就必须确保这种往来循例发生并达成其目的，即最终完成交易。",
      "totalCount": 221,
      "appLink": "weread://bestbookmark?bookId=3300119806&chapterUid=24&rangeStart=7983&rangeEnd=8074",
      "webLink": "https://weread.qq.com/web/reader/8f932710813ab954cg016adf?chapterUid=24&rangeStart=7983&rangeEnd=8074"
    },
    {
      "bookmarkId": "3300119806_29_4467-4549",
      "chapterUid": 29,
      "range": "4467-4549",
      "markText": "穷人被迫陷入这样一种境地：他们要么不得不将自己仅有的一点钱或资源花在毫无意义的消费物品上，而不是基本必需品上，以扭转整体上的社会屈辱；要么就面临被嘲弄和取笑的前景。",
      "totalCount": 195,
      "appLink": "weread://bestbookmark?bookId=3300119806&chapterUid=29&rangeStart=4467&rangeEnd=4549",
      "webLink": "https://weread.qq.com/web/reader/8f932710813ab954cg016adf?chapterUid=29&rangeStart=4467&rangeEnd=4549"
    },
    {
      "bookmarkId": "3300119806_24_7035-7097",
      "chapterUid": 24,
      "range": "7035-7097",
      "markText": "而使用化妆品并不总是一种奢侈。由于害怕被视为过时落伍而遭淘汰，女士们和先生们开始染发，而四十来岁的人则参加体育运动以保持身形",
      "totalCount": 187,
      "appLink": "weread://bestbookmark?bookId=3300119806&chapterUid=24&rangeStart=7035&rangeEnd=7097",
      "webLink": "https://weread.qq.com/web/reader/8f932710813ab954cg016adf?chapterUid=24&rangeStart=7035&rangeEnd=7097"
    },
    {
      "bookmarkId": "3300119806_24_10749-10791",
      "chapterUid": 24,
      "range": "10749-10791",
      "markText": "最后但并非最不重要的一点是，当公司不再需要他时，他将离开公司，不去抱怨，也不打官司。",
      "totalCount": 180,
      "appLink": "weread://bestbookmark?bookId=3300119806&chapterUid=24&rangeStart=10749&rangeEnd=10791",
      "webLink": "https://weread.qq.com/web/reader/8f932710813ab954cg016adf?chapterUid=24&rangeStart=10749&rangeEnd=10791"
    },
    {
      "bookmarkId": "3300119806_24_15567-15758",
      "chapterUid": 24,
      "range": "15567-15758",
      "markText": "如果说商品拜物教注定要隐藏生产者社会中人性的、太人性的属性，那么就要轮到主体性拜物教(subjectivity fetishism)来掩盖消费者社会商品化、太商品化的现实了。",
      "totalCount": 180,
      "appLink": "weread://bestbookmark?bookId=3300119806&chapterUid=24&rangeStart=15567&rangeEnd=15758",
      "webLink": "https://weread.qq.com/web/reader/8f932710813ab954cg016adf?chapterUid=24&rangeStart=15567&rangeEnd=15758"
    },
    {
      "bookmarkId": "3300119806_28_3748-3896",
      "chapterUid": 28,
      "range": "3748-3896",
      "markText": "消费社会只要设法使其成员的不满足（因此，用它自己的话来说，他们的不快乐）持久存在，它就会蓬勃发展。而达到这种效果的明确方法，就是在消费品被炒作进入消费者欲望的世界后不久，又对其进行诋毁和贬值。",
      "totalCount": 156,
      "appLink": "weread://bestbookmark?bookId=3300119806&chapterUid=28&rangeStart=3748&rangeEnd=3896",
      "webLink": "https://weread.qq.com/web/reader/8f932710813ab954cg016adf?chapterUid=28&rangeStart=3748&rangeEnd=3896"
    },
    {
      "bookmarkId": "3300119806_24_6617-6762",
      "chapterUid": 24,
      "range": "6617-6762",
      "markText": "为了获得他们梦寐以求的社会奖赏，他们需要通过某种测试，测试要求他们将自己重新塑造成商品，也就是说，能够攫取关注并吸引需求和客户的产品。",
      "totalCount": 154,
      "appLink": "weread://bestbookmark?bookId=3300119806&chapterUid=24&rangeStart=6617&rangeEnd=6762",
      "webLink": "https://weread.qq.com/web/reader/8f932710813ab954cg016adf?chapterUid=24&rangeStart=6617&rangeEnd=6762"
    },
    {
      "bookmarkId": "3300119806_24_4610-4693",
      "chapterUid": 24,
      "range": "4610-4693",
      "markText": "那些缺乏现金、信用卡和/或购物热情的人，要不就是对市场营销的花言巧语免疫的人。因此，作为负向筛选的结果，只有那些资金丰厚、心怀渴求的玩家才会被允许留在消费主义游戏中。",
      "totalCount": 143,
      "appLink": "weread://bestbookmark?bookId=3300119806&chapterUid=24&rangeStart=4610&rangeEnd=4693",
      "webLink": "https://weread.qq.com/web/reader/8f932710813ab954cg016adf?chapterUid=24&rangeStart=4610&rangeEnd=4693"
    },
    {
      "bookmarkId": "3300119806_24_7543-7643",
      "chapterUid": 24,
      "range": "7543-7643",
      "markText": "八十年后，杰梅茵·格里尔(Germaine Greer)已经观察到：“即使在中国西北最偏远的地方，女性也把睡衣一般的宽松家常衣着搁到一边，换上软垫胸罩和性感裙子，把一头直发烫卷洗染，攒钱购买化妆品。”",
      "totalCount": 120,
      "appLink": "weread://bestbookmark?bookId=3300119806&chapterUid=24&rangeStart=7543&rangeEnd=7643",
      "webLink": "https://weread.qq.com/web/reader/8f932710813ab954cg016adf?chapterUid=24&rangeStart=7543&rangeEnd=7643"
    },
    {
      "bookmarkId": "3300119806_24_3303-3389",
      "chapterUid": 24,
      "range": "3303-3389",
      "markText": "这个社会恶名昭著，它抹去了曾经将私人与公共分开的界限，将公开揭露私事视为公共美德和义务，并将所有拒绝被化约为私人信任的东西，以及那些拒绝信任它们的人，从公共传播中一并抹除。",
      "totalCount": 119,
      "appLink": "weread://bestbookmark?bookId=3300119806&chapterUid=24&rangeStart=3303&rangeEnd=3389",
      "webLink": "https://weread.qq.com/web/reader/8f932710813ab954cg016adf?chapterUid=24&rangeStart=3303&rangeEnd=3389"
    },
    {
      "bookmarkId": "3300119806_26_5548-5605",
      "chapterUid": 26,
      "range": "5548-5605",
      "markText": "因此（到目前为止）并未造成地位的损失，从过早终局的碎片之中，或者更确切地说，从僵死的开局之中，仍然可能打捞出希望。",
      "totalCount": 119,
      "appLink": "weread://bestbookmark?bookId=3300119806&chapterUid=26&rangeStart=5548&rangeEnd=5605",
      "webLink": "https://weread.qq.com/web/reader/8f932710813ab954cg016adf?chapterUid=26&rangeStart=5548&rangeEnd=5605"
    },
    {
      "bookmarkId": "3300119806_24_8325-8369",
      "chapterUid": 24,
      "range": "8325-8369",
      "markText": "求职者必须保持适当的营养和健康，习惯有纪律的行为，并具备他们求职岗位的工作惯例所需的技能",
      "totalCount": 112,
      "appLink": "weread://bestbookmark?bookId=3300119806&chapterUid=24&rangeStart=8325&rangeEnd=8369",
      "webLink": "https://weread.qq.com/web/reader/8f932710813ab954cg016adf?chapterUid=24&rangeStart=8325&rangeEnd=8369"
