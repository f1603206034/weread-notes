  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "906852_4_2192-2269",
      "chapterUid": 4,
      "range": "2192-2269",
      "markText": "犹太国家则力图把这段悲剧的历史用来当做其政治合法性的依据，当做其过去和将来政策的安全通行证，并且，最重要的是，当做它为可能要干的不道义行为提前支付的代价。",
      "totalCount": 935,
      "appLink": "weread://bestbookmark?bookId=906852&chapterUid=4&rangeStart=2192&rangeEnd=2269",
      "webLink": "https://weread.qq.com/web/reader/ef432b305dd664ef447bcb5?chapterUid=4&rangeStart=2192&rangeEnd=2269"
    },
    {
      "bookmarkId": "906852_8_2825-2902",
      "chapterUid": 8,
      "range": "2825-2902",
      "markText": "纳粹党卫军头目（似乎是肯定地）依赖于组织惯例而不是个人热情，依赖于纪律而不是意识形态的沉迷。对血腥任务的忠诚就是——也确实是——对组织的忠诚的一个衍生物。",
      "totalCount": 704,
      "appLink": "weread://bestbookmark?bookId=906852&chapterUid=8&rangeStart=2825&rangeEnd=2902",
      "webLink": "https://weread.qq.com/web/reader/ef432b305dd664ef447bcb5?chapterUid=8&rangeStart=2825&rangeEnd=2902"
    },
    {
      "bookmarkId": "906852_3_1049-1058",
      "chapterUid": 3,
      "range": "1049-1058",
      "markText": "沉默是最大的悲哀。",
      "totalCount": 675,
      "appLink": "weread://bestbookmark?bookId=906852&chapterUid=3&rangeStart=1049&rangeEnd=1058",
      "webLink": "https://weread.qq.com/web/reader/ef432b305dd664ef447bcb5?chapterUid=3&rangeStart=1049&rangeEnd=1058"
    },
    {
      "bookmarkId": "906852_4_5720-5798",
      "chapterUid": 4,
      "range": "5720-5798",
      "markText": "认为大屠杀的刽子手是我们文明的一种损伤或一个痼疾——而不是文明恐怖却合理的产物——不仅导致了自我辩解的道德安慰，而且导致了在道德和政治上失去戒备的可怕危险。",
      "totalCount": 666,
      "appLink": "weread://bestbookmark?bookId=906852&chapterUid=4&rangeStart=5720&rangeEnd=5798",
      "webLink": "https://weread.qq.com/web/reader/ef432b305dd664ef447bcb5?chapterUid=4&rangeStart=5720&rangeEnd=5798"
    },
    {
      "bookmarkId": "906852_5_6290-6313",
      "chapterUid": 5,
      "range": "6290-6313",
      "markText": "大屠杀是现代性的一个失败，而不是它的一个产物。",
      "totalCount": 544,
      "appLink": "weread://bestbookmark?bookId=906852&chapterUid=5&rangeStart=6290&rangeEnd=6313",
      "webLink": "https://weread.qq.com/web/reader/ef432b305dd664ef447bcb5?chapterUid=5&rangeStart=6290&rangeEnd=6313"
    },
    {
      "bookmarkId": "906852_4_1918-1996",
      "chapterUid": 4,
      "range": "1918-1996",
      "markText": "大屠杀经常作为发生在犹太人身上，而且仅仅是发生在犹太人身上的悲剧，沉积在公众的意识里，因此对于所有其他人而言，它要求惋惜、怜悯，也许还有谢罪，但也仅此而已。",
      "totalCount": 528,
      "appLink": "weread://bestbookmark?bookId=906852&chapterUid=4&rangeStart=1918&rangeEnd=1996",
      "webLink": "https://weread.qq.com/web/reader/ef432b305dd664ef447bcb5?chapterUid=4&rangeStart=1918&rangeEnd=1996"
    },
    {
      "bookmarkId": "906852_18_5539-5584",
      "chapterUid": 18,
      "range": "5539-5584",
      "markText": "人就是他行动前的样子；无论他做什么都改变不了他的本质。大致而言，这就是种族主义的哲学本质。",
      "totalCount": 512,
      "appLink": "weread://bestbookmark?bookId=906852&chapterUid=18&rangeStart=5539&rangeEnd=5584",
      "webLink": "https://weread.qq.com/web/reader/ef432b305dd664ef447bcb5?chapterUid=18&rangeStart=5539&rangeEnd=5584"
    },
    {
      "bookmarkId": "906852_4_7694-7758",
      "chapterUid": 4,
      "range": "7694-7758",
      "markText": "大屠杀是现代性所忽略、淡化或者无法解决的旧紧张同理性有效行为的强有力手段之间独一无二的一次遭遇，而这种手段又是现代进程本身的产物",
      "totalCount": 408,
      "appLink": "weread://bestbookmark?bookId=906852&chapterUid=4&rangeStart=7694&rangeEnd=7758",
      "webLink": "https://weread.qq.com/web/reader/ef432b305dd664ef447bcb5?chapterUid=4&rangeStart=7694&rangeEnd=7758"
    },
    {
      "bookmarkId": "906852_4_1535-1596",
      "chapterUid": 4,
      "range": "1535-1596",
      "markText": "透过这扇窗我所看到的一切一点儿也不令人愉快。但是，所见的画面越是抑郁沉闷，我就越是坚信倘若拒绝看出窗外，就将是非常危险的。",
      "totalCount": 405,
      "appLink": "weread://bestbookmark?bookId=906852&chapterUid=4&rangeStart=1535&rangeEnd=1596",
      "webLink": "https://weread.qq.com/web/reader/ef432b305dd664ef447bcb5?chapterUid=4&rangeStart=1535&rangeEnd=1596"
    },
    {
      "bookmarkId": "906852_7_7095-7168",
      "chapterUid": 7,
      "range": "7095-7168",
      "markText": "大屠杀不是人类前现代的野蛮未被完全根除之残留的一次非理性的外溢。它是现代性大厦里的一位合法居民；更准确些，它是其他任何一座大厦里都不可能有的居民。",
      "totalCount": 390,
      "appLink": "weread://bestbookmark?bookId=906852&chapterUid=7&rangeStart=7095&rangeEnd=7168",
      "webLink": "https://weread.qq.com/web/reader/ef432b305dd664ef447bcb5?chapterUid=7&rangeStart=7095&rangeEnd=7168"
    },
    {
      "bookmarkId": "906852_8_1611-1667",
      "chapterUid": 8,
      "range": "1611-1667",
      "markText": "进行屠杀的刽子手大多数都是正常人，不管已经有的精神检测之网多么牢密，他们也能顺畅地通过，这在道德上是令人烦忧的。",
      "totalCount": 360,
      "appLink": "weread://bestbookmark?bookId=906852&chapterUid=8&rangeStart=1611&rangeEnd=1667",
      "webLink": "https://weread.qq.com/web/reader/ef432b305dd664ef447bcb5?chapterUid=8&rangeStart=1611&rangeEnd=1667"
    },
    {
      "bookmarkId": "906852_9_1444-1513",
      "chapterUid": 9,
      "range": "1444-1513",
      "markText": "意图和实际完成之间有很大的距离，两者之间的空间里充满了大量的细微行为和不相干的行动者。“中间人”挡住了行动者的目光，让他看不见行为的结果。",
      "totalCount": 360,
      "appLink": "weread://bestbookmark?bookId=906852&chapterUid=9&rangeStart=1444&rangeEnd=1513",
      "webLink": "https://weread.qq.com/web/reader/ef432b305dd664ef447bcb5?chapterUid=9&rangeStart=1444&rangeEnd=1513"
    },
    {
      "bookmarkId": "906852_6_2244-2444",
      "chapterUid": 6,
      "range": "2244-2444",
      "markText": "“最终解决”标示出了欧洲工业体系走上歧途的那一点；走到了升华生命这个启蒙运动之夙愿的对立面，这个体系已开始自我损耗。而当初欧洲正是凭借其工业体系以及依附于它的精神才得以统治全世界的。",
      "totalCount": 357,
      "appLink": "weread://bestbookmark?bookId=906852&chapterUid=6&rangeStart=2244&rangeEnd=2444",
      "webLink": "https://weread.qq.com/web/reader/ef432b305dd664ef447bcb5?chapterUid=6&rangeStart=2244&rangeEnd=2444"
    },
    {
      "bookmarkId": "906852_6_7766-7813",
      "chapterUid": 6,
      "range": "7766-7813",
      "markText": "换句话说，我打算将大屠杀看成是对现代社会具有的潜在可能性进行的一次罕见而又重要并且可靠的检验。",
      "totalCount": 357,
      "appLink": "weread://bestbookmark?bookId=906852&chapterUid=6&rangeStart=7766&rangeEnd=7813",
      "webLink": "https://weread.qq.com/web/reader/ef432b305dd664ef447bcb5?chapterUid=6&rangeStart=7766&rangeEnd=7813"
    },
    {
      "bookmarkId": "906852_9_3350-3399",
      "chapterUid": 9,
      "range": "3350-3399",
      "markText": "大屠杀在技术和管理上的成功要部分地归功于娴熟地运用了现代官僚体系和现代技术所提供的“道德催眠药”。",
      "totalCount": 357,
      "appLink": "weread://bestbookmark?bookId=906852&chapterUid=9&rangeStart=3350&rangeEnd=3399",
      "webLink": "https://weread.qq.com/web/reader/ef432b305dd664ef447bcb5?chapterUid=9&rangeStart=3350&rangeEnd=3399"
    },
    {
      "bookmarkId": "906852_8_4672-4767",
      "chapterUid": 8,
      "range": "4672-4767",
      "markText": "对一个公仆来说，这种行为意味着“最高意义上的道德戒律和自我牺牲”。通过荣誉，纪律取代了道德责任。惟有组织内的规则被作为正当性的源泉和保证，现在这已经变成最高的美德，从而否定个人良知的权威性。",
      "totalCount": 350,
      "appLink": "weread://bestbookmark?bookId=906852&chapterUid=8&rangeStart=4672&rangeEnd=4767",
      "webLink": "https://weread.qq.com/web/reader/ef432b305dd664ef447bcb5?chapterUid=8&rangeStart=4672&rangeEnd=4767"
    },
    {
      "bookmarkId": "906852_4_2378-2424",
      "chapterUid": 4,
      "range": "2378-2424",
      "markText": "大屠杀的意义已经在多大程度上被简化为私有的不幸和一个民族的灾难，并且这种简化又是多么的危险。",
      "totalCount": 340,
      "appLink": "weread://bestbookmark?bookId=906852&chapterUid=4&rangeStart=2378&rangeEnd=2424",
      "webLink": "https://weread.qq.com/web/reader/ef432b305dd664ef447bcb5?chapterUid=4&rangeStart=2378&rangeEnd=2424"
    },
    {
      "bookmarkId": "906852_9_2250-2337",
      "chapterUid": 9,
      "range": "2250-2337",
      "markText": "行为与其后果之间的身体和（或）精神距离的增加超过了道德自抑发挥作用的程度；它抹杀了行为的道德意义，因而预先避免了个人所持的道德正当标准与行为的社会后果不道德性之间的一切冲突。",
      "totalCount": 336,
      "appLink": "weread://bestbookmark?bookId=906852&chapterUid=9&rangeStart=2250&rangeEnd=2337",
      "webLink": "https://weread.qq.com/web/reader/ef432b305dd664ef447bcb5?chapterUid=9&rangeStart=2250&rangeEnd=2337"
    },
    {
      "bookmarkId": "906852_4_1727-1787",
      "chapterUid": 4,
      "range": "1727-1787",
      "markText": "我以为（是因为疏忽而不是经过了深思熟虑）大屠杀是历史正常发展过程中的断裂，文明化社会体内生长的毒瘤，健全心智的片刻疯狂。",
      "totalCount": 330,
      "appLink": "weread://bestbookmark?bookId=906852&chapterUid=4&rangeStart=1727&rangeEnd=1787",
      "webLink": "https://weread.qq.com/web/reader/ef432b305dd664ef447bcb5?chapterUid=4&rangeStart=1727&rangeEnd=1787"
    },
    {
      "bookmarkId": "906852_6_1163-1253",
      "chapterUid": 6,
      "range": "1163-1253",
      "markText": "不可能“提前看出”个人为牺牲而做出准备或者个人在灾难面前会表现出懦弱的迹象、征兆或者暗示；也就是说，不可能在要求他们振作起来或者仅仅是“使他们醒悟”的情境之外来判断他们其后的表现。",
      "totalCount": 330,
      "appLink": "weread://bestbookmark?bookId=906852&chapterUid=6&rangeStart=1163&rangeEnd=1253",
      "webLink": "https://weread.qq.com/web/reader/ef432b305dd664ef447bcb5?chapterUid=6&rangeStart=1163&rangeEnd=1253"
    }
