  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "33889219_7_7061-7139",
      "chapterUid": 7,
      "range": "7061-7139",
      "markText": "美国人把自己的全部生活调节到经常应付挑战上，并且随时准备应战。日本人则把自己的信念建立在万事预先俱有安排的生活方式上，在他们那里，最大的威胁莫过于未曾料到。",
      "totalCount": 378,
      "appLink": "weread://bestbookmark?bookId=33889219&chapterUid=7&rangeStart=7061&rangeEnd=7139",
      "webLink": "https://weread.qq.com/web/reader/0bc327a072051bc30bc9229?chapterUid=7&rangeStart=7061&rangeEnd=7139"
    },
    {
      "bookmarkId": "33889219_7_14982-15024",
      "chapterUid": 7,
      "range": "14982-15024",
      "markText": "好像他们在生命中翻开了新的一页，其内容与旧的一页完全相反，但他们却表现出同样的忠诚。",
      "totalCount": 342,
      "appLink": "weread://bestbookmark?bookId=33889219&chapterUid=7&rangeStart=14982&rangeEnd=15024",
      "webLink": "https://weread.qq.com/web/reader/0bc327a072051bc30bc9229?chapterUid=7&rangeStart=14982&rangeEnd=15024"
    },
    {
      "bookmarkId": "33889219_6_3165-3196",
      "chapterUid": 6,
      "range": "3165-3196",
      "markText": "问题是日本人将如何行动，而不是我们处在他们的境遇时将如何行动。",
      "totalCount": 272,
      "appLink": "weread://bestbookmark?bookId=33889219&chapterUid=6&rangeStart=3165&rangeEnd=3196",
      "webLink": "https://weread.qq.com/web/reader/0bc327a072051bc30bc9229?chapterUid=6&rangeStart=3165&rangeEnd=3196"
    },
    {
      "bookmarkId": "33889219_6_4660-4716",
      "chapterUid": 6,
      "range": "4660-4716",
      "markText": "日本人与其他东方民族不同，有强烈描写自我的冲动，既写他们的生活琐事，也写他们的全球扩张计划，其坦率实在令人惊异。",
      "totalCount": 221,
      "appLink": "weread://bestbookmark?bookId=33889219&chapterUid=6&rangeStart=4660&rangeEnd=4716",
      "webLink": "https://weread.qq.com/web/reader/0bc327a072051bc30bc9229?chapterUid=6&rangeStart=4660&rangeEnd=4716"
    },
    {
      "bookmarkId": "33889219_7_15267-15309",
      "chapterUid": 7,
      "range": "15267-15309",
      "markText": "但日本人的行为则好像是：择定一条道路便全力以赴，如果失败，就很自然地选择另一条道路。",
      "totalCount": 221,
      "appLink": "weread://bestbookmark?bookId=33889219&chapterUid=7&rangeStart=15267&rangeEnd=15309",
      "webLink": "https://weread.qq.com/web/reader/0bc327a072051bc30bc9229?chapterUid=7&rangeStart=15267&rangeEnd=15309"
    },
    {
      "bookmarkId": "33889219_13_5775-5907",
      "chapterUid": 13,
      "range": "5775-5907",
      "markText": "他们说，如果一个项目采用竞争的方法，被测试者的思想就会集中于担心失败，因而工作受到损失。他们对竞争对手异常敏感，仿佛是对自己的一种侵犯，因而注意力转到与侵犯者的关系上，而不是专心从事工作。 [3]",
      "totalCount": 180,
      "appLink": "weread://bestbookmark?bookId=33889219&chapterUid=13&rangeStart=5775&rangeEnd=5907",
      "webLink": "https://weread.qq.com/web/reader/0bc327a072051bc30bc9229?chapterUid=13&rangeStart=5775&rangeEnd=5907"
    },
    {
      "bookmarkId": "33889219_8_1993-2086",
      "chapterUid": 8,
      "range": "1993-2086",
      "markText": "平等，对美国人而言，是指盼一个更美好世界的最崇高、最道德的基础。对我们来说，它意味着拥有不受专制压迫、不受干涉、不受强制的自由；意味着在法律面前人人平等和人人都有改善自己生活条件的权利。",
      "totalCount": 169,
      "appLink": "weread://bestbookmark?bookId=33889219&chapterUid=8&rangeStart=1993&rangeEnd=2086",
      "webLink": "https://weread.qq.com/web/reader/0bc327a072051bc30bc9229?chapterUid=8&rangeStart=1993&rangeEnd=2086"
    },
    {
      "bookmarkId": "33889219_6_4917-4967",
      "chapterUid": 6,
      "range": "4917-4967",
      "markText": "他们为什么对一些无足轻重的行为大肆攻击，而对骇人听闻的暴行却满不介意，这种态度的背后到底隐藏着什么？",
      "totalCount": 168,
      "appLink": "weread://bestbookmark?bookId=33889219&chapterUid=6&rangeStart=4917&rangeEnd=4967",
      "webLink": "https://weread.qq.com/web/reader/0bc327a072051bc30bc9229?chapterUid=6&rangeStart=4917&rangeEnd=4967"
    },
    {
      "bookmarkId": "33889219_7_6794-6809",
      "chapterUid": 7,
      "range": "6794-6809",
      "markText": "败得越惨，事态就发展得越顺利。",
      "totalCount": 160,
      "appLink": "weread://bestbookmark?bookId=33889219&chapterUid=7&rangeStart=6794&rangeEnd=6809",
      "webLink": "https://weread.qq.com/web/reader/0bc327a072051bc30bc9229?chapterUid=7&rangeStart=6794&rangeEnd=6809"
    },
    {
      "bookmarkId": "33889219_15_18980-19024",
      "chapterUid": 15,
      "range": "18980-19024",
      "markText": "真正的耻感文化依靠外部的强制力来做善行。真正的罪感文化则依靠罪恶感在内心的反应来做善行。",
      "totalCount": 153,
      "appLink": "weread://bestbookmark?bookId=33889219&chapterUid=15&rangeStart=18980&rangeEnd=19024",
      "webLink": "https://weread.qq.com/web/reader/0bc327a072051bc30bc9229?chapterUid=15&rangeStart=18980&rangeEnd=19024"
    },
    {
      "bookmarkId": "33889219_7_1717-1740",
      "chapterUid": 7,
      "range": "1717-1740",
      "markText": "这一点与我们热爱平等的美国人，是水火不相容的。",
      "totalCount": 144,
      "appLink": "weread://bestbookmark?bookId=33889219&chapterUid=7&rangeStart=1717&rangeEnd=1740",
      "webLink": "https://weread.qq.com/web/reader/0bc327a072051bc30bc9229?chapterUid=7&rangeStart=1717&rangeEnd=1740"
    },
    {
      "bookmarkId": "33889219_7_6473-6519",
      "chapterUid": 7,
      "range": "6473-6519",
      "markText": "他们绝不说：“要发生的事终于发生了”，而是说：“我们所等待的终于来临了。我们欢迎它的到来。”",
      "totalCount": 140,
      "appLink": "weread://bestbookmark?bookId=33889219&chapterUid=7&rangeStart=6473&rangeEnd=6519",
      "webLink": "https://weread.qq.com/web/reader/0bc327a072051bc30bc9229?chapterUid=7&rangeStart=6473&rangeEnd=6519"
    },
    {
      "bookmarkId": "33889219_8_5111-5181",
      "chapterUid": 8,
      "range": "5111-5181",
      "markText": "在封建帝制时期，这种半自治性质的大宗族共同体，只是偶尔在名义上受国家管理，那些由不断更迭的政府所指派的、逍遥自在的官员，在这个地区乃是外人。",
