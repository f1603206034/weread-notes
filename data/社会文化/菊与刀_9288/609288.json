      "appLink": "weread://bestbookmark?bookId=609288&chapterUid=5&rangeStart=2629&rangeEnd=2705",
      "webLink": "https://weread.qq.com/web/reader/c4132040594c08c41c28129?chapterUid=5&rangeStart=2629&rangeEnd=2705"
    },
    {
