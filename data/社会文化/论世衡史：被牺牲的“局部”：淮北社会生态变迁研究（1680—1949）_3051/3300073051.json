          "colorLabel": "",
          "createTime": 1735118444,
          "createTimeFormatted": "2024-12-25 17:20:44",
          "chapterUid": 11,
          "appLink": "weread://bestbookmark?bookId=3300073051&chapterUid=11&rangeStart=45930&rangeEnd=45991",
