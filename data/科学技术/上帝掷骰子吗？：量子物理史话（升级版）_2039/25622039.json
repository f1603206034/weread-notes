  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "25622039_99_4542-4560",
      "chapterUid": 99,
      "range": "4542-4560",
      "markText": "好，演员到齐。那么，好戏也该上演了。",
      "totalCount": 3817,
      "appLink": "weread://bestbookmark?bookId=25622039&chapterUid=99&rangeStart=4542&rangeEnd=4560",
      "webLink": "https://weread.qq.com/web/reader/bd5320f07186f617bd52222?chapterUid=99&rangeStart=4542&rangeEnd=4560"
    },
    {
      "bookmarkId": "25622039_179_1412-1470",
      "chapterUid": 179,
      "range": "1412-1470",
      "markText": "普朗克委婉地表示，他研究物理是出于对自然和理性的兴趣，只是想把现有的东西搞清楚罢了，并不奢望能够做出什么巨大的成就。",
      "totalCount": 3096,
      "appLink": "weread://bestbookmark?bookId=25622039&chapterUid=179&rangeStart=1412&rangeEnd=1470",
      "webLink": "https://weread.qq.com/web/reader/bd5320f07186f617bd52222?chapterUid=179&rangeStart=1412&rangeEnd=1470"
    },
    {
      "bookmarkId": "25622039_180_1219-1253",
      "chapterUid": 180,
      "range": "1219-1253",
      "markText": "必须假定，能量在发射和吸收的时候，不是连续不断，而是分成一份一份的。",
      "totalCount": 2352,
      "appLink": "weread://bestbookmark?bookId=25622039&chapterUid=180&rangeStart=1219&rangeEnd=1253",
      "webLink": "https://weread.qq.com/web/reader/bd5320f07186f617bd52222?chapterUid=180&rangeStart=1219&rangeEnd=1253"
    },
    {
      "bookmarkId": "25622039_204_4042-4106",
      "chapterUid": 204,
      "range": "4042-4106",
      "markText": "波动突然咧嘴一笑：“不错，每次我们只能在一条缝上测量到电子。但是，你要知道，一旦我们展开这种测量的时候，干涉条纹也就消失了……”",
      "totalCount": 2329,
      "appLink": "weread://bestbookmark?bookId=25622039&chapterUid=204&rangeStart=4042&rangeEnd=4106",
      "webLink": "https://weread.qq.com/web/reader/bd5320f07186f617bd52222?chapterUid=204&rangeStart=4042&rangeEnd=4106"
    },
    {
      "bookmarkId": "25622039_87_1657-1694",
      "chapterUid": 87,
      "range": "1657-1694",
      "markText": "不过现在已经没时间考虑那么多了。请大家坐好，系好安全带，我们的旅程开始了。",
      "totalCount": 2250,
      "appLink": "weread://bestbookmark?bookId=25622039&chapterUid=87&rangeStart=1657&rangeEnd=1694",
      "webLink": "https://weread.qq.com/web/reader/bd5320f07186f617bd52222?chapterUid=87&rangeStart=1657&rangeEnd=1694"
    },
    {
      "bookmarkId": "25622039_185_5227-5293",
      "chapterUid": 185,
      "range": "5227-5293",
      "markText": "狄拉克获奖的时候才31岁，他对卢瑟福说他不想领这个奖，因为他讨厌在公众中的名声。卢瑟福劝道，如果不领奖的话，那么这个名声可就更响了。",
      "totalCount": 2016,
      "appLink": "weread://bestbookmark?bookId=25622039&chapterUid=185&rangeStart=5227&rangeEnd=5293",
      "webLink": "https://weread.qq.com/web/reader/bd5320f07186f617bd52222?chapterUid=185&rangeStart=5227&rangeEnd=5293"
    },
    {
      "bookmarkId": "25622039_172_4249-4325",
      "chapterUid": 172,
      "range": "4249-4325",
      "markText": "但是波动说巧妙地摆脱了这个难题：它假设了一种看不见摸不着的介质来实现光的传播，这种介质有一个十分响亮而让人印象深刻的名字，叫作“以太”(Aether)。",
      "totalCount": 1989,
      "appLink": "weread://bestbookmark?bookId=25622039&chapterUid=172&rangeStart=4249&rangeEnd=4325",
      "webLink": "https://weread.qq.com/web/reader/bd5320f07186f617bd52222?chapterUid=172&rangeStart=4249&rangeEnd=4325"
