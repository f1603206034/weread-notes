  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "39457314_40_518-571",
      "chapterUid": 40,
      "range": "518-571",
      "markText": "如果宇宙无法为人类世代提供无穷无尽的谜题，那它就实在太渺小，太可悲了……大自然不会一下子彰显它的全部奥秘。",
      "totalCount": 2754,
      "appLink": "weread://bestbookmark?bookId=39457314&chapterUid=40&rangeStart=518&rangeEnd=571",
      "webLink": "https://weread.qq.com/web/reader/371322e0725a12223719991?chapterUid=40&rangeStart=518&rangeEnd=571"
    },
    {
      "bookmarkId": "39457314_61_744-794",
      "chapterUid": 61,
      "range": "744-794",
      "markText": "已知有涯，而未知无涯；我们如同立于荒岛之上，被苍茫大海所困。每一代人的任务，都是填出一小块新的陆地。",
      "totalCount": 2112,
      "appLink": "weread://bestbookmark?bookId=39457314&chapterUid=61&rangeStart=744&rangeEnd=794",
      "webLink": "https://weread.qq.com/web/reader/371322e0725a12223719991?chapterUid=61&rangeStart=744&rangeEnd=794"
    },
    {
      "bookmarkId": "39457314_42_9377-9406",
      "chapterUid": 42,
      "range": "9377-9406",
      "markText": "没有物种可以永存，它们存世的时间或长或短，总归要走向消亡。",
      "totalCount": 2067,
      "appLink": "weread://bestbookmark?bookId=39457314&chapterUid=42&rangeStart=9377&rangeEnd=9406",
      "webLink": "https://weread.qq.com/web/reader/371322e0725a12223719991?chapterUid=42&rangeStart=9377&rangeEnd=9406"
    },
    {
      "bookmarkId": "39457314_42_7254-7309",
      "chapterUid": 42,
      "range": "7254-7309",
      "markText": "7000万年对于一个寿命只有它百万分之一的物种来说到底意味着什么？我们就像蝴蝶，飞翔在日光下，以为白昼是永恒。",
      "totalCount": 2052,
      "appLink": "weread://bestbookmark?bookId=39457314&chapterUid=42&rangeStart=7254&rangeEnd=7309",
      "webLink": "https://weread.qq.com/web/reader/371322e0725a12223719991?chapterUid=42&rangeStart=7254&rangeEnd=7309"
    },
    {
      "bookmarkId": "39457314_62_1826-1863",
      "chapterUid": 62,
      "range": "1826-1863",
      "markText": "群星代表了一种秩序，一种可预测性，一种永恒。从某些角度来看，它们抚慰人心。",
      "totalCount": 1963,
      "appLink": "weread://bestbookmark?bookId=39457314&chapterUid=62&rangeStart=1826&rangeEnd=1863",
      "webLink": "https://weread.qq.com/web/reader/371322e0725a12223719991?chapterUid=62&rangeStart=1826&rangeEnd=1863"
    },
    {
      "bookmarkId": "39457314_61_5217-5300",
      "chapterUid": 61,
      "range": "5217-5300",
      "markText": "生活在当下是一种幸运，我们身边有那么多才华横溢、求知若渴的同族，与此同时，对知识的探求又得到了普罗大众的尊重。人类生于群星，暂居于地球，现在终于开始了漫长的返乡之旅。",
      "totalCount": 1887,
      "appLink": "weread://bestbookmark?bookId=39457314&chapterUid=61&rangeStart=5217&rangeEnd=5300",
      "webLink": "https://weread.qq.com/web/reader/371322e0725a12223719991?chapterUid=61&rangeStart=5217&rangeEnd=5300"
    },
    {
      "bookmarkId": "39457314_61_1516-1539",
      "chapterUid": 61,
      "range": "1516-1539",
      "markText": "毕竟苍穹浩瀚，我们不过是晨空中一粒飞扬的尘埃。",
      "totalCount": 1833,
      "appLink": "weread://bestbookmark?bookId=39457314&chapterUid=61&rangeStart=1516&rangeEnd=1539",
      "webLink": "https://weread.qq.com/web/reader/371322e0725a12223719991?chapterUid=61&rangeStart=1516&rangeEnd=1539"
    },
    {
      "bookmarkId": "39457314_49_11668-11718",
      "chapterUid": 49,
      "range": "11668-11718",
      "markText": "我们DNA里的氮、牙齿里的钙、血液里的铁，还有苹果派里的碳全部出自恒星内部。人类是由星际物质构成的。",
      "totalCount": 1708,
      "appLink": "weread://bestbookmark?bookId=39457314&chapterUid=49&rangeStart=11668&rangeEnd=11718",
      "webLink": "https://weread.qq.com/web/reader/371322e0725a12223719991?chapterUid=49&rangeStart=11668&rangeEnd=11718"
    },
    {
      "bookmarkId": "39457314_45_20832-20880",
      "chapterUid": 45,
      "range": "20832-20880",
      "markText": "我们知道，有些国家一直在研究和存储细菌武器。他们时不时会搞出些意外，所幸从没发展成全球性的瘟疫。",
      "totalCount": 1644,
      "appLink": "weread://bestbookmark?bookId=39457314&chapterUid=45&rangeStart=20832&rangeEnd=20880",
      "webLink": "https://weread.qq.com/web/reader/371322e0725a12223719991?chapterUid=45&rangeStart=20832&rangeEnd=20880"
    },
    {
      "bookmarkId": "39457314_60_10174-10185",
      "chapterUid": 60,
      "range": "10174-10185",
      "markText": "我们一直都是太空旅行者",
      "totalCount": 1610,
      "appLink": "weread://bestbookmark?bookId=39457314&chapterUid=60&rangeStart=10174&rangeEnd=10185",
      "webLink": "https://weread.qq.com/web/reader/371322e0725a12223719991?chapterUid=60&rangeStart=10174&rangeEnd=10185"
    },
    {
      "bookmarkId": "39457314_42_10125-10190",
      "chapterUid": 42,
      "range": "10125-10190",
      "markText": "植物和动物呼吸着彼此的气息，浑然一体。整个地球上的生命在相互复苏，而这个优美的循环由1.5亿千米外的恒星提供动力，多么神奇的协作！",
      "totalCount": 1404,
      "appLink": "weread://bestbookmark?bookId=39457314&chapterUid=42&rangeStart=10125&rangeEnd=10190",
      "webLink": "https://weread.qq.com/web/reader/371322e0725a12223719991?chapterUid=42&rangeStart=10125&rangeEnd=10190"
    },
    {
      "bookmarkId": "39457314_42_11559-11627",
      "chapterUid": 42,
      "range": "11559-11627",
      "markText": "尽管目前人们还不知道该怎么重排核苷酸序列来创造全新的人类，但将来某一天，我们肯定能让新生儿具备任何想要的特征。只是这个前景令人警醒不安。",
      "totalCount": 1343,
      "appLink": "weread://bestbookmark?bookId=39457314&chapterUid=42&rangeStart=11559&rangeEnd=11627",
      "webLink": "https://weread.qq.com/web/reader/371322e0725a12223719991?chapterUid=42&rangeStart=11559&rangeEnd=11627"
    },
    {
      "bookmarkId": "39457314_42_8603-8647",
      "chapterUid": 42,
      "range": "8603-8647",
      "markText": "这种选择，不仅决定了20亿年前的微生物的命运，也让我们人类至今依然热衷于交换DNA片段。",
      "totalCount": 1326,
      "appLink": "weread://bestbookmark?bookId=39457314&chapterUid=42&rangeStart=8603&rangeEnd=8647",
      "webLink": "https://weread.qq.com/web/reader/371322e0725a12223719991?chapterUid=42&rangeStart=8603&rangeEnd=8647"
    },
    {
      "bookmarkId": "39457314_61_12031-12095",
      "chapterUid": 61,
      "range": "12031-12095",
      "markText": "我们研究太空，发现自己其实生活在一个稀疏星系最偏远角落一颗寻常恒星旁的尘埃上。我们只是浩瀚太空里的一粒沙，宇宙历史长河里一滴水。",
      "totalCount": 1264,
      "appLink": "weread://bestbookmark?bookId=39457314&chapterUid=61&rangeStart=12031&rangeEnd=12095",
      "webLink": "https://weread.qq.com/web/reader/371322e0725a12223719991?chapterUid=61&rangeStart=12031&rangeEnd=12095"
    },
    {
      "bookmarkId": "39457314_61_2887-2931",
