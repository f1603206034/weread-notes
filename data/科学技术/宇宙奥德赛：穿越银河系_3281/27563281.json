  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "27563281_23_5329-5386",
      "chapterUid": 23,
      "range": "5329-5386",
      "markText": "这是贝尔女士一生中最光辉的时刻。在那个寒冷的平安夜里，有一种人类前所未见的全新天体，在遥远的夜空中为她一个人闪耀。",
      "totalCount": 540,
      "appLink": "weread://bestbookmark?bookId=27563281&chapterUid=23&rangeStart=5329&rangeEnd=5386",
      "webLink": "https://weread.qq.com/web/reader/55032d8071a49511550b5f0?chapterUid=23&rangeStart=5329&rangeEnd=5386"
    },
    {
      "bookmarkId": "27563281_30_4451-4516",
      "chapterUid": 30,
      "range": "4451-4516",
      "markText": "得知了梅奥尔遇到的困难以后，奥尔特提了一个极为高明的建议：既然在欧洲古籍里找不到，不如去天文记录堪称世界一绝的中国古籍里碰碰运气。",
      "totalCount": 450,
      "appLink": "weread://bestbookmark?bookId=27563281&chapterUid=30&rangeStart=4451&rangeEnd=4516",
      "webLink": "https://weread.qq.com/web/reader/55032d8071a49511550b5f0?chapterUid=30&rangeStart=4451&rangeEnd=4516"
    },
    {
      "bookmarkId": "27563281_12_3073-3138",
      "chapterUid": 12,
      "range": "3073-3138",
      "markText": "这段痛苦的经历也让钱德拉塞卡形成了独一无二的研究风格：他一生中先后进入了7个不同的天文学研究领域，并且在每个领域都做到了世界第一。",
      "totalCount": 374,
      "appLink": "weread://bestbookmark?bookId=27563281&chapterUid=12&rangeStart=3073&rangeEnd=3138",
      "webLink": "https://weread.qq.com/web/reader/55032d8071a49511550b5f0?chapterUid=12&rangeStart=3073&rangeEnd=3138"
    },
    {
      "bookmarkId": "27563281_6_3234-3325",
      "chapterUid": 6,
      "range": "3234-3325",
      "markText": "兴奋不已的拉格朗日立刻给曾经做过相关研究的欧拉写信，描述了自己的新理论。这封信让欧拉大为赞赏。为此，他甚至压下了一篇自己已经写好、内容非常相似的论文，好让拉格朗日的论文能够率先发表。",
      "totalCount": 352,
      "appLink": "weread://bestbookmark?bookId=27563281&chapterUid=6&rangeStart=3234&rangeEnd=3325",
      "webLink": "https://weread.qq.com/web/reader/55032d8071a49511550b5f0?chapterUid=6&rangeStart=3234&rangeEnd=3325"
    },
    {
      "bookmarkId": "27563281_39_5130-5150",
      "chapterUid": 39,
      "range": "5130-5150",
      "markText": "不知道这么多的黄金，最终会落入谁的口袋。",
      "totalCount": 340,
      "appLink": "weread://bestbookmark?bookId=27563281&chapterUid=39&rangeStart=5130&rangeEnd=5150",
      "webLink": "https://weread.qq.com/web/reader/55032d8071a49511550b5f0?chapterUid=39&rangeStart=5130&rangeEnd=5150"
    },
    {
      "bookmarkId": "27563281_13_4743-4790",
      "chapterUid": 13,
      "range": "4743-4790",
      "markText": "这个系外行星探索领域的先驱，就这样成为一场影响深远的社会运动（即Me Too运动）的“先烈”。",
      "totalCount": 320,
      "appLink": "weread://bestbookmark?bookId=27563281&chapterUid=13&rangeStart=4743&rangeEnd=4790",
      "webLink": "https://weread.qq.com/web/reader/55032d8071a49511550b5f0?chapterUid=13&rangeStart=4743&rangeEnd=4790"
    },
    {
      "bookmarkId": "27563281_24_1204-1275",
      "chapterUid": 24,
      "range": "1204-1275",
      "markText": "兹威基是一个很粗鲁的人，他最喜欢骂自己看不上的人是“混球”。由于怕别人听不懂，还非要在后面补充一句：“具有球对称性，无论从哪个方向看都是混蛋”",
      "totalCount": 315,
      "appLink": "weread://bestbookmark?bookId=27563281&chapterUid=24&rangeStart=1204&rangeEnd=1275",
      "webLink": "https://weread.qq.com/web/reader/55032d8071a49511550b5f0?chapterUid=24&rangeStart=1204&rangeEnd=1275"
    },
    {
      "bookmarkId": "27563281_16_4090-4160",
      "chapterUid": 16,
      "range": "4090-4160",
      "markText": "如果宇宙大寂静的图像真是对的，那么所有的智能文明都注定要永远困在自己的孤岛上。他们就只能悄悄地诞生，悄悄地兴盛，悄悄地衰败，最后悄悄地灭绝。",
      "totalCount": 288,
      "appLink": "weread://bestbookmark?bookId=27563281&chapterUid=16&rangeStart=4090&rangeEnd=4160",
      "webLink": "https://weread.qq.com/web/reader/55032d8071a49511550b5f0?chapterUid=16&rangeStart=4090&rangeEnd=4160"
    },
    {
      "bookmarkId": "27563281_8_2097-2164",
      "chapterUid": 8,
      "range": "2097-2164",
      "markText": "如果某颗恒星正在靠近我们，它发出的光的频率就会变大，这称为蓝移；反过来，如果此恒星正在远离我们，它发出的光的频率就会变小，这称为红移。",
      "totalCount": 272,
      "appLink": "weread://bestbookmark?bookId=27563281&chapterUid=8&rangeStart=2097&rangeEnd=2164",
      "webLink": "https://weread.qq.com/web/reader/55032d8071a49511550b5f0?chapterUid=8&rangeStart=2097&rangeEnd=2164"
    },
    {
      "bookmarkId": "27563281_22_4724-4746",
      "chapterUid": 22,
      "range": "4724-4746",
      "markText": "置身于地球这个绿洲，人类还是一如既往的幸运。",
      "totalCount": 270,
      "appLink": "weread://bestbookmark?bookId=27563281&chapterUid=22&rangeStart=4724&rangeEnd=4746",
      "webLink": "https://weread.qq.com/web/reader/55032d8071a49511550b5f0?chapterUid=22&rangeStart=4724&rangeEnd=4746"
    },
    {
      "bookmarkId": "27563281_27_7926-7947",
      "chapterUid": 27,
      "range": "7926-7947",
      "markText": "原因在于，法国人觉得黑洞这个名字过于色情。",
      "totalCount": 270,
      "appLink": "weread://bestbookmark?bookId=27563281&chapterUid=27&rangeStart=7926&rangeEnd=7947",
      "webLink": "https://weread.qq.com/web/reader/55032d8071a49511550b5f0?chapterUid=27&rangeStart=7926&rangeEnd=7947"
    },
    {
      "bookmarkId": "27563281_6_4292-4377",
      "chapterUid": 6,
      "range": "4292-4377",
      "markText": "这意味着，如果能把人造卫星或空间望远镜送到拉格朗日点，它们就能在不依赖额外燃料的情况下，一直相对于地球保持静止。因此，拉格朗日点是放置人造卫星或空间望远镜的最理想的位置。",
      "totalCount": 255,
      "appLink": "weread://bestbookmark?bookId=27563281&chapterUid=6&rangeStart=4292&rangeEnd=4377",
      "webLink": "https://weread.qq.com/web/reader/55032d8071a49511550b5f0?chapterUid=6&rangeStart=4292&rangeEnd=4377"
    },
    {
      "bookmarkId": "27563281_5_2021-2051",
      "chapterUid": 5,
      "range": "2021-2051",
      "markText": "我删掉了以前爱写的大段大段的人物传记，让故事读起来更为流畅。",
      "totalCount": 234,
      "appLink": "weread://bestbookmark?bookId=27563281&chapterUid=5&rangeStart=2021&rangeEnd=2051",
      "webLink": "https://weread.qq.com/web/reader/55032d8071a49511550b5f0?chapterUid=5&rangeStart=2021&rangeEnd=2051"
    },
    {
      "bookmarkId": "27563281_23_6203-6290",
      "chapterUid": 23,
      "range": "6203-6290",
      "markText": "出人意料的是，贝尔把这300万美元全部捐了出去。她捐助的是一个旨在帮助女科学家职业发展的基金会。贝尔在捐款的时候表示，希望自己曾经遭遇过的不公，不要在其他的女科学家身上重演。",
      "totalCount": 231,
      "appLink": "weread://bestbookmark?bookId=27563281&chapterUid=23&rangeStart=6203&rangeEnd=6290",
      "webLink": "https://weread.qq.com/web/reader/55032d8071a49511550b5f0?chapterUid=23&rangeStart=6203&rangeEnd=6290"
    },
    {
      "bookmarkId": "27563281_9_4344-4421",
      "chapterUid": 9,
      "range": "4344-4421",
      "markText": "不妨畅想一下。如果有朝一日，“突破摄星”计划真的能拍到比邻星b的照片，并且在上面发现长得像水熊虫的三体人，我们就可以理直气壮地告诉它们：“你们才是虫子！”",
      "totalCount": 228,
      "appLink": "weread://bestbookmark?bookId=27563281&chapterUid=9&rangeStart=4344&rangeEnd=4421",
