  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "694735_25_580-610",
      "chapterUid": 25,
      "range": "580-610",
      "markText": "科学的最基本态度之一就是疑问，科学的最基本精神之一就是批判。",
      "totalCount": 2952,
      "appLink": "weread://bestbookmark?bookId=694735&chapterUid=25&rangeStart=580&rangeEnd=610",
      "webLink": "https://weread.qq.com/web/reader/5c6321005a99cf5c649fade?chapterUid=25&rangeStart=580&rangeEnd=610"
    },
    {
      "bookmarkId": "694735_27_420-465",
      "chapterUid": 27,
      "range": "420-465",
      "markText": "作为宇宙中高等生物的人类不满足于自身的生存和种族的绵延，还一代代地探索着存在和生命的意义。",
      "totalCount": 1116,
      "appLink": "weread://bestbookmark?bookId=694735&chapterUid=27&rangeStart=420&rangeEnd=465",
      "webLink": "https://weread.qq.com/web/reader/5c6321005a99cf5c649fade?chapterUid=27&rangeStart=420&rangeEnd=465"
    },
    {
      "bookmarkId": "694735_30_9072-9144",
      "chapterUid": 30,
      "range": "9072-9144",
      "markText": "我们看到的从很远星系来的光是在几百万年之前发出的，至于我们看到的最远物体，光是在大约80亿年前发出的。这样，当我们看宇宙时，我们是在看它的过去。",
      "totalCount": 1080,
      "appLink": "weread://bestbookmark?bookId=694735&chapterUid=30&rangeStart=9072&rangeEnd=9144",
      "webLink": "https://weread.qq.com/web/reader/5c6321005a99cf5c649fade?chapterUid=30&rangeStart=9072&rangeEnd=9144"
    },
    {
      "bookmarkId": "694735_30_2429-2486",
      "chapterUid": 30,
      "range": "2429-2486",
      "markText": "事件的位置以及它们之间的距离对于在有轨电车上和铁轨上的人来讲是不同的，所以没有理由以为一个人的立场比别人的更优越。",
      "totalCount": 1003,
      "appLink": "weread://bestbookmark?bookId=694735&chapterUid=30&rangeStart=2429&rangeEnd=2486",
      "webLink": "https://weread.qq.com/web/reader/5c6321005a99cf5c649fade?chapterUid=30&rangeStart=2429&rangeEnd=2486"
    },
    {
      "bookmarkId": "694735_29_6525-6613",
      "chapterUid": 29,
      "range": "6525-6613",
      "markText": "一个好的理论必须满足以下两个要求：首先，这个理论必须能准确地描述大量的观测——这些观测是根据只包含少数任选的元素的模型所做出的；其次，这个理论能对未来观测的结果作出明确的预言。",
      "totalCount": 996,
      "appLink": "weread://bestbookmark?bookId=694735&chapterUid=29&rangeStart=6525&rangeEnd=6613",
      "webLink": "https://weread.qq.com/web/reader/5c6321005a99cf5c649fade?chapterUid=29&rangeStart=6525&rangeEnd=6613"
    },
    {
      "bookmarkId": "694735_36_6088-6123",
      "chapterUid": 36,
      "range": "6088-6123",
      "markText": "人存原理可以解释为：“我们看到的宇宙之所以如此，乃是因为我们的存在。”",
      "totalCount": 882,
      "appLink": "weread://bestbookmark?bookId=694735&chapterUid=36&rangeStart=6088&rangeEnd=6123",
      "webLink": "https://weread.qq.com/web/reader/5c6321005a99cf5c649fade?chapterUid=36&rangeStart=6088&rangeEnd=6123"
    },
    {
      "bookmarkId": "694735_29_2178-2238",
      "chapterUid": 29,
      "range": "2178-2238",
      "markText": "它被基督教会接纳为与《圣经》相一致的宇宙图象。这是因为它具有巨大优势，即在固定恒星天球之外为天堂和地狱留下了大量的空间。",
      "totalCount": 846,
      "appLink": "weread://bestbookmark?bookId=694735&chapterUid=29&rangeStart=2178&rangeEnd=2238",
      "webLink": "https://weread.qq.com/web/reader/5c6321005a99cf5c649fade?chapterUid=29&rangeStart=2178&rangeEnd=2238"
    },
    {
      "bookmarkId": "694735_29_7377-7400",
      "chapterUid": 29,
      "range": "7377-7400",
      "markText": "科学的终极目的是提供描述整个宇宙的单一的理论。",
      "totalCount": 754,
      "appLink": "weread://bestbookmark?bookId=694735&chapterUid=29&rangeStart=7377&rangeEnd=7400",
      "webLink": "https://weread.qq.com/web/reader/5c6321005a99cf5c649fade?chapterUid=29&rangeStart=7377&rangeEnd=7400"
    },
    {
      "bookmarkId": "694735_25_1640-1700",
      "chapterUid": 25,
      "range": "1640-1700",
      "markText": "科学是超越宗教差别的，超越民族差别的，超越党派差别的，超越文化和地域差别的，科学是普适的、独立的，它自身就是自身的主宰。",
      "totalCount": 682,
      "appLink": "weread://bestbookmark?bookId=694735&chapterUid=25&rangeStart=1640&rangeEnd=1700",
      "webLink": "https://weread.qq.com/web/reader/5c6321005a99cf5c649fade?chapterUid=25&rangeStart=1640&rangeEnd=1700"
    },
    {
      "bookmarkId": "694735_34_10212-10252",
      "chapterUid": 34,
      "range": "10212-10252",
      "markText": "我进行了约定的赔偿，那就是给索恩订阅一年的《藏春阁》，这使他开放的妻子相当恼火。",
      "totalCount": 595,
      "appLink": "weread://bestbookmark?bookId=694735&chapterUid=34&rangeStart=10212&rangeEnd=10252",
      "webLink": "https://weread.qq.com/web/reader/5c6321005a99cf5c649fade?chapterUid=34&rangeStart=10212&rangeEnd=10252"
    },
    {
      "bookmarkId": "694735_30_12292-12361",
      "chapterUid": 30,
      "range": "12292-12361",
      "markText": "1962年，人们利用一对安装在水塔顶上和底下的非常准确的钟，验证了这个预言。发现底下的那只更接近地球的钟走得较慢，这和广义相对论正好相符。",
      "totalCount": 561,
      "appLink": "weread://bestbookmark?bookId=694735&chapterUid=30&rangeStart=12292&rangeEnd=12361",
      "webLink": "https://weread.qq.com/web/reader/5c6321005a99cf5c649fade?chapterUid=30&rangeStart=12292&rangeEnd=12361"
    },
    {
      "bookmarkId": "694735_36_17845-17930",
      "chapterUid": 36,
      "range": "17845-17930",
      "markText": "只要宇宙有一个开端，我们就可以设想存在一个造物主。但是，如果宇宙的的确确是完全自足的，没有边界或边缘，它就既没有开端也没有终结：它就是存在。那么，还会有造物主存身之处吗？",
      "totalCount": 558,
      "appLink": "weread://bestbookmark?bookId=694735&chapterUid=36&rangeStart=17845&rangeEnd=17930",
      "webLink": "https://weread.qq.com/web/reader/5c6321005a99cf5c649fade?chapterUid=36&rangeStart=17845&rangeEnd=17930"
    },
    {
      "bookmarkId": "694735_27_1183-1244",
      "chapterUid": 27,
      "range": "1183-1244",
      "markText": "由于边界条件只能由宇宙外的造物主给定，所以宇宙的命运就操纵在造物主手中。这就是从牛顿时代起一直困扰人类智慧的第一推动问题。",
      "totalCount": 527,
      "appLink": "weread://bestbookmark?bookId=694735&chapterUid=27&rangeStart=1183&rangeEnd=1244",
      "webLink": "https://weread.qq.com/web/reader/5c6321005a99cf5c649fade?chapterUid=27&rangeStart=1183&rangeEnd=1244"
    },
    {
      "bookmarkId": "694735_30_13275-13306",
      "chapterUid": 30,
      "range": "13275-13306",
      "markText": "爱因斯坦广义相对论意味着，宇宙必须有个开端，并且可能有个终结。",
      "totalCount": 527,
      "appLink": "weread://bestbookmark?bookId=694735&chapterUid=30&rangeStart=13275&rangeEnd=13306",
      "webLink": "https://weread.qq.com/web/reader/5c6321005a99cf5c649fade?chapterUid=30&rangeStart=13275&rangeEnd=13306"
    },
    {
      "bookmarkId": "694735_29_6804-6879",
