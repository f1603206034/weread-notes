          "markText": "概率模型描述不确定性的艺术",
          "colorStyle": 1,
          "colorLabel": "",
          "createTime": 1750488218,
          "createTimeFormatted": "2025-06-21 14:43:38",
          "chapterUid": 8,
          "appLink": "weread://bestbookmark?bookId=3300036801&chapterUid=8&rangeStart=2780&rangeEnd=2793",
