  ],
  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300036801_10_16411-16431",
      "chapterUid": 10,
      "range": "16411-16431",
      "markText": "因此单个点所组成的事件的概率必定为 0。",
      "totalCount": 80,
      "appLink": "weread://bestbookmark?bookId=3300036801&chapterUid=10&rangeStart=16411&rangeEnd=16431",
      "webLink": "https://weread.qq.com/web/reader/dd732930813ab74e0g0113e0?chapterUid=10&rangeStart=16411&rangeEnd=16431"
    },
    {
      "bookmarkId": "3300036801_16_47298-47340",
      "chapterUid": 16,
      "range": "47298-47340",
      "markText": "。怎样利用一枚不均匀硬币做出无偏决策，即以 1/2的概率看电影，1/2的概率看歌剧呢",
      "totalCount": 68,
      "appLink": "weread://bestbookmark?bookId=3300036801&chapterUid=16&rangeStart=47298&rangeEnd=47340",
      "webLink": "https://weread.qq.com/web/reader/dd732930813ab74e0g0113e0?chapterUid=16&rangeStart=47298&rangeEnd=47340"
    },
    {
      "bookmarkId": "3300036801_10_1355-1522",
      "chapterUid": 10,
      "range": "1355-1522",
      "markText": "这个非负数刻画了我们对事件 的认识或所产生信念的强度。",
      "totalCount": 52,
      "appLink": "weread://bestbookmark?bookId=3300036801&chapterUid=10&rangeStart=1355&rangeEnd=1522",
      "webLink": "https://weread.qq.com/web/reader/dd732930813ab74e0g0113e0?chapterUid=10&rangeStart=1355&rangeEnd=1522"
    },
    {
      "bookmarkId": "3300036801_18_812-834",
      "chapterUid": 18,
      "range": "812-834",
      "markText": "随机变量是试验结果的实值函数。",
      "totalCount": 52,
      "appLink": "weread://bestbookmark?bookId=3300036801&chapterUid=18&rangeStart=812&rangeEnd=834",
      "webLink": "https://weread.qq.com/web/reader/dd732930813ab74e0g0113e0?chapterUid=18&rangeStart=812&rangeEnd=834"
    },
    {
      "bookmarkId": "3300036801_21_31162-31408",
      "chapterUid": 21,
      "range": "31162-31408",
      "markText": "最后一个等式利用了泊松概率质量函数的归一化性质。 相似的计算指出泊松随机变量的方差为 （见 2.7节例 2.20）。在后续章节中将用不同的方法导出这个事实。",
      "totalCount": 51,
      "appLink": "weread://bestbookmark?bookId=3300036801&chapterUid=21&rangeStart=31162&rangeEnd=31408",
      "webLink": "https://weread.qq.com/web/reader/dd732930813ab74e0g0113e0?chapterUid=21&rangeStart=31162&rangeEnd=31408"
    },
    {
      "bookmarkId": "3300036801_10_2628-2700",
      "chapterUid": 10,
      "range": "2628-2700",
      "markText": "在确定样本空间的时候，不同的试验结果必须是相互排斥的，这样，在试验过程中只可能产生唯一的结果",
      "totalCount": 48,
      "appLink": "weread://bestbookmark?bookId=3300036801&chapterUid=10&rangeStart=2628&rangeEnd=2700",
      "webLink": "https://weread.qq.com/web/reader/dd732930813ab74e0g0113e0?chapterUid=10&rangeStart=2628&rangeEnd=2700"
    },
    {
      "bookmarkId": "3300036801_14_29749-29813",
      "chapterUid": 14,
      "range": "29749-29813",
      "markText": "分割的一个小组的大小为 3，用于放置字母 T，另一个小组的大小为 2，用于放置字母 O，第三个小组的大小为 1，用于放置字母 A",
      "totalCount": 48,
      "appLink": "weread://bestbookmark?bookId=3300036801&chapterUid=14&rangeStart=29749&rangeEnd=29813",
      "webLink": "https://weread.qq.com/web/reader/dd732930813ab74e0g0113e0?chapterUid=14&rangeStart=29749&rangeEnd=29813"
    },
    {
      "bookmarkId": "3300036801_10_9907-9933",
      "chapterUid": 10,
      "range": "9907-9933",
      "markText": "有限多个互不相容事件的并的概率等于它们各自的概率之和",
