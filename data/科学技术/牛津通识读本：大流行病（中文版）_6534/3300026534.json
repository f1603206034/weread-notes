      "chapterUid": 6,
      "range": "3656-3680",
      "markText": "薄伽丘在《十日谈》中生动描述了人们对鼠疫的恐惧。",
      "totalCount": 45,
      "appLink": "weread://bestbookmark?bookId=3300026534&chapterUid=6&rangeStart=3656&rangeEnd=3680",
