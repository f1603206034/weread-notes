    },
    {
      "bookmarkId": "25737640_153_961-984",
      "chapterUid": 153,
      "range": "961-984",
      "markText": "如果，从你的全世界路过，那么，我就在终点等你。",
      "totalCount": 2172,
      "appLink": "weread://bestbookmark?bookId=25737640&chapterUid=153&rangeStart=961&rangeEnd=984",
