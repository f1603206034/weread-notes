      "appLink": "weread://bestbookmark?bookId=40317513&chapterUid=16&rangeStart=2213&rangeEnd=2243",
      "webLink": "https://weread.qq.com/web/reader/33c32c207267324933c162d?chapterUid=16&rangeStart=2213&rangeEnd=2243"
    },
