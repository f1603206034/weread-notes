  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "25079409_4_3168-3244",
      "chapterUid": 4,
      "range": "3168-3244",
      "markText": "两性情感中一旦有冷静的功利意识出现，当事人心中便会有“隐秘的恐惧”萌生，那一个“爱”字便难以说出口了。短暂恋情的收场正是身体感性的溃退和生命理性的胜利。",
      "totalCount": 748,
      "appLink": "weread://bestbookmark?bookId=25079409&chapterUid=4&rangeStart=3168&rangeEnd=3244",
      "webLink": "https://weread.qq.com/web/reader/6a932310717eae716a95192?chapterUid=4&rangeStart=3168&rangeEnd=3244"
    },
    {
      "bookmarkId": "25079409_14_2293-2363",
      "chapterUid": 14,
      "range": "2293-2363",
      "markText": "不会，我不会爱上一个我瞧不起的人。我要爱一个能够使我服服帖帖的人……但是我希望不要遇到那样的人，谢谢上帝，我不要落到任何人的手里，不，绝不！",
      "totalCount": 736,
      "appLink": "weread://bestbookmark?bookId=25079409&chapterUid=14&rangeStart=2293&rangeEnd=2363",
      "webLink": "https://weread.qq.com/web/reader/6a932310717eae716a95192?chapterUid=14&rangeStart=2293&rangeEnd=2363"
    },
    {
      "bookmarkId": "25079409_25_2715-2738",
      "chapterUid": 25,
      "range": "2715-2738",
      "markText": "最重要的事：要过正常的生活，不要做激情的奴隶。",
      "totalCount": 688,
      "appLink": "weread://bestbookmark?bookId=25079409&chapterUid=25&rangeStart=2715&rangeEnd=2738",
      "webLink": "https://weread.qq.com/web/reader/6a932310717eae716a95192?chapterUid=25&rangeStart=2715&rangeEnd=2738"
    },
    {
      "bookmarkId": "25079409_25_2355-2418",
      "chapterUid": 25,
      "range": "2355-2418",
      "markText": "可是，说老实话，我对父亲不曾有过丝毫的恶感，相反地，他在我眼里倒显得更高大了：这个矛盾还是让心理学家就他们所知道的来做解释吧。",
      "totalCount": 630,
      "appLink": "weread://bestbookmark?bookId=25079409&chapterUid=25&rangeStart=2355&rangeEnd=2418",
      "webLink": "https://weread.qq.com/web/reader/6a932310717eae716a95192?chapterUid=25&rangeStart=2355&rangeEnd=2418"
    },
    {
      "bookmarkId": "25079409_12_1478-1530",
      "chapterUid": 12,
      "range": "1478-1530",
      "markText": "年轻人，您懂吗，我们正在玩‘摸彩’；公爵小姐是给奖人——谁拿到‘幸运’的票子，那个人就有吻她的手的权利。",
      "totalCount": 588,
      "appLink": "weread://bestbookmark?bookId=25079409&chapterUid=12&rangeStart=1478&rangeEnd=1530",
      "webLink": "https://weread.qq.com/web/reader/6a932310717eae716a95192?chapterUid=12&rangeStart=1478&rangeEnd=1530"
    },
    {
      "bookmarkId": "25079409_9_7014-7044",
      "chapterUid": 9,
      "range": "7014-7044",
      "markText": "我突然觉得非常悲哀……我竭力忍住不要哭……我嫉妒那个骠骑兵。",
      "totalCount": 580,
      "appLink": "weread://bestbookmark?bookId=25079409&chapterUid=9&rangeStart=7014&rangeEnd=7044",
      "webLink": "https://weread.qq.com/web/reader/6a932310717eae716a95192?chapterUid=9&rangeStart=7014&rangeEnd=7044"
    },
    {
      "bookmarkId": "25079409_11_2011-2116",
      "chapterUid": 11,
      "range": "2011-2116",
      "markText": "齐娜伊达对我的态度把我完全毁了。却不料她走过我身边的时候，她眼睛里又带着先前那种温柔的表情，很快地低声对我说： “八点钟到我们家里来，听到吗？一定来……”",
      "totalCount": 540,
      "appLink": "weread://bestbookmark?bookId=25079409&chapterUid=11&rangeStart=2011&rangeEnd=2116",
      "webLink": "https://weread.qq.com/web/reader/6a932310717eae716a95192?chapterUid=11&rangeStart=2011&rangeEnd=2116"
    },
    {
      "bookmarkId": "25079409_19_752-811",
      "chapterUid": 19,
      "range": "752-811",
      "markText": "我的想象开始在活动了。我想象：我怎样从敌人手里救出她来，我怎样满身鲜血地从监牢里把她抢救出来，又怎样倒在她的脚下死去。",
      "totalCount": 510,
      "appLink": "weread://bestbookmark?bookId=25079409&chapterUid=19&rangeStart=752&rangeEnd=811",
      "webLink": "https://weread.qq.com/web/reader/6a932310717eae716a95192?chapterUid=19&rangeStart=752&rangeEnd=811"
    },
    {
      "bookmarkId": "25079409_24_1930-1965",
      "chapterUid": 24,
      "range": "1930-1965",
      "markText": "我心灵里所有的花朵一下子全给摘下来，丢在我身边，散在各处，让人践踏了。",
      "totalCount": 490,
      "appLink": "weread://bestbookmark?bookId=25079409&chapterUid=24&rangeStart=1930&rangeEnd=1965",
      "webLink": "https://weread.qq.com/web/reader/6a932310717eae716a95192?chapterUid=24&rangeStart=1930&rangeEnd=1965"
    },
    {
      "bookmarkId": "25079409_4_4226-4251",
      "chapterUid": 4,
      "range": "4226-4251",
      "markText": "爱情的审美永远是美感决定着美，而不是美才引起美感的",
      "totalCount": 480,
      "appLink": "weread://bestbookmark?bookId=25079409&chapterUid=4&rangeStart=4226&rangeEnd=4251",
      "webLink": "https://weread.qq.com/web/reader/6a932310717eae716a95192?chapterUid=4&rangeStart=4226&rangeEnd=4251"
    },
    {
      "bookmarkId": "25079409_25_2235-2280",
      "chapterUid": 25,
      "range": "2235-2280",
      "markText": "我不希望将来我再有这样的感情；然而要是我一生不曾有过这样的感情，我就会觉得自己是不幸的了。",
      "totalCount": 480,
      "appLink": "weread://bestbookmark?bookId=25079409&chapterUid=25&rangeStart=2235&rangeEnd=2280",
      "webLink": "https://weread.qq.com/web/reader/6a932310717eae716a95192?chapterUid=25&rangeStart=2235&rangeEnd=2280"
    },
    {
      "bookmarkId": "25079409_28_636-678",
      "chapterUid": 28,
      "range": "636-678",
      "markText": "年轻小伙的美好情愫，中年男人的魔鬼欲望，妙龄少女的无常命运，在《初恋》中都化作了诗。",
