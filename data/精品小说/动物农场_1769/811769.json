  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "811769_7_3315-3341",
      "chapterUid": 7,
      "range": "3315-3341",
      "markText": "实际上，他们总是发现，讲话的是谁，他们就会同意谁的。",
      "totalCount": 7497,
      "appLink": "weread://bestbookmark?bookId=811769&chapterUid=7&rangeStart=3315&rangeEnd=3341",
      "webLink": "https://weread.qq.com/web/reader/b74324c05c62f9b743e3e8a?chapterUid=7&rangeStart=3315&rangeEnd=3341"
    },
    {
      "bookmarkId": "811769_17_4002-4044",
      "chapterUid": 17,
      "range": "4002-4044",
      "markText": "窗外的动物们从猪看到人，又从人看到猪，再从猪看到人；但他们已分不出谁是猪，谁是人了。",
      "totalCount": 6256,
      "appLink": "weread://bestbookmark?bookId=811769&chapterUid=17&rangeStart=4002&rangeEnd=4044",
      "webLink": "https://weread.qq.com/web/reader/b74324c05c62f9b743e3e8a?chapterUid=17&rangeStart=4002&rangeEnd=4044"
    },
    {
      "bookmarkId": "811769_16_3196-3213",
      "chapterUid": 16,
      "range": "3196-3213",
      "markText": "一头猪正直立起来在用他的后腿走路。",
      "totalCount": 6048,
      "appLink": "weread://bestbookmark?bookId=811769&chapterUid=16&rangeStart=3196&rangeEnd=3213",
      "webLink": "https://weread.qq.com/web/reader/b74324c05c62f9b743e3e8a?chapterUid=16&rangeStart=3196&rangeEnd=3213"
    },
    {
      "bookmarkId": "811769_9_371-467",
      "chapterUid": 9,
      "range": "371-467",
      "markText": "这一年，动物们一直像奴隶般地干苦役活。但他们乐在其中，流血流汗甚至牺牲也心甘情愿，因为他们深深地意识到：他们干的每件事都是为他们自己和未来的同类的利益，而不是为了那帮游手好闲、偷摸成性的人类。",
      "totalCount": 3360,
      "appLink": "weread://bestbookmark?bookId=811769&chapterUid=9&rangeStart=371&rangeEnd=467",
      "webLink": "https://weread.qq.com/web/reader/b74324c05c62f9b743e3e8a?chapterUid=9&rangeStart=371&rangeEnd=467"
    },
    {
      "bookmarkId": "811769_4_1418-1465",
      "chapterUid": 4,
      "range": "1418-1465",
      "markText": "“同志，”斯诺鲍说，“那些你如此钟爱的饰带全是奴隶的标记。你难道不明白自由比饰带更有价值吗？”",
      "totalCount": 3184,
      "appLink": "weread://bestbookmark?bookId=811769&chapterUid=4&rangeStart=1418&rangeEnd=1465",
      "webLink": "https://weread.qq.com/web/reader/b74324c05c62f9b743e3e8a?chapterUid=4&rangeStart=1418&rangeEnd=1465"
    },
    {
      "bookmarkId": "811769_17_705-757",
      "chapterUid": 17,
      "range": "705-757",
      "markText": "所有动物一律平等 但有些动物比其他动物更平等",
      "totalCount": 2860,
      "appLink": "weread://bestbookmark?bookId=811769&chapterUid=17&rangeStart=705&rangeEnd=757",
      "webLink": "https://weread.qq.com/web/reader/b74324c05c62f9b743e3e8a?chapterUid=17&rangeStart=705&rangeEnd=757"
    },
    {
      "bookmarkId": "811769_8_1292-1341",
      "chapterUid": 8,
      "range": "1292-1341",
      "markText": "大家都注意到，他们始终紧挨着拿破仑，对他摆着尾巴。那姿势，竟和别的狗过去对琼斯先生的做法一模一样。",
      "totalCount": 2453,
      "appLink": "weread://bestbookmark?bookId=811769&chapterUid=8&rangeStart=1292&rangeEnd=1341",
      "webLink": "https://weread.qq.com/web/reader/b74324c05c62f9b743e3e8a?chapterUid=8&rangeStart=1292&rangeEnd=1341"
    },
    {
      "bookmarkId": "811769_4_3269-3331",
      "chapterUid": 4,
      "range": "3269-3331",
      "markText": "鲍克瑟听到这里，便把他夏天戴的一顶小草帽也拿出来，这顶草帽本来是防止蝇虫钻入耳朵才戴的，他也把它和别的东西一道扔进了火堆里。",
      "totalCount": 2280,
      "appLink": "weread://bestbookmark?bookId=811769&chapterUid=4&rangeStart=3269&rangeEnd=3331",
      "webLink": "https://weread.qq.com/web/reader/b74324c05c62f9b743e3e8a?chapterUid=4&rangeStart=3269&rangeEnd=3331"
    },
    {
