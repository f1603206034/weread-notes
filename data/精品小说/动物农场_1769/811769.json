      "appLink": "weread://bestbookmark?bookId=811769&chapterUid=3&rangeStart=1262&rangeEnd=1295",
      "webLink": "https://weread.qq.com/web/reader/b74324c05c62f9b743e3e8a?chapterUid=3&rangeStart=1262&rangeEnd=1295"
    },
    {
      "bookmarkId": "811769_15_2421-2485",
