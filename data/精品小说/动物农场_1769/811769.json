    {
      "chapterUid": 3,
      "chapterTitle": "第1章",
      "items": [
        {
          "type": "highlight",
          "bookmarkId": "811769_3_1613-1693",
          "range": "1613-1693",
          "rangeStart": 1613,
          "rangeEnd": 1693,
          "markText": "猫是最后一个来的，她像往常一样，到处寻找最热乎的地方，最后在鲍克瑟和克拉弗当中挤了进去。少校讲话时，她从头到尾都在心满意足地打呼噜，少校的讲话她一个字也没听到。",
          "colorStyle": 2,
          "colorLabel": "",
          "createTime": 1745101754,
          "createTimeFormatted": "2025-04-20 06:29:14",
          "chapterUid": 3,
          "appLink": "weread://bestbookmark?bookId=811769&chapterUid=3&rangeStart=1613&rangeEnd=1693",
          "webLink": "https://weread.qq.com/web/reader/b74324c05c62f9b743e3e8a?chapterUid=3&rangeStart=1613&rangeEnd=1693"
