      "appLink": "weread://bestbookmark?bookId=605358&chapterUid=5&rangeStart=16312&rangeEnd=16347",
      "webLink": "https://weread.qq.com/web/reader/5f432bd0593cae5f417653c?chapterUid=5&rangeStart=16312&rangeEnd=16347"
