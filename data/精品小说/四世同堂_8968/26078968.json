      "appLink": "weread://bestbookmark?bookId=26078968&chapterUid=30&rangeStart=4507&rangeEnd=4538",
      "webLink": "https://weread.qq.com/web/reader/32232710718deef8322406a?chapterUid=30&rangeStart=4507&rangeEnd=4538"
