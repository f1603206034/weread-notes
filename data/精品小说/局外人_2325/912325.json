  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "912325_19_3409-3460",
      "chapterUid": 19,
      "range": "3409-3460",
      "markText": "我想，这又是一个忙忙乱乱的星期天，妈妈已经下葬入土，而我明天又该上班了，生活仍是老样子，没有任何变化。",
      "totalCount": 28320,
      "appLink": "weread://bestbookmark?bookId=912325&chapterUid=19&rangeStart=3409&rangeEnd=3460",
      "webLink": "https://weread.qq.com/web/reader/7bd329e05debc57bdc79852?chapterUid=19&rangeStart=3409&rangeEnd=3460"
    },
    {
      "bookmarkId": "912325_23_7085-7181",
      "chapterUid": 23,
      "range": "7085-7181",
      "markText": "我意识到我打破了这一天的平衡，打破了海滩上不寻常的寂静，在这种平衡与寂静中，我原本是幸福自在的。接着，我又对准那具尸体开了四枪，子弹打进去，没有显露出什么，这就像我在苦难之门上急促地叩了四下。",
      "totalCount": 25362,
      "appLink": "weread://bestbookmark?bookId=912325&chapterUid=23&rangeStart=7085&rangeEnd=7181",
      "webLink": "https://weread.qq.com/web/reader/7bd329e05debc57bdc79852?chapterUid=23&rangeStart=7085&rangeEnd=7181"
    },
    {
      "bookmarkId": "912325_29_8517-8575",
      "chapterUid": 29,
      "range": "8517-8575",
      "markText": "为了善始善终，功德圆满，为了不感到自己属于另类，我期望处决我的那天，有很多人前来看热闹，他们都向我发出仇恨的叫喊声。",
      "totalCount": 24416,
      "appLink": "weread://bestbookmark?bookId=912325&chapterUid=29&rangeStart=8517&rangeEnd=8575",
      "webLink": "https://weread.qq.com/web/reader/7bd329e05debc57bdc79852?chapterUid=29&rangeStart=8517&rangeEnd=8575"
    },
    {
      "bookmarkId": "912325_18_406-426",
      "chapterUid": 18,
      "range": "406-426",
      "markText": "今天，妈妈死了。也许是在昨天，我搞不清。",
      "totalCount": 23550,
      "appLink": "weread://bestbookmark?bookId=912325&chapterUid=18&rangeStart=406&rangeEnd=426",
      "webLink": "https://weread.qq.com/web/reader/7bd329e05debc57bdc79852?chapterUid=18&rangeStart=406&rangeEnd=426"
    },
    {
      "bookmarkId": "912325_26_5284-5299",
      "chapterUid": 26,
      "range": "5284-5299",
      "markText": "人生在世，永远也不该演戏作假。",
      "totalCount": 20670,
      "appLink": "weread://bestbookmark?bookId=912325&chapterUid=26&rangeStart=5284&rangeEnd=5299",
      "webLink": "https://weread.qq.com/web/reader/7bd329e05debc57bdc79852?chapterUid=26&rangeStart=5284&rangeEnd=5299"
    },
    {
      "bookmarkId": "912325_22_957-995",
      "chapterUid": 22,
      "range": "957-995",
      "markText": "人们永远也无法改变生活，什么样的生活都差不多，而我在这里的生活并不使我厌烦。",
      "totalCount": 18972,
      "appLink": "weread://bestbookmark?bookId=912325&chapterUid=22&rangeStart=957&rangeEnd=995",
      "webLink": "https://weread.qq.com/web/reader/7bd329e05debc57bdc79852?chapterUid=22&rangeStart=957&rangeEnd=995"
    },
    {
      "bookmarkId": "912325_28_601-670",
      "chapterUid": 28,
      "range": "601-670",
      "markText": "可以说，人们好像是在把我完全撇开的情况下处理这桩案子。所有这一切都是在没有我参与的情况下进行的。我的命运由他们决定，而根本不征求我的意见。",
      "totalCount": 17784,
      "appLink": "weread://bestbookmark?bookId=912325&chapterUid=28&rangeStart=601&rangeEnd=670",
      "webLink": "https://weread.qq.com/web/reader/7bd329e05debc57bdc79852?chapterUid=28&rangeStart=601&rangeEnd=670"
    },
    {
      "bookmarkId": "912325_23_1965-2011",
      "chapterUid": 23,
      "range": "1965-2011",
      "markText": "确实不错，他妻子跟玛丽已经在说说笑笑了。这时，我萌生出要结婚的念头，这也许是我生平的第一次。",
      "totalCount": 14875,
      "appLink": "weread://bestbookmark?bookId=912325&chapterUid=23&rangeStart=1965&rangeEnd=2011",
      "webLink": "https://weread.qq.com/web/reader/7bd329e05debc57bdc79852?chapterUid=23&rangeStart=1965&rangeEnd=2011"
    },
    {
      "bookmarkId": "912325_26_634-712",
      "chapterUid": 26,
      "range": "634-712",
      "markText": "我被捕的那天，先被关在一个已经有几个囚犯的牢房里，他们多数是阿拉伯人，看见我进来都笑了，接着就问我犯了什么事。我说我杀了一个阿拉伯人，他们一听就不再吭声了。",
      "totalCount": 12045,
      "appLink": "weread://bestbookmark?bookId=912325&chapterUid=26&rangeStart=634&rangeEnd=712",
      "webLink": "https://weread.qq.com/web/reader/7bd329e05debc57bdc79852?chapterUid=26&rangeStart=634&rangeEnd=712"
    },
    {
      "bookmarkId": "912325_29_6948-7013",
      "chapterUid": 29,
      "range": "6948-7013",
      "markText": "他企图变换话题，问我为什么称他为“先生”而不是“我的父亲”，这可把我惹火了，我对他说他本来就不是我的父亲，他到别人那里去当父亲吧。",
      "totalCount": 11664,
      "appLink": "weread://bestbookmark?bookId=912325&chapterUid=29&rangeStart=6948&rangeEnd=7013",
      "webLink": "https://weread.qq.com/web/reader/7bd329e05debc57bdc79852?chapterUid=29&rangeStart=6948&rangeEnd=7013"
    },
    {
      "bookmarkId": "912325_20_4168-4204",
      "chapterUid": 20,
      "range": "4168-4204",
      "markText": "我对他说，我永远也不可能知道该怎么做，但我很理解他要惩罚那个女人的心理。",
      "totalCount": 11382,
      "appLink": "weread://bestbookmark?bookId=912325&chapterUid=20&rangeStart=4168&rangeEnd=4204",
      "webLink": "https://weread.qq.com/web/reader/7bd329e05debc57bdc79852?chapterUid=20&rangeStart=4168&rangeEnd=4204"
    },
    {
      "bookmarkId": "912325_18_674-715",
      "chapterUid": 18,
      "range": "674-715",
      "markText": "似乎眼下我妈还没有死。要等到下葬之后，此事才算定论入档，一切才披上正式悼念的色彩。",
      "totalCount": 11220,
      "appLink": "weread://bestbookmark?bookId=912325&chapterUid=18&rangeStart=674&rangeEnd=715",
      "webLink": "https://weread.qq.com/web/reader/7bd329e05debc57bdc79852?chapterUid=18&rangeStart=674&rangeEnd=715"
    },
    {
      "bookmarkId": "912325_26_5449-5531",
      "chapterUid": 26,
      "range": "5449-5531",
      "markText": "日子，过起来当然就长，但是拖拖拉拉，日复一日，年复一年，最后就混淆成了一片。每个日子都丧失了自己的名字。对我来说，只有“昨天”与“明天”这样的字，才具有一定的意义。",
      "totalCount": 10746,
      "appLink": "weread://bestbookmark?bookId=912325&chapterUid=26&rangeStart=5449&rangeEnd=5531",
      "webLink": "https://weread.qq.com/web/reader/7bd329e05debc57bdc79852?chapterUid=26&rangeStart=5449&rangeEnd=5531"
    },
    {
      "bookmarkId": "912325_25_3941-3977",
      "chapterUid": 25,
      "range": "3941-3977",
      "markText": "像往常那样，当我听某个人说话听烦了，想要摆脱他时，就装出欣然同意的样子。",
      "totalCount": 10724,
      "appLink": "weread://bestbookmark?bookId=912325&chapterUid=25&rangeStart=3941&rangeEnd=3977",
      "webLink": "https://weread.qq.com/web/reader/7bd329e05debc57bdc79852?chapterUid=25&rangeStart=3941&rangeEnd=3977"
    },
    {
      "bookmarkId": "912325_27_5642-5674",
      "chapterUid": 27,
      "range": "5642-5674",
      "markText": "这就是这场审讯的形象，所有一切都是真的，但又没有任何东西是真的！",
      "totalCount": 10688,
      "appLink": "weread://bestbookmark?bookId=912325&chapterUid=27&rangeStart=5642&rangeEnd=5674",
      "webLink": "https://weread.qq.com/web/reader/7bd329e05debc57bdc79852?chapterUid=27&rangeStart=5642&rangeEnd=5674"
    },
    {
      "bookmarkId": "912325_20_1131-1197",
      "chapterUid": 20,
      "range": "1131-1197",
      "markText": "傍晚，我下班出来，沿着码头慢步回家，这时，颇有幸福自在之感。天空是绿色的，我心情轻快，尽管如此，我还是径直回家，因为我想自己煮土豆。",
      "totalCount": 10458,
      "appLink": "weread://bestbookmark?bookId=912325&chapterUid=20&rangeStart=1131&rangeEnd=1197",
      "webLink": "https://weread.qq.com/web/reader/7bd329e05debc57bdc79852?chapterUid=20&rangeStart=1131&rangeEnd=1197"
    },
    {
      "bookmarkId": "912325_19_1121-1179",
      "chapterUid": 19,
      "range": "1121-1179",
      "markText": "我想对她说这不是我的过错，但我没有说出口，因为我想起我对老板也这么说过。其实说这个毫无意义，反正，人总得有点什么错。",
      "totalCount": 10152,
      "appLink": "weread://bestbookmark?bookId=912325&chapterUid=19&rangeStart=1121&rangeEnd=1179",
      "webLink": "https://weread.qq.com/web/reader/7bd329e05debc57bdc79852?chapterUid=19&rangeStart=1121&rangeEnd=1179"
    },
    {
      "bookmarkId": "912325_22_1091-1137",
      "chapterUid": 22,
      "range": "1091-1137",
      "markText": "当我念大学的时候，有过不少这类雄心大志。但当我辍学之后，很快就懂得了，这一切实际上并不重要。",
      "totalCount": 10026,
      "appLink": "weread://bestbookmark?bookId=912325&chapterUid=22&rangeStart=1091&rangeEnd=1137",
      "webLink": "https://weread.qq.com/web/reader/7bd329e05debc57bdc79852?chapterUid=22&rangeStart=1091&rangeEnd=1137"
    },
    {
      "bookmarkId": "912325_18_1975-2002",
      "chapterUid": 18,
      "range": "1975-2002",
      "markText": "妈妈虽说不是无神论者，可活着的时候从来没有想到过宗教。",
      "totalCount": 9979,
      "appLink": "weread://bestbookmark?bookId=912325&chapterUid=18&rangeStart=1975&rangeEnd=2002",
      "webLink": "https://weread.qq.com/web/reader/7bd329e05debc57bdc79852?chapterUid=18&rangeStart=1975&rangeEnd=2002"
    },
    {
