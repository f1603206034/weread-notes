  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "30890357_24_4889-4921",
      "chapterUid": 24,
      "range": "4889-4921",
      "markText": "洗完烟灰缸和杯子，他从口袋里掏出一把手枪，朝自己的胸膛开了一枪。",
      "totalCount": 396,
      "appLink": "weread://bestbookmark?bookId=30890357&chapterUid=24&rangeStart=4889&rangeEnd=4921",
      "webLink": "https://weread.qq.com/web/reader/a703264071d75975a701bc4?chapterUid=24&rangeStart=4889&rangeEnd=4921"
    },
    {
      "bookmarkId": "30890357_55_1621-1652",
      "chapterUid": 55,
      "range": "1621-1652",
      "markText": "辛格从来不知道他的伙伴能理解多少他所要说的话，不过这并不重要。",
      "totalCount": 304,
      "appLink": "weread://bestbookmark?bookId=30890357&chapterUid=55&rangeStart=1621&rangeEnd=1652",
      "webLink": "https://weread.qq.com/web/reader/a703264071d75975a701bc4?chapterUid=55&rangeStart=1621&rangeEnd=1652"
    },
    {
      "bookmarkId": "30890357_55_494-511",
      "chapterUid": 55,
      "range": "494-511",
      "markText": "镇上生活着两个哑巴，总是形影不离。",
      "totalCount": 270,
      "appLink": "weread://bestbookmark?bookId=30890357&chapterUid=55&rangeStart=494&rangeEnd=511",
      "webLink": "https://weread.qq.com/web/reader/a703264071d75975a701bc4?chapterUid=55&rangeStart=494&rangeEnd=511"
    },
    {
      "bookmarkId": "30890357_5_12604-12704",
      "chapterUid": 5,
      "range": "12604-12704",
      "markText": "店里人还不多，此时正是熬夜的人与刚睡醒的人相遇之时，睡意朦胧的女招待忙着端啤酒还有咖啡，没有嘈杂，也没有交谈，人们似乎都是孤单的。刚醒来的人与刚结束漫长夜晚的人之间的不信任，带给每个人一种疏远的感觉。",
      "totalCount": 252,
      "appLink": "weread://bestbookmark?bookId=30890357&chapterUid=5&rangeStart=12604&rangeEnd=12704",
      "webLink": "https://weread.qq.com/web/reader/a703264071d75975a701bc4?chapterUid=5&rangeStart=12604&rangeEnd=12704"
    },
    {
      "bookmarkId": "30890357_9_3397-3440",
      "chapterUid": 9,
      "range": "3397-3440",
      "markText": "因为他们觉得哑巴能理解一切，不管他们想表达的是什么。而且他懂的可能比他们想表达的更多。",
      "totalCount": 210,
      "appLink": "weread://bestbookmark?bookId=30890357&chapterUid=9&rangeStart=3397&rangeEnd=3440",
      "webLink": "https://weread.qq.com/web/reader/a703264071d75975a701bc4?chapterUid=9&rangeStart=3397&rangeEnd=3440"
    },
    {
      "bookmarkId": "30890357_55_5124-5208",
      "chapterUid": 55,
      "range": "5124-5208",
      "markText": "辛格从窗口绝望地望着他，最后一次用手语和伙伴交谈，可安托纳帕罗斯忙着检查午餐盒里的食物，压根没顾上辛格。车启动时，他把脸转向辛格，笑容平淡而悠远，仿佛两人早已远隔千里。",
      "totalCount": 195,
      "appLink": "weread://bestbookmark?bookId=30890357&chapterUid=55&rangeStart=5124&rangeEnd=5208",
      "webLink": "https://weread.qq.com/web/reader/a703264071d75975a701bc4?chapterUid=55&rangeStart=5124&rangeEnd=5208"
    },
    {
      "bookmarkId": "30890357_55_2235-2256",
      "chapterUid": 55,
      "range": "2235-2256",
      "markText": "他们过于孤独了，所以什么事都无法打扰他们。",
      "totalCount": 170,
      "appLink": "weread://bestbookmark?bookId=30890357&chapterUid=55&rangeStart=2235&rangeEnd=2256",
      "webLink": "https://weread.qq.com/web/reader/a703264071d75975a701bc4?chapterUid=55&rangeStart=2235&rangeEnd=2256"
    },
    {
      "bookmarkId": "30890357_55_5944-6006",
      "chapterUid": 55,
      "range": "5944-6006",
      "markText": "到了晚上，他会在屋子里机械地打转，陌生的情绪郁积难发，只在黎明前的几小时才能稍稍入眠，昏睡着，直到晨曦如短刀般刺破他的眼皮。",
      "totalCount": 170,
      "appLink": "weread://bestbookmark?bookId=30890357&chapterUid=55&rangeStart=5944&rangeEnd=6006",
      "webLink": "https://weread.qq.com/web/reader/a703264071d75975a701bc4?chapterUid=55&rangeStart=5944&rangeEnd=6006"
    },
    {
      "bookmarkId": "30890357_7_11437-11467",
      "chapterUid": 7,
      "range": "11437-11467",
      "markText": "“但我的意思是，假如一个人知道，却没法让别人理解，怎么办？”",
      "totalCount": 154,
      "appLink": "weread://bestbookmark?bookId=30890357&chapterUid=7&rangeStart=11437&rangeEnd=11467",
      "webLink": "https://weread.qq.com/web/reader/a703264071d75975a701bc4?chapterUid=7&rangeStart=11437&rangeEnd=11467"
    },
    {
      "bookmarkId": "30890357_5_1534-1592",
      "chapterUid": 5,
      "range": "1534-1592",
      "markText": "他们婚后的前十五年只是简单地称对方比夫和艾莉斯，一次口角中，他们开始互相称呼对方为先生和夫人，此后，称呼再没改回去。",
      "totalCount": 153,
      "appLink": "weread://bestbookmark?bookId=30890357&chapterUid=5&rangeStart=1534&rangeEnd=1592",
      "webLink": "https://weread.qq.com/web/reader/a703264071d75975a701bc4?chapterUid=5&rangeStart=1534&rangeEnd=1592"
    },
    {
      "bookmarkId": "30890357_55_1728-1810",
      "chapterUid": 55,
      "range": "1728-1810",
      "markText": "那里有把板直的餐椅，是辛格用的；还有另一只加有厚软垫的沙发，安托纳帕罗斯专用。卧室中则只有一张属于安托纳帕罗斯的大双人床，上面盖着鸭绒被；以及一张属于辛格的窄铁床。",
      "totalCount": 144,
      "appLink": "weread://bestbookmark?bookId=30890357&chapterUid=55&rangeStart=1728&rangeEnd=1810",
      "webLink": "https://weread.qq.com/web/reader/a703264071d75975a701bc4?chapterUid=55&rangeStart=1728&rangeEnd=1810"
    },
    {
      "bookmarkId": "30890357_55_2493-2557",
      "chapterUid": 55,
      "range": "2493-2557",
      "markText": "镇上最大的建筑是雇佣了小镇大量人口的工厂，这些棉纺厂又大又兴旺，而大多数工人却很穷。街上行人的脸上常常充满了饥饿孤独的绝望表情。",
      "totalCount": 144,
      "appLink": "weread://bestbookmark?bookId=30890357&chapterUid=55&rangeStart=2493&rangeEnd=2557",
      "webLink": "https://weread.qq.com/web/reader/a703264071d75975a701bc4?chapterUid=55&rangeStart=2493&rangeEnd=2557"
    },
    {
      "bookmarkId": "30890357_17_2030-2064",
      "chapterUid": 17,
      "range": "2030-2064",
      "markText": "他嘲笑过的艾莉斯的某些怪念头，到如今变成了他自己的了——怎么回事呢？",
      "totalCount": 143,
      "appLink": "weread://bestbookmark?bookId=30890357&chapterUid=17&rangeStart=2030&rangeEnd=2064",
      "webLink": "https://weread.qq.com/web/reader/a703264071d75975a701bc4?chapterUid=17&rangeStart=2030&rangeEnd=2064"
    },
    {
      "bookmarkId": "30890357_55_6644-6735",
      "chapterUid": 55,
      "range": "6644-6735",
      "markText": "天气渐暖，让人昏昏欲睡，焦虑逐渐变成了疲倦，辛格的身上出现了一种深深的平静。脸上沉静无比，只有最悲伤或最智慧的脸上才会有这样的表情。是的，他仍漫步于小镇的大街小巷，沉默而孤单，永远。",
      "totalCount": 143,
      "appLink": "weread://bestbookmark?bookId=30890357&chapterUid=55&rangeStart=6644&rangeEnd=6735",
      "webLink": "https://weread.qq.com/web/reader/a703264071d75975a701bc4?chapterUid=55&rangeStart=6644&rangeEnd=6735"
    },
    {
      "bookmarkId": "30890357_55_4069-4113",
      "chapterUid": 55,
      "range": "4069-4113",
      "markText": "当辛格接他出来时，他很不高兴，他不想离开。他很喜欢监狱中的腌猪肉、糖汁玉米面包还有狱友。",
      "totalCount": 126,
      "appLink": "weread://bestbookmark?bookId=30890357&chapterUid=55&rangeStart=4069&rangeEnd=4113",
      "webLink": "https://weread.qq.com/web/reader/a703264071d75975a701bc4?chapterUid=55&rangeStart=4069&rangeEnd=4113"
    },
    {
      "bookmarkId": "30890357_12_8977-9024",
      "chapterUid": 12,
      "range": "8977-9024",
      "markText": "主耶稣，我们都是悲伤的黑人’。于是，他就会把神圣的手放在我的头上，我们会马上变得像棉花一样白。",
      "totalCount": 119,
      "appLink": "weread://bestbookmark?bookId=30890357&chapterUid=12&rangeStart=8977&rangeEnd=9024",
      "webLink": "https://weread.qq.com/web/reader/a703264071d75975a701bc4?chapterUid=12&rangeStart=8977&rangeEnd=9024"
    },
    {
      "bookmarkId": "30890357_55_5737-5794",
      "chapterUid": 55,
      "range": "5737-5794",
      "markText": "除了和安托纳帕罗斯在一起的十年，其余都很不真实，在迷蒙的梦境中，他的伙伴仿如真人。醒后，辛格的心被一种孤独刺痛了。",
      "totalCount": 117,
      "appLink": "weread://bestbookmark?bookId=30890357&chapterUid=55&rangeStart=5737&rangeEnd=5794",
      "webLink": "https://weread.qq.com/web/reader/a703264071d75975a701bc4?chapterUid=55&rangeStart=5737&rangeEnd=5794"
    },
    {
      "bookmarkId": "30890357_6_12653-12713",
      "chapterUid": 6,
      "range": "12653-12713",
      "markText": "你会兴奋地不能自已，还会心跳加速，差点死掉，因为你没有爱，没有安宁。终有一天你会毁灭，就像皮球炸掉。到那时，谁都无法救你",
      "totalCount": 112,
      "appLink": "weread://bestbookmark?bookId=30890357&chapterUid=6&rangeStart=12653&rangeEnd=12713",
      "webLink": "https://weread.qq.com/web/reader/a703264071d75975a701bc4?chapterUid=6&rangeStart=12653&rangeEnd=12713"
    },
    {
      "bookmarkId": "30890357_5_6916-6988",
      "chapterUid": 5,
      "range": "6916-6988",
      "markText": "比夫点点头，然后把报纸整齐地叠好，和其他报纸一起放在柜台下面。到了周末，他会把它们都带到厨房后面的储藏室，他在那儿保存着过去二十一年的所有晚报。",
      "totalCount": 108,
      "appLink": "weread://bestbookmark?bookId=30890357&chapterUid=5&rangeStart=6916&rangeEnd=6988",
      "webLink": "https://weread.qq.com/web/reader/a703264071d75975a701bc4?chapterUid=5&rangeStart=6916&rangeEnd=6988"
    },
    {
      "bookmarkId": "30890357_11_990-1075",
      "chapterUid": 11,
      "range": "990-1075",
      "markText": "十月八日下午，他们睡觉的房间里突然传出呼痛声，比夫急忙上楼。一个小时之内，艾莉斯被送到了医院，医生从她体内取出了一个像新生婴儿那么大的肿瘤。又过了一个小时，艾莉斯去世了。",
      "totalCount": 108,
      "appLink": "weread://bestbookmark?bookId=30890357&chapterUid=11&rangeStart=990&rangeEnd=1075",
      "webLink": "https://weread.qq.com/web/reader/a703264071d75975a701bc4?chapterUid=11&rangeStart=990&rangeEnd=1075"
    }
