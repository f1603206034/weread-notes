      "appLink": "weread://bestbookmark?bookId=851632&chapterUid=11&rangeStart=570&rangeEnd=616",
      "webLink": "https://weread.qq.com/web/reader/f2d323b05cfeb0f2d68a7b7?chapterUid=11&rangeStart=570&rangeEnd=616"
