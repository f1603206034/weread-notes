      "appLink": "weread://bestbookmark?bookId=3300036415&chapterUid=3&rangeStart=648&rangeEnd=662",
      "webLink": "https://weread.qq.com/web/reader/b8f320e0813ab74b9g0157e1?chapterUid=3&rangeStart=648&rangeEnd=662"
