      "appLink": "weread://bestbookmark?bookId=3300036415&chapterUid=4&rangeStart=52375&rangeEnd=52401",
      "webLink": "https://weread.qq.com/web/reader/b8f320e0813ab74b9g0157e1?chapterUid=4&rangeStart=52375&rangeEnd=52401"
    },
    {
      "bookmarkId": "3300036415_5_8473-8492",
      "chapterUid": 5,
      "range": "8473-8492",
      "markText": "然而如此情形之下，哪里容得下一间画室？",
      "totalCount": 846,
      "appLink": "weread://bestbookmark?bookId=3300036415&chapterUid=5&rangeStart=8473&rangeEnd=8492",
      "webLink": "https://weread.qq.com/web/reader/b8f320e0813ab74b9g0157e1?chapterUid=5&rangeStart=8473&rangeEnd=8492"
    },
    {
      "bookmarkId": "3300036415_4_33482-33511",
      "chapterUid": 4,
      "range": "33482-33511",
      "markText": "一个人尽管可以选择简单生活，但终究还是无法挣脱复杂的人生。",
