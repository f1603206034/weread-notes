  "hotBookmarks": [
    {
      "bookmarkId": "3300096146_8_854-863",
      "chapterUid": 8,
      "range": "854-863",
      "markText": "另一位是中国人丁仪",
      "totalCount": 68,
      "appLink": "weread://bestbookmark?bookId=3300096146&chapterUid=8&rangeStart=854&rangeEnd=863",
      "webLink": "https://weread.qq.com/web/reader/8db32080813ab8c0eg01682a?chapterUid=8&rangeStart=854&rangeEnd=863"
