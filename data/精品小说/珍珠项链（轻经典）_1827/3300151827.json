      "appLink": "weread://bestbookmark?bookId=3300151827&chapterUid=3&rangeStart=2027&rangeEnd=2057",
      "webLink": "https://weread.qq.com/web/reader/1bc32b50813aba1ceg017488?chapterUid=3&rangeStart=2027&rangeEnd=2057"
