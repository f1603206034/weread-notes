      "appLink": "weread://bestbookmark?bookId=3300115491&chapterUid=4&rangeStart=4062&rangeEnd=4101",
      "webLink": "https://weread.qq.com/web/reader/2fa32e70813ab939dg011ede?chapterUid=4&rangeStart=4062&rangeEnd=4101"
    },
    {
