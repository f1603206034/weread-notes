  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300043207_101_2358-2387",
      "chapterUid": 101,
      "range": "2358-2387",
      "markText": "然而，有些人说不准是哪儿疼。他们安静不下来。他们无法不嚎。",
      "totalCount": 255,
      "appLink": "weread://bestbookmark?bookId=3300043207&chapterUid=101&rangeStart=2358&rangeEnd=2387",
      "webLink": "https://weread.qq.com/web/reader/7e532650813ab7760g0179f4?chapterUid=101&rangeStart=2358&rangeEnd=2387"
    },
    {
      "bookmarkId": "3300043207_110_1069-1305",
      "chapterUid": 110,
      "range": "1069-1305",
      "markText": "有时候你并不十分喜欢我，她说道。 最近我无法多考虑别的事，他说，说到喜欢，这可是两码事。喜欢需要时间。我没有时间来喜欢你。我无法集中精力去喜欢你。",
      "totalCount": 126,
      "appLink": "weread://bestbookmark?bookId=3300043207&chapterUid=110&rangeStart=1069&rangeEnd=1305",
      "webLink": "https://weread.qq.com/web/reader/7e532650813ab7760g0179f4?chapterUid=110&rangeStart=1069&rangeEnd=1305"
    },
    {
      "bookmarkId": "3300043207_110_6555-6645",
      "chapterUid": 110,
      "range": "6555-6645",
      "markText": "于是，没有舌头而却有满肚子话要说的女孩一个接一个被领过来，戴着面纱和花环，伴着庄严的音乐拾阶蜿蜒而上，来到这座城市的第九个门前。换到现在，你也许会说她像一个娇滴滴的上流社会的新娘。",
      "totalCount": 112,
      "appLink": "weread://bestbookmark?bookId=3300043207&chapterUid=110&rangeStart=6555&rangeEnd=6645",
      "webLink": "https://weread.qq.com/web/reader/7e532650813ab7760g0179f4?chapterUid=110&rangeStart=6555&rangeEnd=6645"
    },
    {
      "bookmarkId": "3300043207_108_3515-3578",
      "chapterUid": 108,
      "range": "3515-3578",
      "markText": "由于长时间不断地把眼睛凑近织物劳作，他们一般到八九岁时就全都瞎了。而地毯的价值是卖主根据它完工后瞎了多少个孩子来衡量和叫卖的。",
      "totalCount": 110,
      "appLink": "weread://bestbookmark?bookId=3300043207&chapterUid=108&rangeStart=3515&rangeEnd=3578",
      "webLink": "https://weread.qq.com/web/reader/7e532650813ab7760g0179f4?chapterUid=108&rangeStart=3515&rangeEnd=3578"
    },
    {
      "bookmarkId": "3300043207_119_840-895",
      "chapterUid": 119,
      "range": "840-895",
      "markText": "为什么我们总是很想纪念自己？甚至在我们还活着的时候也是如此？我们希望表明我们的存在，就像狗在消防栓上撒尿一样。",
      "totalCount": 105,
      "appLink": "weread://bestbookmark?bookId=3300043207&chapterUid=119&rangeStart=840&rangeEnd=895",
      "webLink": "https://weread.qq.com/web/reader/7e532650813ab7760g0179f4?chapterUid=119&rangeStart=840&rangeEnd=895"
    },
    {
      "bookmarkId": "3300043207_108_4162-4223",
      "chapterUid": 108,
      "range": "4162-4223",
      "markText": "这些故事在那些还未失明的织毯儿童中悄悄传开了。这也有可能成为他们的将来。于是，他们中间就流传着一种说法：只有瞎子才能自由。",
      "totalCount": 96,
      "appLink": "weread://bestbookmark?bookId=3300043207&chapterUid=108&rangeStart=4162&rangeEnd=4223",
      "webLink": "https://weread.qq.com/web/reader/7e532650813ab7760g0179f4?chapterUid=108&rangeStart=4162&rangeEnd=4223"
    },
    {
      "bookmarkId": "3300043207_103_1535-1628",
      "chapterUid": 103,
      "range": "1535-1628",
      "markText": "她把照片平放在桌子上，然后盯着它看，就像在往一口水井或一个池塘里看——不是在找自己的倒影，而是在找别的东西，一种她丢失的东西；这东西虽然够不着，却还清晰可见，像沙滩上的一颗宝石闪闪发光。",
      "totalCount": 85,
      "appLink": "weread://bestbookmark?bookId=3300043207&chapterUid=103&rangeStart=1535&rangeEnd=1628",
      "webLink": "https://weread.qq.com/web/reader/7e532650813ab7760g0179f4?chapterUid=103&rangeStart=1535&rangeEnd=1628"
    },
    {
      "bookmarkId": "3300043207_163_5710-5729",
      "chapterUid": 163,
      "range": "5710-5729",
      "markText": "在外表下面，他的内心在燃烧。一直在燃烧",
      "totalCount": 80,
      "appLink": "weread://bestbookmark?bookId=3300043207&chapterUid=163&rangeStart=5710&rangeEnd=5729",
      "webLink": "https://weread.qq.com/web/reader/7e532650813ab7760g0179f4?chapterUid=163&rangeStart=5710&rangeEnd=5729"
    },
    {
      "bookmarkId": "3300043207_113_1832-1916",
      "chapterUid": 113,
      "range": "1832-1916",
      "markText": "我又从镜子中看到一张我曾经精心修饰过的、自怜的少女脸庞，在我现在的脸上忽隐忽现；尤其是在午后时分，阳光斜照，这张脸看上去是如此松软和透明，我可以像褪丝袜一样把它褪下来。",
      "totalCount": 75,
      "appLink": "weread://bestbookmark?bookId=3300043207&chapterUid=113&rangeStart=1832&rangeEnd=1916",
      "webLink": "https://weread.qq.com/web/reader/7e532650813ab7760g0179f4?chapterUid=113&rangeStart=1832&rangeEnd=1916"
    },
    {
      "bookmarkId": "3300043207_101_1388-1419",
      "chapterUid": 101,
      "range": "1388-1419",
      "markText": "与其说是她自己选择了这样的颜色，倒不如说是她被关在这种颜色里。",
      "totalCount": 72,
      "appLink": "weread://bestbookmark?bookId=3300043207&chapterUid=101&rangeStart=1388&rangeEnd=1419",
      "webLink": "https://weread.qq.com/web/reader/7e532650813ab7760g0179f4?chapterUid=101&rangeStart=1388&rangeEnd=1419"
    },
    {
      "bookmarkId": "3300043207_106_4942-5122",
      "chapterUid": 106,
      "range": "4942-5122",
      "markText": "可是你不会更喜欢狗的，他说，对吗？ 她睁大了眼睛。为什么不会呢？ 他说道：狗不会说话。",
      "totalCount": 72,
      "appLink": "weread://bestbookmark?bookId=3300043207&chapterUid=106&rangeStart=4942&rangeEnd=5122",
      "webLink": "https://weread.qq.com/web/reader/7e532650813ab7760g0179f4?chapterUid=106&rangeStart=4942&rangeEnd=5122"
    },
    {
      "bookmarkId": "3300043207_114_1198-1241",
      "chapterUid": 114,
      "range": "1198-1241",
      "markText": "作为他们二十世纪在这个小镇一日游的纪念。瑞妮会用“废物收藏者”这个雅号来形容这些游客。",
      "totalCount": 70,
      "appLink": "weread://bestbookmark?bookId=3300043207&chapterUid=114&rangeStart=1198&rangeEnd=1241",
      "webLink": "https://weread.qq.com/web/reader/7e532650813ab7760g0179f4?chapterUid=114&rangeStart=1198&rangeEnd=1241"
    },
    {
      "bookmarkId": "3300043207_110_5861-5896",
      "chapterUid": 110,
      "range": "5861-5896",
      "markText": "许多女孩都相信一种早就被灌输的理论：整个王国的幸福就依赖她们的无私奉献",
      "totalCount": 68,
      "appLink": "weread://bestbookmark?bookId=3300043207&chapterUid=110&rangeStart=5861&rangeEnd=5896",
      "webLink": "https://weread.qq.com/web/reader/7e532650813ab7760g0179f4?chapterUid=110&rangeStart=5861&rangeEnd=5896"
    },
    {
      "bookmarkId": "3300043207_118_11652-11705",
      "chapterUid": 118,
      "range": "11652-11705",
      "markText": "我们否认母亲们自身的存在；我们把她们创造出来是为了满足我们自己——解决我们的饥饿、我们的愿望、我们的缺陷。",
      "totalCount": 68,
      "appLink": "weread://bestbookmark?bookId=3300043207&chapterUid=118&rangeStart=11652&rangeEnd=11705",
      "webLink": "https://weread.qq.com/web/reader/7e532650813ab7760g0179f4?chapterUid=118&rangeStart=11652&rangeEnd=11705"
    },
    {
      "bookmarkId": "3300043207_190_3971-3987",
      "chapterUid": 190,
      "range": "3971-3987",
      "markText": "至于那本书，劳拉一个字也没写过。",
      "totalCount": 68,
      "appLink": "weread://bestbookmark?bookId=3300043207&chapterUid=190&rangeStart=3971&rangeEnd=3987",
      "webLink": "https://weread.qq.com/web/reader/7e532650813ab7760g0179f4?chapterUid=190&rangeStart=3971&rangeEnd=3987"
    },
    {
      "bookmarkId": "3300043207_149_516-612",
      "chapterUid": 149,
      "range": "516-612",
      "markText": "描写真实的唯一方法是：假设你所写的东西永远没有人会读到。不仅别人读不到，甚至你自己后来也读不到了。否则，你便开始原谅自己。你一定要把写作看成是从右手食指流出长长的墨迹，而左手在不断地把它擦去。",
      "totalCount": 66,
      "appLink": "weread://bestbookmark?bookId=3300043207&chapterUid=149&rangeStart=516&rangeEnd=612",
      "webLink": "https://weread.qq.com/web/reader/7e532650813ab7760g0179f4?chapterUid=149&rangeStart=516&rangeEnd=612"
    },
    {
      "bookmarkId": "3300043207_108_4010-4043",
      "chapterUid": 108,
      "range": "4010-4043",
      "markText": "那些从妓院中逃跑的孩子操起了夜间杀人的行当，作为雇佣刺客非常抢手。",
      "totalCount": 65,
      "appLink": "weread://bestbookmark?bookId=3300043207&chapterUid=108&rangeStart=4010&rangeEnd=4043",
      "webLink": "https://weread.qq.com/web/reader/7e532650813ab7760g0179f4?chapterUid=108&rangeStart=4010&rangeEnd=4043"
    },
    {
      "bookmarkId": "3300043207_112_1230-1287",
      "chapterUid": 112,
      "range": "1230-1287",
      "markText": "我非常害怕从楼梯上摔下去——害怕折断脖子，四仰八叉地躺在地上，身上的内衣暴露无遗，等别人发现时我已经腐烂成一摊脓水",
      "totalCount": 65,
      "appLink": "weread://bestbookmark?bookId=3300043207&chapterUid=112&rangeStart=1230&rangeEnd=1287",
      "webLink": "https://weread.qq.com/web/reader/7e532650813ab7760g0179f4?chapterUid=112&rangeStart=1230&rangeEnd=1287"
    },
    {
      "bookmarkId": "3300043207_120_3574-3590",
      "chapterUid": 120,
      "range": "3574-3590",
      "markText": "可他对我做了什么呢？我想不出来。",
      "totalCount": 65,
      "appLink": "weread://bestbookmark?bookId=3300043207&chapterUid=120&rangeStart=3574&rangeEnd=3590",
      "webLink": "https://weread.qq.com/web/reader/7e532650813ab7760g0179f4?chapterUid=120&rangeStart=3574&rangeEnd=3590"
    },
    {
