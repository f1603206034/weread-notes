  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300081902_21_2033-2061",
      "chapterUid": 21,
      "range": "2033-2061",
      "markText": "等这列电车开过之后就继续向前走吧，他在心里这样做出决定。",
      "totalCount": 550,
      "appLink": "weread://bestbookmark?bookId=3300081902&chapterUid=21&rangeStart=2033&rangeEnd=2061",
      "webLink": "https://weread.qq.com/web/reader/059321e0813ab867eg012d46?chapterUid=21&rangeStart=2033&rangeEnd=2061"
    },
    {
      "bookmarkId": "3300081902_17_9034-9096",
      "chapterUid": 17,
      "range": "9034-9096",
      "markText": "在很久以前的那天，有个女孩对自己说过的这句话。 贵树君，你一定没问题的。",
      "totalCount": 510,
      "appLink": "weread://bestbookmark?bookId=3300081902&chapterUid=17&rangeStart=9034&rangeEnd=9096",
      "webLink": "https://weread.qq.com/web/reader/059321e0813ab867eg012d46?chapterUid=17&rangeStart=9034&rangeEnd=9096"
    },
    {
      "bookmarkId": "3300081902_16_7320-7347",
      "chapterUid": 16,
      "range": "7320-7347",
      "markText": "远野君，我一直都喜欢你，谢谢你这么长时间一直在我身边。",
      "totalCount": 473,
      "appLink": "weread://bestbookmark?bookId=3300081902&chapterUid=16&rangeStart=7320&rangeEnd=7347",
      "webLink": "https://weread.qq.com/web/reader/059321e0813ab867eg012d46?chapterUid=16&rangeStart=7320&rangeEnd=7347"
    },
    {
      "bookmarkId": "3300081902_6_1645-1692",
      "chapterUid": 6,
      "range": "1645-1692",
      "markText": "我越来越确信这一点，我强烈地感觉到只要我们拥有彼此，不管前路如何崎岖，都没有什么能让我们恐惧。",
      "totalCount": 459,
      "appLink": "weread://bestbookmark?bookId=3300081902&chapterUid=6&rangeStart=1645&rangeEnd=1692",
      "webLink": "https://weread.qq.com/web/reader/059321e0813ab867eg012d46?chapterUid=6&rangeStart=1645&rangeEnd=1692"
    },
    {
      "bookmarkId": "3300081902_10_6459-6521",
      "chapterUid": 10,
      "range": "6459-6521",
      "markText": "如果我和小狗一样有尾巴的话，现在一定会欢快地摇个不停吧。啊，幸好我不是小狗，如果有尾巴的话，我隐秘的心思就会全部被他知晓了。",
      "totalCount": 455,
      "appLink": "weread://bestbookmark?bookId=3300081902&chapterUid=10&rangeStart=6459&rangeEnd=6521",
      "webLink": "https://weread.qq.com/web/reader/059321e0813ab867eg012d46?chapterUid=10&rangeStart=6459&rangeEnd=6521"
    },
    {
      "bookmarkId": "3300081902_6_1482-1576",
      "chapterUid": 6,
      "range": "1482-1576",
      "markText": "我有生以来第一次觉得自己对这个世界再无任何畏惧，今后不管遭遇怎样令人不快的事情——肯定会遇到很多，譬如转校、考试、陌生的地方和不熟悉的人——但是只要明里陪在我的身边，我就能忍受所有这一切。",
      "totalCount": 450,
      "appLink": "weread://bestbookmark?bookId=3300081902&chapterUid=6&rangeStart=1482&rangeEnd=1576",
      "webLink": "https://weread.qq.com/web/reader/059321e0813ab867eg012d46?chapterUid=6&rangeStart=1482&rangeEnd=1576"
    },
    {
      "bookmarkId": "3300081902_5_2789-2815",
      "chapterUid": 5,
      "range": "2789-2815",
      "markText": "对于遥远广袤时空里的一切事物，我们都怀有强烈的憧憬。",
      "totalCount": 442,
      "appLink": "weread://bestbookmark?bookId=3300081902&chapterUid=5&rangeStart=2789&rangeEnd=2815",
      "webLink": "https://weread.qq.com/web/reader/059321e0813ab867eg012d46?chapterUid=5&rangeStart=2789&rangeEnd=2815"
    },
    {
      "bookmarkId": "3300081902_5_2345-2440",
      "chapterUid": 5,
      "range": "2345-2440",
      "markText": "我们就像准备冬眠的松鼠拼命储存橡子那样，也像即将出海的航海家努力记住星座的方位一样，不断地收集散落在世界之中的各色各样的闪亮断片。我们把这些断片看作今后人生旅途里必不可少的知识而认真学习着。",
      "totalCount": 435,
      "appLink": "weread://bestbookmark?bookId=3300081902&chapterUid=5&rangeStart=2345&rangeEnd=2440",
      "webLink": "https://weread.qq.com/web/reader/059321e0813ab867eg012d46?chapterUid=5&rangeStart=2345&rangeEnd=2440"
    },
    {
      "bookmarkId": "3300081902_5_444-463",
      "chapterUid": 5,
      "range": "444-463",
      "markText": "“看，真像雪花一样啊。”明里这样说道。",
      "totalCount": 392,
      "appLink": "weread://bestbookmark?bookId=3300081902&chapterUid=5&rangeStart=444&rangeEnd=463",
      "webLink": "https://weread.qq.com/web/reader/059321e0813ab867eg012d46?chapterUid=5&rangeStart=444&rangeEnd=463"
    },
    {
      "bookmarkId": "3300081902_7_6759-6841",
      "chapterUid": 7,
      "range": "6759-6841",
      "markText": "我们的人生是无数事件的集合，那封信只不过是其中的一个组成部分而已。无论多么强烈的感情，最终都会在时光洪流的洗刷下逐渐褪色暗淡，不管那天是交出了信，抑或是没有交出去。",
      "totalCount": 384,
      "appLink": "weread://bestbookmark?bookId=3300081902&chapterUid=7&rangeStart=6759&rangeEnd=6841",
      "webLink": "https://weread.qq.com/web/reader/059321e0813ab867eg012d46?chapterUid=7&rangeStart=6759&rangeEnd=6841"
    },
    {
      "bookmarkId": "3300081902_10_6679-6702",
      "chapterUid": 10,
      "range": "6679-6702",
      "markText": "我也说不清楚为何这种幸福的感觉与悲伤如此相似。",
      "totalCount": 378,
      "appLink": "weread://bestbookmark?bookId=3300081902&chapterUid=10&rangeStart=6679&rangeEnd=6702",
      "webLink": "https://weread.qq.com/web/reader/059321e0813ab867eg012d46?chapterUid=10&rangeStart=6679&rangeEnd=6702"
    },
    {
      "bookmarkId": "3300081902_12_7584-7680",
      "chapterUid": 12,
      "range": "7584-7680",
      "markText": "为什么我们要一直沉默不语地走着呢？明明每次都是远野君你先提出要一起回家的啊，可为什么你一句话都不说呢？为什么你总是对我这样温柔？为什么你会出现在我的面前？为什么我会这般喜欢你？为什么？为什么？",
      "totalCount": 375,
      "appLink": "weread://bestbookmark?bookId=3300081902&chapterUid=12&rangeStart=7584&rangeEnd=7680",
      "webLink": "https://weread.qq.com/web/reader/059321e0813ab867eg012d46?chapterUid=12&rangeStart=7584&rangeEnd=7680"
    },
    {
      "bookmarkId": "3300081902_20_1847-1912",
      "chapterUid": 20,
      "range": "1847-1912",
      "markText": "贵树君，你一定没问题的。不管今后发生什么，贵树君一定会成长为一个出色而温柔的男人。无论贵树君将来到多远的地方，我一定会永远喜欢你。",
      "totalCount": 368,
      "appLink": "weread://bestbookmark?bookId=3300081902&chapterUid=20&rangeStart=1847&rangeEnd=1912",
      "webLink": "https://weread.qq.com/web/reader/059321e0813ab867eg012d46?chapterUid=20&rangeStart=1847&rangeEnd=1912"
    },
    {
      "bookmarkId": "3300081902_17_3870-3940",
      "chapterUid": 17,
      "range": "3870-3940",
