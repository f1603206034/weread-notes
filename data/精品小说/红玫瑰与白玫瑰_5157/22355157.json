    {
      "bookmarkId": "22355157_31_34570-34590",
      "chapterUid": 31,
      "range": "34570-34590",
      "markText": "第二天起床，振保改过自新，又变了个好人。",
      "totalCount": 10728,
      "appLink": "weread://bestbookmark?bookId=22355157&chapterUid=31&rangeStart=34570&rangeEnd=34590",
