  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "43148276_2_2967-3038",
      "chapterUid": 2,
      "range": "2967-3038",
      "markText": "我唯一的自豪之处，就是不被人理解，所以未曾有过一次让人理解我的冲动的表现。我认为，自己命中注定不为他人所注意。孤独越来越肥硕，简直就像一头猪。",
      "totalCount": 1134,
      "appLink": "weread://bestbookmark?bookId=43148276&chapterUid=2&rangeStart=2967&rangeEnd=3038",
      "webLink": "https://weread.qq.com/web/reader/a7b32c80729263f4a7bdf51?chapterUid=2&rangeStart=2967&rangeEnd=3038"
    },
    {
      "bookmarkId": "43148276_2_1279-1377",
      "chapterUid": 2,
      "range": "1279-1377",
      "markText": "我虽然外观上困窘，可是内心世界比谁都富有。一个抱有挥之不去的自卑感的少年，认为自己是被悄悄挑选出来的，这种想法不是很自然吗？我感到，这个世界的某个地方，似乎有一个连我自己也弄不清楚的使命在等待我。",
      "totalCount": 1072,
      "appLink": "weread://bestbookmark?bookId=43148276&chapterUid=2&rangeStart=1279&rangeEnd=1377",
      "webLink": "https://weread.qq.com/web/reader/a7b32c80729263f4a7bdf51?chapterUid=2&rangeStart=1279&rangeEnd=1377"
    },
    {
      "bookmarkId": "43148276_1_43-73",
      "chapterUid": 1,
      "range": "43-73",
      "markText": "但梦想孕育的东西，一旦经过现实的修正，返回来更加刺激着梦想。",
      "totalCount": 784,
      "appLink": "weread://bestbookmark?bookId=43148276&chapterUid=1&rangeStart=43&rangeEnd=73",
      "webLink": "https://weread.qq.com/web/reader/a7b32c80729263f4a7bdf51?chapterUid=1&rangeStart=43&rangeEnd=73"
    },
    {
      "bookmarkId": "43148276_2_4564-4602",
      "chapterUid": 2,
      "range": "4564-4602",
      "markText": "我诅咒有为子快死。几个月后，我的诅咒实现了。打那之后，我确信诅咒是很灵验的。",
      "totalCount": 656,
      "appLink": "weread://bestbookmark?bookId=43148276&chapterUid=2&rangeStart=4564&rangeEnd=4602",
      "webLink": "https://weread.qq.com/web/reader/a7b32c80729263f4a7bdf51?chapterUid=2&rangeStart=4564&rangeEnd=4602"
    },
    {
      "bookmarkId": "43148276_2_1981-2030",
      "chapterUid": 2,
      "range": "1981-2030",
      "markText": "嘲笑这玩意儿，是那么光辉耀眼，同年级少年们那种青春期特有的残酷的调笑，犹如闪光的丛林一样灿然夺目。",
      "totalCount": 630,
      "appLink": "weread://bestbookmark?bookId=43148276&chapterUid=2&rangeStart=1981&rangeEnd=2030",
      "webLink": "https://weread.qq.com/web/reader/a7b32c80729263f4a7bdf51?chapterUid=2&rangeStart=1981&rangeEnd=2030"
    },
    {
      "bookmarkId": "43148276_2_237-260",
      "chapterUid": 2,
      "range": "237-260",
      "markText": "我的变幻无常的心情，也许就是这块土地养成的吧？",
      "totalCount": 624,
      "appLink": "weread://bestbookmark?bookId=43148276&chapterUid=2&rangeStart=237&rangeEnd=260",
      "webLink": "https://weread.qq.com/web/reader/a7b32c80729263f4a7bdf51?chapterUid=2&rangeStart=237&rangeEnd=260"
    },
    {
      "bookmarkId": "43148276_3_8221-8277",
      "chapterUid": 3,
      "range": "8221-8277",
      "markText": "我只是梦想有一个像天空般巨大的压缩机，将灾祸、残败、灭绝人世的悲剧，还有人类、物质、丑陋与美丽，通通压挤成一团。",
      "totalCount": 612,
      "appLink": "weread://bestbookmark?bookId=43148276&chapterUid=3&rangeStart=8221&rangeEnd=8277",
      "webLink": "https://weread.qq.com/web/reader/a7b32c80729263f4a7bdf51?chapterUid=3&rangeStart=8221&rangeEnd=8277"
    },
    {
      "bookmarkId": "43148276_11_11491-11502",
      "chapterUid": 11,
      "range": "11491-11502",
      "markText": "我想，我还是要活下去。",
      "totalCount": 610,
      "appLink": "weread://bestbookmark?bookId=43148276&chapterUid=11&rangeStart=11491&rangeEnd=11502",
      "webLink": "https://weread.qq.com/web/reader/a7b32c80729263f4a7bdf51?chapterUid=11&rangeStart=11491&rangeEnd=11502"
    },
    {
      "bookmarkId": "43148276_2_7988-8041",
      "chapterUid": 2,
      "range": "7988-8041",
      "markText": "无论如何，金阁都应该是美丽的，因而，较之金阁本身的美来，我把这一切全都寄予我内心对于金阁的美好想象之上了。",
      "totalCount": 576,
      "appLink": "weread://bestbookmark?bookId=43148276&chapterUid=2&rangeStart=7988&rangeEnd=8041",
      "webLink": "https://weread.qq.com/web/reader/a7b32c80729263f4a7bdf51?chapterUid=2&rangeStart=7988&rangeEnd=8041"
    },
    {
      "bookmarkId": "43148276_2_3505-3573",
      "chapterUid": 2,
      "range": "3505-3573",
      "markText": "有为子的身子沉浸于洁白而富有弹性的暗影之中，变成了散发着香气的肉块。我想象着自己的手指触摸她温热的肌肤，想象感受到的弹力以及花粉般的芳香",
      "totalCount": 555,
      "appLink": "weread://bestbookmark?bookId=43148276&chapterUid=2&rangeStart=3505&rangeEnd=3573",
      "webLink": "https://weread.qq.com/web/reader/a7b32c80729263f4a7bdf51?chapterUid=2&rangeStart=3505&rangeEnd=3573"
    },
    {
      "bookmarkId": "43148276_3_7508-7532",
      "chapterUid": 3,
      "range": "7508-7532",
      "markText": "烧死我的大火也能烧毁金阁，这一想法几乎使我陶醉。",
      "totalCount": 540,
      "appLink": "weread://bestbookmark?bookId=43148276&chapterUid=3&rangeStart=7508&rangeEnd=7532",
      "webLink": "https://weread.qq.com/web/reader/a7b32c80729263f4a7bdf51?chapterUid=3&rangeStart=7508&rangeEnd=7532"
    },
    {
      "bookmarkId": "43148276_8_18223-18232",
      "chapterUid": 8,
      "range": "18223-18232",
      "markText": "“必须烧掉金阁。”",
      "totalCount": 540,
      "appLink": "weread://bestbookmark?bookId=43148276&chapterUid=8&rangeStart=18223&rangeEnd=18232",
      "webLink": "https://weread.qq.com/web/reader/a7b32c80729263f4a7bdf51?chapterUid=8&rangeStart=18223&rangeEnd=18232"
    },
    {
      "bookmarkId": "43148276_2_4734-4812",
      "chapterUid": 2,
      "range": "4734-4812",
      "markText": "我发现她的眼睛的背后有一个他人的世界——这个世界决不把我们当作一个人，而是主动做我们的同谋和证人——他人必须一概灭亡。为了我能真正地面向太阳，世界必须灭亡。",
      "totalCount": 490,
      "appLink": "weread://bestbookmark?bookId=43148276&chapterUid=2&rangeStart=4734&rangeEnd=4812",
      "webLink": "https://weread.qq.com/web/reader/a7b32c80729263f4a7bdf51?chapterUid=2&rangeStart=4734&rangeEnd=4812"
    },
    {
      "bookmarkId": "43148276_2_7379-7435",
      "chapterUid": 2,
      "range": "7379-7435",
      "markText": "那男子再次举起手枪，对着向回廊奔逃的有为子背后连发数枪，有为子应声倒地。那男子又把枪口对准自己的太阳穴打了一枪。",
      "totalCount": 480,
      "appLink": "weread://bestbookmark?bookId=43148276&chapterUid=2&rangeStart=7379&rangeEnd=7435",
      "webLink": "https://weread.qq.com/web/reader/a7b32c80729263f4a7bdf51?chapterUid=2&rangeStart=7379&rangeEnd=7435"
    },
    {
      "bookmarkId": "43148276_2_10805-10905",
      "chapterUid": 2,
      "range": "10805-10905",
      "markText": "我变换着各种角度，有时歪着头眺望，引不起任何共鸣。这只不过是一座陈旧而灰暗的小小三层建筑，屋顶的凤凰看上去像乌鸦一般。谈不上什么美，只给人一种极不调和的动摇之感。我想，所谓美，就是指这种不美的东西吗？",
      "totalCount": 480,
      "appLink": "weread://bestbookmark?bookId=43148276&chapterUid=2&rangeStart=10805&rangeEnd=10905",
      "webLink": "https://weread.qq.com/web/reader/a7b32c80729263f4a7bdf51?chapterUid=2&rangeStart=10805&rangeEnd=10905"
    },
    {
      "bookmarkId": "43148276_5_11032-11038",
      "chapterUid": 5,
      "range": "11032-11038",
      "markText": "柏木讲完了。",
      "totalCount": 462,
      "appLink": "weread://bestbookmark?bookId=43148276&chapterUid=5&rangeStart=11032&rangeEnd=11038",
      "webLink": "https://weread.qq.com/web/reader/a7b32c80729263f4a7bdf51?chapterUid=5&rangeStart=11032&rangeEnd=11038"
    },
    {
      "bookmarkId": "43148276_2_4072-4131",
      "chapterUid": 2,
      "range": "4072-4131",
      "markText": "没等我参与，现实就横在眼前，而且带着从未见过的重负。这毫无意义的浩大的黑暗的现实，不由分说都给了我，迎头向我压迫过来。",
      "totalCount": 459,
      "appLink": "weread://bestbookmark?bookId=43148276&chapterUid=2&rangeStart=4072&rangeEnd=4131",
      "webLink": "https://weread.qq.com/web/reader/a7b32c80729263f4a7bdf51?chapterUid=2&rangeStart=4072&rangeEnd=4131"
    },
    {
      "bookmarkId": "43148276_3_7749-7796",
      "chapterUid": 3,
      "range": "7749-7796",
      "markText": "所谓战争，对于我们少年来讲，就是一种梦一般缺乏实质的慌乱的体验，一间被斩断人生意义的隔离病房。",
      "totalCount": 459,
      "appLink": "weread://bestbookmark?bookId=43148276&chapterUid=3&rangeStart=7749&rangeEnd=7796",
      "webLink": "https://weread.qq.com/web/reader/a7b32c80729263f4a7bdf51?chapterUid=3&rangeStart=7749&rangeEnd=7796"
    },
    {
      "bookmarkId": "43148276_6_9488-9581",
      "chapterUid": 6,
      "range": "9488-9581",
      "markText": "就是这个时候，美的永恒的存在才真正阻滞我们的人生，毒害我们的生命。生命透过墙缝向我们闪现的瞬间的美，在这种毒害面前不堪一击，它会迅速崩溃、灭亡，将生命本身暴露在灭亡的褪色发白的光芒之下。",
      "totalCount": 448,
      "appLink": "weread://bestbookmark?bookId=43148276&chapterUid=6&rangeStart=9488&rangeEnd=9581",
      "webLink": "https://weread.qq.com/web/reader/a7b32c80729263f4a7bdf51?chapterUid=6&rangeStart=9488&rangeEnd=9581"
    },
    {
      "bookmarkId": "43148276_4_3980-4020",
      "chapterUid": 4,
      "range": "3980-4020",
      "markText": "假如金阁未来没有被炸之虞，那么，我的人生就立即失去意义，我所居住的世界就会瓦解。",
      "totalCount": 434,
      "appLink": "weread://bestbookmark?bookId=43148276&chapterUid=4&rangeStart=3980&rangeEnd=4020",
      "webLink": "https://weread.qq.com/web/reader/a7b32c80729263f4a7bdf51?chapterUid=4&rangeStart=3980&rangeEnd=4020"
