  "hotBookmarks": [
    {
      "bookmarkId": "26767635_24_2627-2684",
      "chapterUid": 24,
      "range": "2627-2684",
      "markText": "显而易见的精明大道我放着不走，却拿起电话打给艾迪·玛斯，说今晚我要去南边拉斯奥林达斯找他谈谈。你看我就有这么精明。",
      "totalCount": 221,
      "appLink": "weread://bestbookmark?bookId=26767635&chapterUid=24&rangeStart=2627&rangeEnd=2684",
      "webLink": "https://weread.qq.com/web/reader/7fe32b60719871137fe9580?chapterUid=24&rangeStart=2627&rangeEnd=2684"
    },
    {
      "bookmarkId": "26767635_11_2375-2387",
      "chapterUid": 11,
      "range": "2375-2387",
      "markText": "死人比破碎的心还要沉重。",
      "totalCount": 170,
      "appLink": "weread://bestbookmark?bookId=26767635&chapterUid=11&rangeStart=2375&rangeEnd=2387",
      "webLink": "https://weread.qq.com/web/reader/7fe32b60719871137fe9580?chapterUid=11&rangeStart=2375&rangeEnd=2387"
    },
    {
      "bookmarkId": "26767635_27_4795-4815",
      "chapterUid": 27,
      "range": "4795-4815",
      "markText": "我放下空酒杯，凶暴地把床扯了个乱七八糟。",
      "totalCount": 144,
      "appLink": "weread://bestbookmark?bookId=26767635&chapterUid=27&rangeStart=4795&rangeEnd=4815",
      "webLink": "https://weread.qq.com/web/reader/7fe32b60719871137fe9580?chapterUid=27&rangeStart=4795&rangeEnd=4815"
    },
    {
      "bookmarkId": "26767635_4_878-949",
      "chapterUid": 4,
      "range": "878-949",
      "markText": "他忙着摆弄把女士绑在树上的绳结，可惜解来解去也没什么进展。我站在底下看，心想要是我住在这屋子里，迟早会爬上去帮他一把。他似乎并不怎么尽心尽力。",
      "totalCount": 126,
      "appLink": "weread://bestbookmark?bookId=26767635&chapterUid=4&rangeStart=878&rangeEnd=949",
      "webLink": "https://weread.qq.com/web/reader/7fe32b60719871137fe9580?chapterUid=4&rangeStart=878&rangeEnd=949"
    },
    {
      "bookmarkId": "26767635_22_2865-2908",
      "chapterUid": 22,
      "range": "2865-2908",
      "markText": "它们对事件的描述与接近真相的程度和报纸文章一贯的水平差不多，也就是从火星到土星的距离。",
      "totalCount": 126,
      "appLink": "weread://bestbookmark?bookId=26767635&chapterUid=22&rangeStart=2865&rangeEnd=2908",
      "webLink": "https://weread.qq.com/web/reader/7fe32b60719871137fe9580?chapterUid=22&rangeStart=2865&rangeEnd=2908"
    },
