  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "41923699_3_416-437",
      "chapterUid": 3,
      "range": "416-437",
      "markText": "让日常阅读成为砍向我们内心冰封大海的斧头。",
      "totalCount": 8822,
      "appLink": "weread://bestbookmark?bookId=41923699&chapterUid=3&rangeStart=416&rangeEnd=437",
      "webLink": "https://weread.qq.com/web/reader/0c232500727fb4730c2c19a?chapterUid=3&rangeStart=416&rangeEnd=437"
    },
    {
      "bookmarkId": "41923699_4_647-726",
      "chapterUid": 4,
      "range": "647-726",
      "markText": "生命令人费解，毫不公平，但无论怎样仍要拥有一次，无法逃避，你知道没有别的路，生命是唯一的确切，是无价之宝，也是无用的垃圾。生命之后再无他物。然而一切始于死亡。",
      "totalCount": 7024,
      "appLink": "weread://bestbookmark?bookId=41923699&chapterUid=4&rangeStart=647&rangeEnd=726",
      "webLink": "https://weread.qq.com/web/reader/0c232500727fb4730c2c19a?chapterUid=4&rangeStart=647&rangeEnd=726"
    },
    {
      "bookmarkId": "41923699_5_13259-13311",
      "chapterUid": 5,
      "range": "13259-13311",
      "markText": "那些从未在生活中感受过疼痛和情绪的人，都是冷酷无情的，他们从未真正活过——所以你必须因为眼泪而心存感激。",
      "totalCount": 4466,
      "appLink": "weread://bestbookmark?bookId=41923699&chapterUid=5&rangeStart=13259&rangeEnd=13311",
      "webLink": "https://weread.qq.com/web/reader/0c232500727fb4730c2c19a?chapterUid=5&rangeStart=13259&rangeEnd=13311"
    },
    {
      "bookmarkId": "41923699_7_1334-1389",
      "chapterUid": 7,
      "range": "1334-1389",
      "markText": "生命始于文字，但死亡居于沉默。所以我们必须不断写作，叙述，自言自语地说出诗文和咒语，以这种方式暂时牵制住死亡。",
      "totalCount": 3822,
      "appLink": "weread://bestbookmark?bookId=41923699&chapterUid=7&rangeStart=1334&rangeEnd=1389",
      "webLink": "https://weread.qq.com/web/reader/0c232500727fb4730c2c19a?chapterUid=7&rangeStart=1334&rangeEnd=1389"
    },
    {
      "bookmarkId": "41923699_5_5358-5407",
      "chapterUid": 5,
      "range": "5358-5407",
      "markText": "“我满怀忧伤，它正在碾碎我的心，摧毁着它。一个心如废墟的人活着有何意义？我要离开这里，拯救自己。”",
      "totalCount": 2652,
      "appLink": "weread://bestbookmark?bookId=41923699&chapterUid=5&rangeStart=5358&rangeEnd=5407",
      "webLink": "https://weread.qq.com/web/reader/0c232500727fb4730c2c19a?chapterUid=5&rangeStart=5358&rangeEnd=5407"
    },
    {
      "bookmarkId": "41923699_5_3429-3467",
      "chapterUid": 5,
      "range": "3429-3467",
      "markText": "天是如此遥远，人们的祷告刚刚升入半空，就像死去的鸟儿一般落下，或是化为冰雹。",
      "totalCount": 2538,
      "appLink": "weread://bestbookmark?bookId=41923699&chapterUid=5&rangeStart=3429&rangeEnd=3467",
      "webLink": "https://weread.qq.com/web/reader/0c232500727fb4730c2c19a?chapterUid=5&rangeStart=3429&rangeEnd=3467"
    },
    {
      "bookmarkId": "41923699_5_9774-9846",
      "chapterUid": 5,
      "range": "9774-9846",
      "markText": "她的死让她缺席，成为黑洞。成为一个永不被提及的伤口：一个永不被提及的伤口，不用护理的伤口，随着时间的推移，最终变成一个根深蒂固、无法治愈的溃疡。",
      "totalCount": 2288,
      "appLink": "weread://bestbookmark?bookId=41923699&chapterUid=5&rangeStart=9774&rangeEnd=9846",
      "webLink": "https://weread.qq.com/web/reader/0c232500727fb4730c2c19a?chapterUid=5&rangeStart=9774&rangeEnd=9846"
    },
    {
      "bookmarkId": "41923699_5_8739-8769",
      "chapterUid": 5,
      "range": "8739-8769",
      "markText": "或许改变世界比疗愈心碎更容易，营造新的时代比应对孤独更容易。",
      "totalCount": 2176,
      "appLink": "weread://bestbookmark?bookId=41923699&chapterUid=5&rangeStart=8739&rangeEnd=8769",
      "webLink": "https://weread.qq.com/web/reader/0c232500727fb4730c2c19a?chapterUid=5&rangeStart=8739&rangeEnd=8769"
    },
    {
      "bookmarkId": "41923699_10_2440-2521",
      "chapterUid": 10,
      "range": "2440-2521",
      "markText": "我们可以无比坚定地做出承诺，却以背叛告终。人类软弱不堪，日常生活中没完没了的烦心事抽干他们的精力，在生存面前剥去他们的尊严，接着一个人的手臂扫过餐桌，像一声尖叫。",
      "totalCount": 1778,
      "appLink": "weread://bestbookmark?bookId=41923699&chapterUid=10&rangeStart=2440&rangeEnd=2521",
      "webLink": "https://weread.qq.com/web/reader/0c232500727fb4730c2c19a?chapterUid=10&rangeStart=2440&rangeEnd=2521"
    },
    {
      "bookmarkId": "41923699_5_4550-4588",
      "chapterUid": 5,
      "range": "4550-4588",
      "markText": "生活在小群体中，人会呼吸困难，那种沉闷感十分压抑，在窒息之前，我要离开这里。",
      "totalCount": 1638,
      "appLink": "weread://bestbookmark?bookId=41923699&chapterUid=5&rangeStart=4550&rangeEnd=4588",
      "webLink": "https://weread.qq.com/web/reader/0c232500727fb4730c2c19a?chapterUid=5&rangeStart=4550&rangeEnd=4588"
    },
    {
      "bookmarkId": "41923699_5_1103-1141",
      "chapterUid": 5,
      "range": "1103-1141",
      "markText": "路边亮起的街灯发出长明的光，监视着你，夺走你的星星和风景，以及挡住你的视线。",
      "totalCount": 1458,
      "appLink": "weread://bestbookmark?bookId=41923699&chapterUid=5&rangeStart=1103&rangeEnd=1141",
      "webLink": "https://weread.qq.com/web/reader/0c232500727fb4730c2c19a?chapterUid=5&rangeStart=1103&rangeEnd=1141"
    },
    {
      "bookmarkId": "41923699_5_3778-3833",
      "chapterUid": 5,
      "range": "3778-3833",
      "markText": "我们来的时候还是孩子，离开时已物是人非。这里本不是故乡，可为什么当车渐渐接近尼亚兹维克，我的心就开始狂跳不止？",
      "totalCount": 1380,
      "appLink": "weread://bestbookmark?bookId=41923699&chapterUid=5&rangeStart=3778&rangeEnd=3833",
      "webLink": "https://weread.qq.com/web/reader/0c232500727fb4730c2c19a?chapterUid=5&rangeStart=3778&rangeEnd=3833"
    },
    {
      "bookmarkId": "41923699_5_5025-5052",
