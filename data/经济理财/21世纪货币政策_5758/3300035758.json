  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300035758_5_2434-2478",
      "chapterUid": 5,
      "range": "2434-2478",
      "markText": "菲利普斯曲线的逻辑是当私人和公共部门的总需求持续超过经济体中的生产能力时，通胀便会加速。",
      "totalCount": 285,
      "appLink": "weread://bestbookmark?bookId=3300035758&chapterUid=5&rangeStart=2434&rangeEnd=2478",
      "webLink": "https://weread.qq.com/web/reader/e4132190813ab7477g0182da?chapterUid=5&rangeStart=2434&rangeEnd=2478"
    },
    {
      "bookmarkId": "3300035758_6_3977-4042",
      "chapterUid": 6,
      "range": "3977-4042",
      "markText": "这种“时断时续”的模式——在通胀飙升时收紧政策，但在失业率开始上升时又立即放松，结果被证明是无效的，并导致通胀和通胀预期逐步上升。",
      "totalCount": 221,
      "appLink": "weread://bestbookmark?bookId=3300035758&chapterUid=6&rangeStart=3977&rangeEnd=4042",
      "webLink": "https://weread.qq.com/web/reader/e4132190813ab7477g0182da?chapterUid=6&rangeStart=3977&rangeEnd=4042"
    },
    {
      "bookmarkId": "3300035758_6_15518-15603",
      "chapterUid": 6,
      "range": "15518-15603",
      "markText": "然而强势美元和美国高利率使得这些国家难以偿还（以美元计价的）贷款，即使美国经济疲软，石油和其他大宗商品价格下跌，还是减少了拉丁美洲债务国的收入，其结果是一场国际债务危机。",
      "totalCount": 180,
      "appLink": "weread://bestbookmark?bookId=3300035758&chapterUid=6&rangeStart=15518&rangeEnd=15603",
      "webLink": "https://weread.qq.com/web/reader/e4132190813ab7477g0182da?chapterUid=6&rangeStart=15518&rangeEnd=15603"
    },
    {
      "bookmarkId": "3300035758_3_6057-6127",
      "chapterUid": 3,
      "range": "6057-6127",
      "markText": "2008年金融危机期间，伯南克实施QE，由于房地产不断下行，只能通过推动股市的上涨恢复经济，但在退出量化宽松政策时也不得不考虑对股市的冲击。",
      "totalCount": 150,
      "appLink": "weread://bestbookmark?bookId=3300035758&chapterUid=3&rangeStart=6057&rangeEnd=6127",
      "webLink": "https://weread.qq.com/web/reader/e4132190813ab7477g0182da?chapterUid=3&rangeStart=6057&rangeEnd=6127"
    },
    {
      "bookmarkId": "3300035758_7_28533-28590",
      "chapterUid": 7,
      "range": "28533-28590",
      "markText": "国际货币基金组织与财政部和美联储合作，说服美国银行延长对韩国的短期贷款，通过550亿美元的救助计划化解了这场危机。",
      "totalCount": 150,
      "appLink": "weread://bestbookmark?bookId=3300035758&chapterUid=7&rangeStart=28533&rangeEnd=28590",
      "webLink": "https://weread.qq.com/web/reader/e4132190813ab7477g0182da?chapterUid=7&rangeStart=28533&rangeEnd=28590"
    },
    {
      "bookmarkId": "3300035758_6_4731-4783",
      "chapterUid": 6,
      "range": "4731-4783",
      "markText": "几十年来，借用外交辞令，更重视就业任务的美联储政策制定者被称为鸽派，而更关注通胀的政策制定者被称为鹰派。",
      "totalCount": 144,
      "appLink": "weread://bestbookmark?bookId=3300035758&chapterUid=6&rangeStart=4731&rangeEnd=4783",
      "webLink": "https://weread.qq.com/web/reader/e4132190813ab7477g0182da?chapterUid=6&rangeStart=4731&rangeEnd=4783"
    },
    {
      "bookmarkId": "3300035758_9_2747-2790",
      "chapterUid": 9,
      "range": "2747-2790",
      "markText": "与其取消拖欠贷款人的赎回权，还不如与借款人重新谈判以降低月供，同时让他们保住自己的房子",
      "totalCount": 144,
      "appLink": "weread://bestbookmark?bookId=3300035758&chapterUid=9&rangeStart=2747&rangeEnd=2790",
      "webLink": "https://weread.qq.com/web/reader/e4132190813ab7477g0182da?chapterUid=9&rangeStart=2747&rangeEnd=2790"
    },
    {
      "bookmarkId": "3300035758_11_7647-7733",
      "chapterUid": 11,
      "range": "7647-7733",
      "markText": "美联储2%的通胀目标旨在平衡我们双重任务的两个部分——这个数字低到足以确保物价的稳定，但同时又高到足以保持我们追求充分就业的能力，可以提供降低利率的空间，而不触及有效下限。",
      "totalCount": 144,
      "appLink": "weread://bestbookmark?bookId=3300035758&chapterUid=11&rangeStart=7647&rangeEnd=7733",
      "webLink": "https://weread.qq.com/web/reader/e4132190813ab7477g0182da?chapterUid=11&rangeStart=7647&rangeEnd=7733"
    },
    {
      "bookmarkId": "3300035758_3_1718-1812",
      "chapterUid": 3,
      "range": "1718-1812",
      "markText": "货币政策对通胀产生抑制效果是有时滞的，需要一年或者更长的时间，如果不能在出现通胀苗头的初期就果断采取措施，那么必然会付出更高的政策代价，从而抑制增长。这意味着，货币政策要走在市场曲线前面。",
      "totalCount": 126,
      "appLink": "weread://bestbookmark?bookId=3300035758&chapterUid=3&rangeStart=1718&rangeEnd=1812",
      "webLink": "https://weread.qq.com/web/reader/e4132190813ab7477g0182da?chapterUid=3&rangeStart=1718&rangeEnd=1812"
    },
    {
      "bookmarkId": "3300035758_3_2091-2175",
      "chapterUid": 3,
      "range": "2091-2175",
      "markText": "鲍威尔在2020年8月提出了平均通胀目标的新框架，不介意通胀暂时高于目标，采用更积极的政策来确保充分就业；应对通货膨胀实际上结束了先发制人的策略，走在了市场曲线的后面。",
      "totalCount": 126,
      "appLink": "weread://bestbookmark?bookId=3300035758&chapterUid=3&rangeStart=2091&rangeEnd=2175",
      "webLink": "https://weread.qq.com/web/reader/e4132190813ab7477g0182da?chapterUid=3&rangeStart=2091&rangeEnd=2175"
    },
    {
      "bookmarkId": "3300035758_3_6733-6772",
      "chapterUid": 3,
      "range": "6733-6772",
      "markText": "这是通过在公开市场上出售国债来减少准备金，或者通过购买国债来增加准备金实现的。",
      "totalCount": 126,
