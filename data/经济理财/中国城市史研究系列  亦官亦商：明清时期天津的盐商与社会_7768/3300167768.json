  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300167768_20_7064-7116",
      "chapterUid": 20,
      "range": "7064-7116",
      "markText": "但家族内合法继承人越多，涉及财富的数额越大，矛盾也就越多，而利用中间人调停成功或自愿妥协的可能性就越小。",
      "totalCount": 80,
      "appLink": "weread://bestbookmark?bookId=3300167768&chapterUid=20&rangeStart=7064&rangeEnd=7116",
      "webLink": "https://weread.qq.com/web/reader/353326d0813aba808g0187cc?chapterUid=20&rangeStart=7064&rangeEnd=7116"
    },
    {
      "bookmarkId": "3300167768_42_3188-3247",
      "chapterUid": 42,
      "range": "3188-3247",
      "markText": "为了扩大这一企业，把华北豆制品推向世界市场并招募工人到法国工作，他劝说岳父长芦纲总姚学源动员其他盐商筹资120万两银。",
      "totalCount": 80,
      "appLink": "weread://bestbookmark?bookId=3300167768&chapterUid=42&rangeStart=3188&rangeEnd=3247",
      "webLink": "https://weread.qq.com/web/reader/353326d0813aba808g0187cc?chapterUid=42&rangeStart=3188&rangeEnd=3247"
    },
    {
      "bookmarkId": "3300167768_52_2129-2180",
      "chapterUid": 52,
      "range": "2129-2180",
      "markText": "凡年满24周岁的当地居民，只要不是靠救济生活，能写出自己的名字、年龄、住址和职业的，都有资格参加选举。",
      "totalCount": 80,
      "appLink": "weread://bestbookmark?bookId=3300167768&chapterUid=52&rangeStart=2129&rangeEnd=2180",
      "webLink": "https://weread.qq.com/web/reader/353326d0813aba808g0187cc?chapterUid=52&rangeStart=2129&rangeEnd=2180"
    },
    {
      "bookmarkId": "3300167768_14_3105-3188",
      "chapterUid": 14,
      "range": "3105-3188",
      "markText": "与较小的盐区（比如河东）不同，主要盐区（比如长芦）的盐价自1638年起就一直有规定，运输费用的多少决定了不同地区盐价的差异（不同盐价区的情形，见附录四地图3）。",
      "totalCount": 79,
      "appLink": "weread://bestbookmark?bookId=3300167768&chapterUid=14&rangeStart=3105&rangeEnd=3188",
      "webLink": "https://weread.qq.com/web/reader/353326d0813aba808g0187cc?chapterUid=14&rangeStart=3105&rangeEnd=3188"
    },
    {
      "bookmarkId": "3300167768_18_3898-4045",
      "chapterUid": 18,
      "range": "3898-4045",
      "markText": "至于筹办北洋新军、“新政”、修筑铁路、对外赔款等支出，俱由芦商缴纳，每引高达6.51两白银，远远超过1.88两的正、杂课和帑利。",
      "totalCount": 79,
      "appLink": "weread://bestbookmark?bookId=3300167768&chapterUid=18&rangeStart=3898&rangeEnd=4045",
      "webLink": "https://weread.qq.com/web/reader/353326d0813aba808g0187cc?chapterUid=18&rangeStart=3898&rangeEnd=4045"
    },
    {
      "bookmarkId": "3300167768_29_10140-10173",
      "chapterUid": 29,
      "range": "10140-10173",
      "markText": "当他拜访赵宅时，赵执信正与朋友饮宴，竟然说“土物拜登，大稿璧谢”。",
      "totalCount": 79,
      "appLink": "weread://bestbookmark?bookId=3300167768&chapterUid=29&rangeStart=10140&rangeEnd=10173",
      "webLink": "https://weread.qq.com/web/reader/353326d0813aba808g0187cc?chapterUid=29&rangeStart=10140&rangeEnd=10173"
    },
    {
      "bookmarkId": "3300167768_30_3721-3758",
      "chapterUid": 30,
      "range": "3721-3758",
      "markText": "在这里，他将自己生平三件事讲述给同时旅食张家的方苞，让他记载下来留传后世。",
      "totalCount": 79,
      "appLink": "weread://bestbookmark?bookId=3300167768&chapterUid=30&rangeStart=3721&rangeEnd=3758",
      "webLink": "https://weread.qq.com/web/reader/353326d0813aba808g0187cc?chapterUid=30&rangeStart=3721&rangeEnd=3758"
    },
    {
      "bookmarkId": "3300167768_45_2845-3109",
      "chapterUid": 45,
      "range": "2845-3109",
      "markText": "随后，商人们在清末建立了许多独立的或附属于商会的研究机构，如1909年成立北洋商团公会，同年来自华南的商人也创建了独立于商会的北洋商学公会，1911年设立了天津工商研究总会，即工务总会。",
      "totalCount": 79,
      "appLink": "weread://bestbookmark?bookId=3300167768&chapterUid=45&rangeStart=2845&rangeEnd=3109",
      "webLink": "https://weread.qq.com/web/reader/353326d0813aba808g0187cc?chapterUid=45&rangeStart=2845&rangeEnd=3109"
    },
    {
      "bookmarkId": "3300167768_47_2295-2357",
      "chapterUid": 47,
      "range": "2295-2357",
      "markText": "英国领事虽然公开拒绝参与讨论，却提出了一项秘密计划：建立一家救济性的银行——直隶保商银行，以承担对外贸易的中国交易商的债务。",
      "totalCount": 79,
      "appLink": "weread://bestbookmark?bookId=3300167768&chapterUid=47&rangeStart=2295&rangeEnd=2357",
      "webLink": "https://weread.qq.com/web/reader/353326d0813aba808g0187cc?chapterUid=47&rangeStart=2295&rangeEnd=2357"
    },
    {
      "bookmarkId": "3300167768_62_780-820",
      "chapterUid": 62,
      "range": "780-820",
      "markText": "随着北方平原地区农业产品的商业化，农户生产的手工业品也开始加入商品流通的大循环。",
      "totalCount": 79,
      "appLink": "weread://bestbookmark?bookId=3300167768&chapterUid=62&rangeStart=780&rangeEnd=820",
      "webLink": "https://weread.qq.com/web/reader/353326d0813aba808g0187cc?chapterUid=62&rangeStart=780&rangeEnd=820"
    },
    {
      "bookmarkId": "3300167768_20_6703-6746",
      "chapterUid": 20,
      "range": "6703-6746",
      "markText": "在身兼父亲和家长双重角色的精明强干的商人的领导下，核心家庭最终转化为数世同堂的大家族。",
      "totalCount": 78,
      "appLink": "weread://bestbookmark?bookId=3300167768&chapterUid=20&rangeStart=6703&rangeEnd=6746",
      "webLink": "https://weread.qq.com/web/reader/353326d0813aba808g0187cc?chapterUid=20&rangeStart=6703&rangeEnd=6746"
    },
    {
      "bookmarkId": "3300167768_20_3678-3843",
      "chapterUid": 20,
      "range": "3678-3843",
      "markText": "为防止过失也好，为避免上级批驳也好，“堂上一点朱，民间千点血”，量刑如何举重明轻，据轻明重，尤需精心处理，纂写判词。",
