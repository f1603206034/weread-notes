  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300053174_21_832-903",
      "chapterUid": 21,
      "range": "832-903",
      "markText": "投资始终是GDP增长的主要动力，国内消费需求始终没有成为GDP增长的主要构成要素，国家的金融和货币政策始终是经济增长和结构调整的主导力量等等。",
      "totalCount": 3744,
      "appLink": "weread://bestbookmark?bookId=3300053174&chapterUid=21&rangeStart=832&rangeEnd=903",
      "webLink": "https://weread.qq.com/web/reader/1e7326a0813ab7b45g014524?chapterUid=21&rangeStart=832&rangeEnd=903"
    },
    {
      "bookmarkId": "3300053174_21_6176-6843",
      "chapterUid": 21,
      "range": "6176-6843",
      "markText": "从实践过程来看，中国社会呈现出的是精英再生产而非精英替代的特征。",
      "totalCount": 3078,
      "appLink": "weread://bestbookmark?bookId=3300053174&chapterUid=21&rangeStart=6176&rangeEnd=6843",
      "webLink": "https://weread.qq.com/web/reader/1e7326a0813ab7b45g014524?chapterUid=21&rangeStart=6176&rangeEnd=6843"
    },
    {
      "bookmarkId": "3300053174_21_702-763",
      "chapterUid": 21,
      "range": "702-763",
      "markText": "中国改革的“渐进”特色，在于市场经济的发展始终是政府放权的结果，市场对于经济资源的配置和调节，始终是以政府放权为前提条件。",
      "totalCount": 1470,
      "appLink": "weread://bestbookmark?bookId=3300053174&chapterUid=21&rangeStart=702&rangeEnd=763",
      "webLink": "https://weread.qq.com/web/reader/1e7326a0813ab7b45g014524?chapterUid=21&rangeStart=702&rangeEnd=763"
    },
    {
      "bookmarkId": "3300053174_21_6076-6139",
      "chapterUid": 21,
      "range": "6076-6139",
      "markText": "精英再生产理论则认为旧有的政治精英会在转型过程中利用其已经掌握的权力去维持在经济和社会中的地位，成长为新的经济精英和社会精英。",
      "totalCount": 1414,
      "appLink": "weread://bestbookmark?bookId=3300053174&chapterUid=21&rangeStart=6076&rangeEnd=6139",
      "webLink": "https://weread.qq.com/web/reader/1e7326a0813ab7b45g014524?chapterUid=21&rangeStart=6076&rangeEnd=6139"
    },
    {
      "bookmarkId": "3300053174_22_19599-19650",
      "chapterUid": 22,
      "range": "19599-19650",
      "markText": "地方政府展开的竞赛表面上是围绕经济，实质上也是在高度集权下展开的政治竞赛，地方经济并不能从竞赛中得益。",
      "totalCount": 1335,
      "appLink": "weread://bestbookmark?bookId=3300053174&chapterUid=22&rangeStart=19599&rangeEnd=19650",
      "webLink": "https://weread.qq.com/web/reader/1e7326a0813ab7b45g014524?chapterUid=22&rangeStart=19599&rangeEnd=19650"
    },
    {
      "bookmarkId": "3300053174_22_10940-10984",
      "chapterUid": 22,
      "range": "10940-10984",
      "markText": "省内的“入党积极分子”在人口中的比重与本省在大跃进之后的非正常死亡率之间存在着密切的联系",
      "totalCount": 1116,
      "appLink": "weread://bestbookmark?bookId=3300053174&chapterUid=22&rangeStart=10940&rangeEnd=10984",
      "webLink": "https://weread.qq.com/web/reader/1e7326a0813ab7b45g014524?chapterUid=22&rangeStart=10940&rangeEnd=10984"
    },
    {
      "bookmarkId": "3300053174_21_4097-4197",
      "chapterUid": 21,
      "range": "4097-4197",
      "markText": "这个体制能够运行无碍，需要两个前提条件。其一就是中央在人事和财政方面的集权，这正是我刚刚论述的重点；其二则是需要基层政府对地方的经济、社会资源拥有强大的控制和动员能力，拥有高效率地完成上级目标的能力。",
      "totalCount": 1088,
      "appLink": "weread://bestbookmark?bookId=3300053174&chapterUid=21&rangeStart=4097&rangeEnd=4197",
      "webLink": "https://weread.qq.com/web/reader/1e7326a0813ab7b45g014524?chapterUid=21&rangeStart=4097&rangeEnd=4197"
    },
    {
