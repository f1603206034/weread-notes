    {
      "bookmarkId": "235061_107_1766-1783",
      "chapterUid": 107,
      "range": "1766-1783",
      "markText": "观念的优先往往比资源的优先更重要。",
      "totalCount": 2486,
      "appLink": "weread://bestbookmark?bookId=235061&chapterUid=107&rangeStart=1766&rangeEnd=1783",
