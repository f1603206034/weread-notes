          "colorStyle": 0,
          "colorLabel": "",
          "createTime": 1764735696,
          "createTimeFormatted": "2025-12-03 12:21:36",
          "chapterUid": 9,
          "appLink": "weread://bestbookmark?bookId=3300113629&chapterUid=9&rangeStart=2365&rangeEnd=2448",
