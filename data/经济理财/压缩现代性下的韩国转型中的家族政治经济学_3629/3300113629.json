  ],
  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300113629_7_857-914",
      "chapterUid": 7,
      "range": "857-914",
      "markText": "国家与社会的关系可以被理解为一种伪家庭约束，个人对国家或说王权的忠诚，可以被谨慎地解读为一个人孝顺父母的衍生现象。",
      "totalCount": 300,
      "appLink": "weread://bestbookmark?bookId=3300113629&chapterUid=7&rangeStart=857&rangeEnd=914",
      "webLink": "https://weread.qq.com/web/reader/2d832bf0813ab92e2g019f69?chapterUid=7&rangeStart=857&rangeEnd=914"
    },
    {
      "bookmarkId": "3300113629_3_5648-5742",
      "chapterUid": 3,
      "range": "5648-5742",
      "markText": "中国人因为无神论发达而导致的特有的贵生倾向以及相应的伦理原则，作为一种文化心理势能却极易被导入资本主义的河床。不仅东亚的情况是这样，东南亚的情况也同样证明，华人总是比当地人更容易发财致富。",
      "totalCount": 288,
      "appLink": "weread://bestbookmark?bookId=3300113629&chapterUid=3&rangeStart=5648&rangeEnd=5742",
      "webLink": "https://weread.qq.com/web/reader/2d832bf0813ab92e2g019f69?chapterUid=3&rangeStart=5648&rangeEnd=5742"
    },
    {
      "bookmarkId": "3300113629_9_2365-2448",
      "chapterUid": 9,
      "range": "2365-2448",
      "markText": "韩国人对正规教育的热情，对其国家的很多方面都有好处，特别是政府不需要太多的政治性说教，就可以要求那些作为极度热切的投资者去认识和接触正式教育的公民大量分担公共教育费用",
      "totalCount": 256,
      "appLink": "weread://bestbookmark?bookId=3300113629&chapterUid=9&rangeStart=2365&rangeEnd=2448",
      "webLink": "https://weread.qq.com/web/reader/2d832bf0813ab92e2g019f69?chapterUid=9&rangeStart=2365&rangeEnd=2448"
    },
    {
      "bookmarkId": "3300113629_14_1218-1290",
      "chapterUid": 14,
      "range": "1218-1290",
      "markText": "尽管日本、韩国和中国台湾的正规教育的质量和性质经常受到质疑，更不用说中国大陆，但他们对教育成就的普遍渴望为人称赞和羡慕，这已成为他们的民族特征。",
      "totalCount": 180,
      "appLink": "weread://bestbookmark?bookId=3300113629&chapterUid=14&rangeStart=1218&rangeEnd=1290",
      "webLink": "https://weread.qq.com/web/reader/2d832bf0813ab92e2g019f69?chapterUid=14&rangeStart=1218&rangeEnd=1290"
    },
    {
      "bookmarkId": "3300113629_31_5064-5140",
      "chapterUid": 31,
      "range": "5064-5140",
      "markText": "大多数农村年轻女性离开农村后，农村单身男性又急切地想寻找配偶，他们想到了一个新颖的解决办法，即与外国新娘（特别是来自越南、中国等国的新娘）进行包办婚姻。",
      "totalCount": 168,
      "appLink": "weread://bestbookmark?bookId=3300113629&chapterUid=31&rangeStart=5064&rangeEnd=5140",
      "webLink": "https://weread.qq.com/web/reader/2d832bf0813ab92e2g019f69?chapterUid=31&rangeStart=5064&rangeEnd=5140"
    },
    {
      "bookmarkId": "3300113629_15_6177-6275",
      "chapterUid": 15,
      "range": "6177-6275",
      "markText": "这些专业团体缺乏对其专业实践的社会和科学基础的信心，更不用说对公众的尊重，任何改革其制度化遗迹的社会尝试或政治尝试都伴随着这些专业团体的生死斗争，在这些斗争中，他们的物质利益毫无保留地被表达出来。",
      "totalCount": 162,
      "appLink": "weread://bestbookmark?bookId=3300113629&chapterUid=15&rangeStart=6177&rangeEnd=6275",
      "webLink": "https://weread.qq.com/web/reader/2d832bf0813ab92e2g019f69?chapterUid=15&rangeStart=6177&rangeEnd=6275"
    },
    {
      "bookmarkId": "3300113629_5_1448-1512",
      "chapterUid": 5,
      "range": "1448-1512",
      "markText": "虽然没有本土学者会否认韩国社会以家庭为中心的事实，但当西方人基于此事实看待韩国社会时，他们仍会不禁怀疑这是西方的东方主义式偏见。",
      "totalCount": 153,
      "appLink": "weread://bestbookmark?bookId=3300113629&chapterUid=5&rangeStart=1448&rangeEnd=1512",
      "webLink": "https://weread.qq.com/web/reader/2d832bf0813ab92e2g019f69?chapterUid=5&rangeStart=1448&rangeEnd=1512"
    },
    {
      "bookmarkId": "3300113629_7_941-979",
      "chapterUid": 7,
      "range": "941-979",
      "markText": "韩国的现代社会、政治和经济制度在很多方面正是依赖于它的存在，而不是使其消亡。",
      "totalCount": 144,
      "appLink": "weread://bestbookmark?bookId=3300113629&chapterUid=7&rangeStart=941&rangeEnd=979",
      "webLink": "https://weread.qq.com/web/reader/2d832bf0813ab92e2g019f69?chapterUid=7&rangeStart=941&rangeEnd=979"
    },
    {
      "bookmarkId": "3300113629_9_2936-2994",
      "chapterUid": 9,
      "range": "2936-2994",
      "markText": "韩国政府对社会再生产的主要立场，可以概括为“最大限度地缩减社会福利和公共支出”，以及将社会福利的政治责任转移给家庭。",
      "totalCount": 144,
      "appLink": "weread://bestbookmark?bookId=3300113629&chapterUid=9&rangeStart=2936&rangeEnd=2994",
      "webLink": "https://weread.qq.com/web/reader/2d832bf0813ab92e2g019f69?chapterUid=9&rangeStart=2936&rangeEnd=2994"
    },
    {
      "bookmarkId": "3300113629_46_1644-1847",
      "chapterUid": 46,
      "range": "1644-1847",
      "markText": "工业资本主义、福利国家、政治和社会关系的民主化，甚至全球化都会促使或迫使现代人去计划并过上“自己的生活”，这涉及个性化的努力和风险。因此，个体化更像是一种制度化的社会变革，而不是一种文化或道德改造。",
      "totalCount": 143,
      "appLink": "weread://bestbookmark?bookId=3300113629&chapterUid=46&rangeStart=1644&rangeEnd=1847",
      "webLink": "https://weread.qq.com/web/reader/2d832bf0813ab92e2g019f69?chapterUid=46&rangeStart=1644&rangeEnd=1847"
    },
    {
      "bookmarkId": "3300113629_6_1988-2038",
      "chapterUid": 6,
      "range": "1988-2038",
      "markText": "因此，家族在经济组织、政治秩序和社会关系中的根本性衰落是现代化进程社会内核这一传统观点是站不住脚的。",
      "totalCount": 140,
      "appLink": "weread://bestbookmark?bookId=3300113629&chapterUid=6&rangeStart=1988&rangeEnd=2038",
      "webLink": "https://weread.qq.com/web/reader/2d832bf0813ab92e2g019f69?chapterUid=6&rangeStart=1988&rangeEnd=2038"
    },
    {
      "bookmarkId": "3300113629_5_934-974",
      "chapterUid": 5,
      "range": "934-974",
      "markText": "这是因为学界认为各种社会（或者非家庭）实体接管了主要的社会功能，如经济生产和教育",
      "totalCount": 136,
      "appLink": "weread://bestbookmark?bookId=3300113629&chapterUid=5&rangeStart=934&rangeEnd=974",
      "webLink": "https://weread.qq.com/web/reader/2d832bf0813ab92e2g019f69?chapterUid=5&rangeStart=934&rangeEnd=974"
    },
    {
      "bookmarkId": "3300113629_18_1842-1872",
      "chapterUid": 18,
      "range": "1842-1872",
      "markText": "在这种背景下，韩国的古话“无子乃福”更加频繁地在民众间流传。",
      "totalCount": 130,
      "appLink": "weread://bestbookmark?bookId=3300113629&chapterUid=18&rangeStart=1842&rangeEnd=1872",
      "webLink": "https://weread.qq.com/web/reader/2d832bf0813ab92e2g019f69?chapterUid=18&rangeStart=1842&rangeEnd=1872"
    },
    {
      "bookmarkId": "3300113629_47_8593-8646",
      "chapterUid": 47,
      "range": "8593-8646",
      "markText": "从柏拉图到马克思，再到一些现代女权主义者，许多人认为家庭必须经历“消亡”，才能为真正的社群主义社会秩序让路",
      "totalCount": 128,
      "appLink": "weread://bestbookmark?bookId=3300113629&chapterUid=47&rangeStart=8593&rangeEnd=8646",
      "webLink": "https://weread.qq.com/web/reader/2d832bf0813ab92e2g019f69?chapterUid=47&rangeStart=8593&rangeEnd=8646"
    },
    {
      "bookmarkId": "3300113629_3_943-1006",
      "chapterUid": 3,
      "range": "943-1006",
      "markText": "韩国受到了儒家文化的哪些影响，这在它的发展过程中起到过什么作用？而它又是如何在这样的路径依赖下，成功地实现了自己的现代化转型？",
      "totalCount": 126,
      "appLink": "weread://bestbookmark?bookId=3300113629&chapterUid=3&rangeStart=943&rangeEnd=1006",
      "webLink": "https://weread.qq.com/web/reader/2d832bf0813ab92e2g019f69?chapterUid=3&rangeStart=943&rangeEnd=1006"
    },
    {
      "bookmarkId": "3300113629_12_3688-3743",
      "chapterUid": 12,
      "range": "3688-3743",
      "markText": "工具家庭主义不可避免要付出的代价就是，许多的韩国家庭倾向于牺牲正常家庭的生活质量，以换取其成员在社会上的成功。",
      "totalCount": 126,
      "appLink": "weread://bestbookmark?bookId=3300113629&chapterUid=12&rangeStart=3688&rangeEnd=3743",
      "webLink": "https://weread.qq.com/web/reader/2d832bf0813ab92e2g019f69?chapterUid=12&rangeStart=3688&rangeEnd=3743"
    },
    {
      "bookmarkId": "3300113629_7_1065-1154",
      "chapterUid": 7,
      "range": "1065-1154",
      "markText": "当底层遭到猖獗的殖民经济剥削和政治虐待时，当一场巨大的内战使社会关系和经济活动紊乱无序时，当政治制度不稳定且公民受到专制统治时，大多数人束手无策，只能寄希望于家庭团结来保证生存。",
      "totalCount": 120,
      "appLink": "weread://bestbookmark?bookId=3300113629&chapterUid=7&rangeStart=1065&rangeEnd=1154",
      "webLink": "https://weread.qq.com/web/reader/2d832bf0813ab92e2g019f69?chapterUid=7&rangeStart=1065&rangeEnd=1154"
    },
    {
      "bookmarkId": "3300113629_7_1345-1376",
      "chapterUid": 7,
      "range": "1345-1376",
      "markText": "导致朝鲜半岛上除亲属关系网之外的底层民间（社区）社会彻底瓦解。",
      "totalCount": 120,
      "appLink": "weread://bestbookmark?bookId=3300113629&chapterUid=7&rangeStart=1345&rangeEnd=1376",
      "webLink": "https://weread.qq.com/web/reader/2d832bf0813ab92e2g019f69?chapterUid=7&rangeStart=1345&rangeEnd=1376"
    },
    {
      "bookmarkId": "3300113629_12_4102-4199",
      "chapterUid": 12,
      "range": "4102-4199",
      "markText": "此现象衍生出一个说明性术语“裙裾之风”(chima baram)，这个词被用来讽刺女性用贿赂来左右教师、组织孩子补习功课、通过房地产投机增加家庭金融资产、发展与丈夫上级妻子的人际关系等不当作为。",
      "totalCount": 119,
      "appLink": "weread://bestbookmark?bookId=3300113629&chapterUid=12&rangeStart=4102&rangeEnd=4199",
      "webLink": "https://weread.qq.com/web/reader/2d832bf0813ab92e2g019f69?chapterUid=12&rangeStart=4102&rangeEnd=4199"
    },
    {
      "bookmarkId": "3300113629_24_2757-2811",
      "chapterUid": 24,
      "range": "2757-2811",
      "markText": "在某种意义上，为了实现韩国以男性为主导的工业现代化，这种对女性阶级地位和社会活动的遏制和操纵就显得更为必要。",
      "totalCount": 119,
      "appLink": "weread://bestbookmark?bookId=3300113629&chapterUid=24&rangeStart=2757&rangeEnd=2811",
      "webLink": "https://weread.qq.com/web/reader/2d832bf0813ab92e2g019f69?chapterUid=24&rangeStart=2757&rangeEnd=2811"
    }
  ],
