  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "650985_4_1271-1318",
      "chapterUid": 4,
      "range": "1271-1318",
      "markText": "如果一个人为了自己的利益，能够刺激别人的利己心而自愿替自己做事，他就可以比较容易地达到目的了。",
      "totalCount": 14586,
      "appLink": "weread://bestbookmark?bookId=650985&chapterUid=4&rangeStart=1271&rangeEnd=1318",
      "webLink": "https://weread.qq.com/web/reader/6c4324d059eee96c43a4b3e?chapterUid=4&rangeStart=1271&rangeEnd=1318"
    },
    {
      "bookmarkId": "650985_4_1447-1496",
      "chapterUid": 4,
      "range": "1447-1496",
      "markText": "我们不说唤起别人利他心的话，而改说唤起别人利己心的话。就算我们自己有需要，也要说这样做对他们有利。",
      "totalCount": 5902,
      "appLink": "weread://bestbookmark?bookId=650985&chapterUid=4&rangeStart=1447&rangeEnd=1496",
      "webLink": "https://weread.qq.com/web/reader/6c4324d059eee96c43a4b3e?chapterUid=4&rangeStart=1447&rangeEnd=1496"
    },
    {
      "bookmarkId": "650985_3_2283-2331",
      "chapterUid": 3,
      "range": "2283-2331",
      "markText": "也许就是因为农业不能采用完全的分工制度，才使得农业在劳动生产力的增进上，总是跟不上制造业的步伐。",
      "totalCount": 5516,
      "appLink": "weread://bestbookmark?bookId=650985&chapterUid=3&rangeStart=2283&rangeEnd=2331",
      "webLink": "https://weread.qq.com/web/reader/6c4324d059eee96c43a4b3e?chapterUid=3&rangeStart=2283&rangeEnd=2331"
    },
    {
      "bookmarkId": "650985_3_493-537",
      "chapterUid": 3,
      "range": "493-537",
      "markText": "分工出现之后，劳动生产力得到了最大的增进，运用劳动时的熟练程度、技巧和判断力也得以加强。",
      "totalCount": 5320,
      "appLink": "weread://bestbookmark?bookId=650985&chapterUid=3&rangeStart=493&rangeEnd=537",
      "webLink": "https://weread.qq.com/web/reader/6c4324d059eee96c43a4b3e?chapterUid=3&rangeStart=493&rangeEnd=537"
    },
    {
      "bookmarkId": "650985_5_2705-2760",
      "chapterUid": 5,
      "range": "2705-2760",
      "markText": "但是，有一点很奇怪：对于对外贸易，古代的埃及人、印度人和中国人都不鼓励。内陆的航行，似乎是他们财富的全部来源。",
      "totalCount": 5248,
      "appLink": "weread://bestbookmark?bookId=650985&chapterUid=5&rangeStart=2705&rangeEnd=2760",
      "webLink": "https://weread.qq.com/web/reader/6c4324d059eee96c43a4b3e?chapterUid=5&rangeStart=2705&rangeEnd=2760"
    },
    {
      "bookmarkId": "650985_3_4098-4176",
      "chapterUid": 3,
      "range": "4098-4176",
      "markText": "一个农村劳动者，如果他每半小时就要换一次工作和劳动工具，而且几乎每天都必须从事二十项不同的工作，那么他自然（甚至可以说是必然）会养成闲荡、偷懒、随便等习惯。",
      "totalCount": 5230,
      "appLink": "weread://bestbookmark?bookId=650985&chapterUid=3&rangeStart=4098&rangeEnd=4176",
      "webLink": "https://weread.qq.com/web/reader/6c4324d059eee96c43a4b3e?chapterUid=3&rangeStart=4098&rangeEnd=4176"
    },
    {
      "bookmarkId": "650985_10_4766-4847",
      "chapterUid": 10,
      "range": "4766-4847",
      "markText": "决定劳动工资增高的因素，不是现有的国民财富有多庞大，而是国民财富的不断增加。所以，出现最高劳动工资的国家，往往不是最富有的国家，而是那些最快变得富裕、繁荣的国家。",
      "totalCount": 5152,
      "appLink": "weread://bestbookmark?bookId=650985&chapterUid=10&rangeStart=4766&rangeEnd=4847",
      "webLink": "https://weread.qq.com/web/reader/6c4324d059eee96c43a4b3e?chapterUid=10&rangeStart=4766&rangeEnd=4847"
    },
    {
      "bookmarkId": "650985_7_3090-3125",
      "chapterUid": 7,
      "range": "3090-3125",
      "markText": "换句话说，就是劳动价格高时，货物的价格低；劳动价格低时，货物的价格高。",
      "totalCount": 4953,
      "appLink": "weread://bestbookmark?bookId=650985&chapterUid=7&rangeStart=3090&rangeEnd=3125",
      "webLink": "https://weread.qq.com/web/reader/6c4324d059eee96c43a4b3e?chapterUid=7&rangeStart=3090&rangeEnd=3125"
    },
    {
      "bookmarkId": "650985_3_4444-4494",
      "chapterUid": 3,
      "range": "4444-4494",
      "markText": "人类的注意力如果只集中于单一的事物上，会比分散在许多事物上更容易发现达到目标的更简易、更便利的方法。",
      "totalCount": 4760,
      "appLink": "weread://bestbookmark?bookId=650985&chapterUid=3&rangeStart=4444&rangeEnd=4494",
      "webLink": "https://weread.qq.com/web/reader/6c4324d059eee96c43a4b3e?chapterUid=3&rangeStart=4444&rangeEnd=4494"
    },
    {
      "bookmarkId": "650985_3_2726-2780",
      "chapterUid": 3,
      "range": "2726-2780",
      "markText": "由此可见，贫国尽管在耕种上处于劣势，也同样可以生产出品质优良、售价低廉的小麦，有能力在相当程度上与富国竞争。",
      "totalCount": 4131,
      "appLink": "weread://bestbookmark?bookId=650985&chapterUid=3&rangeStart=2726&rangeEnd=2780",
      "webLink": "https://weread.qq.com/web/reader/6c4324d059eee96c43a4b3e?chapterUid=3&rangeStart=2726&rangeEnd=2780"
    },
    {
      "bookmarkId": "650985_7_1192-1223",
      "chapterUid": 7,
      "range": "1192-1223",
      "markText": "劳动可以用来衡量一切商品的交换价值，却不能衡量一切商品的价值。",
      "totalCount": 4104,
      "appLink": "weread://bestbookmark?bookId=650985&chapterUid=7&rangeStart=1192&rangeEnd=1223",
      "webLink": "https://weread.qq.com/web/reader/6c4324d059eee96c43a4b3e?chapterUid=7&rangeStart=1192&rangeEnd=1223"
    },
    {
      "bookmarkId": "650985_5_1074-1151",
      "chapterUid": 5,
      "range": "1074-1151",
      "markText": "水运开拓的市场，比陆运开拓的市场要广大得多。所以，一直以来，各种产业的分工改良都自然而然地从沿海、沿河一带开始。这种改良要想在内地得以普及，往往需要许久。",
      "totalCount": 4103,
      "appLink": "weread://bestbookmark?bookId=650985&chapterUid=5&rangeStart=1074&rangeEnd=1151",
      "webLink": "https://weread.qq.com/web/reader/6c4324d059eee96c43a4b3e?chapterUid=5&rangeStart=1074&rangeEnd=1151"
    },
    {
      "bookmarkId": "650985_3_5381-5440",
      "chapterUid": 3,
      "range": "5381-5440",
      "markText": "一个人所需的物品可以通过与别人交换而得到充分供应，别人所需的物品也可以从他那里获得，就这样，社会各阶层都普遍富裕起来。",
      "totalCount": 4063,
      "appLink": "weread://bestbookmark?bookId=650985&chapterUid=3&rangeStart=5381&rangeEnd=5440",
      "webLink": "https://weread.qq.com/web/reader/6c4324d059eee96c43a4b3e?chapterUid=3&rangeStart=5381&rangeEnd=5440"
    },
    {
      "bookmarkId": "650985_7_576-596",
      "chapterUid": 7,
      "range": "576-596",
      "markText": "衡量一切商品交换价值的真实尺度就是劳动。",
      "totalCount": 4020,
      "appLink": "weread://bestbookmark?bookId=650985&chapterUid=7&rangeStart=576&rangeEnd=596",
      "webLink": "https://weread.qq.com/web/reader/6c4324d059eee96c43a4b3e?chapterUid=7&rangeStart=576&rangeEnd=596"
    },
    {
      "bookmarkId": "650985_4_2237-2284",
      "chapterUid": 4,
      "range": "2237-2284",
      "markText": "成年人在其所从事的不同职位上所表现出的非常不同的才能，与其说是分工的原因，不如说是分工的结果。",
      "totalCount": 3618,
      "appLink": "weread://bestbookmark?bookId=650985&chapterUid=4&rangeStart=2237&rangeEnd=2284",
      "webLink": "https://weread.qq.com/web/reader/6c4324d059eee96c43a4b3e?chapterUid=4&rangeStart=2237&rangeEnd=2284"
    },
    {
      "bookmarkId": "650985_3_3074-3158",
      "chapterUid": 3,
      "range": "3074-3158",
      "markText": "第一，劳动者因为专业而掌握了技巧；第二，免除了由一种工作转到另一种工作所带来的时间损失；第三，随着简化和缩减劳动的机械的发明，一个人能够做原本需要许多人才能完成的工作。",
      "totalCount": 3520,
      "appLink": "weread://bestbookmark?bookId=650985&chapterUid=3&rangeStart=3074&rangeEnd=3158",
      "webLink": "https://weread.qq.com/web/reader/6c4324d059eee96c43a4b3e?chapterUid=3&rangeStart=3074&rangeEnd=3158"
    },
    {
      "bookmarkId": "650985_3_6203-6297",
      "chapterUid": 3,
      "range": "6203-6297",
      "markText": "总之，任意一样你观察到的东西，都投入了各种劳动。由此可以知道，如果没有千千万万人的协作，一个文明社会中的、微不足道的人，要想按照他现在所适应的舒服简单的方式取得其所需的日用品，是不可能的。",
      "totalCount": 3406,
      "appLink": "weread://bestbookmark?bookId=650985&chapterUid=3&rangeStart=6203&rangeEnd=6297",
      "webLink": "https://weread.qq.com/web/reader/6c4324d059eee96c43a4b3e?chapterUid=3&rangeStart=6203&rangeEnd=6297"
    },
    {
      "bookmarkId": "650985_9_1571-1612",
      "chapterUid": 9,
      "range": "1571-1612",
      "markText": "决定市场价格上升程度的因素有两个，一是货品的缺乏程度；二是竞争者的富有和奢侈程度。",
      "totalCount": 3248,
      "appLink": "weread://bestbookmark?bookId=650985&chapterUid=9&rangeStart=1571&rangeEnd=1612",
      "webLink": "https://weread.qq.com/web/reader/6c4324d059eee96c43a4b3e?chapterUid=9&rangeStart=1571&rangeEnd=1612"
    },
    {
      "bookmarkId": "650985_10_14595-14630",
      "chapterUid": 10,
      "range": "14595-14630",
      "markText": "如果雇主有理性和人道，就不应该鼓励劳动者勤勉，而应该让他们适度地休息。",
      "totalCount": 3145,
      "appLink": "weread://bestbookmark?bookId=650985&chapterUid=10&rangeStart=14595&rangeEnd=14630",
      "webLink": "https://weread.qq.com/web/reader/6c4324d059eee96c43a4b3e?chapterUid=10&rangeStart=14595&rangeEnd=14630"
    },
    {
      "bookmarkId": "650985_3_5262-5296",
      "chapterUid": 3,
      "range": "5262-5296",
      "markText": "因为分工的出现，在政治修明的国家里，就连最底层的劳苦大众也普遍富裕。",
      "totalCount": 3024,
      "appLink": "weread://bestbookmark?bookId=650985&chapterUid=3&rangeStart=5262&rangeEnd=5296",
