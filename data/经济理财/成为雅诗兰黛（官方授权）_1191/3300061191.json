    {
      "bookmarkId": "3300061191_13_8053-8098",
      "chapterUid": 13,
      "range": "8053-8098",
      "markText": "故事是一种强有力的传播途径，一个优秀的故事讲述者，可以把故事讲得比自己的亲身经历更吸引人。",
      "totalCount": 342,
      "appLink": "weread://bestbookmark?bookId=3300061191&chapterUid=13&rangeStart=8053&rangeEnd=8098",
      "webLink": "https://weread.qq.com/web/reader/655324c0813ab7e67g01180d?chapterUid=13&rangeStart=8053&rangeEnd=8098"
    },
    {
      "bookmarkId": "3300061191_8_4301-4354",
      "chapterUid": 8,
      "range": "4301-4354",
