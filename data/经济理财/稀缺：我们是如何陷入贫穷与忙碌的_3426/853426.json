  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "853426_35_6624-6723",
      "chapterUid": 35,
      "range": "6624-6723",
      "markText": "稀缺俘获大脑(scarcity captures the mind)　稀缺造成的后果不仅仅是因为我们会因拥有的太少而感到不悦，而是因为它会改变我们的思维方式，会强行侵入我们的思想之中。",
      "totalCount": 9405,
      "appLink": "weread://bestbookmark?bookId=853426&chapterUid=35&rangeStart=6624&rangeEnd=6723",
      "webLink": "https://weread.qq.com/web/reader/36b321405d05b236bb0ce7d?chapterUid=35&rangeStart=6624&rangeEnd=6723"
    },
    {
      "bookmarkId": "853426_38_20495-20575",
      "chapterUid": 38,
      "range": "20495-20575",
      "markText": "稀缺会改变我们看待事物的眼光，让我们做出不同选择。这种现象会让我们变得更有成效；但同时也会让我们为此付出代价：这种“专心致志”会令我们忽略原本很重要的其他事物。",
      "totalCount": 8768,
      "appLink": "weread://bestbookmark?bookId=853426&chapterUid=38&rangeStart=20495&rangeEnd=20575",
      "webLink": "https://weread.qq.com/web/reader/36b321405d05b236bb0ce7d?chapterUid=38&rangeStart=20495&rangeEnd=20575"
    },
    {
      "bookmarkId": "853426_33_1174-1201",
      "chapterUid": 33,
      "range": "1174-1201",
      "markText": "如果你想要什么，不要等急需的时候才去要，而要提前积累。",
      "totalCount": 7740,
      "appLink": "weread://bestbookmark?bookId=853426&chapterUid=33&rangeStart=1174&rangeEnd=1201",
      "webLink": "https://weread.qq.com/web/reader/36b321405d05b236bb0ce7d?chapterUid=33&rangeStart=1174&rangeEnd=1201"
    },
    {
      "bookmarkId": "853426_38_5638-5724",
      "chapterUid": 38,
      "range": "5638-5724",
      "markText": "无论是有关工作还是娱乐，只要时间有限，我们都会尽量将其利用得淋漓尽致。我们将这种现象称为“专注红利”(focus dividend)，也就是稀缺俘获大脑时所产生的积极成果。",
      "totalCount": 7668,
      "appLink": "weread://bestbookmark?bookId=853426&chapterUid=38&rangeStart=5638&rangeEnd=5724",
      "webLink": "https://weread.qq.com/web/reader/36b321405d05b236bb0ce7d?chapterUid=38&rangeStart=5638&rangeEnd=5724"
    },
    {
      "bookmarkId": "853426_38_11591-11657",
      "chapterUid": 38,
      "range": "11591-11657",
      "markText": "专注具有积极意义：稀缺会迫使我们专注在迫近的重要事情上；管窥则是消极的：稀缺导致我们有了管窥之见，让我们忽略了其他可能更重要的事情。",
      "totalCount": 7582,
      "appLink": "weread://bestbookmark?bookId=853426&chapterUid=38&rangeStart=11591&rangeEnd=11657",
      "webLink": "https://weread.qq.com/web/reader/36b321405d05b236bb0ce7d?chapterUid=38&rangeStart=11591&rangeEnd=11657"
    },
    {
      "bookmarkId": "853426_35_14390-14486",
      "chapterUid": 35,
      "range": "14390-14486",
      "markText": "稀缺会俘获我们的注意力，并带来一点点好处：我们能够在应对迫切需求时，做得更好。但从长远的角度来看，我们的损失更大：我们会忽视其他需要关注的事项，在生活的其他方面变得不那么有成效。",
      "totalCount": 7425,
      "appLink": "weread://bestbookmark?bookId=853426&chapterUid=35&rangeStart=14390&rangeEnd=14486",
      "webLink": "https://weread.qq.com/web/reader/36b321405d05b236bb0ce7d?chapterUid=35&rangeStart=14390&rangeEnd=14486"
    },
    {
      "bookmarkId": "853426_35_12806-12898",
      "chapterUid": 35,
      "range": "12806-12898",
      "markText": "带宽(bandwidth)　就是心智的容量，包括两种能力，分别为认知能力和执行控制力。稀缺会降低所有这些带宽的容量，致使我们缺乏洞察力和前瞻性，还会减弱我们的执行控制力。",
      "totalCount": 7088,
      "appLink": "weread://bestbookmark?bookId=853426&chapterUid=35&rangeStart=12806&rangeEnd=12898",
      "webLink": "https://weread.qq.com/web/reader/36b321405d05b236bb0ce7d?chapterUid=35&rangeStart=12806&rangeEnd=12898"
    },
    {
      "bookmarkId": "853426_38_3127-3162",
      "chapterUid": 38,
      "range": "3127-3162",
      "markText": "一旦时间不够用的现实变得无法逃避，我们就会开始集中精力。",
      "totalCount": 6300,
      "appLink": "weread://bestbookmark?bookId=853426&chapterUid=38&rangeStart=3127&rangeEnd=3162",
      "webLink": "https://weread.qq.com/web/reader/36b321405d05b236bb0ce7d?chapterUid=38&rangeStart=3127&rangeEnd=3162"
    },
    {
      "bookmarkId": "853426_38_8864-8956",
      "chapterUid": 38,
      "range": "8864-8956",
      "markText": "我们不能通过胳肢自己来取乐，同样，也很难以提高工作绩效为目的，用假装有个截止日期的方式来自我欺骗。空想出来的截止日期不过是一个空想而已，它永远也不会像真正的截止日期那样俘获我们的大脑。",
      "totalCount": 5724,
      "appLink": "weread://bestbookmark?bookId=853426&chapterUid=38&rangeStart=8864&rangeEnd=8956",
      "webLink": "https://weread.qq.com/web/reader/36b321405d05b236bb0ce7d?chapterUid=38&rangeStart=8864&rangeEnd=8956"
    },
    {
      "bookmarkId": "853426_34_534-610",
      "chapterUid": 34,
      "range": "534-610",
      "markText": "阅读一本书并不是要把书中的每一行的每个字都认一遍，而是较真地弄明白作者的意思，并理解作者的思想，才能进一步真正掌握一本书的观点、视角以及可能的现实应用。",
      "totalCount": 5512,
      "appLink": "weread://bestbookmark?bookId=853426&chapterUid=34&rangeStart=534&rangeEnd=610",
      "webLink": "https://weread.qq.com/web/reader/36b321405d05b236bb0ce7d?chapterUid=34&rangeStart=534&rangeEnd=610"
    },
    {
      "bookmarkId": "853426_38_1806-1841",
      "chapterUid": 38,
      "range": "1806-1841",
      "markText": "稀缺，会迫使人做出选择。所有抽象的事物都会变得具体起来。",
      "totalCount": 5280,
      "appLink": "weread://bestbookmark?bookId=853426&chapterUid=38&rangeStart=1806&rangeEnd=1841",
      "webLink": "https://weread.qq.com/web/reader/36b321405d05b236bb0ce7d?chapterUid=38&rangeStart=1806&rangeEnd=1841"
    },
    {
      "bookmarkId": "853426_40_8416-8458",
      "chapterUid": 40,
      "range": "8416-8458",
      "markText": "稀缺会直接减少带宽——不是减少某人与生俱来的带宽容量，而是减少其当下能用得上的容量。",
      "totalCount": 5094,
      "appLink": "weread://bestbookmark?bookId=853426&chapterUid=40&rangeStart=8416&rangeEnd=8458",
      "webLink": "https://weread.qq.com/web/reader/36b321405d05b236bb0ce7d?chapterUid=40&rangeStart=8416&rangeEnd=8458"
    },
    {
      "bookmarkId": "853426_35_12443-12518",
      "chapterUid": 35,
      "range": "12443-12518",
      "markText": "稀缺心态(scarcity mindset)　稀缺是一种心态。当它俘获我们的注意力时，就会改变我们的思维方式，影响我们的决策和行为方式。",
      "totalCount": 4768,
      "appLink": "weread://bestbookmark?bookId=853426&chapterUid=35&rangeStart=12443&rangeEnd=12518",
      "webLink": "https://weread.qq.com/web/reader/36b321405d05b236bb0ce7d?chapterUid=35&rangeStart=12443&rangeEnd=12518"
    },
    {
      "bookmarkId": "853426_38_10886-10937",
      "chapterUid": 38,
      "range": "10886-10937",
      "markText": "管窥(tunneling)　专注于某一事物就意味着我们会忽略其他事物，也叫“隧道视野”。",
      "totalCount": 4662,
      "appLink": "weread://bestbookmark?bookId=853426&chapterUid=38&rangeStart=10886&rangeEnd=10937",
      "webLink": "https://weread.qq.com/web/reader/36b321405d05b236bb0ce7d?chapterUid=38&rangeStart=10886&rangeEnd=10937"
    },
    {
      "bookmarkId": "853426_35_3458-3475",
      "chapterUid": 35,
      "range": "3458-3475",
      "markText": "稀缺，是“拥有”少于“需要”的感觉",
      "totalCount": 4590,
      "appLink": "weread://bestbookmark?bookId=853426&chapterUid=35&rangeStart=3458&rangeEnd=3475",
      "webLink": "https://weread.qq.com/web/reader/36b321405d05b236bb0ce7d?chapterUid=35&rangeStart=3458&rangeEnd=3475"
    },
    {
      "bookmarkId": "853426_45_16731-16777",
      "chapterUid": 45,
      "range": "16731-16777",
      "markText": "因为专注，所以拥有专业技能；因为专业，所以有了管窥之见；因为管窥，所以产生了一系列负面后果。",
      "totalCount": 4560,
      "appLink": "weread://bestbookmark?bookId=853426&chapterUid=45&rangeStart=16731&rangeEnd=16777",
      "webLink": "https://weread.qq.com/web/reader/36b321405d05b236bb0ce7d?chapterUid=45&rangeStart=16731&rangeEnd=16777"
    },
    {
      "bookmarkId": "853426_38_5296-5342",
      "chapterUid": 38,
      "range": "5296-5342",
      "markText": "截止日期是一种很有效的手段，之所以这么说，是因为产生了时间稀缺，而它可以让人集中精力去做事。",
      "totalCount": 4216,
      "appLink": "weread://bestbookmark?bookId=853426&chapterUid=38&rangeStart=5296&rangeEnd=5342",
      "webLink": "https://weread.qq.com/web/reader/36b321405d05b236bb0ce7d?chapterUid=38&rangeStart=5296&rangeEnd=5342"
    },
    {
      "bookmarkId": "853426_47_5817-5917",
      "chapterUid": 47,
      "range": "5817-5917",
      "markText": "当今天的资源，无论是时间还是金钱，能在当下为你带来比未来更大的利益时，借用就是行得通的做法。而当我们有了管窥之见时，借用就会超越得失均衡的限度。当面临稀缺状况时，我们的借用，从长期来看通常是不合理的。",
