          "appLink": "weread://bestbookmark?bookId=853426&chapterUid=38&rangeStart=20495&rangeEnd=20575",
          "webLink": "https://weread.qq.com/web/reader/36b321405d05b236bb0ce7d?chapterUid=38&rangeStart=20495&rangeEnd=20575"
