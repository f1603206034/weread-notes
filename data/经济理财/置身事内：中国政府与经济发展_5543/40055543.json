    {
      "chapterUid": 53,
      "chapterTitle": "第八章 总结：政府与经济发展",
      "items": [
        {
          "type": "highlight",
          "bookmarkId": "40055543_53_1210-1309",
          "range": "1210-1309",
          "rangeStart": 1210,
          "rangeEnd": 1309,
          "markText": "一套严格的概念框架无疑有助于厘清问题，但也经常让人错把问题当成答案。社会科学总渴望发现一套‘放之四海而皆准’的方法和规律，但这种心态需要成熟起来。不要低估经济现实的复杂性，也不要高估科学工具的质量。",
          "colorStyle": 1,
          "colorLabel": "",
          "createTime": 1698277758,
          "createTimeFormatted": "2023-10-26 07:49:18",
          "chapterUid": 53,
          "appLink": "weread://bestbookmark?bookId=40055543&chapterUid=53&rangeStart=1210&rangeEnd=1309",
          "webLink": "https://weread.qq.com/web/reader/2a332d10726332f72a34943?chapterUid=53&rangeStart=1210&rangeEnd=1309"
        }
      ]
    }
