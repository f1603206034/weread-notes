  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "40055543_16_6218-6275",
      "chapterUid": 16,
      "range": "6218-6275",
      "markText": "成功的政策背后是成功的协商和妥协，而不是机械的命令与执行，所以理解利益冲突，理解协调和解决机制，是理解政策的基础。",
      "totalCount": 34920,
      "appLink": "weread://bestbookmark?bookId=40055543&chapterUid=16&rangeStart=6218&rangeEnd=6275",
      "webLink": "https://weread.qq.com/web/reader/2a332d10726332f72a34943?chapterUid=16&rangeStart=6218&rangeEnd=6275"
    },
    {
      "bookmarkId": "40055543_59_1443-1461",
      "chapterUid": 59,
      "range": "1443-1461",
      "markText": "生活过得好一点，比大多数宏伟更宏伟。",
      "totalCount": 30564,
      "appLink": "weread://bestbookmark?bookId=40055543&chapterUid=59&rangeStart=1443&rangeEnd=1461",
      "webLink": "https://weread.qq.com/web/reader/2a332d10726332f72a34943?chapterUid=59&rangeStart=1443&rangeEnd=1461"
    },
    {
      "bookmarkId": "40055543_8_4237-4295",
      "chapterUid": 8,
      "range": "4237-4295",
      "markText": "在任何体制下，权力运作都受到两种约束：做事的能力及做事的意愿。前者取决于掌握的资源，后者取决于各方的积极性和主动性。",
      "totalCount": 28000,
      "appLink": "weread://bestbookmark?bookId=40055543&chapterUid=8&rangeStart=4237&rangeEnd=4295",
      "webLink": "https://weread.qq.com/web/reader/2a332d10726332f72a34943?chapterUid=8&rangeStart=4237&rangeEnd=4295"
    },
    {
      "bookmarkId": "40055543_10_5609-5696",
      "chapterUid": 10,
      "range": "5609-5696",
      "markText": "因为信息复杂，不可信的信息比比皆是，而权力和责任又高度个人化，所以体制内的规章制度无法完全取代个人信任。上级在提拔下级时，除考虑工作能力外，关键岗位上都要尽量安排信得过的人。",
      "totalCount": 22266,
      "appLink": "weread://bestbookmark?bookId=40055543&chapterUid=10&rangeStart=5609&rangeEnd=5696",
      "webLink": "https://weread.qq.com/web/reader/2a332d10726332f72a34943?chapterUid=10&rangeStart=5609&rangeEnd=5696"
    },
    {
      "bookmarkId": "40055543_5_763-837",
      "chapterUid": 5,
      "range": "763-837",
      "markText": "要避免把舶来的理论化成先入为主的判断——看到现实与理论不符，便直斥现实之非，进而把要了解的现象变成了讥讽的对象——否则就丧失了“同情的理解”的机会。",
      "totalCount": 21606,
      "appLink": "weread://bestbookmark?bookId=40055543&chapterUid=5&rangeStart=763&rangeEnd=837",
      "webLink": "https://weread.qq.com/web/reader/2a332d10726332f72a34943?chapterUid=5&rangeStart=763&rangeEnd=837"
    },
    {
      "bookmarkId": "40055543_5_1180-1217",
      "chapterUid": 5,
      "range": "1180-1217",
      "markText": "对读者来说，了解政府认为应该怎么办，比了解“我”认为应该怎么办，重要得多。",
      "totalCount": 21280,
      "appLink": "weread://bestbookmark?bookId=40055543&chapterUid=5&rangeStart=1180&rangeEnd=1217",
      "webLink": "https://weread.qq.com/web/reader/2a332d10726332f72a34943?chapterUid=5&rangeStart=1180&rangeEnd=1217"
    },
    {
      "bookmarkId": "40055543_21_983-1059",
      "chapterUid": 21,
      "range": "983-1059",
      "markText": "土地资本化的魔力，在于可以挣脱物理属性，在抽象的意义上交易承诺和希望，将过去的储蓄、现在的收入、未来的前途，统统汇聚和封存在一小片土地上，使其价值暴增。",
      "totalCount": 20536,
      "appLink": "weread://bestbookmark?bookId=40055543&chapterUid=21&rangeStart=983&rangeEnd=1059",
      "webLink": "https://weread.qq.com/web/reader/2a332d10726332f72a34943?chapterUid=21&rangeStart=983&rangeEnd=1059"
    },
    {
      "bookmarkId": "40055543_9_5278-5318",
      "chapterUid": 9,
      "range": "5278-5318",
      "markText": "我国经济中有个现象：处在行政交界（尤其是省交界处）的地区，经济发展普遍比较落后。",
      "totalCount": 14910,
      "appLink": "weread://bestbookmark?bookId=40055543&chapterUid=9&rangeStart=5278&rangeEnd=5318",
      "webLink": "https://weread.qq.com/web/reader/2a332d10726332f72a34943?chapterUid=9&rangeStart=5278&rangeEnd=5318"
    },
    {
      "bookmarkId": "40055543_5_2733-2768",
      "chapterUid": 5,
      "range": "2733-2768",
      "markText": "本书的一切错漏之处都归我自己。希望读者批评指正，争取有机会再版时改正。",
      "totalCount": 12903,
      "appLink": "weread://bestbookmark?bookId=40055543&chapterUid=5&rangeStart=2733&rangeEnd=2768",
      "webLink": "https://weread.qq.com/web/reader/2a332d10726332f72a34943?chapterUid=5&rangeStart=2733&rangeEnd=2768"
    },
    {
      "bookmarkId": "40055543_5_662-706",
      "chapterUid": 5,
      "range": "662-706",
      "markText": "在我国，政府不但影响“蛋糕”的分配，也参与“蛋糕”的生产，所以我们不可能脱离政府谈经济。",
      "totalCount": 11920,
      "appLink": "weread://bestbookmark?bookId=40055543&chapterUid=5&rangeStart=662&rangeEnd=706",
      "webLink": "https://weread.qq.com/web/reader/2a332d10726332f72a34943?chapterUid=5&rangeStart=662&rangeEnd=706"
    },
    {
      "bookmarkId": "40055543_10_542-579",
      "chapterUid": 10,
      "range": "542-579",
      "markText": "所以有信息优势的一方，或者说能以更低代价获取信息的一方，自然就有决策优势。",
      "totalCount": 11808,
      "appLink": "weread://bestbookmark?bookId=40055543&chapterUid=10&rangeStart=542&rangeEnd=579",
      "webLink": "https://weread.qq.com/web/reader/2a332d10726332f72a34943?chapterUid=10&rangeStart=542&rangeEnd=579"
    },
    {
      "bookmarkId": "40055543_24_3119-3208",
      "chapterUid": 24,
      "range": "3119-3208",
      "markText": "出于政绩考虑，地方官员在基础设施投资方面常常偏重“看得见”的工程建设，比如城市道路、桥梁、地铁、绿地等，相对忽视“看不见”的工程，比如地下管网。所以每逢暴雨，“看海”的城市就很多",
      "totalCount": 11610,
      "appLink": "weread://bestbookmark?bookId=40055543&chapterUid=24&rangeStart=3119&rangeEnd=3208",
      "webLink": "https://weread.qq.com/web/reader/2a332d10726332f72a34943?chapterUid=24&rangeStart=3119&rangeEnd=3208"
    },
    {
      "bookmarkId": "40055543_40_876-929",
      "chapterUid": 40,
      "range": "876-929",
      "markText": "人们在乐观时往往会低估负债的风险，过多借债。当风险出现时，又会因为债务负担沉重而缺乏腾挪空间，没办法应对。",
      "totalCount": 11385,
      "appLink": "weread://bestbookmark?bookId=40055543&chapterUid=40&rangeStart=876&rangeEnd=929",
      "webLink": "https://weread.qq.com/web/reader/2a332d10726332f72a34943?chapterUid=40&rangeStart=876&rangeEnd=929"
    },
    {
      "bookmarkId": "40055543_9_635-707",
      "chapterUid": 9,
      "range": "635-707",
      "markText": "一件事情该不该由地方自主决定，可以从外部性的角度来考虑。若此事只影响本地，没有外部性，就该由本地全权处理；若还影响其他地方，那上级就该出面协调。",
      "totalCount": 10730,
      "appLink": "weread://bestbookmark?bookId=40055543&chapterUid=9&rangeStart=635&rangeEnd=707",
      "webLink": "https://weread.qq.com/web/reader/2a332d10726332f72a34943?chapterUid=9&rangeStart=635&rangeEnd=707"
    },
    {
      "bookmarkId": "40055543_10_5379-5408",
      "chapterUid": 10,
      "range": "5379-5408",
      "markText": "所谓权力，实质就是在说不清楚的情况下由谁来拍板决策的问题。",
      "totalCount": 10530,
      "appLink": "weread://bestbookmark?bookId=40055543&chapterUid=10&rangeStart=5379&rangeEnd=5408",
      "webLink": "https://weread.qq.com/web/reader/2a332d10726332f72a34943?chapterUid=10&rangeStart=5379&rangeEnd=5408"
    },
    {
      "bookmarkId": "40055543_28_9803-9903",
