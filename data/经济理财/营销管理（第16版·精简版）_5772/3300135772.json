          "range": "1014-1064",
          "rangeStart": 1014,
          "rangeEnd": 1064,
          "markText": "市场营销(marketing)是指以与组织目标相一致的方式识别并满足人类与社会的需求。",
          "colorStyle": 0,
          "colorLabel": "",
          "createTime": 1767098222,
          "createTimeFormatted": "2025-12-30 20:37:02",
          "chapterUid": 9,
          "appLink": "weread://bestbookmark?bookId=3300135772&chapterUid=9&rangeStart=1014&rangeEnd=1064",
