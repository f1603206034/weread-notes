      ]
    }
  ],
  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300135772_9_1014-1064",
      "chapterUid": 9,
      "range": "1014-1064",
      "markText": "市场营销(marketing)是指以与组织目标相一致的方式识别并满足人类与社会的需求。",
      "totalCount": 832,
      "appLink": "weread://bestbookmark?bookId=3300135772&chapterUid=9&rangeStart=1014&rangeEnd=1064",
      "webLink": "https://weread.qq.com/web/reader/dd332b80813ab9b89g012936?chapterUid=9&rangeStart=1014&rangeEnd=1064"
    },
    {
      "bookmarkId": "3300135772_9_1375-1452",
      "chapterUid": 9,
      "range": "1375-1452",
      "markText": "营销管理(marketing management)是选择目标市场并通过创造、传递和沟通卓越的顾客价值，来获取、维持和发展顾客的艺术和科学。",
      "totalCount": 400,
      "appLink": "weread://bestbookmark?bookId=3300135772&chapterUid=9&rangeStart=1375&rangeEnd=1452",
      "webLink": "https://weread.qq.com/web/reader/dd332b80813ab9b89g012936?chapterUid=9&rangeStart=1375&rangeEnd=1452"
    },
    {
      "bookmarkId": "3300135772_4_684-731",
      "chapterUid": 4,
      "range": "684-731",
      "markText": "科特勒认为，市场营销应以顾客为中心，而非以产品为中心。企业的使命是创造顾客，而非单纯推销产品。",
      "totalCount": 384,
      "appLink": "weread://bestbookmark?bookId=3300135772&chapterUid=4&rangeStart=684&rangeEnd=731",
      "webLink": "https://weread.qq.com/web/reader/dd332b80813ab9b89g012936?chapterUid=4&rangeStart=684&rangeEnd=731"
    },
    {
      "bookmarkId": "3300135772_9_1176-1198",
      "chapterUid": 9,
      "range": "1176-1198",
      "markText": "将个人的或社会的需求转变成可盈利的商业机会。",
      "totalCount": 375,
      "appLink": "weread://bestbookmark?bookId=3300135772&chapterUid=9&rangeStart=1176&rangeEnd=1198",
      "webLink": "https://weread.qq.com/web/reader/dd332b80813ab9b89g012936?chapterUid=9&rangeStart=1176&rangeEnd=1198"
    },
    {
      "bookmarkId": "3300135772_9_7469-7533",
      "chapterUid": 9,
      "range": "7469-7533",
      "markText": "越来越多的公司选择拥有品牌而非实体资产，在保留公司的核心业务的同时，将其他非核心业务分包给那些能够比自己做得更好且更廉价的公司。",
      "totalCount": 312,
      "appLink": "weread://bestbookmark?bookId=3300135772&chapterUid=9&rangeStart=7469&rangeEnd=7533",
      "webLink": "https://weread.qq.com/web/reader/dd332b80813ab9b89g012936?chapterUid=9&rangeStart=7469&rangeEnd=7533"
    },
    {
      "bookmarkId": "3300135772_9_8732-8828",
      "chapterUid": 9,
      "range": "8732-8828",
      "markText": "出色的营销人员不再将单一的销售收入当作检视营销效果的指标，他们还会解读市场份额、客户流失率、顾客满意度、产品质量及其他指标的情况。他们也会考虑营销活动和项目在法律、伦理、社会和环境方面的影响。",
      "totalCount": 289,
      "appLink": "weread://bestbookmark?bookId=3300135772&chapterUid=9&rangeStart=8732&rangeEnd=8828",
      "webLink": "https://weread.qq.com/web/reader/dd332b80813ab9b89g012936?chapterUid=9&rangeStart=8732&rangeEnd=8828"
    },
    {
      "bookmarkId": "3300135772_4_2239-2276",
      "chapterUid": 4,
      "range": "2239-2276",
      "markText": "五年内，如果你还在按着一样的方式做着一样的生意，那么你离关门大吉就不远了”",
      "totalCount": 272,
      "appLink": "weread://bestbookmark?bookId=3300135772&chapterUid=4&rangeStart=2239&rangeEnd=2276",
      "webLink": "https://weread.qq.com/web/reader/dd332b80813ab9b89g012936?chapterUid=4&rangeStart=2239&rangeEnd=2276"
    },
    {
      "bookmarkId": "3300135772_9_1246-1296",
      "chapterUid": 9,
      "range": "1246-1296",
      "markText": "市场营销是创造、沟通、传递和交换对顾客、客户、合作伙伴和整个社会有价值的产品的一种活动、制度和过程。",
      "totalCount": 234,
      "appLink": "weread://bestbookmark?bookId=3300135772&chapterUid=9&rangeStart=1246&rangeEnd=1296",
      "webLink": "https://weread.qq.com/web/reader/dd332b80813ab9b89g012936?chapterUid=9&rangeStart=1246&rangeEnd=1296"
    },
    {
      "bookmarkId": "3300135772_12_6263-6330",
      "chapterUid": 12,
      "range": "6263-6330",
      "markText": "营销者并不创造需要，因为需要先于营销者存在。营销者可能会宣传奔驰汽车能满足一个人对社会地位的需要，然而他们并没有创造对社会地位的需要。",
      "totalCount": 224,
      "appLink": "weread://bestbookmark?bookId=3300135772&chapterUid=12&rangeStart=6263&rangeEnd=6330",
      "webLink": "https://weread.qq.com/web/reader/dd332b80813ab9b89g012936?chapterUid=12&rangeStart=6263&rangeEnd=6330"
    },
    {
      "bookmarkId": "3300135772_9_8438-8484",
      "chapterUid": 9,
      "range": "8438-8484",
      "markText": "只有高级管理人员清晰地传达出公司的营销导向和理念如何服务于客户的愿景，部门间的协作才能实现。",
      "totalCount": 221,
      "appLink": "weread://bestbookmark?bookId=3300135772&chapterUid=9&rangeStart=8438&rangeEnd=8484",
      "webLink": "https://weread.qq.com/web/reader/dd332b80813ab9b89g012936?chapterUid=9&rangeStart=8438&rangeEnd=8484"
    },
    {
      "bookmarkId": "3300135772_9_13343-13401",
      "chapterUid": 9,
      "range": "13343-13401",
      "markText": "当市场领导者们厌恶风险，执着于保护现有的市场和物质资源，并且对效率和利润比对创新更感兴趣时，它们就会错过趋势和机会。",
      "totalCount": 210,
      "appLink": "weread://bestbookmark?bookId=3300135772&chapterUid=9&rangeStart=13343&rangeEnd=13401",
      "webLink": "https://weread.qq.com/web/reader/dd332b80813ab9b89g012936?chapterUid=9&rangeStart=13343&rangeEnd=13401"
    },
    {
      "bookmarkId": "3300135772_9_1504-1549",
      "chapterUid": 9,
      "range": "1504-1549",
      "markText": "营销通常涵盖10个不同的领域：产品、服务、事件、体验、人物、地点、财产、组织、信息和观念。",
      "totalCount": 198,
      "appLink": "weread://bestbookmark?bookId=3300135772&chapterUid=9&rangeStart=1504&rangeEnd=1549",
      "webLink": "https://weread.qq.com/web/reader/dd332b80813ab9b89g012936?chapterUid=9&rangeStart=1504&rangeEnd=1549"
    },
    {
      "bookmarkId": "3300135772_10_788-876",
      "chapterUid": 10,
      "range": "788-876",
      "markText": "企业必须坚持一个战略，但也要随时间的推移不断改进它。在当今瞬息万变的营销世界中，确定最佳的长期战略至关重要。任何成功营销战略的核心都是开发持久的价值主张，以满足真正的顾客需要。",
      "totalCount": 182,
      "appLink": "weread://bestbookmark?bookId=3300135772&chapterUid=10&rangeStart=788&rangeEnd=876",
      "webLink": "https://weread.qq.com/web/reader/dd332b80813ab9b89g012936?chapterUid=10&rangeStart=788&rangeEnd=876"
    },
