  "content": [
    {
      "chapterUid": 23,
      "chapterTitle": "01 证券分析的范围与局限以及内在价值的概念",
      "items": [
        {
          "type": "highlight",
          "bookmarkId": "3300153273_23_4191-4223",
          "range": "4191-4223",
          "rangeStart": 4191,
          "rangeEnd": 4223,
          "markText": "必须有合理理由才能认为，这个平均盈利或升跌趋势能可靠地预测未来。",
          "colorStyle": 0,
          "colorLabel": "",
          "createTime": 1762236723,
          "createTimeFormatted": "2025-11-04 14:12:03",
          "chapterUid": 23,
          "appLink": "weread://bestbookmark?bookId=3300153273&chapterUid=23&rangeStart=4191&rangeEnd=4223",
