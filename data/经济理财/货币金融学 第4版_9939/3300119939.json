  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300119939_11_18208-18356",
      "chapterUid": 11,
      "range": "18208-18356",
      "markText": "所谓套期保值(hedge)，是指投资者在现货市场和期货市场，对同一种类的金融资产同时进行数量相等但方向相反的买卖活动，即买进或卖出金融资产现货的同时，卖出或买进同等数量的该种金融资产期货，使两个市场的盈亏大致抵消，以达到防范价格波动风险的目的。",
      "totalCount": 1143,
      "appLink": "weread://bestbookmark?bookId=3300119939&chapterUid=11&rangeStart=18208&rangeEnd=18356",
      "webLink": "https://weread.qq.com/web/reader/c9332fa0813ab9559g01990b?chapterUid=11&rangeStart=18208&rangeEnd=18356"
    },
    {
      "bookmarkId": "3300119939_12_59166-59208",
      "chapterUid": 12,
      "range": "59166-59208",
      "markText": "比如，当预期利率上升时，银行应尽量减小资产久期，扩大负债久期，使银行持有久期负缺口；",
      "totalCount": 1135,
      "appLink": "weread://bestbookmark?bookId=3300119939&chapterUid=12&rangeStart=59166&rangeEnd=59208",
      "webLink": "https://weread.qq.com/web/reader/c9332fa0813ab9559g01990b?chapterUid=12&rangeStart=59166&rangeEnd=59208"
    },
    {
      "bookmarkId": "3300119939_10_3493-3532",
      "chapterUid": 10,
      "range": "3493-3532",
      "markText": "传统的商品市场往往是一个有固定场所的有形市场，而金融市场不一定都有固定的场所。",
      "totalCount": 1118,
      "appLink": "weread://bestbookmark?bookId=3300119939&chapterUid=10&rangeStart=3493&rangeEnd=3532",
      "webLink": "https://weread.qq.com/web/reader/c9332fa0813ab9559g01990b?chapterUid=10&rangeStart=3493&rangeEnd=3532"
    },
    {
      "bookmarkId": "3300119939_11_29682-29714",
      "chapterUid": 11,
      "range": "29682-29714",
      "markText": "期权买方的最大损失是期权费，期权卖方的最大收益也是期权费。",
      "totalCount": 1118,
      "appLink": "weread://bestbookmark?bookId=3300119939&chapterUid=11&rangeStart=29682&rangeEnd=29714",
      "webLink": "https://weread.qq.com/web/reader/c9332fa0813ab9559g01990b?chapterUid=11&rangeStart=29682&rangeEnd=29714"
    },
    {
      "bookmarkId": "3300119939_9_37660-37703",
      "chapterUid": 9,
      "range": "37660-37703",
      "markText": "古典利率理论认为，利率由两种力量决定：一是可供利用的储蓄，即资本供给，主要由家庭提供；",
      "totalCount": 1116,
      "appLink": "weread://bestbookmark?bookId=3300119939&chapterUid=9&rangeStart=37660&rangeEnd=37703",
      "webLink": "https://weread.qq.com/web/reader/c9332fa0813ab9559g01990b?chapterUid=9&rangeStart=37660&rangeEnd=37703"
    },
    {
      "bookmarkId": "3300119939_15_26256-26310",
      "chapterUid": 15,
      "range": "26256-26310",
      "markText": "公开市场操作，是指中央银行在金融市场上公开买卖有价证券（主要是政府债券），用以调控货币供应量的一种政策工具。",
      "totalCount": 1101,
      "appLink": "weread://bestbookmark?bookId=3300119939&chapterUid=15&rangeStart=26256&rangeEnd=26310",
      "webLink": "https://weread.qq.com/web/reader/c9332fa0813ab9559g01990b?chapterUid=15&rangeStart=26256&rangeEnd=26310"
    },
    {
      "bookmarkId": "3300119939_12_37676-37744",
      "chapterUid": 12,
      "range": "37676-37744",
      "markText": "金融担保是银行根据交易中一方的申请，为申请人向交易的另一方出具履约保证，承诺当申请人不能履约时，由银行按照约定履行债务或承担责任的行为。",
      "totalCount": 1095,
      "appLink": "weread://bestbookmark?bookId=3300119939&chapterUid=12&rangeStart=37676&rangeEnd=37744",
      "webLink": "https://weread.qq.com/web/reader/c9332fa0813ab9559g01990b?chapterUid=12&rangeStart=37676&rangeEnd=37744"
    },
    {
      "bookmarkId": "3300119939_15_35429-35487",
      "chapterUid": 15,
      "range": "35429-35487",
      "markText": "结构性货币政策工具是中国特色的货币政策工具，主要是指中央银行引导金融机构信贷投向，发挥精准滴灌、杠杆撬动作用的工具。",
      "totalCount": 1072,
      "appLink": "weread://bestbookmark?bookId=3300119939&chapterUid=15&rangeStart=35429&rangeEnd=35487",
      "webLink": "https://weread.qq.com/web/reader/c9332fa0813ab9559g01990b?chapterUid=15&rangeStart=35429&rangeEnd=35487"
    },
    {
      "bookmarkId": "3300119939_12_2008-2044",
      "chapterUid": 12,
      "range": "2008-2044",
      "markText": "货币经营商是指专门经营货币兑换、保管与汇兑业务的组织，是银行早期的萌芽。",
      "totalCount": 1069,
      "appLink": "weread://bestbookmark?bookId=3300119939&chapterUid=12&rangeStart=2008&rangeEnd=2044",
      "webLink": "https://weread.qq.com/web/reader/c9332fa0813ab9559g01990b?chapterUid=12&rangeStart=2008&rangeEnd=2044"
    },
    {
      "bookmarkId": "3300119939_11_16007-16096",
      "chapterUid": 11,
      "range": "16007-16096",
      "markText": "货币期货(foreign exchange futures)，也叫外汇期货，是指交易双方约定在未来某一时间，依据现在约定的汇率以一种货币买卖另一种货币的标准化合约。",
      "totalCount": 1065,
      "appLink": "weread://bestbookmark?bookId=3300119939&chapterUid=11&rangeStart=16007&rangeEnd=16096",
      "webLink": "https://weread.qq.com/web/reader/c9332fa0813ab9559g01990b?chapterUid=11&rangeStart=16007&rangeEnd=16096"
    },
    {
      "bookmarkId": "3300119939_16_74018-74053",
      "chapterUid": 16,
      "range": "74018-74053",
      "markText": "第三，货币、固定收益证券、浮动收益证券的收益率及价格水平的预期变动率；",
      "totalCount": 1065,
      "appLink": "weread://bestbookmark?bookId=3300119939&chapterUid=16&rangeStart=74018&rangeEnd=74053",
      "webLink": "https://weread.qq.com/web/reader/c9332fa0813ab9559g01990b?chapterUid=16&rangeStart=74018&rangeEnd=74053"
    },
    {
      "bookmarkId": "3300119939_12_35718-35788",
      "chapterUid": 12,
      "range": "35718-35788",
      "markText": "承诺业务，是指商业银行承诺在未来某一时期内或者某一时间，按照约定条件向客户提供约定的信用业务的一类新型表外业务，如贷款承诺和票据发行便利等。",
      "totalCount": 1059,
      "appLink": "weread://bestbookmark?bookId=3300119939&chapterUid=12&rangeStart=35718&rangeEnd=35788",
      "webLink": "https://weread.qq.com/web/reader/c9332fa0813ab9559g01990b?chapterUid=12&rangeStart=35718&rangeEnd=35788"
    },
    {
      "bookmarkId": "3300119939_17_10067-10140",
      "chapterUid": 17,
      "range": "10067-10140",
      "markText": "2.利润推动型通货膨胀　它是指垄断企业凭借其垄断地位，通过提高垄断产品的价格来获得垄断利润，使得总供给曲线上移，从而引起的通货膨胀。",
      "totalCount": 1057,
      "appLink": "weread://bestbookmark?bookId=3300119939&chapterUid=17&rangeStart=10067&rangeEnd=10140",
      "webLink": "https://weread.qq.com/web/reader/c9332fa0813ab9559g01990b?chapterUid=17&rangeStart=10067&rangeEnd=10140"
    },
    {
      "bookmarkId": "3300119939_11_43769-43830",
      "chapterUid": 11,
      "range": "43769-43830",
      "markText": "信用衍生产品场外市场是指银行间市场，在我国银行间市场发行及交易的用于管理信用风险的信用衍生产品被称为“信用风险缓释工具”；",
      "totalCount": 1048,
      "appLink": "weread://bestbookmark?bookId=3300119939&chapterUid=11&rangeStart=43769&rangeEnd=43830",
      "webLink": "https://weread.qq.com/web/reader/c9332fa0813ab9559g01990b?chapterUid=11&rangeStart=43769&rangeEnd=43830"
    },
    {
      "bookmarkId": "3300119939_10_6916-6987",
      "chapterUid": 10,
      "range": "6916-6987",
      "markText": "优化资源配置功能，是指金融市场通过定价机制自动引导资金的合理配置，进而引导资源从低效益部门向高效益部门流动，从而实现资源的合理配置和有效利用。",
      "totalCount": 1042,
      "appLink": "weread://bestbookmark?bookId=3300119939&chapterUid=10&rangeStart=6916&rangeEnd=6987",
      "webLink": "https://weread.qq.com/web/reader/c9332fa0813ab9559g01990b?chapterUid=10&rangeStart=6916&rangeEnd=6987"
    },
    {
      "bookmarkId": "3300119939_7_1360-1408",
      "chapterUid": 7,
      "range": "1360-1408",
      "markText": "货币是现代金融和经济学理论中最常见、最重要的一个概念，也是最容易引起混淆、最难以理解的一个概念。",
      "totalCount": 1038,
      "appLink": "weread://bestbookmark?bookId=3300119939&chapterUid=7&rangeStart=1360&rangeEnd=1408",
      "webLink": "https://weread.qq.com/web/reader/c9332fa0813ab9559g01990b?chapterUid=7&rangeStart=1360&rangeEnd=1408"
    },
    {
      "bookmarkId": "3300119939_12_7847-7863",
      "chapterUid": 12,
      "range": "7847-7863",
      "markText": "其特殊性具体表现在如下几个方面。",
      "totalCount": 1023,
      "appLink": "weread://bestbookmark?bookId=3300119939&chapterUid=12&rangeStart=7847&rangeEnd=7863",
      "webLink": "https://weread.qq.com/web/reader/c9332fa0813ab9559g01990b?chapterUid=12&rangeStart=7847&rangeEnd=7863"
    },
    {
      "bookmarkId": "3300119939_8_24322-24386",
      "chapterUid": 8,
      "range": "24322-24386",
      "markText": "存款性金融机构，是指接受个人和机构存款，并发放贷款的金融机构，主要包括商业银行、储蓄银行、信用合作社、乡村银行等银行类金融机构。",
      "totalCount": 1013,
      "appLink": "weread://bestbookmark?bookId=3300119939&chapterUid=8&rangeStart=24322&rangeEnd=24386",
      "webLink": "https://weread.qq.com/web/reader/c9332fa0813ab9559g01990b?chapterUid=8&rangeStart=24322&rangeEnd=24386"
    },
    {
      "bookmarkId": "3300119939_15_19916-19974",
      "chapterUid": 15,
      "range": "19916-19974",
      "markText": "货币政策要达到最终目标，需要经过一个传导过程，一般是中央银行运用货币政策工具→近期中介目标→远期中介目标→最终目标。",
      "totalCount": 1000,
      "appLink": "weread://bestbookmark?bookId=3300119939&chapterUid=15&rangeStart=19916&rangeEnd=19974",
      "webLink": "https://weread.qq.com/web/reader/c9332fa0813ab9559g01990b?chapterUid=15&rangeStart=19916&rangeEnd=19974"
    },
    {
      "bookmarkId": "3300119939_14_17413-17438",
      "chapterUid": 14,
      "range": "17413-17438",
      "markText": "虽然各国金融管理体制不同，但在依法管理上是一致的。",
      "totalCount": 979,
      "appLink": "weread://bestbookmark?bookId=3300119939&chapterUid=14&rangeStart=17413&rangeEnd=17438",
      "webLink": "https://weread.qq.com/web/reader/c9332fa0813ab9559g01990b?chapterUid=14&rangeStart=17413&rangeEnd=17438"
    }
