  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "26211801_9_2297-2358",
      "chapterUid": 9,
      "range": "2297-2358",
      "markText": "在Git中，开发者将源代码存入名叫“Git仓库”的资料库中并加以使用。而GitHub则是在网络上提供Git仓库的一项服务。",
      "totalCount": 156,
      "appLink": "weread://bestbookmark?bookId=26211801&chapterUid=9&rangeStart=2297&rangeEnd=2358",
      "webLink": "https://weread.qq.com/web/reader/173323a0718ff5d9173e0af?chapterUid=9&rangeStart=2297&rangeEnd=2358"
    },
    {
      "bookmarkId": "26211801_16_425-453",
      "chapterUid": 16,
      "range": "425-453",
      "markText": "Git属于分散型版本管理系统，是为版本管理而设计的软件。",
      "totalCount": 96,
      "appLink": "weread://bestbookmark?bookId=26211801&chapterUid=16&rangeStart=425&rangeEnd=453",
      "webLink": "https://weread.qq.com/web/reader/173323a0718ff5d9173e0af?chapterUid=16&rangeStart=425&rangeEnd=453"
    },
    {
      "bookmarkId": "26211801_11_1629-1681",
      "chapterUid": 11,
      "range": "1629-1681",
      "markText": "GitHub的出现为软件开发者的世界带来了真正意义上的“民主”，让所有人都平等地拥有了更改源代码的权利。",
      "totalCount": 90,
      "appLink": "weread://bestbookmark?bookId=26211801&chapterUid=11&rangeStart=1629&rangeEnd=1681",
      "webLink": "https://weread.qq.com/web/reader/173323a0718ff5d9173e0af?chapterUid=11&rangeStart=1629&rangeEnd=1681"
    },
    {
      "bookmarkId": "26211801_27_4354-4390",
      "chapterUid": 27,
      "range": "4354-4390",
      "markText": "即便在开发过程中发现了BUG，也需要再创建新的分支，在新分支中进行修正。",
      "totalCount": 90,
