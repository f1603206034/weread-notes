  ],
  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "3300028868_9_10024-10154",
      "chapterUid": 9,
      "range": "10024-10154",
      "markText": "你可以将深度神经网络看作多级信息蒸馏（information distillation）过程：信息穿过连续的过滤器，其纯度越来越高（对任务的帮助越来越大）。",
      "totalCount": 270,
      "appLink": "weread://bestbookmark?bookId=3300028868&chapterUid=9&rangeStart=10024&rangeEnd=10154",
      "webLink": "https://weread.qq.com/web/reader/33f32c90813ab71c6g018fff?chapterUid=9&rangeStart=10024&rangeEnd=10154"
    },
    {
      "bookmarkId": "3300028868_9_22631-22734",
      "chapterUid": 9,
      "range": "22631-22734",
      "markText": "深度学习的变革之处在于，模型可以在同一时间共同学习所有表示层，而不是依次连续学习（这被称为贪婪学习）。",
      "totalCount": 238,
      "appLink": "weread://bestbookmark?bookId=3300028868&chapterUid=9&rangeStart=22631&rangeEnd=22734",
      "webLink": "https://weread.qq.com/web/reader/33f32c90813ab71c6g018fff?chapterUid=9&rangeStart=22631&rangeEnd=22734"
    },
    {
      "bookmarkId": "3300028868_9_8003-8106",
      "chapterUid": 9,
      "range": "8003-8106",
      "markText": "机器学习中的学习指的是，寻找某种数据变换的自动搜索过程。在反馈信号的指引下，这种变换可以生成有用的数据表示，这种表示则可以用更简单的规则来解决手头的任务。",
      "totalCount": 234,
      "appLink": "weread://bestbookmark?bookId=3300028868&chapterUid=9&rangeStart=8003&rangeEnd=8106",
      "webLink": "https://weread.qq.com/web/reader/33f32c90813ab71c6g018fff?chapterUid=9&rangeStart=8003&rangeEnd=8106"
    },
    {
      "bookmarkId": "3300028868_9_8770-8865",
      "chapterUid": 9,
      "range": "8770-8865",
      "markText": "深度学习之“深度”并不是说这种方法能够获取更深层次的理解，而是指一系列连续的表示层。数据模型所包含的层数被称为该模型的深度（depth）。",
      "totalCount": 224,
      "appLink": "weread://bestbookmark?bookId=3300028868&chapterUid=9&rangeStart=8770&rangeEnd=8865",
      "webLink": "https://weread.qq.com/web/reader/33f32c90813ab71c6g018fff?chapterUid=9&rangeStart=8770&rangeEnd=8865"
    },
    {
      "bookmarkId": "3300028868_9_12841-12869",
      "chapterUid": 9,
      "range": "12841-12869",
      "markText": "一旦具有足够大的规模，这个简单的机制将产生魔法般的效果。",
      "totalCount": 224,
      "appLink": "weread://bestbookmark?bookId=3300028868&chapterUid=9&rangeStart=12841&rangeEnd=12869",
      "webLink": "https://weread.qq.com/web/reader/33f32c90813ab71c6g018fff?chapterUid=9&rangeStart=12841&rangeEnd=12869"
    },
    {
      "bookmarkId": "3300028868_9_5786-5916",
      "chapterUid": 9,
      "range": "5786-5916",
      "markText": "机器学习和深度学习的核心问题在于有意义地变换数据，换句话说，在于学习输入数据的有用表示（representation）——这种表示可以让数据更接近预期输出。",
      "totalCount": 221,
      "appLink": "weread://bestbookmark?bookId=3300028868&chapterUid=9&rangeStart=5786&rangeEnd=5916",
      "webLink": "https://weread.qq.com/web/reader/33f32c90813ab71c6g018fff?chapterUid=9&rangeStart=5786&rangeEnd=5916"
    },
    {
      "bookmarkId": "3300028868_4_389-415",
      "chapterUid": 4,
      "range": "389-415",
      "markText": "献给我的儿子Sylvain，希望你有一天能阅读本书。",
      "totalCount": 216,
      "appLink": "weread://bestbookmark?bookId=3300028868&chapterUid=4&rangeStart=389&rangeEnd=415",
      "webLink": "https://weread.qq.com/web/reader/33f32c90813ab71c6g018fff?chapterUid=4&rangeStart=389&rangeEnd=415"
    },
    {
      "bookmarkId": "3300028868_9_2361-2487",
      "chapterUid": 9,
      "range": "2361-2487",
      "markText": "事实上，在相当长的时间内，大多数专家相信，只要程序员手动编写足够多的明确规则来处理存储在显式数据库中的知识，就可以实现与人类水平相当的人工智能。这一方法被称为符号主义人工智能（symbolic AI）",
      "totalCount": 182,
      "appLink": "weread://bestbookmark?bookId=3300028868&chapterUid=9&rangeStart=2361&rangeEnd=2487",
      "webLink": "https://weread.qq.com/web/reader/33f32c90813ab71c6g018fff?chapterUid=9&rangeStart=2361&rangeEnd=2487"
    },
    {
      "bookmarkId": "3300028868_9_4981-5079",
      "chapterUid": 9,
      "range": "4981-5079",
      "markText": "机器学习（尤其是深度学习）呈现出相对较少的数学理论（可能过于少了），从根本上来说是一门工程学科。与理论物理或数学不同，机器学习是一门非常注重实践的学科，由经验发现所驱动，并深深依赖于软硬件的发展。",
      "totalCount": 180,
      "appLink": "weread://bestbookmark?bookId=3300028868&chapterUid=9&rangeStart=4981&rangeEnd=5079",
      "webLink": "https://weread.qq.com/web/reader/33f32c90813ab71c6g018fff?chapterUid=9&rangeStart=4981&rangeEnd=5079"
    },
    {
      "bookmarkId": "3300028868_9_25171-25213",
      "chapterUid": 9,
      "range": "25171-25213",
      "markText": "与数学或物理学不同，仅靠一支笔和一张纸不能实现机器学习的重大进展，它是一门工程科学。",
      "totalCount": 165,
      "appLink": "weread://bestbookmark?bookId=3300028868&chapterUid=9&rangeStart=25171&rangeEnd=25213",
      "webLink": "https://weread.qq.com/web/reader/33f32c90813ab71c6g018fff?chapterUid=9&rangeStart=25171&rangeEnd=25213"
    },
    {
      "bookmarkId": "3300028868_9_10466-10538",
      "chapterUid": 9,
      "range": "10466-10538",
      "markText": "这就是深度学习的技术定义：一种多层的学习数据表示的方法。这个想法很简单，但事实证明，如果具有足够大的规模，那么非常简单的机制将产生魔法般的效果。",
      "totalCount": 162,
      "appLink": "weread://bestbookmark?bookId=3300028868&chapterUid=9&rangeStart=10466&rangeEnd=10538",
      "webLink": "https://weread.qq.com/web/reader/33f32c90813ab71c6g018fff?chapterUid=9&rangeStart=10466&rangeEnd=10538"
    },
    {
      "bookmarkId": "3300028868_9_8260-8352",
      "chapterUid": 9,
      "range": "8260-8352",
      "markText": "机器学习算法在寻找这些变换时通常没有创造性，仅仅是遍历一组预先定义的操作，这组操作叫作假设空间（hypothesis space）。",
      "totalCount": 154,
      "appLink": "weread://bestbookmark?bookId=3300028868&chapterUid=9&rangeStart=8260&rangeEnd=8352",
      "webLink": "https://weread.qq.com/web/reader/33f32c90813ab71c6g018fff?chapterUid=9&rangeStart=8260&rangeEnd=8352"
    },
    {
      "bookmarkId": "3300028868_9_8421-8468",
      "chapterUid": 9,
      "range": "8421-8468",
      "markText": "机器学习就是指在预先定义的可能性空间中，利用反馈信号的指引，在输入数据中寻找有用的表示和规则。",
      "totalCount": 154,
      "appLink": "weread://bestbookmark?bookId=3300028868&chapterUid=9&rangeStart=8421&rangeEnd=8468",
      "webLink": "https://weread.qq.com/web/reader/33f32c90813ab71c6g018fff?chapterUid=9&rangeStart=8421&rangeEnd=8468"
    },
    {
      "bookmarkId": "3300028868_9_22109-22161",
      "chapterUid": 9,
      "range": "22109-22161",
      "markText": "深度学习还让解决问题变得更加简单，因为它将特征工程完全自动化，而这曾经是机器学习工作流程中最关键的一步。",
      "totalCount": 153,
      "appLink": "weread://bestbookmark?bookId=3300028868&chapterUid=9&rangeStart=22109&rangeEnd=22161",
      "webLink": "https://weread.qq.com/web/reader/33f32c90813ab71c6g018fff?chapterUid=9&rangeStart=22109&rangeEnd=22161"
    },
    {
      "bookmarkId": "3300028868_13_14148-14187",
      "chapterUid": 13,
      "range": "14148-14187",
      "markText": "深度神经网络以分层和模块化的方式组织学到的表示，这与自然数据的组织方式相呼应。",
      "totalCount": 153,
      "appLink": "weread://bestbookmark?bookId=3300028868&chapterUid=13&rangeStart=14148&rangeEnd=14187",
      "webLink": "https://weread.qq.com/web/reader/33f32c90813ab71c6g018fff?chapterUid=13&rangeStart=14148&rangeEnd=14187"
    },
    {
      "bookmarkId": "3300028868_9_3376-3433",
      "chapterUid": 9,
      "range": "3376-3433",
      "markText": "分析机谈不上能创造什么东西。它能做的是我们知道如何命令它去做的任何事情……它的职责是帮助我们去实现我们已知的事情。",
      "totalCount": 144,
      "appLink": "weread://bestbookmark?bookId=3300028868&chapterUid=9&rangeStart=3376&rangeEnd=3433",
      "webLink": "https://weread.qq.com/web/reader/33f32c90813ab71c6g018fff?chapterUid=9&rangeStart=3376&rangeEnd=3433"
    },
    {
      "bookmarkId": "3300028868_10_2084-2253",
      "chapterUid": 10,
      "range": "2084-2253",
      "markText": "在机器学习中，分类问题中的某个类别叫作类（class），数据点叫作样本（sample），与某个样本对应的类叫作标签（label）。",
      "totalCount": 144,
      "appLink": "weread://bestbookmark?bookId=3300028868&chapterUid=10&rangeStart=2084&rangeEnd=2253",
      "webLink": "https://weread.qq.com/web/reader/33f32c90813ab71c6g018fff?chapterUid=10&rangeStart=2084&rangeEnd=2253"
    },
    {
      "bookmarkId": "3300028868_10_22331-22400",
      "chapterUid": 10,
      "range": "22331-22400",
      "markText": "同样，在GPU上运行TensorFlow代码，逐元素运算都是通过完全向量化的CUDA来完成的，可以最大限度地利用高度并行的GPU芯片架构。",
      "totalCount": 136,
      "appLink": "weread://bestbookmark?bookId=3300028868&chapterUid=10&rangeStart=22331&rangeEnd=22400",
      "webLink": "https://weread.qq.com/web/reader/33f32c90813ab71c6g018fff?chapterUid=10&rangeStart=22331&rangeEnd=22400"
    },
    {
      "bookmarkId": "3300028868_9_12141-12259",
      "chapterUid": 9,
      "range": "12141-12259",
      "markText": "这种调节是优化器（optimizer）的任务，它实现了所谓的反向传播（backpropagation）算法，这是深度学习的核心算法。",
      "totalCount": 128,
      "appLink": "weread://bestbookmark?bookId=3300028868&chapterUid=9&rangeStart=12141&rangeEnd=12259",
      "webLink": "https://weread.qq.com/web/reader/33f32c90813ab71c6g018fff?chapterUid=9&rangeStart=12141&rangeEnd=12259"
    },
    {
      "bookmarkId": "3300028868_9_6169-6210",
      "chapterUid": 9,
      "range": "6169-6210",
      "markText": "机器学习模型旨在为输入数据寻找合适的表示（对数据进行变换），使其更适合手头的任务。",
      "totalCount": 126,
      "appLink": "weread://bestbookmark?bookId=3300028868&chapterUid=9&rangeStart=6169&rangeEnd=6210",
