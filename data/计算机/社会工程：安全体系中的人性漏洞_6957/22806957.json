  "bookReviews": [],
  "hotBookmarks": [
    {
      "bookmarkId": "22806957_4_2696-2769",
      "chapterUid": 4,
      "range": "2696-2769",
      "markText": "无论系统有多安全，总有方法攻破它。通常，系统中的人是最好欺骗和操纵的。制造恐慌、运用影响力、采用操纵策略和建立信任感等方法都可以让受害者消除戒备。",
      "totalCount": 308,
      "appLink": "weread://bestbookmark?bookId=22806957&chapterUid=4&rangeStart=2696&rangeEnd=2769",
      "webLink": "https://weread.qq.com/web/reader/e9432870715c01ade947384?chapterUid=4&rangeStart=2696&rangeEnd=2769"
    },
    {
      "bookmarkId": "22806957_4_3212-3239",
      "chapterUid": 4,
      "range": "3212-3239",
      "markText": "如果你认为自己不可能被骗，那么你就是我最想骗的那个人。",
      "totalCount": 240,
      "appLink": "weread://bestbookmark?bookId=22806957&chapterUid=4&rangeStart=3212&rangeEnd=3239",
      "webLink": "https://weread.qq.com/web/reader/e9432870715c01ade947384?chapterUid=4&rangeStart=3212&rangeEnd=3239"
    },
    {
      "bookmarkId": "22806957_4_567-615",
      "chapterUid": 4,
      "range": "567-615",
      "markText": "必须置身事外才能全面地理解安全，从本质上来说就是把自己作为一个局外人，尝试用其他方式来进入系统。",
      "totalCount": 192,
      "appLink": "weread://bestbookmark?bookId=22806957&chapterUid=4&rangeStart=567&rangeEnd=615",
      "webLink": "https://weread.qq.com/web/reader/e9432870715c01ade947384?chapterUid=4&rangeStart=567&rangeEnd=615"
    },
    {
      "bookmarkId": "22806957_4_1181-1214",
      "chapterUid": 4,
      "range": "1181-1214",
      "markText": "不管事情看似多么不可能，几乎总会有一种巧妙的、意想不到的解决方法。",
      "totalCount": 162,
      "appLink": "weread://bestbookmark?bookId=22806957&chapterUid=4&rangeStart=1181&rangeEnd=1214",
      "webLink": "https://weread.qq.com/web/reader/e9432870715c01ade947384?chapterUid=4&rangeStart=1181&rangeEnd=1214"
    },
    {
      "bookmarkId": "22806957_8_1955-2034",
      "chapterUid": 8,
      "range": "1955-2034",
      "markText": "真正的社会工程不仅是以为自己在扮演角色，而且在那个时刻，你就是那个人，你就是那个角色，你的生活就是那样的",
      "totalCount": 144,
      "appLink": "weread://bestbookmark?bookId=22806957&chapterUid=8&rangeStart=1955&rangeEnd=2034",
      "webLink": "https://weread.qq.com/web/reader/e9432870715c01ade947384?chapterUid=8&rangeStart=1955&rangeEnd=2034"
    },
    {
      "bookmarkId": "22806957_8_5279-5354",
      "chapterUid": 8,
      "range": "5279-5354",
      "markText": "如果这些人中有一个减肥成功，并且没有因此而对其他人品头论足，相反却乐于帮助约翰，那么约翰对体重的看法可能会发生变化，开始认为减肥是可行的，而且还不错。",
      "totalCount": 144,
      "appLink": "weread://bestbookmark?bookId=22806957&chapterUid=8&rangeStart=5279&rangeEnd=5354",
      "webLink": "https://weread.qq.com/web/reader/e9432870715c01ade947384?chapterUid=8&rangeStart=5279&rangeEnd=5354"
    },
    {
      "bookmarkId": "22806957_7_1333-1373",
      "chapterUid": 7,
      "range": "1333-1373",
      "markText": "减弱攻击影响的唯一正确方法是知晓其存在、掌握其原理并懂得攻击者的思维过程和心理。",
      "totalCount": 135,
      "appLink": "weread://bestbookmark?bookId=22806957&chapterUid=7&rangeStart=1333&rangeEnd=1373",
      "webLink": "https://weread.qq.com/web/reader/e9432870715c01ade947384?chapterUid=7&rangeStart=1333&rangeEnd=1373"
    },
    {
      "bookmarkId": "22806957_8_6963-7028",
      "chapterUid": 8,
      "range": "6963-7028",
      "markText": "当一些人或某个人不支持“正确”的领导人时，粮食会变得稀缺，工作也会被那些支持者“抢去”。人们发现这个问题时，很快就会转变成支持者。",
      "totalCount": 126,
      "appLink": "weread://bestbookmark?bookId=22806957&chapterUid=8&rangeStart=6963&rangeEnd=7028",
      "webLink": "https://weread.qq.com/web/reader/e9432870715c01ade947384?chapterUid=8&rangeStart=6963&rangeEnd=7028"
    },
    {
      "bookmarkId": "22806957_4_2946-2996",
      "chapterUid": 4,
      "range": "2946-2996",
      "markText": "社会工程学研究系统中最薄弱的一环——人，以及如何运用人性攻击的技巧攻破看似安全的系统。",
      "totalCount": 120,
      "appLink": "weread://bestbookmark?bookId=22806957&chapterUid=4&rangeStart=2946&rangeEnd=2996",
      "webLink": "https://weread.qq.com/web/reader/e9432870715c01ade947384?chapterUid=4&rangeStart=2946&rangeEnd=2996"
    },
    {
      "bookmarkId": "22806957_4_2870-2899",
      "chapterUid": 4,
      "range": "2870-2899",
      "markText": "承认系统有漏洞并且可能被攻破，是让系统更加安全的首要条件。",
      "totalCount": 112,
      "appLink": "weread://bestbookmark?bookId=22806957&chapterUid=4&rangeStart=2870&rangeEnd=2899",
      "webLink": "https://weread.qq.com/web/reader/e9432870715c01ade947384?chapterUid=4&rangeStart=2870&rangeEnd=2899"
    },
    {
      "bookmarkId": "22806957_10_433-490",
      "chapterUid": 10,
      "range": "433-490",
      "markText": "战争的胜利百分之九十取决于情报。 ——拿破仑·波拿巴",
      "totalCount": 112,
      "appLink": "weread://bestbookmark?bookId=22806957&chapterUid=10&rangeStart=433&rangeEnd=490",
      "webLink": "https://weread.qq.com/web/reader/e9432870715c01ade947384?chapterUid=10&rangeStart=433&rangeEnd=490"
    },
    {
      "bookmarkId": "22806957_5_2977-2995",
      "chapterUid": 5,
      "range": "2977-2995",
      "markText": "爱因斯坦曾经说过：“信息并非知识。”",
      "totalCount": 102,
      "appLink": "weread://bestbookmark?bookId=22806957&chapterUid=5&rangeStart=2977&rangeEnd=2995",
      "webLink": "https://weread.qq.com/web/reader/e9432870715c01ade947384?chapterUid=5&rangeStart=2977&rangeEnd=2995"
    },
    {
      "bookmarkId": "22806957_8_1488-1575",
      "chapterUid": 8,
      "range": "1488-1575",
      "markText": "我对该定义进行了扩展，认为社会工程的真正定义是：一种操纵他人采取特定行动的行为，该行动不一定符合“目标人”的最佳利益，其结果包括获取信息、取得访问权限或让目标采取特定的行动。",
      "totalCount": 100,
      "appLink": "weread://bestbookmark?bookId=22806957&chapterUid=8&rangeStart=1488&rangeEnd=1575",
      "webLink": "https://weread.qq.com/web/reader/e9432870715c01ade947384?chapterUid=8&rangeStart=1488&rangeEnd=1575"
    },
    {
      "bookmarkId": "22806957_4_711-798",
      "chapterUid": 4,
      "range": "711-798",
      "markText": "我不属于这部分人。过去10年中，我比历史上任何人设的骗局都要多。我在赌场赢过庄家、伪造过体育赛事、操纵过拍卖、诱骗过他人交出心爱之物，也轻松侵入过几个号称坚不可破的安全系统。",
      "totalCount": 96,
      "appLink": "weread://bestbookmark?bookId=22806957&chapterUid=4&rangeStart=711&rangeEnd=798",
      "webLink": "https://weread.qq.com/web/reader/e9432870715c01ade947384?chapterUid=4&rangeStart=711&rangeEnd=798"
    },
    {
      "bookmarkId": "22806957_7_3051-3096",
      "chapterUid": 7,
      "range": "3051-3096",
      "markText": "孙子曰：“知己知彼，百战不殆。”真是至理名言！但只是“知”尚且不够，知行合一才是智慧所在。",
      "totalCount": 96,
      "appLink": "weread://bestbookmark?bookId=22806957&chapterUid=7&rangeStart=3051&rangeEnd=3096",
      "webLink": "https://weread.qq.com/web/reader/e9432870715c01ade947384?chapterUid=7&rangeStart=3051&rangeEnd=3096"
    },
    {
      "bookmarkId": "22806957_8_8477-8512",
      "chapterUid": 8,
      "range": "8477-8512",
      "markText": "一个未被检查的不满员工可能比一群虎视眈眈的专业黑客所造成的破坏还要大。",
      "totalCount": 96,
      "appLink": "weread://bestbookmark?bookId=22806957&chapterUid=8&rangeStart=8477&rangeEnd=8512",
      "webLink": "https://weread.qq.com/web/reader/e9432870715c01ade947384?chapterUid=8&rangeStart=8477&rangeEnd=8512"
    },
    {
      "bookmarkId": "22806957_8_5825-5895",
      "chapterUid": 8,
      "range": "5825-5895",
      "markText": "告诉对方被选中进行一笔很赚钱的交易，但是需要他提供一个小小的帮助。如果目标愿意帮助发信人从一家外国银行提取一大笔钱，那么他也可以分到一部分。",
      "totalCount": 90,
      "appLink": "weread://bestbookmark?bookId=22806957&chapterUid=8&rangeStart=5825&rangeEnd=5895",
      "webLink": "https://weread.qq.com/web/reader/e9432870715c01ade947384?chapterUid=8&rangeStart=5825&rangeEnd=5895"
    },
    {
      "bookmarkId": "22806957_17_1678-1705",
      "chapterUid": 17,
      "range": "1678-1705",
      "markText": "最要紧的是你不能装成自己不可能成为的人。",
      "totalCount": 90,
      "appLink": "weread://bestbookmark?bookId=22806957&chapterUid=17&rangeStart=1678&rangeEnd=1705",
      "webLink": "https://weread.qq.com/web/reader/e9432870715c01ade947384?chapterUid=17&rangeStart=1678&rangeEnd=1705"
    },
    {
      "bookmarkId": "22806957_17_2388-2416",
      "chapterUid": 17,
      "range": "2388-2416",
      "markText": "有时，世界上的“最佳交流者”其实是那些听的比说的多的人。",
      "totalCount": 80,
      "appLink": "weread://bestbookmark?bookId=22806957&chapterUid=17&rangeStart=2388&rangeEnd=2416",
      "webLink": "https://weread.qq.com/web/reader/e9432870715c01ade947384?chapterUid=17&rangeStart=2388&rangeEnd=2416"
    },
    {
      "bookmarkId": "22806957_25_449-472",
      "chapterUid": 25,
      "range": "449-472",
      "markText": "我们看待事物的方式而不是事物本身，决定着一切。",
      "totalCount": 75,
      "appLink": "weread://bestbookmark?bookId=22806957&chapterUid=25&rangeStart=449&rangeEnd=472",
      "webLink": "https://weread.qq.com/web/reader/e9432870715c01ade947384?chapterUid=25&rangeStart=449&rangeEnd=472"
    }
  ],
